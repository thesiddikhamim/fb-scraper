[
  {
    "title": "\u0986\u09ae\u09b0\u09be \u098f\u0995 \u0990\u09a4\u09bf\u09b9\u09be\u09b8\u09bf\u0995 \u09a6\u09bf\u09a8\u09c7\u09b0 \u09b8\u09be\u0995\u09cd\u09b7\u09c0 \u09b9\u09af\u09bc\u09c7\u099b\u09bf\u0964 \u09af\u09c7 \u09b8\u0982\u09b8\u09a6 \u098f\u0995\u09b8\u09ae\u09af\u09bc \u09ab\u09cd\u09af\u09be\u09b8\u09bf\u09ac\u09be\u09a6\u09c7\u09b0 \u09ac\u09c0\u099c \u09ac\u09aa\u09a8 \u0995\u09b0\u09c7\u099b\u09bf\u09b2,...",
    "description": "\u0986\u09ae\u09b0\u09be \u098f\u0995 \u0990\u09a4\u09bf\u09b9\u09be\u09b8\u09bf\u0995 \u09a6\u09bf\u09a8\u09c7\u09b0 \u09b8\u09be\u0995\u09cd\u09b7\u09c0 \u09b9\u09af\u09bc\u09c7\u099b\u09bf\u0964 \u09af\u09c7 \u09b8\u0982\u09b8\u09a6 \u098f\u0995\u09b8\u09ae\u09af\u09bc \u09ab\u09cd\u09af\u09be\u09b8\u09bf\u09ac\u09be\u09a6\u09c7\u09b0 \u09ac\u09c0\u099c \u09ac\u09aa\u09a8 \u0995\u09b0\u09c7\u099b\u09bf\u09b2, \u09af\u09c7 \u09b8\u0982\u09b8\u09a6\u0995\u09c7 \u09b9\u09be\u09b8\u09bf-\u09a0\u09be\u099f\u09cd\u099f\u09be, \u0997\u09be\u09a8-\u09ac\u09be\u099c\u09a8\u09be \u0993 \u09a4\u09cb\u09b7\u09be\u09ae\u09cb\u09a6\u09c7\u09b0 \u0995\u09c7\u09a8\u09cd\u09a6\u09cd\u09b0\u09c7 \u09aa\u09b0\u09bf\u09a3\u09a4 \u0995\u09b0\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09bf\u09b2-\u09b8\u09c7\u0987 \u09b8\u0982\u09b8\u09a6 \u0986\u099c \u0997\u09a3\u09a4\u09a8\u09cd\u09a4\u09cd\u09b0\u09c7\u09b0 \u09aa\u09a5\u09c7 \u09a8\u09a4\u09c1\u09a8 \u09af\u09be\u09a4\u09cd\u09b0\u09be \u09b6\u09c1\u09b0\u09c1 \u0995\u09b0\u09c7\u099b\u09c7\u0964 \u0986\u09ae\u09b0\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8 \u0995\u09b0\u09bf, \u09b8\u09b0\u0995\u09be\u09b0\u09bf \u09a6\u09b2\u09c7\u09b0 \u09b6\u09c1\u09ad\u09ac\u09c1\u09a6\u09cd\u09a7\u09bf\u09b0 \u0989\u09a6\u09af\u09bc \u0998\u099f\u09ac\u09c7\u0964 \u0997\u09a3\u09ad\u09cb\u099f\u09c7\u09b0 \u0997\u09a3\u09b0\u09be\u09df \u0985\u09a8\u09c1\u09af\u09be\u09df\u09c0 \u09b8\u0982\u09b8\u09cd\u0995\u09be\u09b0 \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09be\u09ac \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09af\u09bc\u09a8\u09c7\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u09a4\u09be\u0981\u09b0\u09be \u09b6\u09b9\u09bf\u09a6\u09a6\u09c7\u09b0 \u098b\u09a3 \u09aa\u09b0\u09bf\u09b6\u09cb\u09a7\u09c7 \u098f\u0997\u09bf\u09af\u09bc\u09c7 \u0986\u09b8\u09ac\u09c7\u0964 \u09b6\u09b9\u09c0\u09a6\u09a6\u09c7\u09b0 \u09b0\u09c7\u0996\u09c7 \u09af\u09be\u0993\u09af\u09bc\u09be \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0995\u09be\u099b\u09c7 \u098f\u0995 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u0986\u09ae\u09be\u09a8\u09a4\u0964 \u0986\u09ae\u09b0\u09be \u0995\u09a5\u09be \u09a6\u09bf\u099a\u09cd\u099b\u09bf, \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b6\u09b0\u09c0\u09b0\u09c7\u09b0 \u09b6\u09c7\u09b7 \u09b6\u0995\u09cd\u09a4\u09bf \u09a6\u09bf\u09af\u09bc\u09c7 \u09b9\u09b2\u09c7\u0993 \u0986\u09ae\u09b0\u09be \u09b6\u09b9\u09c0\u09a6\u09a6\u09c7\u09b0 \u098f\u0987 \u0986\u09ae\u09be\u09a8\u09a4 \u09b0\u0995\u09cd\u09b7\u09be \u0995\u09b0\u09ac, \u0987\u09a8\u09b6\u09be\u0986\u09b2\u09cd\u09b2\u09be\u09b9\u0964",
