    "title": "\u09b8\u09bf\u09b2\u09c7\u099f\u09c7 \u09b9\u09af\u09b0\u09a4 \u09b6\u09be\u09b9\u099c\u09be\u09b2\u09be\u09b2 \u09b0\u09b9. \u09a6\u09b0\u0997\u09be\u09b9 \u0995\u09c7\u09a8\u09cd\u09a6\u09cd\u09b0\u09c0\u09af\u09bc \u099c\u09be\u09ae\u09c7 \u09ae\u09b8\u099c\u09bf\u09a6\u09c7 \u0986\u099c \u09a4\u09be\u09b0\u09be\u09ac\u09bf\u09b0 \u09a8\u09be\u09ae\u09be\u099c \u09b6\u09c7\u09b7\u09c7 \u09b9\u09af\u09b0\u09a4...",
    "description": "\u09b8\u09bf\u09b2\u09c7\u099f\u09c7 \u09b9\u09af\u09b0\u09a4 \u09b6\u09be\u09b9\u099c\u09be\u09b2\u09be\u09b2 \u09b0\u09b9. \u09a6\u09b0\u0997\u09be\u09b9 \u0995\u09c7\u09a8\u09cd\u09a6\u09cd\u09b0\u09c0\u09af\u09bc \u099c\u09be\u09ae\u09c7 \u09ae\u09b8\u099c\u09bf\u09a6\u09c7 \u0986\u099c \u09a4\u09be\u09b0\u09be\u09ac\u09bf\u09b0 \u09a8\u09be\u09ae\u09be\u099c \u09b6\u09c7\u09b7\u09c7 \u09b9\u09af\u09b0\u09a4 \u09b6\u09be\u09b9\u099c\u09be\u09b2\u09be\u09b2 \u09b0\u09b9. \u098f\u09b0 \u09ae\u09be\u099c\u09be\u09b0 \u099c\u09bf\u09af\u09bc\u09be\u09b0\u09a4 \u0995\u09b0\u09c7\u09a8 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf- \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09af\u09bc\u0995 \u0993 \u09ac\u09bf\u09b0\u09cb\u09a7\u09c0 \u09a6\u09b2\u09c0\u09af\u09bc \u099a\u09bf\u09ab \u09b9\u09c1\u0987\u09aa \u09ae\u09cb\u0983 \u09a8\u09be\u09b9\u09bf\u09a6 \u0987\u09b8\u09b2\u09be\u09ae\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
