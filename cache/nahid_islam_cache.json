[
  {
    "title": "\u09af\u09be\u09a8\u09cd\u09a4\u09cd\u09b0\u09bf\u0995 \u099c\u09c0\u09ac\u09a8\u09af\u09be\u09a4\u09cd\u09b0\u09be\u09af\u09bc \u0995\u09cd\u09b2\u09be\u09a8\u09cd\u09a4, \u0995\u09b0\u09cd\u09ae\u09ac\u09cd\u09af\u09b8\u09cd\u09a4 \u09a8\u0997\u09b0\u09ac\u09be\u09b8\u09c0\u09b0 \u099c\u09a8\u09cd\u09af \u09b8\u09c1\u0996\u09ac\u09b0! \u0997\u09a4 \u09ac\u099b\u09b0\u09c7\u09b0 \u09a7\u09be\u09b0\u09be\u09ac\u09be\u09b9...",
    "description": "\u09af\u09be\u09a8\u09cd\u09a4\u09cd\u09b0\u09bf\u0995 \u099c\u09c0\u09ac\u09a8\u09af\u09be\u09a4\u09cd\u09b0\u09be\u09af\u09bc \u0995\u09cd\u09b2\u09be\u09a8\u09cd\u09a4, \u0995\u09b0\u09cd\u09ae\u09ac\u09cd\u09af\u09b8\u09cd\u09a4 \u09a8\u0997\u09b0\u09ac\u09be\u09b8\u09c0\u09b0 \u099c\u09a8\u09cd\u09af \u09b8\u09c1\u0996\u09ac\u09b0! \u0997\u09a4 \u09ac\u099b\u09b0\u09c7\u09b0 \u09a7\u09be\u09b0\u09be\u09ac\u09be\u09b9\u09bf\u0995\u09a4\u09be\u09af\u09bc \u098f\u09ac\u09be\u09b0\u0993 \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u0989\u09a6\u09cd\u09af\u09cb\u0997\u09c7 \u09b0\u09be\u099c\u09a7\u09be\u09a8\u09c0\u09a4\u09c7 \u0986\u09af\u09bc\u09cb\u099c\u09bf\u09a4 \u09b9\u099a\u09cd\u099b\u09c7 \u09a4\u09bf\u09a8 \u09a6\u09bf\u09a8\u09ac\u09cd\u09af\u09be\u09aa\u09c0 \u0988\u09a6 \u0989\u09ce\u09b8\u09ac\u0964 \u099a\u09be\u0981\u09a6\u09b0\u09be\u09a4\u09c7 \u09ae\u09c7\u09b9\u09c7\u09a6\u09c0 \u0989\u09ce\u09b8\u09ac, \u0988\u09a6\u09c7\u09b0 \u09a8\u09be\u09ae\u09be\u099c\u09c7\u09b0 \u09aa\u09b0 \u09ac\u09b0\u09cd\u09a3\u09be\u09a2\u09cd\u09af \u0988\u09a6 \u09ae\u09bf\u099b\u09bf\u09b2 \u098f\u09ac\u0982 \u09aa\u09b0\u09a6\u09bf\u09a8 \u0998\u09c1\u09a1\u09bc\u09bf \u0989\u09ce\u09b8\u09ac; \u098f\u09ae\u09a8 \u0985\u09a8\u09a8\u09cd\u09af \u09b8\u09ac \u0986\u09af\u09bc\u09cb\u099c\u09a8\u09c7 \u0986\u09ac\u09be\u09b0\u0993 \u09ab\u09bf\u09b0\u09c7 \u0986\u09b8\u099b\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09aa\u09be\u0981\u099a\u09b6\u09cb \u09ac\u099b\u09b0\u09c7\u09b0 \u0990\u09a4\u09bf\u09b9\u09cd\u09af\u0964 \u09b8\u09ac \u09ad\u09c7\u09a6\u09be\u09ad\u09c7\u09a6 \u09ad\u09c1\u09b2\u09c7 \u098f\u0987 \u0986\u09a8\u09a8\u09cd\u09a6\u09cb\u09ce\u09b8\u09ac\u09c7 \u09b6\u09be\u09ae\u09bf\u09b2 \u09b9\u0993\u09af\u09bc\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u09a8\u0997\u09b0\u09ac\u09be\u09b8\u09c0\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995 \u0986\u09b9\u09cd\u09ac\u09be\u09a8 \u099c\u09be\u09a8\u09be\u099a\u09cd\u099b\u09bf\u0964",
