[
  {
    "title": "\u0986\u099c \u09e6\u09ed \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09e8\u09e6\u09e8\u09ec, \u09ac\u09bf\u09b6\u09cd\u09ac \u09b8\u09cd\u09ac\u09be\u09b8\u09cd\u09a5\u09cd\u09af \u09a6\u09bf\u09ac\u09b8\u0964 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be\u09b0 \u09eb\u09eb \u09ac\u099b\u09b0 \u09aa\u09b0 \u0986\u09ae\u09b0\u09be \u09af\u0996\u09a8 \u098f\u0987 \u09a6\u09bf\u09a8\u099f\u09bf ...",
    "description": "\u0986\u099c \u09e6\u09ed \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09e8\u09e6\u09e8\u09ec, \u09ac\u09bf\u09b6\u09cd\u09ac \u09b8\u09cd\u09ac\u09be\u09b8\u09cd\u09a5\u09cd\u09af \u09a6\u09bf\u09ac\u09b8\u0964 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be\u09b0 \u09eb\u09eb \u09ac\u099b\u09b0 \u09aa\u09b0 \u0986\u09ae\u09b0\u09be \u09af\u0996\u09a8 \u098f\u0987 \u09a6\u09bf\u09a8\u099f\u09bf \u0989\u09a6\u09af\u09be\u09aa\u09a8 \u0995\u09b0\u099b\u09bf, \u09a4\u0996\u09a8\u0993 \u098f \u09a6\u09c7\u09b6\u09c7\u09b0 \u099c\u09a8\u0997\u09a3\u09c7\u09b0 \u098f\u0995\u099f\u09bf \u09ac\u09a1\u09bc \u0985\u0982\u09b6 \u09aa\u09cd\u09b0\u09af\u09bc\u09cb\u099c\u09a8\u09c0\u09af\u09bc \u099a\u09bf\u0995\u09bf\u09ce\u09b8\u09be\u09b8\u09c7\u09ac\u09be \u09a5\u09c7\u0995\u09c7 \u09ac\u099e\u09cd\u099a\u09bf\u09a4\u0964 \u09aa\u09cd\u09b0\u09be\u09a8\u09cd\u09a4\u09bf\u0995 \u099c\u09a8\u09aa\u09a6\u0997\u09c1\u09b2\u09cb\u09a4\u09c7 \u098f\u0987 \u09aa\u09b0\u09bf\u09b8\u09cd\u09a5\u09bf\u09a4\u09bf \u0986\u09b0\u0993 \u09ad\u09af\u09bc\u09be\u09ac\u09b9\u0964 \u0985\u09a5\u099a \u09b8\u0982\u09ac\u09bf\u09a7\u09be\u09a8 \u0985\u09a8\u09c1\u09af\u09be\u09af\u09bc\u09c0, \u09b8\u0995\u09b2 \u09a8\u09be\u0997\u09b0\u09bf\u0995\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u09ae\u09be\u09a8\u09b8\u09ae\u09cd\u09ae\u09a4 \u099a\u09bf\u0995\u09bf\u09ce\u09b8\u09be \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u0995\u09b0\u09be \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0\u09c7\u09b0 \u0985\u09a8\u09cd\u09af\u09a4\u09ae \u09aa\u09cd\u09b0\u09a7\u09be\u09a8 \u09a6\u09be\u09af\u09bc\u09bf\u09a4\u09cd\u09ac\u0964 \u09b8\u09c1\u09b8\u09cd\u09ac\u09be\u09b8\u09cd\u09a5\u09cd\u09af\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u0985\u09aa\u09b0\u09bf\u09b9\u09be\u09b0\u09cd\u09af \u09aa\u09c1\u09b7\u09cd\u099f\u09bf\u0995\u09b0 \u0996\u09be\u09a6\u09cd\u09af \u0993 \u09b8\u09c1\u09aa\u09c7\u09af\u09bc \u09aa\u09be\u09a8\u09bf \u098f\u0996\u09a8\u09cb \u0985\u09a8\u09c7\u0995 \u09ae\u09be\u09a8\u09c1\u09b7\u09c7\u09b0 \u09a8\u09be\u0997\u09be\u09b2\u09c7\u09b0 \u09ac\u09be\u0987\u09b0\u09c7 \u09b0\u09af\u09bc\u09c7 \u0997\u09c7\u099b\u09c7, \u09af\u09be \u0997\u09ad\u09c0\u09b0 \u0989\u09a6\u09cd\u09ac\u09c7\u0997\u09c7\u09b0 \u09ac\u09bf\u09b7\u09af\u09bc\u0964 \u098f\u0987 \u09a6\u09bf\u09a8\u099f\u09bf\u09a4\u09c7 \u0986\u09ae\u09b0\u09be \u0997\u09ad\u09c0\u09b0 \u09b6\u09cd\u09b0\u09a6\u09cd\u09a7\u09be \u0993 \u0995\u09c3\u09a4\u099c\u09cd\u099e\u09a4\u09be \u099c\u09be\u09a8\u09be\u0987 \u09b8\u09c7\u0987\u09b8\u09ac \u099a\u09bf\u0995\u09bf\u09ce\u09b8\u0995 \u0993 \u09b8\u09cd\u09ac\u09be\u09b8\u09cd\u09a5\u09cd\u09af\u0995\u09b0\u09cd\u09ae\u09c0\u09a6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf, \u09af\u09be\u09b0\u09be \u09a8\u09be\u09a8\u09be\u09ac\u09bf\u09a7 \u09b8\u09c0\u09ae\u09be\u09ac\u09a6\u09cd\u09a7\u09a4\u09be\u09b0 \u09ae\u09a7\u09cd\u09af\u09c7\u0993 \u09a8\u09bf\u09b7\u09cd\u09a0\u09be \u0993 \u09ae\u09be\u09a8\u09ac\u09bf\u0995\u09a4\u09be\u09af\u09bc \u09ae\u09be\u09a8\u09c1\u09b7\u09c7\u09b0 \u09b8\u09c7\u09ac\u09be\u09af\u09bc \u09a8\u09bf\u099c\u09c7\u09a6\u09c7\u09b0 \u09a8\u09bf\u09af\u09bc\u09cb\u099c\u09bf\u09a4 \u09b0\u09c7\u0996\u09c7\u099b\u09c7\u09a8\u0964 \u09ac\u09bf\u09b6\u09cd\u09ac \u09b8\u09cd\u09ac\u09be\u09b8\u09cd\u09a5\u09cd\u09af \u09a6\u09bf\u09ac\u09b8\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0985\u0999\u09cd\u0997\u09c0\u0995\u09be\u09b0, \u0986\u09ae\u09b0\u09be \u09b6\u09c1\u09a7\u09c1 \u0985\u09b8\u09c1\u09b8\u09cd\u09a5 \u09b9\u09b2\u09c7 \u099a\u09bf\u0995\u09bf\u09ce\u09b8\u09be \u09a8\u09c7\u09ac\u09cb \u09a8\u09be, \u09ac\u09b0\u0982 \u09b8\u099a\u09c7\u09a4\u09a8 \u09b9\u09ac\u09cb\u0964 \u09b0\u09cb\u0997 \u09b9\u0993\u09af\u09bc\u09be\u09b0 \u0986\u0997\u09c7\u0987 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b0\u09cb\u09a7\u09ae\u09c2\u09b2\u0995 \u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u0997\u09c1\u09b0\u09c1\u09a4\u09cd\u09ac \u09a6\u09c7\u09ac\u09cb \u098f\u09ac\u0982 \u09a8\u09bf\u099c\u09c7\u09b0 \u09aa\u09b0\u09bf\u09ac\u09be\u09b0 \u0993 \u0986\u09b6\u09c7\u09aa\u09be\u09b6\u09c7\u09b0 \u09ae\u09be\u09a8\u09c1\u09b7\u09a6\u09c7\u09b0\u0993 \u09b8\u099a\u09c7\u09a4\u09a8 \u0995\u09b0\u09c7 \u09a4\u09c1\u09b2\u09ac\u09cb\u0964 \u0986\u09ae\u09b0\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8 \u0995\u09b0\u09bf, \u098f\u0995\u099f\u09bf \u09b8\u09c1\u09b8\u09cd\u09a5 \u099c\u09be\u09a4\u09bf \u099b\u09be\u09a1\u09bc\u09be \u0995\u09cb\u09a8\u09cb \u09b6\u0995\u09cd\u09a4\u09bf\u09b6\u09be\u09b2\u09c0 \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0 \u0997\u09a1\u09bc\u09c7 \u09a4\u09cb\u09b2\u09be \u09b8\u09ae\u09cd\u09ad\u09ac \u09a8\u09af\u09bc\u0964 \u09a4\u09be\u0987 \u0986\u09b8\u09c1\u09a8, \u0986\u09ae\u09b0\u09be \u09b8\u09ac\u09be\u0987 \u09b8\u099a\u09c7\u09a4\u09a8 \u09b9\u0987, \u09a6\u09be\u09af\u09bc\u09bf\u09a4\u09cd\u09ac \u0997\u09cd\u09b0\u09b9\u09a3 \u0995\u09b0\u09bf\u2014\u09a8\u09bf\u099c\u09c7\u09b0 \u099c\u09a8\u09cd\u09af, \u09aa\u09b0\u09bf\u09ac\u09be\u09b0\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u098f\u09ac\u0982 \u09a6\u09c7\u09b6\u09c7\u09b0 \u099c\u09a8\u09cd\u09af\u0964",
