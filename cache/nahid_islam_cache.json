  {
    "title": "\u099c\u09be\u09a4\u09c0\u09df \u09af\u09c1\u09ac\u09b6\u0995\u09cd\u09a4\u09bf, \"\u09a2\u09be\u0995\u09be \u09ae\u09b9\u09be\u09a8\u0997\u09b0 \u0989\u09a4\u09cd\u09a4\u09b0\", \"\u09a2\u09be\u0995\u09be \u09ae\u09b9\u09be\u09a8\u0997\u09b0 \u09a6\u0995\u09cd\u09b7\u09bf\u09a3\", \"\u09a2\u09be\u0995\u09be \u09ae\u09b9\u09be\u09a8\u0997\u09b0 \u09aa\u09c2\u09b0\u09cd\u09ac\" \u0993...",
    "description": "\u099c\u09be\u09a4\u09c0\u09df \u09af\u09c1\u09ac\u09b6\u0995\u09cd\u09a4\u09bf, \"\u09a2\u09be\u0995\u09be \u09ae\u09b9\u09be\u09a8\u0997\u09b0 \u0989\u09a4\u09cd\u09a4\u09b0\", \"\u09a2\u09be\u0995\u09be \u09ae\u09b9\u09be\u09a8\u0997\u09b0 \u09a6\u0995\u09cd\u09b7\u09bf\u09a3\", \"\u09a2\u09be\u0995\u09be \u09ae\u09b9\u09be\u09a8\u0997\u09b0 \u09aa\u09c2\u09b0\u09cd\u09ac\" \u0993 \"\u09a2\u09be\u0995\u09be \u09ae\u09b9\u09be\u09a8\u0997\u09b0 \u09aa\u09b6\u09cd\u099a\u09bf\u09ae\" \u098f\u09b0 \u0986\u0982\u09b6\u09bf\u0995 \u0986\u09b9\u09ac\u09be\u09df\u0995 \u0995\u09ae\u09bf\u099f\u09bf \u0997\u09a0\u09bf\u09a4 \u09b9\u09df\u09c7\u099b\u09c7\u0964 \u09a6\u09be\u09df\u09bf\u09a4\u09cd\u09ac\u09aa\u09cd\u09b0\u09be\u09aa\u09cd\u09a4 \u09b8\u0995\u09b2\u0995\u09c7 \u099c\u09be\u09a8\u09be\u0987 \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995 \u09b6\u09c1\u09ad\u09c7\u099a\u09cd\u099b\u09be \u0993 \u0985\u09ad\u09bf\u09a8\u09a8\u09cd\u09a6\u09a8\u0964",
    "link": "https://www.facebook.com/nahidislamjuly/posts/pfbid0Yki8mHfD6k2PyJKwa5aLaUZsnErKy9ozA8tSvvW6wDoaC3QniCTVPFycjw8vnj1Kl",
    "guid": "https://www.facebook.com/nahidislamjuly/posts/pfbid0Yki8mHfD6k2PyJKwa5aLaUZsnErKy9ozA8tSvvW6wDoaC3QniCTVPFycjw8vnj1Kl",
    "pubDate": "2026-04-20T04:19:11.899429+00:00",
