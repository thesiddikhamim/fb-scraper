    "title": "\u09b9\u09af\u09b0\u09a4 \u09b6\u09be\u09b9\u099c\u09be\u09b2\u09be\u09b2 \u09b0\u09b9. \u09a6\u09b0\u0997\u09be\u09b9 \u0995\u09c7\u09a8\u09cd\u09a6\u09cd\u09b0\u09c0\u09af\u09bc \u099c\u09be\u09ae\u09c7 \u09ae\u09b8\u099c\u09bf\u09a6, \u09b8\u09bf\u09b2\u09c7\u099f\u0964",
    "description": "\u09b9\u09af\u09b0\u09a4 \u09b6\u09be\u09b9\u099c\u09be\u09b2\u09be\u09b2 \u09b0\u09b9. \u09a6\u09b0\u0997\u09be\u09b9 \u0995\u09c7\u09a8\u09cd\u09a6\u09cd\u09b0\u09c0\u09af\u09bc \u099c\u09be\u09ae\u09c7 \u09ae\u09b8\u099c\u09bf\u09a6, \u09b8\u09bf\u09b2\u09c7\u099f\u0964",
