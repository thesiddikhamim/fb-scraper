[
  {
    "title": "\u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u09b0\u09c0\u09b6\u0995\u09cd\u09a4\u09bf\u09b0 \u0986\u09a4\u09cd\u09ae\u09aa\u09cd\u09b0\u0995\u09be\u09b6 \u0998\u09cb\u09b7\u09a3\u09be \u098f\u0995\u09be\u09a4\u09cd\u09a4\u09b0\u09c7\u09b0 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be \u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae \u09a5\u09c7\u0995\u09c7 \u09b6\u09c1\u09b0\u09c1 \u0995\u09b0\u09c7 \u09b8\u09be\u09ae\u09cd...",
    "description": "\u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u09b0\u09c0\u09b6\u0995\u09cd\u09a4\u09bf\u09b0 \u0986\u09a4\u09cd\u09ae\u09aa\u09cd\u09b0\u0995\u09be\u09b6 \u0998\u09cb\u09b7\u09a3\u09be \u098f\u0995\u09be\u09a4\u09cd\u09a4\u09b0\u09c7\u09b0 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be \u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae \u09a5\u09c7\u0995\u09c7 \u09b6\u09c1\u09b0\u09c1 \u0995\u09b0\u09c7 \u09b8\u09be\u09ae\u09cd\u09aa\u09cd\u09b0\u09a4\u09bf\u0995 \u099c\u09c1\u09b2\u09be\u0987 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8\u2014\u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u099c\u09be\u09a4\u09c0\u09df \u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae\u09c7 \u09a6\u09c7\u09b6\u09c7\u09b0 \u09a8\u09be\u09b0\u09c0\u09b0\u09be \u09b8\u09be\u09b9\u09b8, \u09a4\u09cd\u09af\u09be\u0997 \u0993 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u09c7\u09b0 \u0989\u099c\u09cd\u099c\u09cd\u09ac\u09b2 \u09a6\u09c3\u09b7\u09cd\u099f\u09be\u09a8\u09cd\u09a4 \u09b8\u09cd\u09a5\u09be\u09aa\u09a8 \u0995\u09b0\u09c7\u099b\u09c7\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09a6\u09c1\u0983\u0996\u099c\u09a8\u0995 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09a4\u09be \u09b9\u09b2\u09cb, \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be\u09b0 \u098f\u09a4 \u09ac\u099b\u09b0 \u09aa\u09b0\u0993 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09a8\u09be\u09b0\u09c0\u09b0\u09be \u0998\u09b0\u09c7-\u09ac\u09be\u0987\u09b0\u09c7 \u09b8\u09b0\u09cd\u09ac\u09a4\u09cd\u09b0 \u09b8\u09b9\u09bf\u0982\u09b8\u09a4\u09be, \u09a7\u09b0\u09cd\u09b7\u09a3, \u09a8\u09bf\u09b0\u09cd\u09af\u09be\u09a4\u09a8 \u0993 \u09ac\u09c8\u09b7\u09ae\u09cd\u09af\u09c7\u09b0 \u09b6\u09bf\u0995\u09be\u09b0 \u09b9\u099a\u09cd\u099b\u09c7\u09a8\u0964 \u099c\u09c1\u09b2\u09be\u0987 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8\u09c7\u09b0 \u09ae\u09a7\u09cd\u09af \u09a6\u09bf\u09df\u09c7 \u09af\u09c7 \u09a8\u09a4\u09c1\u09a8 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09a8\u09bf\u09b0\u09cd\u09ae\u09be\u09a3\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09be\u09b6\u09be \u09b8\u09c3\u09b7\u09cd\u099f\u09bf \u09b9\u09df\u09c7\u099b\u09c7, \u09b8\u09c7\u0987 \u09a8\u09a4\u09c1\u09a8 \u09a6\u09c7\u09b6 \u0993 \u09a8\u09a4\u09c1\u09a8 \u09ac\u09a8\u09cd\u09a6\u09cb\u09ac\u09b8\u09cd\u09a4 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be\u09b0 \u09b2\u09dc\u09be\u0987\u09df\u09c7 \u09a8\u09be\u09b0\u09c0\u09b0 \u09b8\u0995\u09cd\u09b0\u09bf\u09df \u0985\u0982\u09b6\u0997\u09cd\u09b0\u09b9\u09a3 \u0993 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u0995\u09b0\u09be \u098f\u0996\u09a8 \u09b8\u09ae\u09df\u09c7\u09b0 \u09a6\u09be\u09ac\u09bf\u0964 \u098f\u0995\u099f\u09bf \u0997\u09a3\u09a4\u09be\u09a8\u09cd\u09a4\u09cd\u09b0\u09bf\u0995, \u09ac\u09c8\u09b7\u09ae\u09cd\u09af\u09b9\u09c0\u09a8, \u0985\u09a8\u09cd\u09a4\u09b0\u09cd\u09ad\u09c1\u0995\u09cd\u09a4\u09bf\u09ae\u09c2\u09b2\u0995 \u098f\u09ac\u0982 \u09a6\u09be\u09df-\u09a6\u09b0\u09a6\u09c7\u09b0 \u09b8\u09ae\u09be\u099c \u0997\u09dc\u09c7 \u09a4\u09c1\u09b2\u09a4\u09c7 \u09a8\u09be\u09b0\u09c0\u09a6\u09c7\u09b0 \u09b6\u09c1\u09a7\u09c1 \u0985\u0982\u09b6\u0997\u09cd\u09b0\u09b9\u09a3\u0995\u09be\u09b0\u09c0 \u09a8\u09df\u2014\u09aa\u09b0\u09bf\u09ac\u09b0\u09cd\u09a4\u09a8\u09c7\u09b0 \u0985\u0997\u09cd\u09b0\u09a3\u09c0 \u09b6\u0995\u09cd\u09a4\u09bf \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09bf\u09a4 \u0995\u09b0\u09a4\u09c7 \u09b9\u09ac\u09c7\u0964 \u098f\u0987 \u09b2\u0995\u09cd\u09b7\u09cd\u09af\u0995\u09c7 \u09b8\u09be\u09ae\u09a8\u09c7 \u09b0\u09c7\u0996\u09c7 \u09a8\u09be\u09b0\u09c0\u09b0 \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be, \u0995\u09cd\u09b7\u09ae\u09a4\u09be\u09df\u09a8 \u0993 \u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u0995\u09b0\u09be\u09b0 \u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae\u09c7 \u09b8\u09be\u09b0\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09a8\u09be\u09b0\u09c0\u09a6\u09c7\u09b0 \u09b8\u0982\u0997\u09a0\u09bf\u09a4 \u0995\u09b0\u09a4\u09c7 \u201c\u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u09b0\u09c0\u09b6\u0995\u09cd\u09a4\u09bf\u201d \u0986\u09a4\u09cd\u09ae\u09aa\u09cd\u09b0\u0995\u09be\u09b6 \u0995\u09b0\u09c7\u099b\u09c7\u0964 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u09c7 \u09b0\u09af\u09bc\u09c7\u099b\u09c7\u09a8 \u09ab\u200d\u09cd\u09af\u09be\u09b8\u09bf\u09ac\u09be\u09a6 \u09ac\u09bf\u09b0\u09cb\u09a7\u09c0 \u09b2\u09a1\u09bc\u09be\u0987\u09af\u09bc\u09c7\u09b0 \u09a4\u09bf\u09a8 \u09b8\u09be\u09b9\u09b8\u09c0 \u09ae\u09c1\u0996\u0964 \u09ae\u09a8\u09bf\u09b0\u09be \u09b6\u09be\u09b0\u09ae\u09bf\u09a8, \u09a1\u09be\u0983 \u09ae\u09be\u09b9\u09ae\u09c1\u09a6\u09be \u0986\u09b2\u09ae \u09ae\u09bf\u09a4\u09c1 \u098f\u09ac\u0982 \u09a8\u09c1\u09b8\u09b0\u09be\u09a4 \u09a4\u09be\u09ac\u09be\u09b8\u09b8\u09c1\u09ae\u0964 \u09a8\u09a4\u09c1\u09a8 \u098f\u0987 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u0995\u09c7 \u0985\u09ad\u09bf\u09a8\u09a8\u09cd\u09a6\u09a8 \u0993 \u09b6\u09c1\u09ad\u0995\u09be\u09ae\u09a8\u09be \u099c\u09be\u09a8\u09be\u0987\u0964 \u09a4\u09be\u09a6\u09c7\u09b0 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u09c7 \u0986\u09b0\u0993 \u09ac\u09c7\u0997\u09ac\u09be\u09a8 \u09b9\u09ac\u09c7 \u09a8\u09be\u09b0\u09c0\u09b0 \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be, \u0985\u09a7\u09bf\u0995\u09be\u09b0 \u0993 \u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4\u09c7\u09b0 \u09b2\u09a1\u09bc\u09be\u0987\u0964 \u09a8\u09be\u09b0\u09c0\u09b6\u0995\u09cd\u09a4\u09bf \u09b9\u09af\u09bc\u09c7 \u0989\u09a0\u09ac\u09c7 \u098f\u09a6\u09c7\u09b6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u099c\u09a8\u09aa\u09a6\u09c7\u09b0 \u09ac\u099e\u09cd\u099a\u09bf\u09a4 \u09a8\u09be\u09b0\u09c0\u09a6\u09c7\u09b0 \u09a8\u09bf\u09b0\u09cd\u09ad\u09b0\u09af\u09cb\u0997\u09cd\u09af \u09a0\u09bf\u0995\u09be\u09a8\u09be\u0964",
    "link": "https://www.facebook.com/nahidislamjuly/posts/pfbid02fbt2T4MKmsdYB31Y5VHdip9jouELHRvQ9FmXTs9bcWyLgVJafXn6dyg5yG5nPZ9El",
    "guid": "https://www.facebook.com/nahidislamjuly/posts/pfbid02fbt2T4MKmsdYB31Y5VHdip9jouELHRvQ9FmXTs9bcWyLgVJafXn6dyg5yG5nPZ9El",
