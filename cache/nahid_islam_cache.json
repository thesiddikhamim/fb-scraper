  },
  {
    "title": "\u09ac\u09be\u0982\u09b2\u09be \u09a8\u09ac\u09ac\u09b0\u09cd\u09b7 \u0989\u09aa\u09b2\u0995\u09cd\u09b7\u09c7 \u09ac\u09b0\u09cd\u09a3\u09be\u09a2\u09cd\u09af \u09ac\u09c8\u09b6\u09be\u0996\u09c0 \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09ae\u09be\u09b2\u09be\u09b0 \u0986\u09af\u09bc\u09cb\u099c\u09a8 \u0995\u09b0\u099b\u09c7 \u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd...",
    "description": "\u09ac\u09be\u0982\u09b2\u09be \u09a8\u09ac\u09ac\u09b0\u09cd\u09b7 \u0989\u09aa\u09b2\u0995\u09cd\u09b7\u09c7 \u09ac\u09b0\u09cd\u09a3\u09be\u09a2\u09cd\u09af \u09ac\u09c8\u09b6\u09be\u0996\u09c0 \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09ae\u09be\u09b2\u09be\u09b0 \u0986\u09af\u09bc\u09cb\u099c\u09a8 \u0995\u09b0\u099b\u09c7 \u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf- \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u0964 \u09ac\u09c8\u09b6\u09be\u0996\u09c0 \u09b0\u200d\u09cd\u09af\u09be\u09b2\u09bf, \u09ae\u09a8\u09cb\u099c\u09cd\u099e \u09b8\u09be\u0982\u09b8\u09cd\u0995\u09c3\u09a4\u09bf\u0995 \u09aa\u09b0\u09bf\u09ac\u09c7\u09b6\u09a8\u09be, \u09ac\u09be\u09df\u09cb\u09b8\u09cd\u0995\u09cb\u09aa\u09b8\u09b9 \u09a6\u09bf\u09a8\u09ac\u09cd\u09af\u09be\u09aa\u09c0 \u09a8\u09be\u09a8\u09be \u0986\u09df\u09cb\u099c\u09a8\u09c7\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u0989\u09ce\u09b8\u09ac\u09c7\u09b0 \u0986\u09a8\u09a8\u09cd\u09a6\u09c7 \u09ae\u09c1\u0996\u09b0 \u09b9\u09df\u09c7 \u0989\u09a0\u09ac\u09c7 \u09aa\u09c1\u09b0\u09cb \u09b6\u09b9\u09b0\u0964 \u0986\u09b8\u09c1\u09a8, \u09a8\u09ac\u09ac\u09b0\u09cd\u09b7\u09c7\u09b0 \u098f\u0987 \u0986\u09a8\u09a8\u09cd\u09a6 \u09ad\u09be\u0997\u09be\u09ad\u09be\u0997\u09bf \u0995\u09b0\u09bf \u098f\u0995\u09b8\u09be\u09a5\u09c7\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09be\u09a3\u09c7\u09b0 \u098f\u0987 \u0989\u09ce\u09b8\u09ac\u09c7 \u09b8\u0995\u09b2\u0995\u09c7 \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995 \u0986\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09a3 \u099c\u09be\u09a8\u09be\u099a\u09cd\u099b\u09bf\u0964 \u09b6\u09c1\u09ad \u09a8\u09ac\u09ac\u09b0\u09cd\u09b7!",
    "link": "https://www.facebook.com/nahidislamjuly/posts/pfbid02pGvVy51BysrsHfqnT5MWCTRnw6PtJSsm38aEx9t5Gdudu4KrqDYcFokQvpRk3fUhl",
    "guid": "https://www.facebook.com/nahidislamjuly/posts/pfbid02pGvVy51BysrsHfqnT5MWCTRnw6PtJSsm38aEx9t5Gdudu4KrqDYcFokQvpRk3fUhl",
    "pubDate": "2026-04-13T17:15:28.893680+00:00",
