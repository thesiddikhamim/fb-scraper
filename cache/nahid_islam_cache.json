[
  {
    "title": "\u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09b0 \u0985\u09b6\u09c7\u09b7 \u09b0\u09b9\u09ae\u09a4\u09c7 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u0989\u09ae\u09b0\u09be\u09b9 \u09aa\u09be\u09b2\u09a8 \u098f\u09ac\u0982 \u09ae\u09b9\u09be\u09a8\u09ac\u09c0 \u09b9\u09af\u09b0\u09a4 \u09ae\u09c1\u09b9\u09be\u09ae\u09cd\u09ae\u09a6 (\u09b8\u09be.)-\u098f\u09b0 \u09b0\u0993\u099c\u09be \u09ae\u09cb\u09ac\u09be...",
    "description": "\u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09b0 \u0985\u09b6\u09c7\u09b7 \u09b0\u09b9\u09ae\u09a4\u09c7 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u0989\u09ae\u09b0\u09be\u09b9 \u09aa\u09be\u09b2\u09a8 \u098f\u09ac\u0982 \u09ae\u09b9\u09be\u09a8\u09ac\u09c0 \u09b9\u09af\u09b0\u09a4 \u09ae\u09c1\u09b9\u09be\u09ae\u09cd\u09ae\u09a6 (\u09b8\u09be.)-\u098f\u09b0 \u09b0\u0993\u099c\u09be \u09ae\u09cb\u09ac\u09be\u09b0\u0995 \u099c\u09bf\u09af\u09bc\u09be\u09b0\u09a4 \u09b6\u09c7\u09b7\u09c7 \u09a6\u09c7\u09b6\u09c7 \u09ab\u09bf\u09b0\u09c7\u099b\u09c7\u09a8 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf (\u098f\u09a8\u09b8\u09bf\u09aa\u09bf)-\u098f\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09af\u09bc\u0995 \u0993 \u09ac\u09bf\u09b0\u09cb\u09a7\u09c0 \u09a6\u09b2\u09c0\u09af\u09bc \u099a\u09bf\u09ab \u09b9\u09c1\u0987\u09aa \u09ae\u09cb. \u09a8\u09be\u09b9\u09bf\u09a6 \u0987\u09b8\u09b2\u09be\u09ae\u0964 \u09b8\u09cc\u09a6\u09bf \u0986\u09b0\u09ac\u09c7\u09b0 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u09a8\u0997\u09b0\u09c0 \u09ae\u09a6\u09bf\u09a8\u09be \u09a5\u09c7\u0995\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09ac\u09bf\u09ae\u09be\u09a8\u09c7\u09b0 \u098f\u0995\u099f\u09bf \u09a8\u09bf\u09af\u09bc\u09ae\u09bf\u09a4 \u09ab\u09cd\u09b2\u09be\u0987\u099f\u09c7 \u09a4\u09bf\u09a8\u09bf \u0986\u099c \u09ac\u09c7\u09b2\u09be \u09aa\u09cd\u09b0\u09be\u09af\u09bc \u09aa\u09cc\u09a8\u09c7 \u09a6\u09c1\u0987\u099f\u09be\u09af\u09bc \u09b9\u09af\u09b0\u09a4 \u09b6\u09be\u09b9\u099c\u09be\u09b2\u09be\u09b2 \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09ac\u09bf\u09ae\u09be\u09a8\u09ac\u09a8\u09cd\u09a6\u09b0-\u098f \u0985\u09ac\u09a4\u09b0\u09a3 \u0995\u09b0\u09c7\u09a8\u0964 \u09b8\u09bf\u09a8\u09bf\u09df\u09b0 \u09af\u09c1\u0997\u09cd\u09ae \u0986\u09b9\u09cd\u09ac\u09be\u09df\u0995 \u0986\u09b0\u09bf\u09ab\u09c1\u09b2 \u0987\u09b8\u09b2\u09be\u09ae \u0986\u09a6\u09c0\u09ac\u09c7\u09b0 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u09c7 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf\u09b0 \u09a8\u09c7\u09a4\u09be\u0995\u09b0\u09cd\u09ae\u09c0\u09b0\u09be \u09a4\u09be\u0995\u09c7 \u09ac\u09bf\u09ae\u09be\u09a8\u09ac\u09a8\u09cd\u09a6\u09b0\u09c7 \u0989\u09b7\u09cd\u09a3 \u0985\u09ad\u09cd\u09af\u09b0\u09cd\u09a5\u09a8\u09be \u099c\u09be\u09a8\u09be\u09a8\u0964 \u098f\u09b8\u09ae\u09df \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09af\u09c1\u09ac\u09b6\u0995\u09cd\u09a4\u09bf, \u099c\u09be\u09a4\u09c0\u09af\u09bc \u099b\u09be\u09a4\u09cd\u09b0\u09b6\u0995\u09cd\u09a4\u09bf, \u09a8\u09cd\u09af\u09be\u09b6\u09a8\u09be\u09b2 \u0993\u09b2\u09be\u09ae\u09be \u098f\u09b2\u09be\u09af\u09bc\u09c7\u09a8\u09cd\u09b8 \u098f\u09b0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u09aa\u09b0\u09cd\u09af\u09be\u09af\u09bc\u09c7\u09b0 \u09a8\u09c7\u09a4\u09c3\u09ac\u09c3\u09a8\u09cd\u09a6 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u099b\u09bf\u09b2\u09c7\u09a8\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
