[
  {
    "title": "\u0986\u09ae\u09b0\u09be \u098f\u09ae\u09a8 \u098f\u0995\u099f\u09be \u09a6\u09c7\u09b6\u09c7\u09b0 \u09a6\u09bf\u0995\u09c7 \u09af\u09be\u099a\u09cd\u099b\u09bf \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u099a\u09be\u0981\u09a6\u09be\u09ac\u09be\u099c\u0995\u09c7 \u099a\u09be\u0981\u09a6\u09be\u09ac\u09be\u099c \u09ac\u09b2\u09be \u09af\u09be\u09ac\u09c7 \u09a8\u09be\u0964 \u099a\u09be\u0981\u09a6\u09be\u09ac\u09be\u099c...",
    "description": "\u0986\u09ae\u09b0\u09be \u098f\u09ae\u09a8 \u098f\u0995\u099f\u09be \u09a6\u09c7\u09b6\u09c7\u09b0 \u09a6\u09bf\u0995\u09c7 \u09af\u09be\u099a\u09cd\u099b\u09bf \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u099a\u09be\u0981\u09a6\u09be\u09ac\u09be\u099c\u0995\u09c7 \u099a\u09be\u0981\u09a6\u09be\u09ac\u09be\u099c \u09ac\u09b2\u09be \u09af\u09be\u09ac\u09c7 \u09a8\u09be\u0964 \u099a\u09be\u0981\u09a6\u09be\u09ac\u09be\u099c \u09ac\u09b2\u09b2\u09c7 \u09ae\u09be\u09ae\u09b2\u09be \u09a6\u09c7\u0993\u09af\u09bc\u09be \u09b9\u09ac\u09c7\u0964 \u09b8\u09c7\u0987 \u09aa\u09c1\u09b0\u09a8\u09cb \u0995\u09be\u09af\u09bc\u09a6\u09be, \u09ab\u09cd\u09af\u09be\u09b8\u09bf\u09ac\u09be\u09a6\u09c0 \u09aa\u09cd\u09b0\u09ac\u09a3\u09a4\u09be\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u098f \u09aa\u09cd\u09b0\u099c\u09a8\u09cd\u09ae\u0995\u09c7 \u09aa\u09c1\u09b0\u09cb\u09a8\u09cb \u0995\u09be\u09af\u09bc\u09a6\u09be\u09af\u09bc \u09b0\u09c1\u0996\u09c7 \u09a6\u09c7\u09af\u09bc\u09be \u09af\u09be\u09ac\u09c7 \u09a8\u09be\u0964 \u099c\u09c7\u09b2, \u099c\u09c1\u09b2\u09c1\u09ae \u0993 \u09b9\u09c1\u09b2\u09bf\u09af\u09bc\u09be \u0985\u09a4\u09bf\u0995\u09cd\u09b0\u09ae \u0995\u09b0\u09c7\u0987 \u098f \u09aa\u09cd\u09b0\u099c\u09a8\u09cd\u09ae \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8 \u0998\u099f\u09bf\u09af\u09bc\u09c7\u099b\u09c7\u0964 \u09ae\u09bf\u09a5\u09cd\u09af\u09be \u09ae\u09be\u09ae\u09b2\u09be \u09a6\u09bf\u09af\u09bc\u09c7 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0\u09a6\u09c7\u09b0 \u09ae\u09c1\u0996 \u09ac\u09a8\u09cd\u09a7 \u0995\u09b0\u09be \u09af\u09be\u09ac\u09c7 \u09a8\u09be\u0964 \u098f\u0995 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0\u0995\u09c7 \u09a5\u09be\u09ae\u09be\u09a4\u09c7 \u099a\u09be\u0987\u09b2\u09c7 \u0998\u09b0\u09c7 \u0998\u09b0\u09c7 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0 \u09a4\u09c8\u09b0\u09bf \u09b9\u09ac\u09c7\u0964",
