    "title": "\u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf- \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09a2\u09be\u0995\u09be \u09ae\u09b9\u09be\u09a8\u0997\u09b0\u09c0 \u0989\u09a4\u09cd\u09a4\u09b0 \u0986\u09af\u09bc\u09cb\u099c\u09bf\u09a4 \u0987\u09ab\u09a4\u09be\u09b0 \u09ae\u09be\u09b9\u09ab\u09bf\u09b2 \u0993 \u0986\u09b2\u09cb\u099a\u09a8\u09be \u09b8...",
    "description": "\u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf- \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09a2\u09be\u0995\u09be \u09ae\u09b9\u09be\u09a8\u0997\u09b0\u09c0 \u0989\u09a4\u09cd\u09a4\u09b0 \u0986\u09af\u09bc\u09cb\u099c\u09bf\u09a4 \u0987\u09ab\u09a4\u09be\u09b0 \u09ae\u09be\u09b9\u09ab\u09bf\u09b2 \u0993 \u0986\u09b2\u09cb\u099a\u09a8\u09be \u09b8\u09ad\u09be\u0964 #Nahidislam #NCPBangladesh",
