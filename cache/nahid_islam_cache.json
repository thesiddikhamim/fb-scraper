    "title": "\u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u09b0\u09c0\u09b6\u0995\u09cd\u09a4\u09bf\u09b0 \u0986\u09a4\u09cd\u09ae\u09aa\u09cd\u09b0\u0995\u09be\u09b6 \u0993 \u09b8\u09be\u09ae\u09cd\u09aa\u09cd\u09b0\u09a4\u09bf\u0995 \u09a8\u09be\u09b0\u09c0 \u09a8\u09bf\u09b0\u09cd\u09af\u09be\u09a4\u09a8 \u0993 \u09a7\u09b0\u09cd\u09b7\u09a3\u09c7\u09b0 \u09ac\u09bf\u099a\u09be\u09b0 \u09ac\u09bf\u09b7\u09af\u09bc\u0995 \u0986...",
    "description": "\u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u09b0\u09c0\u09b6\u0995\u09cd\u09a4\u09bf\u09b0 \u0986\u09a4\u09cd\u09ae\u09aa\u09cd\u09b0\u0995\u09be\u09b6 \u0993 \u09b8\u09be\u09ae\u09cd\u09aa\u09cd\u09b0\u09a4\u09bf\u0995 \u09a8\u09be\u09b0\u09c0 \u09a8\u09bf\u09b0\u09cd\u09af\u09be\u09a4\u09a8 \u0993 \u09a7\u09b0\u09cd\u09b7\u09a3\u09c7\u09b0 \u09ac\u09bf\u099a\u09be\u09b0 \u09ac\u09bf\u09b7\u09af\u09bc\u0995 \u0986\u09b2\u09cb\u099a\u09a8\u09be \u09b8\u09ad\u09be\u0964 \u09b8\u09b0\u09be\u09b8\u09b0\u09bf\u2026",
