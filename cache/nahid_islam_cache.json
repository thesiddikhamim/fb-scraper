[
  {
    "title": "\u0985\u09a8\u09cd\u09a4\u09b0\u09cd\u09ac\u09b0\u09cd\u09a4\u09c0\u0995\u09be\u09b2\u09c0\u09a8 \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0 \u09b8\u09ae\u09af\u09bc \u09a8\u09be\u09b0\u09c0\u09b0 \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be\u09b9\u09c0\u09a8\u09a4\u09be \u09a8\u09bf\u09af\u09bc\u09c7 \u0985\u09a8\u09c7\u0995 \u0995\u09a5\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09c7, \u0986\u09ae\u09b0\u09be\u0993 ...",
    "description": "\u0985\u09a8\u09cd\u09a4\u09b0\u09cd\u09ac\u09b0\u09cd\u09a4\u09c0\u0995\u09be\u09b2\u09c0\u09a8 \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0 \u09b8\u09ae\u09af\u09bc \u09a8\u09be\u09b0\u09c0\u09b0 \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be\u09b9\u09c0\u09a8\u09a4\u09be \u09a8\u09bf\u09af\u09bc\u09c7 \u0985\u09a8\u09c7\u0995 \u0995\u09a5\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09c7, \u0986\u09ae\u09b0\u09be\u0993 \u0995\u09a5\u09be \u09ac\u09b2\u09c7\u099b\u09bf\u0964 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u09b8\u09b0\u0995\u09be\u09b0 \u0997\u09a0\u09a8\u09c7\u09b0 \u09aa\u09b0 \u09a8\u09be\u09b0\u09c0 \u09a8\u09bf\u09aa\u09c0\u09a1\u09bc\u09a8, \u09a7*\u09b0\u09cd\u09b7\u09a3\u09c7\u09b0 \u09ae\u09b9\u09be\u09ae\u09be\u09b0\u09c0 \u099a\u09b2\u099b\u09c7\u0964 \u0986\u09ab\u09b8\u09cb\u09b8! \u098f\u0996\u09a8 \u0997\u09a3\u09ae\u09be\u09a7\u09cd\u09af\u09ae, \u09b8\u09c1\u09b6\u09c0\u09b2 \u09b8\u09ae\u09be\u099c \u09b8\u09ac\u09be\u0987 \u0985\u09a6\u09cd\u09ad\u09c1\u09a4 \u09a8\u09c0\u09b0\u09ac\u09a4\u09be \u09aa\u09be\u09b2\u09a8 \u0995\u09b0\u099b\u09c7\u0964 \u0995\u09cb\u09a8\u09cb \u09b2\u09c7\u0996\u09be\u09b2\u09c7\u0996\u09bf \u09a6\u09c7\u0996\u099b\u09bf \u09a8\u09be\u0964 \u0986\u09ae\u09b0\u09be \u0995\u09a5\u09be \u09a6\u09bf\u099a\u09cd\u099b\u09bf, \u0997\u09cb\u099f\u09be \u09a6\u09c7\u09b6 \u09a8\u09c0\u09b0\u09ac\u09a4\u09be \u09aa\u09be\u09b2\u09a8\u200c \u0995\u09b0\u09b2\u09c7\u0993 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf \u099a\u09c1\u09aa \u09a5\u09be\u0995\u09ac\u09c7 \u09a8\u09be\u0964 \u0986\u09ae\u09b0\u09be \u09ae\u09be\u09a0\u09c7 \u09a5\u09be\u0995\u09ac\u09cb\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ae\u09be-\u09ac\u09cb\u09a8\u09a6\u09c7\u09b0 \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be \u09a8\u09bf\u09af\u09bc\u09c7 \u0995\u09cb\u09a8\u09cb \u099b\u09be\u09a1\u09bc \u09a6\u09c7\u09af\u09bc\u09be \u09b9\u09ac\u09c7 \u09a8\u09be, \u0987\u09a8\u09b6\u09be\u0986\u09b2\u09cd\u09b2\u09be\u09b9\u0964",
