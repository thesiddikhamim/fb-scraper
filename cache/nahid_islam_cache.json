[
  {
    "title": "\u0997\u09a3\u0986\u09a8\u09cd\u09a6\u09cb\u09b2\u09a8 \u099b\u09be\u09a1\u09bc\u09be \u09b8\u09b0\u0995\u09be\u09b0 \u09b8\u0982\u09b8\u09cd\u0995\u09be\u09b0 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09af\u09bc\u09a8 \u0995\u09b0\u09ac\u09c7 \u09a8\u09be: \u09a8\u09be\u09b9\u09bf\u09a6 \u0987\u09b8\u09b2\u09be\u09ae \u0986\u099c \u09e7\u09e8 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09e8\u09e6\u09e8\u09ec,...",
    "description": "\u0997\u09a3\u0986\u09a8\u09cd\u09a6\u09cb\u09b2\u09a8 \u099b\u09be\u09a1\u09bc\u09be \u09b8\u09b0\u0995\u09be\u09b0 \u09b8\u0982\u09b8\u09cd\u0995\u09be\u09b0 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09af\u09bc\u09a8 \u0995\u09b0\u09ac\u09c7 \u09a8\u09be: \u09a8\u09be\u09b9\u09bf\u09a6 \u0987\u09b8\u09b2\u09be\u09ae \u0986\u099c \u09e7\u09e8 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09e8\u09e6\u09e8\u09ec, \u09ae\u0999\u09cd\u0997\u09b2\u09ac\u09be\u09b0: \u09b0\u09be\u099c\u09a7\u09be\u09a8\u09c0\u09b0 \u0995\u09be\u0995\u09b0\u09be\u0987\u09b2\u09c7\u09b0 \u09a1\u09bf\u09aa\u09cd\u09b2\u09cb\u09ae\u09be \u0987\u099e\u09cd\u099c\u09bf\u09a8\u09bf\u09af\u09bc\u09be\u09b0\u09cd\u09b8 \u0987\u09a8\u09b8\u09cd\u099f\u09bf\u099f\u09bf\u0989\u09b6\u09a8 \u09ae\u09bf\u09b2\u09a8\u09be\u09af\u09bc\u09a4\u09a8\u09c7 \u099c\u09c1\u09b2\u09be\u0987 \u09b6\u09b9\u09bf\u09a6 \u09aa\u09b0\u09bf\u09ac\u09be\u09b0 \u0993 \u099c\u09c1\u09b2\u09be\u0987 \u09af\u09cb\u09a6\u09cd\u09a7\u09be\u09a6\u09c7\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u09ae\u09a4\u09ac\u09bf\u09a8\u09bf\u09ae\u09af\u09bc \u09b8\u09ad\u09be \u0995\u09b0\u09c7\u099b\u09c7 \u098f\u0997\u09be\u09b0\u09cb \u09a6\u09b2\u09c0\u09af\u09bc \u099c\u09cb\u099f\u0964 \u098f\u09a4\u09c7 \u09b8\u09ad\u09be\u09aa\u09a4\u09bf\u09b0 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af\u09c7 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf- \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09af\u09bc\u0995 \u0993 \u09ac\u09bf\u09b0\u09cb\u09a7\u09c0 \u09a6\u09b2\u09c0\u09af\u09bc \u099a\u09bf\u09ab \u09b9\u09c1\u0987\u09aa \u09ae\u09cb\u0983 \u09a8\u09be\u09b9\u09bf\u09a6 \u0987\u09b8\u09b2\u09be\u09ae \u09ac\u09b2\u09c7\u09a8, \u2018\u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8\u09c7\u09b0 \u09a6\u09c1\u0987 \u09ac\u099b\u09b0 \u09aa\u09b0\u0993 \u0986\u09ae\u09b0\u09be \u09b8\u09ac\u09be\u0987 \u098f\u0995 \u099c\u09be\u09af\u09bc\u0997\u09be\u09af\u09bc \u0986\u099b\u09bf\u0964 \u0986\u09ae\u09b0\u09be \u09b8\u09c7\u0987 \u0990\u0995\u09cd\u09af\u09c7\u09b0 \u099c\u09be\u09af\u09bc\u0997\u09be\u09af\u09bc \u0986\u099b\u09bf \u09af\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u0995\u09c7 \u09b8\u0982\u09b8\u09cd\u0995\u09be\u09b0\u09c7\u09b0 \u09ae\u09a7\u09cd\u09af \u09a6\u09bf\u09af\u09bc\u09c7 \u09aa\u09b0\u09bf\u09ac\u09b0\u09cd\u09a4\u09a8 \u0995\u09b0\u09a4\u09c7 \u09b9\u09ac\u09c7\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u098f\u0987 \u09aa\u09b0\u09bf\u09ac\u09b0\u09cd\u09a4\u09a8\u09c7\u09b0 \u09aa\u09a5\u09c7 \u09aa\u09cd\u09b0\u09a7\u09be\u09a8 \u09ac\u09be\u09a7\u09be \u09b9\u09af\u09bc\u09c7 \u09a6\u09be\u0981\u09a1\u09bc\u09bf\u09af\u09bc\u09c7\u099b\u09c7 \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u09b8\u09b0\u0995\u09be\u09b0\u0964' \u09b8\u09b0\u0995\u09be\u09b0 \u0995\u0996\u09a8\u09cb \u09b8\u0982\u09b8\u09cd\u0995\u09be\u09b0 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09af\u09bc\u09a8 \u0995\u09b0\u09ac\u09c7 \u09a8\u09be \u0989\u09b2\u09cd\u09b2\u09c7\u0996 \u0995\u09b0\u09c7 \u09a8\u09be\u09b9\u09bf\u09a6 \u0987\u09b8\u09b2\u09be\u09ae \u09ac\u09b2\u09c7\u09a8, \u2018\u0986\u09ae\u09b0\u09be \u099a\u09c7\u09af\u09bc\u09c7\u099b\u09bf\u09b2\u09be\u09ae \u09b8\u0982\u09b8\u09a6\u09c7 \u09b8\u09ac\u0995\u09bf\u099b\u09c1\u09b0 \u09b8\u09ae\u09be\u09a7\u09be\u09a8 \u09b9\u09ac\u09c7\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09b8\u0982\u09b8\u09a6\u0995\u09c7 \u09ac\u09cd\u09af\u09b0\u09cd\u09a5 \u0995\u09b0\u09c7 \u09a6\u09c7\u09af\u09bc\u09be\u09b0 \u099a\u09c7\u09b7\u09cd\u099f\u09be \u099a\u09b2\u099b\u09c7\u0964 \u098f\u099c\u09a8\u09cd\u09af \u098f\u09ac\u09be\u09b0 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0997\u09a3\u0986\u09a8\u09cd\u09a6\u09cb\u09b2\u09a8\u09c7\u09b0 \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09c1\u09a4\u09bf \u09a8\u09bf\u09a4\u09c7 \u09b9\u09ac\u09c7\u0964 \u0997\u09a3\u0986\u09a8\u09cd\u09a6\u09cb\u09b2\u09a8 \u099b\u09be\u09a1\u09bc\u09be \u09b8\u09b0\u0995\u09be\u09b0 \u09b8\u0982\u09b8\u09cd\u0995\u09be\u09b0 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09af\u09bc\u09a8 \u0995\u09b0\u09ac\u09c7 \u09a8\u09be\u0964 \u09a4\u09ac\u09c7 \u098f\u09ac\u09be\u09b0 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09aa\u09b0\u09bf\u0995\u09b2\u09cd\u09aa\u09a8\u09be \u09ae\u09cb\u09a4\u09be\u09ac\u09c7\u0995 \u09b0\u09be\u099c\u09aa\u09a5\u09c7 \u09a8\u09be\u09ae\u09a4\u09c7 \u09b9\u09ac\u09c7\u0964 \u098f\u09ac\u09be\u09b0 \u0986\u09b0 \u09ac\u09cd\u09af\u09b0\u09cd\u09a5 \u0995\u09bf\u0982\u09ac\u09be \u0985\u09b0\u09cd\u09a7\u09c7\u0995 \u09b8\u09ab\u09b2 \u09b9\u09a4\u09c7 \u099a\u09be\u0987 \u09a8\u09be\u0964' \u09a8\u09be\u09b9\u09bf\u09a6 \u0987\u09b8\u09b2\u09be\u09ae \u09ac\u09b2\u09c7\u09a8, '\u09b8\u0982\u09b8\u09cd\u0995\u09be\u09b0 \u0995\u09cb\u09a8\u09cb \u09a6\u09b2\u09c7\u09b0 \u09a8\u09be\u0964 \u098f\u099f\u09be \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09b0\u0995\u09cd\u09b7\u09be\u09b0 \u09a6\u09be\u09ac\u09bf\u0964 \u0986\u09ae\u09b0\u09be \u0990\u0995\u09cd\u09af\u09ac\u09a6\u09cd\u09a7 \u0986\u099b\u09bf\u0964 \u098f\u09ac\u09be\u09b0 \u0986\u09ae\u09b0\u09be \u09ae\u099e\u09cd\u099a\u09c7 \u09af\u09be\u09b0\u09be \u09ac\u09b8\u09c7 \u0986\u099b\u09bf \u09a4\u09be\u09b0\u09be \u09b8\u09be\u09ae\u09a8\u09c7 \u09a6\u09be\u0981\u09a1\u09bc\u09be\u09ac\u09cb\u0964 \u0997\u09c1\u09b2\u09bf \u0986\u09b8\u09b2\u09c7 \u0986\u0997\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ac\u09c1\u0995\u09c7 \u09b2\u09be\u0997\u09ac\u09c7\u0964 \u0986\u09aa\u09a8\u09be\u09b0\u09be \u09b8\u09b9\u09af\u09cb\u0997\u09bf\u09a4\u09be \u0995\u09b0\u09ac\u09c7\u09a8\u0964 \u0987\u09a8\u09b6\u09be\u0986\u09b2\u09cd\u09b2\u09be\u09b9, \u09a8\u09a4\u09c1\u09a8 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be \u09b9\u09ac\u09c7\u0964 \u09b8\u0982\u09b8\u09cd\u0995\u09be\u09b0 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09af\u09bc\u09a8 \u0995\u09b0\u09be \u09b9\u09ac\u09c7\u0964 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u0995\u09bf\u0982\u09ac\u09be \u0995\u09cb\u09a8\u09cb \u09ac\u09bf\u09a6\u09c7\u09b6\u09bf \u09b6\u0995\u09cd\u09a4\u09bf \u09ac\u09be\u09a7\u09be \u09a6\u09bf\u09b2\u09c7 \u09a4\u09be\u09a6\u09c7\u09b0 \u09aa\u09b0\u09be\u099c\u09bf\u09a4 \u0995\u09b0\u09be \u09b9\u09ac\u09c7\u0964' \u09b6\u09b9\u09bf\u09a6 \u09aa\u09b0\u09bf\u09ac\u09be\u09b0 \u09a8\u09bf\u09af\u09bc\u09c7 \u09b8\u09b0\u0995\u09be\u09b0 \u09ac\u09cd\u09af\u09ac\u09b9\u09be\u09b0 \u0995\u09b0\u099b\u09c7 \u0989\u09b2\u09cd\u09b2\u09c7\u0996 \u0995\u09b0\u09c7 \u09a8\u09be\u09b9\u09bf\u09a6 \u0987\u09b8\u09b2\u09be\u09ae \u09ac\u09b2\u09c7\u09a8, '\u099c\u09c1\u09b2\u09be\u0987 \u09b6\u09b9\u09bf\u09a6 \u0993 \u0986\u09b9\u09a4\u09b0\u09be \u098f\u09a6\u09c7\u09b6\u09c7\u09b0 \u09b8\u09ae\u09cd\u09aa\u09a6\u0964 \u09a4\u09be\u09a6\u09c7\u09b0 \u09a8\u09bf\u09af\u09bc\u09c7 \u0986\u09ae\u09b0\u09be \u09b0\u09be\u099c\u09a8\u09c0\u09a4\u09bf \u0995\u09b0\u09a4\u09c7 \u099a\u09be\u0987 \u09a8\u09be\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09a6\u09be\u09ac\u09bf \u09b8\u09ae\u09b0\u09cd\u09a5\u09a8 \u0995\u09b0\u09b2\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u09b9\u09af\u09cb\u0997\u09bf\u09a4\u09be \u0995\u09b0\u09ac\u09c7\u09a8\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09b8\u09b0\u0995\u09be\u09b0 \u0995\u0996\u09a8\u09cb \u099c\u09c1\u09b2\u09be\u0987 \u09af\u09cb\u09a6\u09cd\u09a7\u09be, \u0995\u0996\u09a8\u0993 \u098f\u0995\u09be\u09a4\u09cd\u09a4\u09b0\u09c7\u09b0 \u09a8\u09be\u09ae \u09ac\u09cd\u09af\u09ac\u09b9\u09be\u09b0 \u0995\u09b0\u09c7 \u09a4\u09be\u09a6\u09c7\u09b0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u0995\u09be\u099c\u09c7\u09b0 \u09ac\u09c8\u09a7\u09a4\u09be \u09a6\u09bf\u099a\u09cd\u099b\u09c7\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u099a\u09ac\u09cd\u09ac\u09bf\u09b6 \u098f\u09ac\u0982 \u098f\u0995\u09be\u09a4\u09cd\u09a4\u09b0 \u0995\u09cb\u09a8\u09cb\u099f\u09bf\u0995\u09c7\u0987 \u09a7\u09be\u09b0\u09a3 \u09a4\u09be\u09b0\u09be \u09a7\u09be\u09b0\u09a3 \u0995\u09b0\u09c7 \u09a8\u09be\u0964' \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u09b8\u09b0\u0995\u09be\u09b0 \u0997\u09a0\u09a8\u09c7\u09b0 \u09aa\u09b0 \u09a5\u09c7\u0995\u09c7\u0987 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09aa\u09c7\u099b\u09a8\u09c7\u09b0 \u09a6\u09bf\u0995\u09c7 \u09b9\u09be\u0981\u099f\u099b\u09c7 \u0985\u09ad\u09bf\u09af\u09cb\u0997 \u0995\u09b0\u09c7 \u09a8\u09be\u09b9\u09bf\u09a6 \u0987\u09b8\u09b2\u09be\u09ae \u09ac\u09b2\u09c7\u09a8, \u098f\u09a6\u09c7\u09b6\u09c7\u09b0 \u0997\u09a3\u0986\u09a8\u09cd\u09a6\u09cb\u09b2\u09a8\u09c7\u09b0 \u09b8\u09c1\u09ab\u09b2 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u09ad\u09cb\u0997 \u0995\u09b0\u09c7\u099b\u09c7\u0964 \u09a8\u09ac\u09cd\u09ac\u0987 \u098f\u09b0 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8\u09c7\u09b0 \u09b8\u09c1\u09ab\u09b2 \u09a4\u09be\u09b0\u09be \u09ad\u09cb\u0997 \u0995\u09b0\u09c7\u099b\u09c7\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u0995\u09cd\u09b7\u09ae\u09a4\u09be\u09af\u09bc \u09ac\u09b8\u09c7 \u09a4\u09bf\u09a8 \u099c\u09cb\u099f\u09c7\u09b0 \u09b0\u09c2\u09aa\u09b0\u09c7\u0996\u09be\u0995\u09c7 \u099b\u09c1\u0981\u09a1\u09bc\u09c7 \u09ab\u09c7\u09b2\u09c7 \u09a6\u09bf\u09af\u09bc\u09c7\u099b\u09c7\u0964 \u098f\u0996\u09a8\u0993 \u099c\u09c1\u09b2\u09be\u0987 \u09b8\u09a8\u09a6 \u098f\u09ac\u0982 \u0985\u09a7\u09cd\u09af\u09be\u09a6\u09c7\u09b6 \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09be\u0996\u09cd\u09af\u09be\u09a8 \u0995\u09b0\u099b\u09c7\u0964' \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09c7 \u098f\u0997\u09be\u09b0\u09cb \u09a6\u09b2\u09c0\u09af\u09bc \u099c\u09cb\u099f\u09c7\u09b0 \u09b6\u09c0\u09b0\u09cd\u09b7 \u09a8\u09c7\u09a4\u09be\u09b0\u09be \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u099b\u09bf\u09b2\u09c7\u09a8\u0964",
    "link": "https://www.facebook.com/nahidislamjuly/posts/pfbid0VN1vEzRhMRRoovMH1wZmJZVyG24RvbfPqwCqrrj2Q2EqiFHPxfd3K2X5WumoYqTRl",
    "guid": "https://www.facebook.com/nahidislamjuly/posts/pfbid0VN1vEzRhMRRoovMH1wZmJZVyG24RvbfPqwCqrrj2Q2EqiFHPxfd3K2X5WumoYqTRl",
