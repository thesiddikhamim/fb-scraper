[
  {
    "title": "\u09a6\u09cc\u09b2\u09a4\u09a6\u09bf\u09af\u09bc\u09be \u09ab\u09c7\u09b0\u09bf\u0998\u09be\u099f\u09c7 \u09b8\u0982\u0998\u099f\u09bf\u09a4 \u09ae\u09b0\u09cd\u09ae\u09be\u09a8\u09cd\u09a4\u09bf\u0995 \u09ac\u09be\u09b8 \u09a6\u09c1\u09b0\u09cd\u0998\u099f\u09a8\u09be\u09af\u09bc \u09b9\u09a4\u09be\u09b9\u09a4\u09c7\u09b0 \u09b8\u0982\u09ac\u09be\u09a6\u09c7 \u0986\u09ae\u09b0\u09be \u0997\u09ad\u09c0\u09b0\u09ad\u09be\u09ac\u09c7...",
    "description": "\u09a6\u09cc\u09b2\u09a4\u09a6\u09bf\u09af\u09bc\u09be \u09ab\u09c7\u09b0\u09bf\u0998\u09be\u099f\u09c7 \u09b8\u0982\u0998\u099f\u09bf\u09a4 \u09ae\u09b0\u09cd\u09ae\u09be\u09a8\u09cd\u09a4\u09bf\u0995 \u09ac\u09be\u09b8 \u09a6\u09c1\u09b0\u09cd\u0998\u099f\u09a8\u09be\u09af\u09bc \u09b9\u09a4\u09be\u09b9\u09a4\u09c7\u09b0 \u09b8\u0982\u09ac\u09be\u09a6\u09c7 \u0986\u09ae\u09b0\u09be \u0997\u09ad\u09c0\u09b0\u09ad\u09be\u09ac\u09c7 \u09b6\u09cb\u0995\u09be\u09b9\u09a4 \u0993 \u09ac\u09cd\u09af\u09a5\u09bf\u09a4\u0964 \u099c\u09c0\u09ac\u09a8\u09c7\u09b0 \u09b8\u09cd\u09ac\u09be\u09ad\u09be\u09ac\u09bf\u0995 \u099b\u09a8\u09cd\u09a6 \u09a5\u09be\u09ae\u09bf\u09af\u09bc\u09c7 \u098f\u0987 \u09a6\u09c1\u09b0\u09cd\u0998\u099f\u09a8\u09be \u09ae\u09c1\u09b9\u09c2\u09b0\u09cd\u09a4\u09c7\u0987 \u0985\u09b8\u0982\u0996\u09cd\u09af \u09aa\u09b0\u09bf\u09ac\u09be\u09b0\u0995\u09c7 \u09b6\u09cb\u0995\u09c7\u09b0 \u09b8\u09be\u0997\u09b0\u09c7 \u09a8\u09bf\u09ae\u099c\u09cd\u099c\u09bf\u09a4 \u0995\u09b0\u09c7\u099b\u09c7\u0964 \u09af\u09be\u09b0\u09be \u098f\u0987 \u09a6\u09c1\u09b0\u09cd\u0998\u099f\u09a8\u09be\u09af\u09bc \u09aa\u09cd\u09b0\u09be\u09a3 \u09b9\u09be\u09b0\u09bf\u09af\u09bc\u09c7\u099b\u09c7\u09a8, \u09a4\u09be\u09a6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09c7\u0995\u09c7\u09b0 \u09ac\u09bf\u09a6\u09c7\u09b9\u09c0 \u0986\u09a4\u09cd\u09ae\u09be\u09b0 \u09ae\u09be\u0997\u09ab\u09bf\u09b0\u09be\u09a4 \u0995\u09be\u09ae\u09a8\u09be \u0995\u09b0\u099b\u09bf\u0964 \u09ae\u09b9\u09be\u09a8 \u0986\u09b2\u09cd\u09b2\u09be\u09b9 \u09af\u09c7\u09a8 \u09a4\u09be\u09a6\u09c7\u09b0 \u099c\u09be\u09a8\u09cd\u09a8\u09be\u09a4\u09c1\u09b2 \u09ab\u09c7\u09b0\u09a6\u09cc\u09b8 \u09a8\u09b8\u09bf\u09ac \u0995\u09b0\u09c7\u09a8\u0964 \u09b6\u09cb\u0995\u09b8\u09a8\u09cd\u09a4\u09aa\u09cd\u09a4 \u09aa\u09b0\u09bf\u09ac\u09be\u09b0\u0997\u09c1\u09b2\u09cb\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995 \u09b8\u09ae\u09ac\u09c7\u09a6\u09a8\u09be \u099c\u09be\u09a8\u09be\u099a\u09cd\u099b\u09bf\u0964 \u0986\u09b9\u09a4\u09a6\u09c7\u09b0 \u09a6\u09cd\u09b0\u09c1\u09a4 \u0993 \u09b8\u09b0\u09cd\u09ac\u09cb\u099a\u09cd\u099a \u099a\u09bf\u0995\u09bf\u09ce\u09b8\u09be \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u0995\u09b0\u09be \u098f\u09ac\u0982 \u09a8\u09bf\u0996\u09cb\u0981\u099c\u09a6\u09c7\u09b0 \u0989\u09a6\u09cd\u09a7\u09be\u09b0\u09c7 \u09b8\u0982\u09b6\u09cd\u09b2\u09bf\u09b7\u09cd\u099f \u09b8\u0995\u09b2 \u0995\u09b0\u09cd\u09a4\u09c3\u09aa\u0995\u09cd\u09b7\u0995\u09c7 \u09b8\u09b0\u09cd\u09ac\u09cb\u099a\u09cd\u099a \u09a4\u09ce\u09aa\u09b0 \u09b9\u09ac\u09be\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09a8 \u099c\u09be\u09a8\u09be\u099a\u09cd\u099b\u09bf\u0964 \u098f \u09a7\u09b0\u09a8\u09c7\u09b0 \u09a6\u09c1\u09b0\u09cd\u0998\u099f\u09a8\u09be \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u09be\u09ae\u0997\u09cd\u09b0\u09bf\u0995 \u0985\u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be\u09aa\u09a8\u09be \u0993 \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be\u09b9\u09c0\u09a8\u09a4\u09be\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u099a\u09cd\u099b\u09ac\u09bf\u0964 \u09aa\u09cd\u09b0\u09b6\u09cd\u09a8 \u099c\u09be\u0997\u09c7, \u0986\u09b0 \u0995\u09a4\u09a6\u09bf\u09a8 \u098f\u09ad\u09be\u09ac\u09c7 \u09aa\u09cd\u09b0\u09bf\u09af\u09bc\u099c\u09a8 \u09b9\u09be\u09b0\u09be\u09a8\u09cb\u09b0 \u09ac\u09c7\u09a6\u09a8\u09be \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u09b9\u09cd\u09af \u0995\u09b0\u09a4\u09c7 \u09b9\u09ac\u09c7? \u098f\u0987 \u0997\u09ad\u09c0\u09b0 \u09b6\u09cb\u0995\u09c7\u09b0 \u09ae\u09c1\u09b9\u09c2\u09b0\u09cd\u09a4\u09c7 \u0986\u09b8\u09c1\u09a8, \u0986\u09ae\u09b0\u09be \u09b8\u09ac\u09be\u0987 \u0995\u09cd\u09b7\u09a4\u09bf\u0997\u09cd\u09b0\u09b8\u09cd\u09a4\u09a6\u09c7\u09b0 \u09aa\u09be\u09b6\u09c7 \u09a6\u09be\u0981\u09a1\u09bc\u09be\u0987, \u09b8\u09b9\u09ae\u09b0\u09cd\u09ae\u09bf\u09a4\u09be\u09b0 \u09b9\u09be\u09a4 \u09ac\u09be\u09a1\u09bc\u09bf\u09af\u09bc\u09c7 \u09a6\u09bf\u0987\u0964 \u09ae\u09b9\u09be\u09a8 \u0986\u09b2\u09cd\u09b2\u09be\u09b9 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u09ac\u09be\u0987\u0995\u09c7 \u09b9\u09c7\u09ab\u09be\u099c\u09a4 \u0995\u09b0\u09c1\u09a8\u0964",
    "link": "https://www.facebook.com/nahidislamjuly/posts/pfbid02MLfPwVoqM2JXemJiAHuh4av5MgCB49hUS4C5Zg8BgrVqkXQ1fH4mm7VmQdexuPqnl",
    "guid": "https://www.facebook.com/nahidislamjuly/posts/pfbid02MLfPwVoqM2JXemJiAHuh4av5MgCB49hUS4C5Zg8BgrVqkXQ1fH4mm7VmQdexuPqnl",
    "pubDate": "2026-03-26T11:37:27.529845+00:00",
    "image": "https://scontent-ams2-1.xx.fbcdn.net/v/t39.30808-6/657360820_122193791378528998_6846794924235075900_n.jpg?stp=dst-jpg_p526x296_tt6&_nc_cat=111&ccb=1-7&_nc_sid=7b2446&_nc_ohc=CC_5LwjN-M0Q7kNvwEL6Jni&_nc_oc=AdptijvWorqaFVDILcls44BASLNrl6lVItTqQvYkRmcW-Rh-aVMRV8R_RYGs7TCHh9U&_nc_zt=23&_nc_ht=scontent-ams2-1.xx&_nc_gid=-SpuS7vv1qc85s-OVHY2pg&_nc_ss=7a30f&oh=00_AfxNpvkkv0qEkGP3HCEVixrZKmkMTg6BrDZ-mNFxE-x7DA&oe=69CD9C81"
  },
  {
    "title": "\u0986\u099c \u09e8\u09ec\u09b6\u09c7 \u09ae\u09be\u09b0\u09cd\u099a, \u09ae\u09b9\u09be\u09a8 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be \u0993 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a6\u09bf\u09ac\u09b8\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0987\u09a4\u09bf\u09b9\u09be\u09b8\u09c7 \u098f\u0995 \u0985\u09a8\u09a8\u09cd\u09af \u0997\u09cc\u09b0\u09ac\u09ae\u09af\u09bc \u0993 \u0986...",
    "description": "\u0986\u099c \u09e8\u09ec\u09b6\u09c7 \u09ae\u09be\u09b0\u09cd\u099a, \u09ae\u09b9\u09be\u09a8 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be \u0993 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a6\u09bf\u09ac\u09b8\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0987\u09a4\u09bf\u09b9\u09be\u09b8\u09c7 \u098f\u0995 \u0985\u09a8\u09a8\u09cd\u09af \u0997\u09cc\u09b0\u09ac\u09ae\u09af\u09bc \u0993 \u0986\u09a4\u09cd\u09ae\u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be\u09b0 \u09a6\u09bf\u09a8\u0964 \u0997\u09ad\u09c0\u09b0 \u09b6\u09cd\u09b0\u09a6\u09cd\u09a7\u09be \u0993 \u0995\u09c3\u09a4\u099c\u09cd\u099e\u09a4\u09be\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u09b8\u09cd\u09ae\u09b0\u09a3 \u0995\u09b0\u099b\u09bf \u09ae\u09b9\u09be\u09a8 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7\u09c7\u09b0 \u09b8\u0995\u09b2 \u09ac\u09c0\u09b0 \u09b6\u09b9\u09bf\u09a6\u0995\u09c7, \u09af\u09be\u09a6\u09c7\u09b0 \u0985\u09ae\u09b0 \u0986\u09a4\u09cd\u09ae\u09a4\u09cd\u09af\u09be\u0997\u09c7\u09b0 \u09ac\u09bf\u09a8\u09bf\u09ae\u09af\u09bc\u09c7 \u0985\u09b0\u09cd\u099c\u09bf\u09a4 \u09b9\u09af\u09bc\u09c7\u099b\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8-\u09b8\u09be\u09b0\u09cd\u09ac\u09ad\u09cc\u09ae \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u0964 \u09b6\u09cd\u09b0\u09a6\u09cd\u09a7\u09be\u09ad\u09b0\u09c7 \u09b8\u09cd\u09ae\u09b0\u09a3 \u0995\u09b0\u099b\u09bf \u09b8\u09c7\u0987 \u09a8\u09bf\u09b0\u09cd\u09af\u09be\u09a4\u09bf\u09a4 \u09ac\u09c0\u09b0\u09be\u0999\u09cd\u0997\u09a8\u09be\u09a6\u09c7\u09b0, \u09af\u09be\u09a6\u09c7\u09b0 \u09a4\u09cd\u09af\u09be\u0997 \u0993 \u09b8\u09be\u09b9\u09b8 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u0987\u09a4\u09bf\u09b9\u09be\u09b8\u0995\u09c7 \u0995\u09b0\u09c7\u099b\u09c7 \u0986\u09b0\u0993 \u09ae\u09b9\u09bf\u09ae\u09be\u09a8\u09cd\u09ac\u09bf\u09a4\u0964 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be\u09b0 \u09eb\u09eb\u09a4\u09ae \u09ac\u09b0\u09cd\u09b7\u09aa\u09c2\u09b0\u09cd\u09a4\u09bf\u09a4\u09c7 \u09a6\u09c7\u09b6\u09c7 \u0993 \u09aa\u09cd\u09b0\u09ac\u09be\u09b8\u09c7 \u0985\u09ac\u09b8\u09cd\u09a5\u09be\u09a8\u09b0\u09a4 \u09b8\u0995\u09b2 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09bf\u0995\u09c7 \u099c\u09be\u09a8\u09be\u0987 \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995 \u09b6\u09c1\u09ad\u09c7\u099a\u09cd\u099b\u09be \u0993 \u0985\u09ad\u09bf\u09a8\u09a8\u09cd\u09a6\u09a8\u0964 \u09e7\u09ef\u09ed\u09e7-\u098f\u09b0 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be \u0995\u09c7\u09ac\u09b2 \u098f\u0995\u099f\u09bf \u09ad\u09c2\u0996\u09a3\u09cd\u09a1\u09c7\u09b0 \u0985\u09b0\u09cd\u099c\u09a8 \u09a8\u09af\u09bc; \u098f\u099f\u09bf \u099b\u09bf\u09b2 \u09a8\u09cd\u09af\u09be\u09af\u09bc, \u09b8\u09be\u09ae\u09cd\u09af, \u0997\u09a3\u09a4\u09a8\u09cd\u09a4\u09cd\u09b0 \u0993 \u09ae\u09be\u09a8\u09ac\u09bf\u0995 \u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be\u09b0 \u09ad\u09bf\u09a4\u09cd\u09a4\u09bf\u09a4\u09c7 \u098f\u0995\u099f\u09bf \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0 \u0997\u09a0\u09a8\u09c7\u09b0 \u0985\u0999\u09cd\u0997\u09c0\u0995\u09be\u09b0\u0964 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be\u09b0 \u098f\u09a4 \u09ac\u099b\u09b0 \u09aa\u09b0\u0993 \u09b8\u09c7\u0987 \u0985\u0999\u09cd\u0997\u09c0\u0995\u09be\u09b0 \u0986\u099c\u0993 \u09aa\u09c2\u09b0\u09cd\u09a3 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09af\u09bc\u09a8\u09c7\u09b0 \u0985\u09aa\u09c7\u0995\u09cd\u09b7\u09be\u09af\u09bc\u0964 \u0997\u09a3\u09a4\u09a8\u09cd\u09a4\u09cd\u09b0\u09c7\u09b0 \u09b8\u09cd\u09ac\u09be\u09ad\u09be\u09ac\u09bf\u0995 \u09a7\u09be\u09b0\u09be\u0995\u09c7 \u09ac\u09be\u09a7\u09be\u0997\u09cd\u09b0\u09b8\u09cd\u09a4 \u0995\u09b0\u09c7 \u098f\u0987 \u099c\u09be\u09a4\u09bf\u09b0 \u0993\u09aa\u09b0 \u09ac\u09be\u09b0\u09ac\u09be\u09b0 \u099a\u09be\u09aa\u09bf\u09af\u09bc\u09c7 \u09a6\u09c7\u0993\u09af\u09bc\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09c7 \u09b8\u09cd\u09ac\u09c8\u09b0\u09be\u099a\u09be\u09b0 \u0993 \u09ab\u09cd\u09af\u09be\u09b8\u09bf\u09ac\u09be\u09a6\u09c7\u09b0 \u0985\u09a8\u09cd\u09a7\u0995\u09be\u09b0 \u09b6\u09be\u09b8\u09a8\u0964 \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0\u0995\u09c7 \u09a6\u09c1\u09b0\u09cd\u09ac\u09b2 \u0995\u09b0\u09c7 \u09ac\u09bf\u09a6\u09c7\u09b6\u09bf \u09b6\u0995\u09cd\u09a4\u09bf\u09b0 \u0995\u09be\u099b\u09c7 \u09a8\u09a4\u099c\u09be\u09a8\u09c1 \u0995\u09b0\u09be\u09b0 \u0985\u09aa\u099a\u09c7\u09b7\u09cd\u099f\u09be\u0993 \u09b9\u09af\u09bc\u09c7\u099b\u09c7 \u09ac\u09b9\u09c1\u09ac\u09be\u09b0\u0964 \u09a4\u09ac\u09c1\u0993 \u098f\u0987 \u09ad\u09c2\u0996\u09a3\u09cd\u09a1\u09c7\u09b0 \u09ae\u09be\u09a8\u09c1\u09b7 \u0995\u0996\u09a8\u09cb \u09aa\u09b0\u09be\u099c\u09af\u09bc \u09ae\u09be\u09a8\u09c7\u09a8\u09bf\u0964 \u09aa\u09cd\u09b0\u09a4\u09bf\u09ac\u09be\u09b0\u0987 \u0985\u09a7\u09bf\u0995\u09be\u09b0, \u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be \u0993 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be\u09b0 \u09aa\u09cd\u09b0\u09b6\u09cd\u09a8\u09c7 \u099c\u09c7\u0997\u09c7 \u0989\u09a0\u09c7\u099b\u09c7 \u099c\u09a8\u09a4\u09be\u0964 \u09b8\u09ac\u09b6\u09c7\u09b7 \u099c\u09c1\u09b2\u09be\u0987\u09af\u09bc\u09c7\u09b0 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8\u09c7 \u09b9\u09be\u099c\u09be\u09b0\u09cb \u09b6\u09b9\u09bf\u09a6\u09c7\u09b0 \u0986\u09a4\u09cd\u09ae\u09a6\u09be\u09a8\u09c7\u09b0 \u09ac\u09bf\u09a8\u09bf\u09ae\u09af\u09bc\u09c7 \u09b8\u09cd\u09ac\u09c8\u09b0\u09b6\u09be\u09b8\u09a8 \u09a5\u09c7\u0995\u09c7 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf \u09aa\u09c7\u09af\u09bc\u09c7\u099b\u09c7 \u099c\u09be\u09a4\u09bf\u0964 \u098f\u0995\u0987\u09b8\u0999\u09cd\u0997\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0997\u09a3\u09a4\u09be\u09a8\u09cd\u09a4\u09cd\u09b0\u09bf\u0995 \u0985\u09a7\u09bf\u0995\u09be\u09b0 \u0993 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u0986\u09a4\u09cd\u09ae\u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be \u09ab\u09c7\u09b0\u09a4 \u098f\u09b8\u09c7\u099b\u09c7\u0964 \u0986\u099c\u0995\u09c7\u09b0 \u098f\u0987 \u09ae\u09b9\u09be\u09a8 \u09a6\u09bf\u09a8\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09a6\u09c3\u09a2\u09bc \u0985\u0999\u09cd\u0997\u09c0\u0995\u09be\u09b0\u2013 \u09b6\u09b9\u09bf\u09a6\u09a6\u09c7\u09b0 \u09b0\u0995\u09cd\u09a4\u09c7\u09b0 \u098b\u09a3 \u09b6\u09cb\u09a7 \u0995\u09b0\u09a4\u09c7 \u0986\u09ae\u09b0\u09be \u0997\u09a1\u09bc\u09c7 \u09a4\u09c1\u09b2\u09ac\u09cb \u098f\u0995\u099f\u09bf \u099c\u09ac\u09be\u09ac\u09a6\u09bf\u09b9\u09bf\u09ae\u09c2\u09b2\u0995, \u09a8\u09cd\u09af\u09be\u09af\u09bc\u09ad\u09bf\u09a4\u09cd\u09a4\u09bf\u0995 \u0993 \u0985\u09a8\u09cd\u09a4\u09b0\u09cd\u09ad\u09c1\u0995\u09cd\u09a4\u09bf\u09ae\u09c2\u09b2\u0995 \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0\u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be\u0964 \u09a6\u09c1\u09b0\u09cd\u09a8\u09c0\u09a4\u09bf, \u0985\u09a8\u09cd\u09af\u09be\u09af\u09bc \u0993 \u09ac\u09c8\u09b7\u09ae\u09cd\u09af\u09c7\u09b0 \u09ac\u09bf\u09b0\u09c1\u09a6\u09cd\u09a7\u09c7 \u0986\u09aa\u09b8\u09b9\u09c0\u09a8 \u0985\u09ac\u09b8\u09cd\u09a5\u09be\u09a8 \u09a8\u09bf\u09af\u09bc\u09c7 \u0986\u09ae\u09b0\u09be \u098f\u0997\u09bf\u09af\u09bc\u09c7 \u09af\u09be\u09ac \u098f\u0995\u099f\u09bf \u0986\u09a7\u09c1\u09a8\u09bf\u0995, \u0989\u09a8\u09cd\u09a8\u09a4 \u0993 \u09ae\u09be\u09a8\u09ac\u09bf\u0995 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09aa\u09a5\u09c7\u2013\u09af\u09c7\u0996\u09be\u09a8\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09a8\u09be\u0997\u09b0\u09bf\u0995\u09c7\u09b0 \u0985\u09a7\u09bf\u0995\u09be\u09b0, \u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be \u0993 \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be \u09b8\u09ae\u09be\u09a8\u09ad\u09be\u09ac\u09c7 \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u09a5\u09be\u0995\u09ac\u09c7\u0964 \u09a8\u09a4\u09c1\u09a8 \u09aa\u09cd\u09b0\u099c\u09a8\u09cd\u09ae\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u0986\u09b9\u09cd\u09ac\u09be\u09a8\u2013 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7\u09c7\u09b0 \u09b8\u09a4\u09cd\u09af\u09bf\u0995\u09be\u09b0\u09c7\u09b0 \u0986\u0995\u09be\u0999\u09cd\u0995\u09cd\u09b7\u09be \u09b9\u09c3\u09a6\u09af\u09bc\u09c7 \u09a7\u09be\u09b0\u09a3 \u0995\u09b0\u09c7 \u09b8\u09a4\u09cd\u09af, \u09a8\u09cd\u09af\u09be\u09af\u09bc, \u09b8\u09be\u09b9\u09b8 \u0993 \u09a6\u09c7\u09b6\u09aa\u09cd\u09b0\u09c7\u09ae\u09c7\u09b0 \u0986\u09a6\u09b0\u09cd\u09b6\u09c7 \u0986\u09ae\u09b0\u09be \u09a8\u09bf\u099c\u09c7\u09a6\u09c7\u09b0 \u0997\u09a1\u09bc\u09c7 \u09a4\u09c1\u09b2\u09ac\u09cb\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b9\u09be\u09a4\u09c7\u0987 \u09b0\u099a\u09bf\u09a4 \u09b9\u09ac\u09c7 \u0986\u0997\u09be\u09ae\u09c0\u09b0 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u0964 \u09ae\u09b9\u09be\u09a8 \u0986\u09b2\u09cd\u09b2\u09be\u09b9 \u09a4\u09be\u2019\u0986\u09b2\u09be\u09b0 \u09a8\u09bf\u0995\u099f \u09a6\u09c7\u09b6\u09c7\u09b0 \u09b6\u09be\u09a8\u09cd\u09a4\u09bf, \u09b8\u09ae\u09c3\u09a6\u09cd\u09a7\u09bf, \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09b8\u09b0\u09cd\u09ac\u09be\u0999\u09cd\u0997\u09c0\u09a8 \u0995\u09b2\u09cd\u09af\u09be\u09a3 \u0993 \u09b6\u09b9\u09bf\u09a6\u09a6\u09c7\u09b0 \u0986\u09a4\u09cd\u09ae\u09be\u09b0 \u09ae\u09be\u0997\u09ab\u09bf\u09b0\u09be\u09a4 \u0995\u09be\u09ae\u09a8\u09be\u09af\u09bc \u09a6\u09cb\u09af\u09bc\u09be \u0995\u09b0\u09bf\u0964",
