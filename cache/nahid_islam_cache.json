[
  {
    "title": "\u09aa\u09cd\u09b0\u09bf\u09af\u09bc \u09ae\u09af\u09bc\u09ae\u09a8\u09b8\u09bf\u0982\u09b9\u09ac\u09be\u09b8\u09c0, \u0986\u09b8\u09b8\u09be\u09b2\u09be\u09ae\u09c1\u09af\u09bc\u09be\u09b2\u09be\u0987\u0995\u09c1\u09ae\u0964 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf- \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09ae\u09af\u09bc\u09ae\u09a8\u09b8\u09bf\u0982\u09b9...",
    "description": "\u09aa\u09cd\u09b0\u09bf\u09af\u09bc \u09ae\u09af\u09bc\u09ae\u09a8\u09b8\u09bf\u0982\u09b9\u09ac\u09be\u09b8\u09c0, \u0986\u09b8\u09b8\u09be\u09b2\u09be\u09ae\u09c1\u09af\u09bc\u09be\u09b2\u09be\u0987\u0995\u09c1\u09ae\u0964 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf- \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09ae\u09af\u09bc\u09ae\u09a8\u09b8\u09bf\u0982\u09b9 \u09ac\u09bf\u09ad\u09be\u0997\u09c0\u09af\u09bc \u0987\u09ab\u09a4\u09be\u09b0 \u0993 \u09a6\u09cb\u09af\u09bc\u09be \u09ae\u09be\u09b9\u09ab\u09bf\u09b2\u09c7 \u0986\u099c \u0986\u09aa\u09a8\u09be\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u0987\u09ab\u09a4\u09be\u09b0 \u0995\u09b0\u09ac\u09cb, \u0987\u09a8\u09b6\u09be\u0986\u09b2\u09cd\u09b2\u09be\u09b9\u0964",
