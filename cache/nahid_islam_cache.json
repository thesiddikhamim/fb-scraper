    "title": "\u099c\u0999\u09cd\u0997\u09bf\u09ac\u09be\u09a6\u09c7\u09b0 \u09ac\u09bf\u09b0\u09c1\u09a6\u09cd\u09a7\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u099c\u09bf\u09b0\u09cb \u099f\u09b2\u09be\u09b0\u09c7\u09a8\u09cd\u09b8, \u09a4\u09ac\u09c7 \u2018\u0993\u09df\u09be\u09b0 \u0985\u09a8 \u099f\u09c7\u09b0\u09b0\u2019 \u098f\u09b0 \u09aa\u09cd\u09b0\u099c\u09c7\u0995\u09cd\u099f \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 ...",
    "description": "\u099c\u0999\u09cd\u0997\u09bf\u09ac\u09be\u09a6\u09c7\u09b0 \u09ac\u09bf\u09b0\u09c1\u09a6\u09cd\u09a7\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u099c\u09bf\u09b0\u09cb \u099f\u09b2\u09be\u09b0\u09c7\u09a8\u09cd\u09b8, \u09a4\u09ac\u09c7 \u2018\u0993\u09df\u09be\u09b0 \u0985\u09a8 \u099f\u09c7\u09b0\u09b0\u2019 \u098f\u09b0 \u09aa\u09cd\u09b0\u099c\u09c7\u0995\u09cd\u099f \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u099c\u0999\u09cd\u0997\u09bf \u09a8\u09be\u099f\u0995 \u0986\u09ae\u09b0\u09be \u09a6\u09c7\u0996\u09a4\u09c7 \u099a\u09be\u0987 \u09a8\u09be\u0964 #Bangladesh #NCP #Nahidislam",
