    "title": "\u09b8\u0982\u09b8\u09a6\u09c7 \u09ac\u09bf\u09b0\u09cb\u09a7\u09c0 \u09a6\u09b2\u09c7\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u09b9\u0993\u09af\u09bc\u09be \u09ac\u09c8\u09b7\u09ae\u09cd\u09af \u09af\u09c7\u09a8 \u09ac\u09bf\u09b0\u09cb\u09a7\u09c0 \u09a6\u09b2\u09c0\u09af\u09bc \u098f\u09ae\u09aa\u09bf\u09a6\u09c7\u09b0 \u098f\u09b2\u09be\u0995\u09be\u09b0 \u09ae\u09be\u09a8\u09c1\u09b7\u09c7\u09b0 \u09b8\u09be\u09a5...",
    "description": "\u09b8\u0982\u09b8\u09a6\u09c7 \u09ac\u09bf\u09b0\u09cb\u09a7\u09c0 \u09a6\u09b2\u09c7\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u09b9\u0993\u09af\u09bc\u09be \u09ac\u09c8\u09b7\u09ae\u09cd\u09af \u09af\u09c7\u09a8 \u09ac\u09bf\u09b0\u09cb\u09a7\u09c0 \u09a6\u09b2\u09c0\u09af\u09bc \u098f\u09ae\u09aa\u09bf\u09a6\u09c7\u09b0 \u098f\u09b2\u09be\u0995\u09be\u09b0 \u09ae\u09be\u09a8\u09c1\u09b7\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09a8\u09be \u09b9\u09df\u0964 #Bangladesh #NCP #Nahidislam",
