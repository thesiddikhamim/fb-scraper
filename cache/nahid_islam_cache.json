  {
    "title": "\u09b8\u09cd\u09ac\u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u09ac\u09b2\u09c7\u099b\u09bf\u09b2\u09c7\u09a8, \u09a6\u09c7\u09b6\u09c7 \u09ae\u09ac \u0995\u09be\u09b2\u099a\u09be\u09b0 \u09b6\u09c7\u09b7\u0964 \u0985\u09a5\u099a \u09b6\u09be\u09b9\u09ac\u09be\u0997 \u09a5\u09be\u09a8\u09be\u09b0 \u09b8\u09be\u09ae\u09a8\u09c7 \u09b8\u09be\u0982\u09ac\u09be\u09a6\u09bf\u0995\u09a6...",
    "description": "\u09b8\u09cd\u09ac\u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u09ac\u09b2\u09c7\u099b\u09bf\u09b2\u09c7\u09a8, \u09a6\u09c7\u09b6\u09c7 \u09ae\u09ac \u0995\u09be\u09b2\u099a\u09be\u09b0 \u09b6\u09c7\u09b7\u0964 \u0985\u09a5\u099a \u09b6\u09be\u09b9\u09ac\u09be\u0997 \u09a5\u09be\u09a8\u09be\u09b0 \u09b8\u09be\u09ae\u09a8\u09c7 \u09b8\u09be\u0982\u09ac\u09be\u09a6\u09bf\u0995\u09a6\u09c7\u09b0 \u09aa\u09c7\u099f\u09be\u09a8\u09cb \u09b9\u09df\u09c7\u099b\u09c7\u0964 \u098f\u0996\u09a8\u09cb \u09ae\u09be\u09ae\u09b2\u09be\u0993 \u09a8\u09c7\u09df\u09a8\u09bf \u09aa\u09c1\u09b2\u09bf\u09b6\u0964 #NCP #Nahidislam #Bangladesh",
