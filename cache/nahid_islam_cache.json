  },
  {
    "title": "\u0986\u09aa \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6, \u09ac\u09c8\u09b7\u09ae\u09cd\u09af\u09ac\u09bf\u09b0\u09cb\u09a7\u09c0 \u099b\u09be\u09a4\u09cd\u09b0 \u0986\u09a8\u09cd\u09a6\u09cb\u09b2\u09a8 \u0993 \u098f\u09ac\u09bf \u09aa\u09be\u09b0\u09cd\u099f\u09bf \u09a5\u09c7\u0995\u09c7 \u0985\u09b0\u09cd\u09a7\u09b6\u09a4\u09be\u09a7\u09bf\u0995 \u09a8\u09c7\u09a4\u09be\u0995\u09b0\u09cd\u09ae\u09c0 \u099c...",
    "description": "\u0986\u09aa \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6, \u09ac\u09c8\u09b7\u09ae\u09cd\u09af\u09ac\u09bf\u09b0\u09cb\u09a7\u09c0 \u099b\u09be\u09a4\u09cd\u09b0 \u0986\u09a8\u09cd\u09a6\u09cb\u09b2\u09a8 \u0993 \u098f\u09ac\u09bf \u09aa\u09be\u09b0\u09cd\u099f\u09bf \u09a5\u09c7\u0995\u09c7 \u0985\u09b0\u09cd\u09a7\u09b6\u09a4\u09be\u09a7\u09bf\u0995 \u09a8\u09c7\u09a4\u09be\u0995\u09b0\u09cd\u09ae\u09c0 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf (\u098f\u09a8\u09b8\u09bf\u09aa\u09bf)-\u09a4\u09c7 \u09af\u09cb\u0997\u09a6\u09be\u09a8 \u0995\u09b0\u09c7\u099b\u09c7\u09a8\u0964 \u09a4\u09be\u0981\u09a6\u09c7\u09b0 \u09b8\u09ac\u09be\u0987\u0995\u09c7 \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995\u09ad\u09be\u09ac\u09c7 \u09b8\u09cd\u09ac\u09be\u0997\u09a4 \u099c\u09be\u09a8\u09be\u099a\u09cd\u099b\u09bf\u0964 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u09b0\u09be\u099c\u09a8\u09c8\u09a4\u09bf\u0995 \u09a6\u09b2 \u0993 \u09b8\u0982\u0997\u09a0\u09a8\u09c7\u09b0 \u0986\u09b0\u0993 \u0985\u09a8\u09c7\u0995\u09c7\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0986\u09b2\u09cb\u099a\u09a8\u09be \u0985\u09ac\u09cd\u09af\u09be\u09b9\u09a4 \u09b0\u09af\u09bc\u09c7\u099b\u09c7\u0964 \u09a4\u09be\u0981\u09b0\u09be\u0993 \u09b6\u09c0\u0998\u09cd\u09b0\u0987 \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09a4\u09c7 \u09af\u09cb\u0997\u09a6\u09be\u09a8 \u0995\u09b0\u09ac\u09c7\u09a8 \u09ac\u09b2\u09c7 \u0986\u09ae\u09b0\u09be \u0986\u09b6\u09be\u09ac\u09be\u09a6\u09c0\u0964 \u0986\u09ae\u09b0\u09be \u09b6\u09c1\u09b0\u09c1 \u09a5\u09c7\u0995\u09c7\u0987 \u09ac\u09b2\u09c7 \u0986\u09b8\u099b\u09bf, \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09a4\u09c7 \u09af\u09cb\u0997\u09a6\u09be\u09a8\u09c7\u09b0 \u0995\u09cd\u09b7\u09c7\u09a4\u09cd\u09b0\u09c7 \u0995\u09be\u09b0\u0993 \u0985\u09a4\u09c0\u09a4 \u09aa\u09b0\u09bf\u099a\u09af\u09bc\u0995\u09c7 \u09ae\u09c1\u0996\u09cd\u09af \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u09ac\u09bf\u09ac\u09c7\u099a\u09a8\u09be \u0995\u09b0\u09be \u09b9\u09ac\u09c7 \u09a8\u09be\u0964 \u0995\u09c7 \u0986\u0997\u09c7 \u0995\u09cb\u09a8 \u09a6\u09b2 \u09ac\u09be \u09b8\u0982\u0997\u09a0\u09a8\u09c7\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u09af\u09c1\u0995\u09cd\u09a4 \u099b\u09bf\u09b2\u09c7\u09a8, \u09b8\u09c7\u099f\u09bf \u09a6\u09c7\u0996\u09be\u09b0 \u09ac\u09bf\u09b7\u09af\u09bc \u09a8\u09af\u09bc\u0964 \u099b\u09be\u09a4\u09cd\u09b0\u09a6\u09b2, \u099b\u09be\u09a4\u09cd\u09b0\u09b6\u09bf\u09ac\u09bf\u09b0, \u099b\u09be\u09a4\u09cd\u09b0 \u0985\u09a7\u09bf\u0995\u09be\u09b0 \u09aa\u09b0\u09bf\u09b7\u09a6, \u098f\u09ae\u09a8\u0995\u09bf \u099b\u09be\u09a4\u09cd\u09b0\u09b2\u09c0\u0997 \u09a5\u09c7\u0995\u09c7\u0993 \u09af\u09cb\u0997\u09a6\u09be\u09a8 \u0995\u09b0\u09be \u09af\u09be\u09ac\u09c7\u0964 \u09ac\u09bf\u09b6\u09c7\u09b7 \u0995\u09b0\u09c7, \u09af\u09be\u09b0\u09be \u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8\u09c7\u09b0 \u09b8\u09ae\u09af\u09bc \u099b\u09be\u09a4\u09cd\u09b0\u09b2\u09c0\u0997 \u09a4\u09cd\u09af\u09be\u0997 \u0995\u09b0\u09c7 \u099c\u09a8\u09a4\u09be\u09b0 \u0995\u09be\u09a4\u09be\u09b0\u09c7 \u09b6\u09be\u09ae\u09bf\u09b2 \u09b9\u09af\u09bc\u09c7\u099b\u09bf\u09b2\u09c7\u09a8 \u098f\u09ac\u0982 \u09af\u09be\u09b0\u09be \u09ab\u09cd\u09af\u09be\u09b8\u09bf\u09ac\u09be\u09a6 \u09ac\u09be \u0997\u09a3\u09b9\u09a4\u09cd\u09af\u09be\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u09b8\u09ae\u09cd\u09aa\u09c3\u0995\u09cd\u09a4 \u099b\u09bf\u09b2\u09c7\u09a8 \u09a8\u09be, \u09a4\u09be\u0981\u09a6\u09c7\u09b0 \u0986\u09ae\u09b0\u09be \u09b8\u09cd\u09ac\u09be\u0997\u09a4 \u099c\u09be\u09a8\u09be\u0987\u0964 \u09af\u09be\u09b0\u09be \u098f\u09a6\u09c7\u09b6\u09c7\u09b0 \u09b0\u09be\u099c\u09a8\u09c0\u09a4\u09bf\u09a4\u09c7 \u0987\u09a4\u09bf\u09ac\u09be\u099a\u0995 \u09aa\u09b0\u09bf\u09ac\u09b0\u09cd\u09a4\u09a8 \u099a\u09be\u09a8 \u098f\u09ac\u0982 \u099c\u09c1\u09b2\u09be\u0987 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8\u09c7\u09b0 \u0986\u0995\u09be\u0999\u09cd\u0995\u09cd\u09b7\u09be\u0995\u09c7 \u09b9\u09c3\u09a6\u09af\u09bc\u09c7 \u09a7\u09be\u09b0\u09a3 \u0995\u09b0\u09c7\u09a8, \u09a4\u09be\u0981\u09a6\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf\u09b0 \u09a6\u09b0\u099c\u09be \u09b8\u09ac\u09b8\u09ae\u09af\u09bc \u0989\u09a8\u09cd\u09ae\u09c1\u0995\u09cd\u09a4\u0964 \u09a4\u09ac\u09c7 \u099a\u09be\u0981\u09a6\u09be\u09ac\u09be\u099c\u09bf, \u09a6\u09c1\u09b0\u09cd\u09a8\u09c0\u09a4\u09bf, \u0996\u09c1\u09a8, \u09a7\u09b0\u09cd\u09b7\u09a3\u09c7\u09b0 \u09ae\u09a4\u09cb \u0985\u09aa\u09b0\u09be\u09a7\u09c7 \u099c\u09a1\u09bc\u09bf\u09a4 \u0995\u09be\u09b0\u0993 \u099c\u09a8\u09cd\u09af \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09a4\u09c7 \u0995\u09cb\u09a8\u09cb \u09b8\u09cd\u09a5\u09be\u09a8 \u09a8\u09c7\u0987\u0964 \u098f\u099b\u09be\u09a1\u09bc\u09be, \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09a4\u09c7 \u09af\u09cb\u0997\u09a6\u09be\u09a8\u09c7\u09b0 \u09aa\u09b0 \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09c7\u0995\u0995\u09c7 \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09a6\u09b2\u09c0\u09af\u09bc \u0986\u09a6\u09b0\u09cd\u09b6 \u09a7\u09be\u09b0\u09a3 \u0993 \u0985\u09a8\u09c1\u09b8\u09b0\u09a3 \u0995\u09b0\u09be \u09ac\u09be\u09a7\u09cd\u09af\u09a4\u09be\u09ae\u09c2\u09b2\u0995\u0964",
