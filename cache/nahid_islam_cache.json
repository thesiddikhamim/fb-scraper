    "title": "\u099c\u09be\u09a4\u09c0\u09af\u09bc \u09b8\u0982\u09b8\u09a6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a5\u09ae \u0985\u09a7\u09bf\u09ac\u09c7\u09b6\u09a8\u09c7 \u0986\u09a8\u09c0\u09a4 \u09b6\u09cb\u0995 \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09be\u09ac\u09c7 \u09b6\u09b9\u09bf\u09a6 \u09b6\u09b0\u09c0\u09ab \u0993\u09b8\u09ae\u09be\u09a8 \u09b9\u09be\u09a6\u09bf, \u0986\u09a7\u09bf\u09aa\u09a4\u09cd\u09af\u09ac\u09be\u09a6...",
    "description": "\u099c\u09be\u09a4\u09c0\u09af\u09bc \u09b8\u0982\u09b8\u09a6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a5\u09ae \u0985\u09a7\u09bf\u09ac\u09c7\u09b6\u09a8\u09c7 \u0986\u09a8\u09c0\u09a4 \u09b6\u09cb\u0995 \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09be\u09ac\u09c7 \u09b6\u09b9\u09bf\u09a6 \u09b6\u09b0\u09c0\u09ab \u0993\u09b8\u09ae\u09be\u09a8 \u09b9\u09be\u09a6\u09bf, \u0986\u09a7\u09bf\u09aa\u09a4\u09cd\u09af\u09ac\u09be\u09a6 \u09ac\u09bf\u09b0\u09cb\u09a7\u09c0 \u09b2\u09a1\u09bc\u09be\u0987\u09af\u09bc\u09c7\u09b0 \u09b6\u09b9\u09bf\u09a6 \u0986\u09ac\u09b0\u09be\u09b0 \u09ab\u09be\u09b9\u09be\u09a6 \u098f\u09ac\u0982 \u09b8\u09c0\u09ae\u09be\u09a8\u09cd\u09a4\u09c7 \u09b6\u09b9\u09bf\u09a6 \u09b9\u0993\u09df\u09be \u09ab\u09c7\u09b2\u09be\u09a8\u09c0 \u0996\u09be\u09a4\u09c1\u09a8 \u098f\u09b0 \u09a8\u09be\u09ae \u0985\u09a8\u09cd\u09a4\u09b0\u09cd\u09ad\u09c1\u0995\u09cd\u09a4 \u0995\u09b0\u09be\u09b0 \u0985\u09a8\u09c1\u09b0\u09cb\u09a7 \u099c\u09be\u09a8\u09be\u09a8 \u09ac\u09bf\u09b0\u09cb\u09a7\u09c0\u09a6\u09b2\u09c0\u09af\u09bc \u099a\u09bf\u09ab \u09b9\u09c1\u0987\u09aa \u0993 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995- \u09aa\u09be\u09b0\u09cd\u099f\u09bf \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09af\u09bc\u0995 \u09ae\u09cb. \u09a8\u09be\u09b9\u09bf\u09a6 \u0987\u09b8\u09b2\u09be\u09ae\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
