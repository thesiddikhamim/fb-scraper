    "title": "\u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09ac\u09cd\u09af\u09be\u0982\u0995, \u09ac\u09bf\u09b8\u09bf\u09ac\u09bf\u09b0 \u09ae\u09a4\u09cb \u09a6\u09b2\u09c0\u09af\u09bc\u0995\u09b0\u09a3\u09c7\u09b0 \u0989\u09a6\u09cd\u09a6\u09c7\u09b6\u09cd\u09af\u09c7 \u099c\u09c1\u09b2\u09be\u0987 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8 \u09b8\u09cd\u09ae\u09c3\u09a4\u09bf \u099c\u09be\u09a6\u09c1...",
