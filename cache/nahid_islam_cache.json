    "title": "\u098f\u0995\u09a6\u09bf\u0995\u09c7 \u0995\u09c3\u09b7\u0995 \u0995\u09be\u09b0\u09cd\u09a1 \u09a6\u09c7\u09af\u09bc\u09be \u09b9\u099a\u09cd\u099b\u09c7, \u0985\u09a8\u09cd\u09af\u09a6\u09bf\u0995\u09c7 \u09a7\u09be\u09a8 \u09ac\u09bf\u0995\u09cd\u09b0\u09bf \u0995\u09b0\u09c7 \u0995\u09c3\u09b7\u0995\u09b0\u09be \u0989\u09ce\u09aa\u09be\u09a6\u09a8 \u0996\u09b0\u099a\u0993 \u09aa\u09be\u099a\u09cd\u099b\u09c7...",
    "description": "\u098f\u0995\u09a6\u09bf\u0995\u09c7 \u0995\u09c3\u09b7\u0995 \u0995\u09be\u09b0\u09cd\u09a1 \u09a6\u09c7\u09af\u09bc\u09be \u09b9\u099a\u09cd\u099b\u09c7, \u0985\u09a8\u09cd\u09af\u09a6\u09bf\u0995\u09c7 \u09a7\u09be\u09a8 \u09ac\u09bf\u0995\u09cd\u09b0\u09bf \u0995\u09b0\u09c7 \u0995\u09c3\u09b7\u0995\u09b0\u09be \u0989\u09ce\u09aa\u09be\u09a6\u09a8 \u0996\u09b0\u099a\u0993 \u09aa\u09be\u099a\u09cd\u099b\u09c7 \u09a8\u09be : \u09a8\u09be\u09b9\u09bf\u09a6 \u0987\u09b8\u09b2\u09be\u09ae\u0964",
