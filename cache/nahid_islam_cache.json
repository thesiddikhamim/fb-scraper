[
  {
    "title": "\u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf- \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u0995\u09c7 \u09a8\u09bf\u09af\u09bc\u09c7 \u09b0\u099a\u09bf\u09a4 '\u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09af\u09be\u09a4\u09cd\u09b0\u09be' \u09ac\u0987\u09af\u09bc\u09c7\u09b0 \u09ae\u09cb\u09a1\u09bc\u0995 \u0989\u09a8\u09cd\u09ae\u09cb\u099a\u09a8 \u0995...",
    "description": "\u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf- \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u0995\u09c7 \u09a8\u09bf\u09af\u09bc\u09c7 \u09b0\u099a\u09bf\u09a4 '\u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09af\u09be\u09a4\u09cd\u09b0\u09be' \u09ac\u0987\u09af\u09bc\u09c7\u09b0 \u09ae\u09cb\u09a1\u09bc\u0995 \u0989\u09a8\u09cd\u09ae\u09cb\u099a\u09a8 \u0995\u09b0\u09c7\u09a8 \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09af\u09bc\u0995 \u0993 \u09ac\u09bf\u09b0\u09cb\u09a7\u09c0 \u09a6\u09b2\u09c0\u09af\u09bc \u099a\u09bf\u09ab \u09b9\u09c1\u0987\u09aa \u09ae\u09cb\u0983 \u09a8\u09be\u09b9\u09bf\u09a6 \u0987\u09b8\u09b2\u09be\u09ae\u0964 \u09ac\u0987\u099f\u09bf\u09a4\u09c7 \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09b0\u09be\u099c\u09a8\u09c8\u09a4\u09bf\u0995 \u0995\u09b0\u09cd\u09ae\u09b8\u09c2\u099a\u09bf, \u09b8\u09be\u0982\u0997\u09a0\u09a8\u09bf\u0995 \u0995\u09be\u09b0\u09cd\u09af\u0995\u09cd\u09b0\u09ae \u098f\u09ac\u0982 \u09b0\u09be\u099c\u09a8\u09c8\u09a4\u09bf\u0995 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af \u09a4\u09c1\u09b2\u09c7 \u09a7\u09b0\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09c7\u0964 \u09ae\u09cb\u09a1\u09bc\u0995 \u0989\u09a8\u09cd\u09ae\u09cb\u099a\u09a8 \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09c7 \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09b8\u09a6\u09b8\u09cd\u09af\u09b8\u099a\u09bf\u09ac \u0986\u0996\u09a4\u09be\u09b0 \u09b9\u09cb\u09b8\u09c7\u09a8, \u09ac\u0987\u099f\u09bf\u09b0 \u09b2\u09c7\u0996\u0995 \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09af\u09c1\u0997\u09cd\u09ae \u09ae\u09c1\u0996\u09cd\u09af \u09b8\u09ae\u09a8\u09cd\u09ac\u09df\u0995 \u09ae\u09cb. \u09ae\u09be\u09b9\u09be\u09ac\u09c1\u09ac \u0986\u09b2\u09ae, \u09ac\u0987\u09df\u09c7\u09b0 \u09aa\u09cd\u09b0\u0995\u09be\u09b6\u0995 \u0986\u09a6\u09b0\u09cd\u09b6'\u09b0 \u09b8\u09a4\u09cd\u09a4\u09be\u09a7\u09bf\u0995\u09be\u09b0\u09c0 \u099c\u09a8\u09be\u09ac \u09ae\u09be\u09b9\u09ac\u09c1\u09ac \u09b0\u09be\u09b9\u09ae\u09be\u09a8, \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09af\u09c1\u0997\u09cd\u09ae \u0986\u09b9\u09cd\u09ac\u09be\u09df\u0995 \u09b8\u09be\u09b0\u09cb\u09df\u09be\u09b0 \u09a4\u09c1\u09b7\u09be\u09b0, \u09af\u09c1\u0997\u09cd\u09ae \u0986\u09b9\u09cd\u09ac\u09be\u09df\u0995 \u09ae\u09c1\u099c\u09be\u09b9\u09bf\u09a6\u09c1\u09b2 \u0987\u09b8\u09b2\u09be\u09ae \u09b6\u09be\u09b9\u09bf\u09a8, \u098f\u09a8\u09b8\u09bf\u09aa\u09bf \u09a1\u09be\u09df\u09be\u09b8\u09cd\u09aa\u09cb\u09b0\u09be \u098f\u09b2\u09be\u09df\u09c7\u09a8\u09cd\u09b8\u09c7\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09df\u0995 \u09b8\u09be\u0987\u09ab \u0987\u09ac\u09a8\u09c7 \u09b8\u09be\u09b0\u0993\u09df\u09be\u09b0\u09b8\u09b9 \u09a8\u09c7\u09a4\u09c3\u09ac\u09c3\u09a8\u09cd\u09a6 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u099b\u09bf\u09b2\u09c7\u09a8\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
    "link": "https://www.facebook.com/nahidislamjuly/posts/pfbid02PeekTaxUwwUqooTX7CX8j5CMNCKNDamnpBJWmySuq5NK2hXp8KvVEyH9EcDJA3Hvl",
    "guid": "https://www.facebook.com/nahidislamjuly/posts/pfbid02PeekTaxUwwUqooTX7CX8j5CMNCKNDamnpBJWmySuq5NK2hXp8KvVEyH9EcDJA3Hvl",
    "pubDate": "2026-03-06T11:19:36.995987+00:00",
