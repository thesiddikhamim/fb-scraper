    "title": "\u09a1\u09be\u0995\u09cd\u09a4\u09be\u09b0\u09a6\u09c7\u09b0 \u099c\u09c0\u09ac\u09a8\u09c7 \u09a8\u09bf\u099c\u09c7\u09a6\u09c7\u09b0 \u09a6\u09c1\u0983\u0996\u09c7\u09b0 \u099a\u09c7\u09df\u09c7 \u09b0\u09cb\u0997\u09c0\u09a6\u09c7\u09b0 \u09a6\u09c1\u0983\u0996 \u09ac\u09c7\u09b6\u09bf \u09a5\u09be\u0995\u09c7\u0964 \u09a4\u09be\u09b0\u0993\u09aa\u09b0 \u09af\u09a6\u09bf \u09b9\u09df \u0986\u09ae\u09be\u09a6\u09c7...",
    "description": "\u09a1\u09be\u0995\u09cd\u09a4\u09be\u09b0\u09a6\u09c7\u09b0 \u099c\u09c0\u09ac\u09a8\u09c7 \u09a8\u09bf\u099c\u09c7\u09a6\u09c7\u09b0 \u09a6\u09c1\u0983\u0996\u09c7\u09b0 \u099a\u09c7\u09df\u09c7 \u09b0\u09cb\u0997\u09c0\u09a6\u09c7\u09b0 \u09a6\u09c1\u0983\u0996 \u09ac\u09c7\u09b6\u09bf \u09a5\u09be\u0995\u09c7\u0964 \u09a4\u09be\u09b0\u0993\u09aa\u09b0 \u09af\u09a6\u09bf \u09b9\u09df \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ae\u09a4\u09cb \u09b8\u09cd\u09a4\u09cd\u09b0\u09c0\u09b0\u09cb\u0997 \u0993 \u09aa\u09cd\u09b0\u09b8\u09c2\u09a4\u09bf\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b0 \u09a1\u09be\u0995\u09cd\u09a4\u09be\u09b0, \u09a4\u09be\u09b9\u09b2\u09c7 \u09a4\u09cb \u09a6\u09c1\u0983\u0996\u09c7\u09b0 \u09b8\u09c0\u09ae\u09be \u09a5\u09be\u0995\u09c7 \u09a8\u09be\u0964 \u0986\u09b2\u09cd\u099f\u09cd\u09b0\u09be\u09b8\u09a8\u09cb\u0997\u09cd\u09b0\u09be\u09ae\u09c7\u09b0 \u09af\u09c7 \u09ad\u09bf\u09a1\u09bf\u0993\u099f\u09be \u09a6\u09c7\u0996\u09be \u09af\u09be\u099a\u09cd\u099b\u09c7 \u09b8\u09c7\u099f\u09bf \u09e7\u09e7 \u09ac\u099b\u09b0 \u09ac\u09df\u09b8\u09c7\u09b0 \u098f\u0995 \u09b6\u09bf\u09b6\u09c1\u0995\u09a8\u09cd\u09af\u09be\u09b0\u0964 \u09ac\u09be\u09ac\u09be\u09b9\u09be\u09b0\u09be \u098f\u09a4\u09bf\u09ae \u09ae\u09c7\u09df\u09c7\u099f\u09be \u09ac\u09c3\u09a6\u09cd\u09a7\u09be \u09a8\u09be\u09a8\u09c0\u09b0 \u0995\u09be\u099b\u09c7 \u09ae\u09be\u09a8\u09c1\u09b7\u0964 \u09b8\u0982\u09b8\u09be\u09b0\u09c7\u09b0 \u0996\u09b0\u099a \u09af\u09cb\u0997\u09be\u09a4\u09c7 \u09ae\u09be \u099a\u09be\u0995\u09c1\u09b0\u09bf \u0995\u09b0\u09c7\u09a8 \u098f\u0995\u099f\u09bf \u0997\u09be\u09b0\u09cd\u09ae\u09c7\u09a8\u09cd\u099f\u09b8\u09c7\u0964 \u0989\u09a4\u09cd\u09a4\u09ae \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u09b8\u09a8\u09cd\u09a4\u09be\u09a8\u0995\u09c7 \u09ad\u09b0\u09cd\u09a4\u09bf \u0995\u09b0\u09c7\u099b\u09bf\u09b2\u09c7\u09a8 \"\u09ae\u09b9\u09bf\u09b2\u09be \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09df\u0964\" \u0995\u09c7 \u099c\u09be\u09a8\u09a4\u09cb??? ( \u0995\u09a5\u09be\u099f\u09be \u09b6\u09c1\u09a8\u09c7, \u099a\u09bf\u09a8\u09cd\u09a4\u09be \u0995\u09b0\u09a4\u09c7\u0993 \u0996\u09c1\u09ac \u0996\u09be\u09b0\u09be\u09aa \u09b2\u09be\u0997\u099b\u09c7) \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09b0 \u09ac\u09dc \u09b9\u09c1\u099c\u09c1\u09b0\u09c7\u09b0 \u09b6\u09df\u09a4\u09be\u09a8\u09bf\u09b0 \u09b6\u09bf\u0995\u09be\u09b0 \u09b9\u09a4\u09c7 \u09b9\u09ac\u09c7 \u09ac\u09be\u099a\u09cd\u099a\u09be\u099f\u09bf\u0995\u09c7, \u09af\u09bf\u09a8\u09bf \u0985\u09b2\u09b0\u09c7\u09a1\u09bf \u09ac\u09bf\u09ac\u09be\u09b9\u09bf\u09a4 \u0993 \u09eb \u09ae\u09be\u09b8\u09c7\u09b0 \u098f\u0995\u099f\u09bf \u099b\u09c7\u09b2\u09c7 \u09b8\u09a8\u09cd\u09a4\u09be\u09a8\u09c7\u09b0 \u09ac\u09be\u09ac\u09be\u0964 \u09ae\u09c7\u09df\u09c7\u09b0 \u09aa\u09b0\u09bf\u09ac\u09be\u09b0 \u09ae\u09be\u09ae\u09b2\u09be\u09b0 \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09c1\u09a4\u09bf \u09a8\u09bf\u099a\u09cd\u099b\u09c7...... \u0986\u09ae\u09bf \u09ad\u09be\u09ac\u099b\u09bf \u09ae\u09c7\u09df\u09c7\u099f\u09be\u09b0 \u0995\u09a5\u09be.....\"\u099c\u09c0\u09ac\u09a8\u09c7 \u09aa\u09cd\u09b0\u09a5\u09ae\u09ac\u09be\u09b0 \u09ae\u09be\u09b8\u09bf\u0995 \u09b6\u09c1\u09b0\u09c1 \u09b9\u0993\u09df\u09be\u09b0 \u0986\u0997\u09c7, \u09aa\u09cd\u09b0\u09a5\u09ae \u0985\u09ad\u09c1\u09b2\u09c7\u09b6\u09a8\u09c7\u0987 \u09a4\u09be\u09b0 \u098f\u0987 \u0985\u09ac\u09b8\u09cd\u09a5\u09be \u09b9\u09b2\u09cb, \u098f\u099f\u09be\u09b0 \u09a6\u09be\u09df\u09ad\u09be\u09b0 \u0986\u09b8\u09b2\u09c7 \u0995\u09be\u09b0???\" \u09af\u09c7 \u09a8\u09bf\u099c\u09c7\u0987 \u098f\u0995\u099c\u09a8 \u09b6\u09bf\u09b6\u09c1, \u09a4\u09be\u09b0 \u09b8\u09ae\u09b8\u09cd\u09af\u09be \u09b8\u09c7 \u09ac\u09b2\u09c7\u099b\u09c7 \u098f\u09ad\u09be\u09ac\u09c7, \"\u09aa\u09c7\u099f\u099f\u09be \u09ad\u09be\u09b0\u09bf \u09b2\u09be\u0997\u09c7 \u0986\u09b0 \u0995\u09bf \u09af\u09c7\u09a8\u09cb \u09b2\u09dc\u09c7...\" \u0993\u09b0 \u09b9\u09be\u09a4\u09c7 \u0986\u09b0\u09c7\u0995\u099f\u09be \u09b6\u09bf\u09b6\u09c1\u09b0 \u09ad\u09be\u09b0 \u0995\u09c7\u09a8\u09cb????? ****\u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09cd \u0995\u09cb\u09a8 \u099c\u09be\u09b9\u09c7\u09b2\u09bf\u09df\u09be\u09a4 \u09a6\u09c7\u0996\u09be\u099a\u09cd\u099b\u09c7\u09a8 \u0986\u09ae\u09be\u09a6\u09c7\u09b0\u0995\u09c7??? ***\u099c\u09be\u09b2\u09c7\u09ae\u09c7\u09b0 \u09aa\u09b0\u09bf\u099a\u09df \u099c\u09be\u09a8\u09a4\u09c7 \u09aa\u09bf\u09a8 \u0995\u09ae\u09c7\u09a8\u09cd\u099f \u099a\u09c7\u0995 \u0995\u09b0\u09c1\u09a8\u0964",
