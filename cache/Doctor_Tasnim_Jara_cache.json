  },
  {
    "title": "\u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8\u09c0 \u09a4\u09b9\u09ac\u09bf\u09b2\u09c7 \u09af\u09c7 \u0986\u09aa\u09a8\u09be\u09b0\u09be \u0985\u09a8\u09c1\u09a6\u09be\u09a8 \u09a6\u09bf\u09af\u09bc\u09c7\u099b\u09bf\u09b2\u09c7\u09a8, \u09a4\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995\u09ad\u09be\u09ac\u09c7 \u0995\u09c3\u09a4\u099c\u09cd\u099e...",
    "description": "\u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8\u09c0 \u09a4\u09b9\u09ac\u09bf\u09b2\u09c7 \u09af\u09c7 \u0986\u09aa\u09a8\u09be\u09b0\u09be \u0985\u09a8\u09c1\u09a6\u09be\u09a8 \u09a6\u09bf\u09af\u09bc\u09c7\u099b\u09bf\u09b2\u09c7\u09a8, \u09a4\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995\u09ad\u09be\u09ac\u09c7 \u0995\u09c3\u09a4\u099c\u09cd\u099e\u0964 \u09a6\u09b2 \u09a5\u09c7\u0995\u09c7 \u09aa\u09a6\u09a4\u09cd\u09af\u09be\u0997 \u0995\u09b0\u09c7 \u09b8\u09cd\u09ac\u09a4\u09a8\u09cd\u09a4\u09cd\u09b0 \u09aa\u09cd\u09b0\u09be\u09b0\u09cd\u09a5\u09c0 \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8\u09c7 \u0985\u0982\u09b6\u0997\u09cd\u09b0\u09b9\u09a3\u09c7\u09b0 \u09aa\u09cd\u09b0\u09c7\u0995\u09cd\u09b7\u09bf\u09a4\u09c7 \u09af\u09be\u09b0\u09be \u09aa\u09cd\u09b0\u09a6\u09a4\u09cd\u09a4 \u0985\u09a8\u09c1\u09a6\u09be\u09a8 \u09ab\u09c7\u09b0\u09a4 \u09aa\u09c7\u09a4\u09c7 \u099a\u09be\u09a8, \u09a4\u09be\u09b0\u09be \u09a6\u09af\u09bc\u09be \u0995\u09b0\u09c7 \u09a8\u09bf\u0983\u09b8\u0982\u0995\u09cb\u099a\u09c7 \u098f\u0987 \u09ab\u09b0\u09cd\u09ae\u099f\u09bf \u09aa\u09c2\u09b0\u09a3 \u0995\u09b0\u09c7 \u0985\u09b0\u09cd\u09a5 \u09ab\u09c7\u09b0\u09a4 \u09a8\u09bf\u09a8\u0964 \u0986\u09aa\u09a8\u09bf \u09ac\u09cd\u09af\u09be\u0982\u0995\u09c7 \u0985\u09a8\u09c1\u09a6\u09be\u09a8 \u09a6\u09bf\u09af\u09bc\u09c7 \u09a5\u09be\u0995\u09b2\u09c7, \u098f\u0987 \u09ab\u09b0\u09cd\u09ae\u099f\u09bf \u09aa\u09c2\u09b0\u09a3 \u0995\u09b0\u09c1\u09a8: https://forms.gle/9a3H74yrLFFeJoFw8 \u09af\u09be\u09b0\u09be \u09b8\u09b0\u09be\u09b8\u09b0\u09bf \u09ac\u09cd\u09af\u09be\u0982\u0995\u09c7 \u0995\u09cd\u09af\u09be\u09b6 \u099c\u09ae\u09be \u09a6\u09bf\u09df\u09c7\u099b\u09bf\u09b2\u09c7\u09a8, \u09a4\u09be\u09b0\u09be \u09a1\u09bf\u09aa\u09cb\u099c\u09bf\u099f \u09b8\u09cd\u09b2\u09bf\u09aa \u09b9\u09be\u09b0\u09bf\u09af\u09bc\u09c7 \u0997\u09c7\u09b2\u09c7 \u09ac\u09be \u09a8\u09be \u09a5\u09be\u0995\u09b2\u09c7\u0993 \u0986\u09ac\u09c7\u09a6\u09a8 \u0995\u09b0\u09c1\u09a8\u0964 \u09b8\u09c7\u0995\u09cd\u09b7\u09c7\u09a4\u09cd\u09b0\u09c7 \u0995\u09bf\u099b\u09c1 \u0985\u09a4\u09bf\u09b0\u09bf\u0995\u09cd\u09a4 \u09af\u09be\u099a\u09be\u0987 \u09aa\u09cd\u09b0\u0995\u09cd\u09b0\u09bf\u09af\u09bc\u09be\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u0986\u09aa\u09a8\u09be\u09b0 \u0985\u09b0\u09cd\u09a5 \u09ab\u09c7\u09b0\u09a4 \u09a6\u09c7\u09df\u09be \u09b9\u09ac\u09c7\u0964 \u09ac\u09bf\u0995\u09be\u09b6\u09c7 \u0985\u09a8\u09c1\u09a6\u09be\u09a8 \u09a6\u09bf\u09af\u09bc\u09c7 \u09a5\u09be\u0995\u09b2\u09c7, \u098f\u0987 \u09ab\u09b0\u09cd\u09ae\u099f\u09bf \u09aa\u09c2\u09b0\u09a3 \u0995\u09b0\u09c1\u09a8: https://forms.gle/NKTkkNVZvUvyrsGYA \u09ab\u09b0\u09cd\u09ae \u099c\u09ae\u09be \u09a6\u09c7\u0993\u09af\u09bc\u09be\u09b0 \u09b6\u09c7\u09b7 \u09a4\u09be\u09b0\u09bf\u0996: \u09e7\u09e6 \u09ae\u09be\u09b0\u09cd\u099a, \u09e8\u09e6\u09e8\u09ec\u0964 \u0986\u09aa\u09a8\u09be\u09a6\u09c7\u09b0 \u0986\u09b8\u09cd\u09a5\u09be \u0993 \u09ad\u09be\u09b2\u09cb\u09ac\u09be\u09b8\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u0995\u09c3\u09a4\u099c\u09cd\u099e\u09a4\u09be\u0964",
    "link": "https://www.facebook.com/DoctorTasnimJara/posts/pfbid02z8wgUR3T8Ae1o7MC7VzejoEQbiLahEutQe4Toe7pJc6qh6S7JzY1urQLiuuscVhgl",
    "guid": "https://www.facebook.com/DoctorTasnimJara/posts/pfbid02z8wgUR3T8Ae1o7MC7VzejoEQbiLahEutQe4Toe7pJc6qh6S7JzY1urQLiuuscVhgl",
    "pubDate": "2026-03-02T11:42:37.188407+00:00",
    "image": null
  },
  {
    "title": "\u0986\u09aa\u09a8\u09bf \u0995\u09bf \u099c\u09be\u09a8\u09c7\u09a8 \u0997\u09a4 \u09ac\u099b\u09b0 \u09a1\u09c7\u0999\u09cd\u0997\u09c1\u09a4\u09c7 \u09af\u09be\u09b0\u09be \u09ae\u09be\u09b0\u09be \u0997\u09c7\u099b\u09c7\u09a8, \u09a4\u09be\u09a6\u09c7\u09b0 \u0985\u09a7\u09bf\u0995\u09be\u0982\u09b6\u09c7\u09b0 \u09ac\u09df\u09b8 \u099b\u09bf\u09b2 \u09ea\u09e6 \u09ac\u099b\u09b0\u09c7\u09b0 ...",
    "description": "\u0986\u09aa\u09a8\u09bf \u0995\u09bf \u099c\u09be\u09a8\u09c7\u09a8 \u0997\u09a4 \u09ac\u099b\u09b0 \u09a1\u09c7\u0999\u09cd\u0997\u09c1\u09a4\u09c7 \u09af\u09be\u09b0\u09be \u09ae\u09be\u09b0\u09be \u0997\u09c7\u099b\u09c7\u09a8, \u09a4\u09be\u09a6\u09c7\u09b0 \u0985\u09a7\u09bf\u0995\u09be\u0982\u09b6\u09c7\u09b0 \u09ac\u09df\u09b8 \u099b\u09bf\u09b2 \u09ea\u09e6 \u09ac\u099b\u09b0\u09c7\u09b0 \u09a8\u09bf\u099a\u09c7\u0964 \u0985\u09a5\u099a \u09b8\u09b0\u0995\u09be\u09b0 \u09b8\u09a0\u09bf\u0995 \u09b8\u09ae\u09df\u09c7 \u09b8\u09a0\u09bf\u0995 \u09aa\u09a6\u0995\u09cd\u09b7\u09c7\u09aa \u09a8\u09bf\u09b2\u09c7 \u0985\u09a8\u09c7\u0995\u09be\u0982\u09b6\u09c7\u0987 \u09a1\u09c7\u0999\u09cd\u0997\u09c1 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b0\u09cb\u09a7 \u09b8\u09ae\u09cd\u09ad\u09ac\u0964 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf\u09b0 \u0987\u09b6\u09a4\u09c7\u09b9\u09be\u09b0\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b6\u09cd\u09b0\u09c1\u09a4\u09bf \u09a6\u09c7\u09df\u09be \u0986\u099b\u09c7 \u09af\u09c7 \u09a1\u09c7\u0999\u09cd\u0997\u09c1 \u0993 \u099a\u09bf\u0995\u09c1\u09a8\u0997\u09c1\u09a8\u09bf\u09af\u09bc\u09be \u09aa\u09cd\u09b0\u09a4\u09bf\u09b0\u09cb\u09a7\u09c7 \u09ac\u099b\u09b0\u09ac\u09cd\u09af\u09be\u09aa\u09c0 \u09ae\u09b6\u09be \u09a8\u09bf\u09af\u09bc\u09a8\u09cd\u09a4\u09cd\u09b0\u09a3 \u0995\u09be\u09b0\u09cd\u09af\u0995\u09cd\u09b0\u09ae \u09aa\u09b0\u09bf\u099a\u09be\u09b2\u09a8\u09be \u0995\u09b0\u09be \u09b9\u09ac\u09c7\u0964 \u0986\u09b6\u09be \u0995\u09b0\u09bf \u098f\u0987 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b6\u09cd\u09b0\u09c1\u09a4\u09bf\u09b0 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09df\u09a8\u09c7 \u09b8\u09b0\u0995\u09be\u09b0 \u0995\u09be\u099c \u0995\u09b0\u099b\u09c7\u09a8\u0964 \u0986\u099c \u09b8\u09a8\u09cd\u09a7\u09cd\u09af\u09be\u09df \u098f \u09ac\u09bf\u09b7\u09af\u09bc\u09c7 \u09ac\u09bf\u09b8\u09cd\u09a4\u09be\u09b0\u09bf\u09a4 \u0995\u09a5\u09be \u09ac\u09b2\u09ac\u0964",
    "link": "https://www.facebook.com/DoctorTasnimJara/posts/pfbid02waCYXcjWXQsRqEyHHZETrTURLpkwUqXL6tiUQk8br84WHgSx7GbiXQ8UjJSyeia9l",
