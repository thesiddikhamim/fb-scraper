  {
    "title": "\u098f\u0995\u099f\u09bf \u09b0\u09be\u099c\u09a8\u09c8\u09a4\u09bf\u0995 \u09a6\u09b2\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be\u09a8 \u0997\u09dc\u09be\u09b0 \u09aa\u09cd\u09b0\u0995\u09c3\u09a4 \u09b8\u09c1\u09af\u09cb\u0997 \u0986\u09b8\u09c7 \u0995\u09cd\u09b7\u09ae\u09a4\u09be\u09df \u09a5\u09be\u0995\u09be\u0995\u09be\u09b2\u09c0\u09a8 \u09b8\u09ae\u09df\u09c7\u0987...",
    "description": "\u098f\u0995\u099f\u09bf \u09b0\u09be\u099c\u09a8\u09c8\u09a4\u09bf\u0995 \u09a6\u09b2\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be\u09a8 \u0997\u09dc\u09be\u09b0 \u09aa\u09cd\u09b0\u0995\u09c3\u09a4 \u09b8\u09c1\u09af\u09cb\u0997 \u0986\u09b8\u09c7 \u0995\u09cd\u09b7\u09ae\u09a4\u09be\u09df \u09a5\u09be\u0995\u09be\u0995\u09be\u09b2\u09c0\u09a8 \u09b8\u09ae\u09df\u09c7\u0987\u0964 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf\u09b0 \u09b8\u09be\u09ae\u09a8\u09c7 \u098f\u0996\u09a8 \u098f\u0995 \u0990\u09a4\u09bf\u09b9\u09be\u09b8\u09bf\u0995 \u09b8\u09c1\u09af\u09cb\u0997 \u09b8\u09a4\u09cd\u09af\u09bf\u0995\u09be\u09b0\u09c7\u09b0 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8 \u0993 \u09b6\u0995\u09cd\u09a4\u09bf\u09b6\u09be\u09b2\u09c0 \u09a6\u09c1\u09b0\u09cd\u09a8\u09c0\u09a4\u09bf \u09a6\u09ae\u09a8 \u0995\u09ae\u09bf\u09b6\u09a8 \u0997\u09a0\u09a8 \u0995\u09b0\u09be\u0964 \u098f\u0987 \u098f\u0995\u099f\u09bf \u09aa\u09a6\u0995\u09cd\u09b7\u09c7\u09aa\u09c7\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7\u0987 \u09a4\u09be\u09b0\u09be \u09a8\u09bf\u099c\u09c7\u09a6\u09c7\u09b0\u0995\u09c7 \u0985\u09a8\u09a8\u09cd\u09af \u09aa\u09b0\u09cd\u09af\u09be\u09df\u09c7 \u09a8\u09bf\u09df\u09c7 \u09af\u09c7\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u0964 \u0986\u09b6\u09be \u0995\u09b0\u09bf \u09a6\u09c7\u09b6 \u0993 \u099c\u09be\u09a4\u09bf\u09b0 \u09b8\u09cd\u09ac\u09be\u09b0\u09cd\u09a5\u09c7 \u09a4\u09be\u09b0\u09be \u098f\u0987 \u09b8\u09c1\u09af\u09cb\u0997\u099f\u09bf \u0985\u09ac\u09b9\u09c7\u09b2\u09be\u09df \u09a8\u09b7\u09cd\u099f \u0995\u09b0\u09ac\u09c7 \u09a8\u09be\u0964",
    "link": "https://www.facebook.com/DoctorTasnimJara/posts/pfbid0r8ohNeiTP5uKyiQ764ffnpmHwYadVcuaPpG7vPyBAdmTpNXEFqsuyHW22uU854JCl",
    "guid": "https://www.facebook.com/DoctorTasnimJara/posts/pfbid0r8ohNeiTP5uKyiQ764ffnpmHwYadVcuaPpG7vPyBAdmTpNXEFqsuyHW22uU854JCl",
    "pubDate": "2026-03-12T03:34:52.914659+00:00",
    "image": null
