    "title": "\u09b9\u09be\u099c\u09be\u09b0\u09c7\u09b0 \u0985\u09a7\u09bf\u0995 \u09ae\u09be\u09a8\u09c1\u09b7\u0995\u09c7 \u0997\u09c1\u09ae \u0993 \u0996\u09c1\u09a8\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09b8\u09b0\u09be\u09b8\u09b0\u09bf \u099c\u09a1\u09bc\u09bf\u09a4 \u09aa\u09bf\u09b6\u09be\u099a \u099c\u09bf\u09df\u09be\u0989\u09b2 \u0986\u09b9\u09b8\u09be\u09a8\u09c7\u09b0 \u09ac\u09a8\u09cd\u09a6\u09a8\u09be\u09df ...",
    "description": "\u09b9\u09be\u099c\u09be\u09b0\u09c7\u09b0 \u0985\u09a7\u09bf\u0995 \u09ae\u09be\u09a8\u09c1\u09b7\u0995\u09c7 \u0997\u09c1\u09ae \u0993 \u0996\u09c1\u09a8\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09b8\u09b0\u09be\u09b8\u09b0\u09bf \u099c\u09a1\u09bc\u09bf\u09a4 \u09aa\u09bf\u09b6\u09be\u099a \u099c\u09bf\u09df\u09be\u0989\u09b2 \u0986\u09b9\u09b8\u09be\u09a8\u09c7\u09b0 \u09ac\u09a8\u09cd\u09a6\u09a8\u09be\u09df \u09ae\u09c7\u09a4\u09c7\u099b\u09c7 \u0995\u09a4\u09bf\u09aa\u09af\u09bc \u09ac\u09b0\u09be\u09b9 \u09b6\u09be\u09ac\u0995\u0964 \u099c\u09bf\u09df\u09be\u0989\u09b2 \u0995\u09a4\u099f\u09be \u09ad\u09af\u09bc\u09be\u09ac\u09b9 \u09b0\u0995\u09ae\u09c7\u09b0 \u09a8\u09c3\u09b6\u0982\u09b8 \u098f\u0995 \u09a0\u09be\u09a8\u09cd\u09a1\u09be \u09ae\u09be\u09a5\u09be\u09b0 \u0996\u09c1\u09a8\u09bf \u09b8\u09c7\u09b8\u09ac\u09c7\u09b0 \u09ac\u09bf\u09b8\u09cd\u09a4\u09be\u09b0\u09bf\u09a4 \u09b8\u09be\u0995\u09cd\u09b7\u09cd\u09af \u09aa\u09cd\u09b0\u09ae\u09be\u09a3 \u09a4\u09be\u09b0 \u09b8\u09b9\u0995\u09b0\u09cd\u09ae\u09c0\u09b0\u09be \u0987\u09a4\u09cb\u09ae\u09a7\u09cd\u09af\u09c7\u0987 \u09aa\u09cd\u09b0\u09a6\u09be\u09a8 \u0995\u09b0\u09c7\u099b\u09c7\u0964 \u09af\u09be\u09b0\u09be \u099c\u09bf\u09df\u09be\u0989\u09b2 \u0995\u09c7 \u09b8\u09a4\u09a4\u09be \u0993 \u09aa\u09c7\u09b6\u09be\u09a6\u09be\u09b0\u09bf\u09a4\u09cd\u09ac\u09c7\u09b0 \u0985\u09a8\u09a8\u200d\u09cd\u09af \u09a6\u09c3\u09b7\u09cd\u099f\u09be\u09a8\u09cd\u09a4 \u09ac\u09b2\u09c7 \u09b6\u09bf\u09ce\u0995\u09be\u09b0 \u0995\u09b0\u09c7\u099b\u09c7, \u09a4\u09be\u09a6\u09c7\u09b0 \u0989\u09a6\u09cd\u09a6\u09c7\u09b6\u09cd\u09af\u09c7 \u09aa\u09cd\u09b0\u09b6\u09cd\u09a8 \u2014 \u0986\u09aa\u09a8\u09be\u09a6\u09c7\u09b0 \u098f\u09a4 \u09b8\u09ce \u0993 \u09aa\u09c7\u09b6\u09be\u09a6\u09be\u09b0 \u09ad\u09be\u0987\u099f\u09bf \u09b8\u09be\u09ae\u09b0\u09bf\u0995 \u09ac\u09be\u09b9\u09bf\u09a8\u09c0\u09a4\u09c7 \u099a\u09be\u0995\u09c1\u09b0\u09bf\u09b0\u09a4 \u0985\u09ac\u09b8\u09cd\u09a5\u09be\u09df \u09a0\u09bf\u0995 \u0995\u09cb\u09a8 \u09aa\u09cd\u09b0\u0995\u09cd\u09b0\u09bf\u09df\u09be\u09df \u09e8 \u09b2\u0995\u09cd\u09b7 \u09a1\u09b2\u09be\u09b0 \u09ac\u09bf\u09a8\u09bf\u09df\u09cb\u0997 \u0995\u09b0\u09c7 \u09a6\u09cd\u09ac\u09c0\u09aa \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0 \u098f\u09a8\u09cd\u099f\u09bf\u0997\u09be \u09ac\u09be\u09b0\u09ac\u09c1\u09a1\u09be\u09b0 \u09a8\u09be\u0997\u09b0\u09bf\u0995\u09a4\u09cd\u09ac \u0997\u09cd\u09b0\u09b9\u09a3 \u0995\u09b0\u09c7\u099b\u09bf\u09b2\u09cb? \u0995\u09c7\u09a8\u0987\u09ac\u09be \u09a4\u09bf\u09a8\u09bf \u0993 \u09a4\u09be\u09b0 \u09b8\u09cd\u09a4\u09cd\u09b0\u09c0 \u09b8\u0982\u09af\u09c1\u0995\u09cd\u09a4 \u0986\u09b0\u09ac \u0986\u09ae\u09bf\u09b0\u09be\u09a4\u09c7\u09b0 \u09e7\u09e6 \u09ac\u099b\u09b0 \u09ae\u09c7\u09df\u09be\u09a6\u09c0 \u0987\u09a8\u09ad\u09c7\u09b8\u09cd\u099f\u09b0 \u09ad\u09bf\u09b8\u09be \u09a8\u09bf\u09df\u09c7\u099b\u09bf\u09b2\u09c7\u09a8? \u09b8\u09c7\u09a6\u09c7\u09b6\u09c7 \u09a4\u09be\u09b0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u09ac\u09cd\u09af\u09be\u0982\u0995 \u098f\u0995\u09be\u0989\u09a8\u09cd\u099f \u0993 \u09b8\u09ae\u09cd\u09aa\u09a6\u09c7\u09b0 \u09a4\u09a5\u09cd\u09af \u09ac\u09b9\u09c1 \u0986\u0997\u09c7\u0987 \u09aa\u09cd\u09b0\u0995\u09be\u09b6 \u0995\u09b0\u09c7\u099b\u09bf, \u09b8\u09c7\u09b8\u09ac \u098f\u0995\u099f\u09c1 \u0996\u09c1\u0981\u099c\u09c7 \u09ac\u09c7\u09b0 \u0995\u09b0\u09c1\u09a8\u0964 \u0986\u09b0 \u09a2\u09be\u0995\u09be \u09b6\u09b9\u09b0\u09c7 \u09a8\u09be\u09ae\u09c7 \u09ac\u09c7\u09a8\u09be\u09ae\u09c7 \u09b9\u09be\u099c\u09be\u09b0 \u0995\u09cb\u099f\u09bf \u099f\u09be\u0995\u09be\u09b0 \u09b8\u09ae\u09cd\u09aa\u09a6 \u2014 \u09b8\u09c7\u09b8\u09ac\u0993 \u09aa\u09cd\u09b0\u0995\u09be\u09b6 \u0995\u09b0\u09be \u09b9\u09df\u09c7\u099b\u09c7\u0964 \u09aa\u09a4\u09bf\u09a4 \u09b8\u09cd\u09ac\u09c8\u09b0\u09be\u099a\u09be\u09b0\u09c7\u09b0 \u0985\u09a4\u09bf \u09ac\u09bf\u09b6\u09cd\u09ac\u09b8\u09cd\u09a4 \u098f\u0987 \u0996\u09c1\u09a8\u09c0\u0995\u09c7 \u09a4\u09be\u09b0 \u09aa\u09be\u09aa\u09c7\u09b0 \u09b6\u09be\u09b8\u09cd\u09a4\u09bf \u0985\u09ac\u09b6\u09cd\u09af\u0987 \u09ad\u09cb\u0997 \u0995\u09b0\u09a4\u09c7 \u09b9\u09ac\u09c7\u0964",
