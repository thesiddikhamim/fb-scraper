    "title": "\u0985\u09a8\u09c1\u09b8\u09a8\u09cd\u09a7\u09be\u09a8\u09c0 \u09b8\u09be\u0982\u09ac\u09be\u09a6\u09bf\u0995 \u099c\u09c1\u09b2\u0995\u09be\u09b0\u09a8\u09be\u0987\u09a8 \u09b8\u09be\u09df\u09c7\u09b0 \u09a6\u09cd\u09af \u09a1\u09bf\u09b8\u09c7\u09a8\u09cd\u099f\u0995\u09c7 \u099c\u09be\u09a8\u09be\u09a8, \u09a4\u09bf\u09a8\u09bf \u098f\u09ae\u09a8 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af \u09a6\u09c7\u09a8\u09a8\u09bf...",
    "description": "\u0985\u09a8\u09c1\u09b8\u09a8\u09cd\u09a7\u09be\u09a8\u09c0 \u09b8\u09be\u0982\u09ac\u09be\u09a6\u09bf\u0995 \u099c\u09c1\u09b2\u0995\u09be\u09b0\u09a8\u09be\u0987\u09a8 \u09b8\u09be\u09df\u09c7\u09b0 \u09a6\u09cd\u09af \u09a1\u09bf\u09b8\u09c7\u09a8\u09cd\u099f\u0995\u09c7 \u099c\u09be\u09a8\u09be\u09a8, \u09a4\u09bf\u09a8\u09bf \u098f\u09ae\u09a8 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af \u09a6\u09c7\u09a8\u09a8\u09bf\u0964 \u098f\u099b\u09be\u09dc\u09be\u0993, \u099c\u09c1\u09b2\u0995\u09be\u09b0\u09a8\u09be\u0987\u09a8 \u09b8\u09be\u09df\u09c7\u09b0\u09c7\u09b0 \u09b8\u09be\u09ae\u09be\u099c\u09bf\u0995 \u09af\u09cb\u0997\u09be\u09af\u09cb\u0997\u09ae\u09be\u09a7\u09cd\u09af\u09ae \u09ac\u09be \u09b8\u0982\u09ac\u09be\u09a6\u09ae\u09be\u09a7\u09cd\u09af\u09ae \u09b8\u09c2\u09a4\u09cd\u09b0\u09c7\u0993 \u098f\u09ae\u09a8 \u09ae\u09a8\u09cd\u09a4\u09ac\u09cd\u09af \u0996\u09c1\u0981\u099c\u09c7 \u09aa\u09be\u0993\u09df\u09be \u09af\u09be\u09df\u09a8\u09bf\u0964",
