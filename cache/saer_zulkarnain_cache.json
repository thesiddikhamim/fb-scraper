    "title": "\u09b8\u09ae\u09cd\u09aa\u09cd\u09b0\u09a4\u09bf \u09ad\u09be\u09b0\u09a4\u09c7\u09b0 \u09b0\u09be\u099c\u09a7\u09be\u09a8\u09c0 \u09a6\u09bf\u09b2\u09cd\u09b2\u09bf\u09a4\u09c7 \u09aa\u09cd\u09b0\u09c7\u09b8\u0995\u09cd\u09b2\u09be\u09ac \u0985\u09ac \u0987\u09a8\u09cd\u09a1\u09bf\u09af\u09bc\u09be\u09b0 \u09b8\u09ad\u09be\u09aa\u09a4\u09bf \u0997\u09cc\u09a4\u09ae \u09b2\u09be\u09b9\u09bf\u09a1\u09bc\u09c0 \u0986\u0993\u09af...",
    "description": "\u09b8\u09ae\u09cd\u09aa\u09cd\u09b0\u09a4\u09bf \u09ad\u09be\u09b0\u09a4\u09c7\u09b0 \u09b0\u09be\u099c\u09a7\u09be\u09a8\u09c0 \u09a6\u09bf\u09b2\u09cd\u09b2\u09bf\u09a4\u09c7 \u09aa\u09cd\u09b0\u09c7\u09b8\u0995\u09cd\u09b2\u09be\u09ac \u0985\u09ac \u0987\u09a8\u09cd\u09a1\u09bf\u09af\u09bc\u09be\u09b0 \u09b8\u09ad\u09be\u09aa\u09a4\u09bf \u0997\u09cc\u09a4\u09ae \u09b2\u09be\u09b9\u09bf\u09a1\u09bc\u09c0 \u0986\u0993\u09af\u09bc\u09be\u09ae\u09c0 \u09b2\u09c0\u0997\u09c7\u09b0 \u0995\u09af\u09bc\u09c7\u0995\u099c\u09a8 \u09a8\u09c7\u09a4\u09be, \u09ad\u09be\u09b0\u09a4 \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0 \u0995\u09b0\u09cd\u09ae\u0995\u09b0\u09cd\u09a4\u09be \u098f\u09ac\u0982 \u09b8\u09be\u0982\u09ac\u09be\u09a6\u09bf\u0995\u09a6\u09c7\u09b0 \u09a8\u09bf\u09df\u09c7 \u098f\u0995\u099f\u09bf \u0987\u09ab\u09a4\u09be\u09b0 \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09c7\u09b0 \u0986\u09af\u09bc\u09cb\u099c\u09a8 \u0995\u09b0\u09c7\u09a8\u0964 \u09a4\u09ac\u09c7 \u098f\u0987 \u0986\u09af\u09bc\u09cb\u099c\u09a8\u0995\u09c7 \u0998\u09bf\u09b0\u09c7 \u0986\u09b2\u09cb\u099a\u09a8\u09be\u09b0 \u099a\u09be\u0987\u09a4\u09c7 \u09ac\u09c7\u09b6\u09bf \u09a4\u09be\u09ce\u09aa\u09b0\u09cd\u09af\u09aa\u09c2\u09b0\u09cd\u09a3 \u09b9\u09b2\u09cb \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u099f\u09bf \u09af\u09be\u09b0\u09be '\u098f\u09a1\u09bc\u09bf\u09af\u09bc\u09c7 \u0997\u09c7\u099b\u09c7\u09a8', \u09a4\u09be\u09a6\u09c7\u09b0 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4\u09bf \u09a8\u09be-\u09a5\u09be\u0995\u09be\u0964 \u09ac\u09c7\u09b2\u099c\u09bf\u09af\u09bc\u09be\u09ae \u09a5\u09c7\u0995\u09c7 \u09ac\u09bf\u09b6\u09c7\u09b7\u09ad\u09be\u09ac\u09c7 \u0986\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09bf\u09a4 \u09b9\u09af\u09bc\u09c7 \u0986\u09b8\u09be \u09b9\u09be\u09b8\u09be\u09a8 \u09ae\u09be\u09b9\u09ae\u09c1\u09a6 \u098f\u09ac\u0982 \u099c\u09be\u09b9\u09be\u0999\u09cd\u0997\u09c0\u09b0 \u0995\u09ac\u09bf\u09b0 \u09a8\u09be\u09a8\u0995 \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09c7 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u09b9\u09df\u09c7\u099b\u09bf\u09b2\u09c7\u09a8 \u09a0\u09bf\u0995\u0987 \u09a4\u09ac\u09c7 \u0986\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09a3 \u099c\u09be\u09a8\u09be\u09a8\u09cb \u09b8\u09a4\u09cd\u09a4\u09cd\u09ac\u09c7\u0993 \u09ad\u09be\u09b0\u09a4 \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0 \u09aa\u0995\u09cd\u09b7 \u09a5\u09c7\u0995\u09c7 \u0986\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09bf\u0995 \u09ac\u09be \u0985\u09a8\u09be\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09bf\u0995\u2014\u0995\u09cb\u09a8\u09cb \u09aa\u09b0\u09cd\u09af\u09be\u09af\u09bc\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u09a8\u09bf\u09a7\u09bf\u0987 \u098f\u0987 \u0987\u09ab\u09a4\u09be\u09b0\u09c7 \u0985\u0982\u09b6 \u09a8\u09c7\u09a8\u09a8\u09bf\u0964 \u09b6\u09c1\u09a7\u09c1 \u09a4\u09be\u0987 \u09a8\u09af\u09bc, \u09af\u09c7\u09b8\u09ac \u09b8\u09be\u0982\u09ac\u09be\u09a6\u09bf\u0995\u0995\u09c7 \u09a6\u09be\u0993\u09af\u09bc\u09be\u09a4 \u09a6\u09c7\u0993\u09af\u09bc\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09bf\u09b2, \u09a4\u09be\u0981\u09a6\u09c7\u09b0 \u0985\u09a7\u09bf\u0995\u09be\u0982\u09b6\u0987 \u099b\u09bf\u09b2\u09c7\u09a8 \u0985\u09a8\u09c1\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4\u0964 \u09ae\u09c2\u09b2\u09a7\u09be\u09b0\u09be\u09b0 \u0997\u09a3\u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u09a8\u09bf\u09a7\u09bf \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u09b6\u09c1\u09a7\u09c1 \u0987\u09a8\u09cd\u09a1\u09bf\u09af\u09bc\u09be \u099f\u09c1\u09a1\u09c7\u09b0 \u098f\u0995\u099c\u09a8 \u09b8\u09be\u0982\u09ac\u09be\u09a6\u09bf\u0995\u0995\u09c7 \u09b8\u09c7\u0996\u09be\u09a8\u09c7 \u09a6\u09c7\u0996\u09be \u0997\u09c7\u099b\u09c7\u2014\u09af\u09be \u0986\u09af\u09bc\u09cb\u099c\u09a8\u09c7\u09b0 '\u0997\u09c1\u09b0\u09c1\u09a4\u09cd\u09ac' \u09b8\u09ae\u09cd\u09aa\u09b0\u09cd\u0995\u09c7 \u0985\u09a8\u09c7\u0995 \u0995\u09a5\u09be\u0987 \u09ac\u09b2\u09c7\u0964 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8-\u09aa\u09b0\u09ac\u09b0\u09cd\u09a4\u09c0 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09a4\u09be\u09af\u09bc \u098f\u0987 \u0987\u09ab\u09a4\u09be\u09b0\u09c7 \u09ad\u09be\u09b0\u09a4 \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0 \u0995\u09c7\u0989 \u09a8\u09be \u0986\u09b8\u09be \u098f\u09ac\u0982 \u09b8\u09be\u0982\u09ac\u09be\u09a6\u09bf\u0995\u09a6\u09c7\u09b0 \u09af\u09cb\u0997\u09a6\u09be\u09a8\u09c7 \u09ac\u09bf\u09b0\u09a4 \u09a5\u09be\u0995\u09be\u2014\u098f\u0987 \u09a6\u09c1\u0987 \u0998\u099f\u09a8\u09be \u0987\u0999\u09cd\u0997\u09bf\u09a4 \u09ac\u09b9\u09a8 \u0995\u09b0\u09c7: \u09aa\u09cd\u09b0\u09a5\u09ae\u09a4, \u09ad\u09be\u09b0\u09a4 \u09b8\u09b0\u0995\u09be\u09b0 \u09b8\u09ae\u09cd\u09ad\u09ac\u09a4 \u09b8\u099a\u09c7\u09a4\u09a8\u09ad\u09be\u09ac\u09c7\u0987 \u098f\u0987 \u0986\u09af\u09bc\u09cb\u099c\u09a8\u0995\u09c7 '\u098f\u09a1\u09bc\u09bf\u09af\u09bc\u09c7 \u0997\u09c7\u099b\u09c7'\u0964 \u098f\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u09a4\u09be\u0981\u09b0\u09be \u09ac\u09cb\u099d\u09be\u09a4\u09c7 \u099a\u09c7\u09af\u09bc\u09c7\u099b\u09c7\u09a8, \u0986\u0993\u09af\u09bc\u09be\u09ae\u09c0 \u09b2\u09c0\u0997\u09c7\u09b0 \u09aa\u0995\u09cd\u09b7\u09c7 \u0995\u09cb\u09a8\u09cb \u0985\u09ac\u09b8\u09cd\u09a5\u09be\u09a8 \u09a8\u09c7\u0993\u09af\u09bc\u09be\u09b0 \u0986\u0997\u09cd\u09b0\u09b9 \u09a4\u09be\u0981\u09a6\u09c7\u09b0 \u09a8\u09c7\u0987\u0964 \u09ac\u09b0\u0982 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8 \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09bf\u09a4 \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u09b8\u09ae\u09cd\u09aa\u09b0\u09cd\u0995 \u09b8\u09cd\u09a5\u09bf\u09a4\u09bf\u09b6\u09c0\u09b2 \u09b0\u09be\u0996\u09be\u0987 \u098f\u0996\u09a8 \u09a4\u09be\u09a6\u09c7\u09b0 \u09ae\u09c2\u09b2 \u0985\u0997\u09cd\u09b0\u09be\u09a7\u09bf\u0995\u09be\u09b0\u0964 \u09a6\u09cd\u09ac\u09bf\u09a4\u09c0\u09af\u09bc\u09a4, \u098f\u099f\u09bf \u09ad\u09be\u09b0\u09a4\u09c7\u09b0 \u09aa\u0995\u09cd\u09b7 \u09a5\u09c7\u0995\u09c7 \u0986\u0993\u09af\u09bc\u09be\u09ae\u09c0 \u09b2\u09c0\u0997\u0995\u09c7 \u098f\u0995\u099f\u09bf '\u09b6\u0995\u09cd\u09a4 \u09a6\u09c2\u09b0\u09a4\u09cd\u09ac\u09c7\u09b0 \u09ac\u09be\u09b0\u09cd\u09a4\u09be'\u0964 \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u098f\u0995\u09b8\u09ae\u09af\u09bc \u098f\u0987 \u09a6\u09b2\u09c7\u09b0 \u09a8\u09c7\u09a4\u09be\u09b0\u09be \u09a6\u09bf\u09b2\u09cd\u09b2\u09bf\u09b0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u09ae\u09b9\u09b2\u09c7 \u09b8\u09cd\u09ac\u09be\u0997\u09a4 \u0985\u09a4\u09bf\u09a5\u09bf \u099b\u09bf\u09b2\u09c7\u09a8, \u09b8\u09c7\u0996\u09be\u09a8\u09c7 \u098f\u0996\u09a8 \u09a4\u09be\u0981\u09a6\u09c7\u09b0 '\u0995\u09c2\u099f\u09a8\u09c8\u09a4\u09bf\u0995\u09ad\u09be\u09ac\u09c7 \u09ac\u09b0\u09cd\u099c\u09a8' \u09a6\u09c7\u0996\u09bf\u09af\u09bc\u09c7 \u09a6\u09c7\u0993\u09af\u09bc\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09c7\u0964 \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u099f\u09bf \u09a4\u09be\u0987 \u0986\u0993\u09af\u09bc\u09be\u09ae\u09c0 \u09b2\u09c0\u0997\u09c7\u09b0 \u099c\u09a8\u09cd\u09af\u09c7 \u0986\u09a1\u09bc\u09ae\u09cd\u09ac\u09b0\u09c7\u09b0 \u099a\u09be\u0987\u09a4\u09c7 \u098f\u0995\u09b0\u0995\u09ae '\u09ac\u09b0\u09cd\u099c\u09a8\u09c7\u09b0 \u09ae\u09b9\u09a1\u09bc\u09be' \u09b9\u09df\u09c7 \u0997\u09c7\u09b2\u09cb\u0964 \u09ad\u09be\u09b0\u09a4 \u09b8\u09b0\u0995\u09be\u09b0 \u0986\u09b8\u09b2\u09c7\u0993 \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8 \u09b8\u09b0\u0995\u09be\u09b0 \u0993 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09b8\u09ae\u09cd\u09aa\u09b0\u09cd\u0995 \u0989\u09a8\u09cd\u09a8\u09a4 \u0995\u09b0\u09a4\u09c7 \u0995\u09a4\u099f\u09be \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995 \u09b8\u09c7\u099f\u09be\u09b0 \u09aa\u09cd\u09b0\u09ae\u09be\u09a3 \u0986\u09ae\u09b0\u09be \u09aa\u09be\u09ac\u09cb \u09af\u0996\u09a8 \u09a6\u09c7\u09b6\u099f\u09bf \u0985\u09a8\u09cd\u09a4\u09a4 \u099a\u09be\u09b0\u099f\u09bf \u09aa\u09a6\u0995\u09cd\u09b7\u09c7\u09aa \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u0995\u09b0\u09ac\u09c7\u0964 \u09e7. \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09ad\u09be\u09b0\u09a4 \u09b8\u09c0\u09ae\u09be\u09a8\u09cd\u09a4\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c0 \u09a8\u09be\u0997\u09b0\u09bf\u0995\u09a6\u09c7\u09b0 \u0997\u09c1\u09b2\u09bf \u0995\u09b0\u09c7 \u09b9\u09a4\u09cd\u09af\u09be \u09ac\u09be \u09aa\u09be\u0995\u09a1\u09bc\u09be\u0993 \u0995\u09b0\u09c7 \u09a8\u09bf\u099c \u09b8\u09c0\u09ae\u09be\u09a8\u09be\u09df \u09a8\u09bf\u09df\u09c7 \u09a8\u09bf\u09b0\u09cd\u09af\u09be\u09a4\u09a8 \u09b6\u09c2\u09a3\u09cd\u09af\u09c7\u09b0 \u0995\u09cb\u09a0\u09be\u09af\u09bc \u09a8\u09bf\u09df\u09c7 \u0986\u09b8\u09be\u0964 \u09e8. \u09ad\u09be\u09b0\u09a4\u09c7 \u0986\u09b6\u09cd\u09b0\u09bf\u09a4 \u09b6\u09c7\u0996 \u09b9\u09be\u09b8\u09bf\u09a8\u09be\u0995\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7 \u09b9\u09b8\u09cd\u09a4\u09be\u09a8\u09cd\u09a4\u09b0 \u09aa\u09cd\u09b0\u0995\u09cd\u09b0\u09bf\u09af\u09bc\u09be \u09b6\u09c1\u09b0\u09c1 \u0995\u09b0\u09be\u0964 \u09e9. \u099b\u09be\u09a4\u09cd\u09b0\u09a8\u09c7\u09a4\u09be \u0993\u09b8\u09ae\u09be\u09a8 \u09b9\u09be\u09a6\u09bf \u09b9\u09a4\u200d\u09cd\u09af\u09be\u09b0 \u09b8\u09be\u09a5\u09c7 \u099c\u09a1\u09bc\u09bf\u09a4 \u0986\u099f\u0995\u0995\u09c3\u09a4 \u09ac\u09cd\u09af\u0995\u09cd\u09a4\u09bf\u09a6\u09c7\u09b0 \u09a6\u09cd\u09b0\u09c1\u09a4\u09a4\u09be\u09b0 \u09b8\u09be\u09a5\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7 \u09ab\u09c7\u09b0\u09a4 \u09aa\u09be\u09a0\u09be\u09a8\u09cb \u098f\u09ac\u0982 \u098f\u0995\u0987 \u09b8\u09be\u09a5\u09c7 \u099c\u09c1\u09b2\u09be\u0987-\u0986\u0997\u09b7\u09cd\u099f \u09e8\u09e6\u09e8\u09ea \u0986\u09a8\u09cd\u09a6\u09cb\u09b2\u09a8\u09c7 \u09b9\u09a4\u200d\u09cd\u09af\u09be\u09b0 \u09b8\u09be\u09a5\u09c7 \u099c\u09a1\u09bc\u09bf\u09a4 \u0986\u0993\u09df\u09be\u09ae\u09c0 \u09b2\u09c0\u0997 \u09a8\u09c7\u09a4\u09be-\u0995\u09b0\u09cd\u09ae\u09c0 \u098f\u09ac\u0982 \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be \u09b8\u0982\u09b8\u09cd\u09a5\u09be\u09b0 \u09b8\u09a6\u09b8\u09cd\u09af\u09a6\u09c7\u09b0 \u09ab\u09c7\u09b0\u09a4\u09c7\u09b0 \u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be \u0997\u09cd\u09b0\u09b9\u09a3\u0964 \u09ea. \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u0995\u09c7 \u09a4\u09bf\u09b8\u09cd\u09a4\u09be\u09b0 \u09aa\u09be\u09a8\u09bf\u09b0 \u09a8\u09cd\u09af\u09be\u09af\u09cd\u09af \u09b9\u09bf\u09b8\u09cd\u09af\u09be \u09ac\u09c1\u099d\u09bf\u09af\u09bc\u09c7 \u09a6\u09c7\u09df\u09be\u0964",
    "link": "https://www.facebook.com/saerzulkarnain/posts/pfbid02NwA4DPqLF3PTbbSpr5RMs58bsmL6KzS9o6bnVCepX2oXCQPKHxxRYeKtToLXfJGol",
    "guid": "https://www.facebook.com/saerzulkarnain/posts/pfbid02NwA4DPqLF3PTbbSpr5RMs58bsmL6KzS9o6bnVCepX2oXCQPKHxxRYeKtToLXfJGol",
