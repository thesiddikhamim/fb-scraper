    "title": "[\u09a2\u09be\u0995\u09be\u09b0 \u09aa\u09b0\u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0 \u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09a3\u09be\u09b2\u09df \u0995\u09b0\u09cd\u09a4\u09c3\u0995 \u0986\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09bf\u0995 \u09ac\u09a6\u09b2\u09bf\u09b0 \u09a8\u09bf\u09b0\u09cd\u09a6\u09c7\u09b6 \u099c\u09be\u09b0\u09bf\u09b0 \u09e7\u09ea \u09ae\u09be\u09b8 \u09aa\u09b0\u0993 \u09ac\u09be\u09b0...",
    "description": "[\u09a2\u09be\u0995\u09be\u09b0 \u09aa\u09b0\u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0 \u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09a3\u09be\u09b2\u09df \u0995\u09b0\u09cd\u09a4\u09c3\u0995 \u0986\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09bf\u0995 \u09ac\u09a6\u09b2\u09bf\u09b0 \u09a8\u09bf\u09b0\u09cd\u09a6\u09c7\u09b6 \u099c\u09be\u09b0\u09bf\u09b0 \u09e7\u09ea \u09ae\u09be\u09b8 \u09aa\u09b0\u0993 \u09ac\u09be\u09b0\u09cd\u09b2\u09bf\u09a8\u09c7 \u0985\u09ac\u09b8\u09cd\u09a5\u09a4\u09bf \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09a6\u09c2\u09a4\u09be\u09ac\u09be\u09b8 \u099b\u09be\u09dc\u09c7\u09a8\u09a8\u09bf \u098f\u0995 \u09ac\u09bf\u09a4\u09b0\u09cd\u0995\u09bf\u09a4 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09bf \u0995\u09c2\u099f\u09a8\u09c0\u09a4\u09bf\u0995\u0964 \u09a4\u09be\u09b0 \u09a8\u09be\u09ae \u09a4\u09be\u09a8\u09ad\u09c0\u09b0 \u0995\u09ac\u09bf\u09b0\u0964 \u09ac\u09bf\u09a4\u09b0\u09cd\u0995\u09bf\u09a4 \u098f\u0987 \u0995\u09c2\u099f\u09a8\u09c0\u09a4\u09bf\u0995\u09c7\u09b0 \u09ac\u09bf\u09b0\u09c1\u09a6\u09cd\u09a7\u09c7 \u09b8\u09b0\u0995\u09be\u09b0\u09bf \u09a8\u09bf\u09b0\u09cd\u09a6\u09c7\u09b6 \u0985\u09ae\u09be\u09a8\u09cd\u09af, \u09aa\u09cd\u09b0\u09b6\u09be\u09b8\u09a8\u09bf\u0995 \u0985\u09a8\u09bf\u09df\u09ae \u0993 \u09b8\u09b0\u0995\u09be\u09b0\u09bf \u0985\u09b0\u09cd\u09a5 \u09a4\u099b\u09b0\u09c1\u09aa\u09c7\u09b0 \u0985\u09ad\u09bf\u09af\u09cb\u0997 \u0989\u09a0\u09c7\u099b\u09c7\u0964]",
