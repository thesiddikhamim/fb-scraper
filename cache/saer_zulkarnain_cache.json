  },
  {
    "title": "\u09b8\u09a0\u09bf\u0995 \u09b8\u0982\u0996\u09cd\u09af\u09be \u09b9\u09ac\u09c7 \u09b8\u09be\u09a4, \u09b8\u09ae\u09cd\u09ad\u09ac\u09a4 \u0995\u09cb\u09a8 \u098f\u0995 \u0995\u09be\u09b0\u09a3\u09c7 '\u09a8\u09be\u09ac\u09bf\u09b2 \u0997\u09cd\u09b0\u09c1\u09aa' \u098f\u09b0 \u09a8\u09be\u09ae \u09a4\u09be\u09b0\u09be \u0989\u09b2\u09cd\u09b2\u09c7\u0996 \u0995\u09b0\u09c7\u09a8\u09a8\u09bf...",
    "description": "\u09b8\u09a0\u09bf\u0995 \u09b8\u0982\u0996\u09cd\u09af\u09be \u09b9\u09ac\u09c7 \u09b8\u09be\u09a4, \u09b8\u09ae\u09cd\u09ad\u09ac\u09a4 \u0995\u09cb\u09a8 \u098f\u0995 \u0995\u09be\u09b0\u09a3\u09c7 '\u09a8\u09be\u09ac\u09bf\u09b2 \u0997\u09cd\u09b0\u09c1\u09aa' \u098f\u09b0 \u09a8\u09be\u09ae \u09a4\u09be\u09b0\u09be \u0989\u09b2\u09cd\u09b2\u09c7\u0996 \u0995\u09b0\u09c7\u09a8\u09a8\u09bf\u0964 \u09b8\u09a0\u09bf\u0995 \u09b8\u0982\u0996\u09cd\u09af\u09be \u0989\u09b2\u09cd\u09b2\u09c7\u0996 \u0995\u09b0\u09c7 \u09ab\u099f\u09cb\u0995\u09be\u09b0\u09cd\u09a1\u099f\u09bf \u09b8\u0982\u09b6\u09cb\u09a7\u09a8 \u0995\u09b0\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09c7\u0964",
    "link": "https://www.facebook.com/saerzulkarnain/posts/pfbid037Asr4C9jkS57a8Gb3QTAdYjD5sET8dCJxquvdFVT6Bu1u77NFnCR6EPNvyfyx9RKl",
    "guid": "https://www.facebook.com/saerzulkarnain/posts/pfbid037Asr4C9jkS57a8Gb3QTAdYjD5sET8dCJxquvdFVT6Bu1u77NFnCR6EPNvyfyx9RKl",
    "pubDate": "2026-05-05T08:10:07.744347+00:00",
