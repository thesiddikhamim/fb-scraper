[
  {
    "title": "\u09e9\u09e6 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09e8\u09e6\u09e8\u09ec \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0\u09c7\u09b0 \u0997\u09a3\u09a4\u09a8\u09cd\u09a4\u09cd\u09b0\u09c7\u09b0 \u09aa\u09a5\u09c7 \u0989\u09ce\u0995\u09b0\u09cd\u09b7\u09a4\u09be \u0985\u09b0\u09cd\u099c\u09a8\u09c7\u09b0 \u09b2\u0995\u09cd\u09b7\u09cd\u09af\u09c7 \u098f\u0997\u09bf\u09df\u09c7 ...",
    "description": "\u09e9\u09e6 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09e8\u09e6\u09e8\u09ec \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0\u09c7\u09b0 \u0997\u09a3\u09a4\u09a8\u09cd\u09a4\u09cd\u09b0\u09c7\u09b0 \u09aa\u09a5\u09c7 \u0989\u09ce\u0995\u09b0\u09cd\u09b7\u09a4\u09be \u0985\u09b0\u09cd\u099c\u09a8\u09c7\u09b0 \u09b2\u0995\u09cd\u09b7\u09cd\u09af\u09c7 \u098f\u0997\u09bf\u09df\u09c7 \u09af\u09be\u0993\u09df\u09be\u09b0 \u09aa\u09cd\u09b0\u09df\u09be\u09b8\u09c7 \u09b8\u09cd\u09ac\u09b0\u09cd\u09a3\u09be\u0995\u09cd\u09b7\u09b0\u09c7 \u09b2\u09bf\u0996\u09be \u09a5\u09be\u0995\u09ac\u09c7\u0964 \u098f\u0987 \u09a6\u09bf\u09a8 \u0986\u09ae\u09b0\u09be \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u0995\u09cd\u09b7 \u0995\u09b0\u09c7\u099b\u09bf \u099b\u09be\u09a4\u09cd\u09b0-\u099c\u09a8\u09a4\u09be\u09b0 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8\u09c7\u09b0 \u0985\u09a8\u200d\u09cd\u09af\u09a4\u09ae \u0995\u09be\u09a8\u09cd\u09a1\u09be\u09b0\u09c0 \u09a8\u09be\u09b9\u09bf\u09a6 \u0987\u09b8\u09b2\u09be\u09ae\u09c7\u09b0 \u0985\u09b8\u09be\u09a7\u09be\u09b0\u09a3 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af \u2014 \u09af\u09be\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u0985\u09a7\u09cd\u09af\u09be\u09af\u09bc \u098f\u09ae\u09a8\u09ad\u09be\u09ac\u09c7 \u09a4\u09bf\u09a8\u09bf \u09a4\u09c1\u09b2\u09c7 \u09a7\u09b0\u09c7\u099b\u09c7\u09a8, \u09af\u09be \u09ac\u09b9\u09c1\u09a6\u09bf\u09a8 \u09b8\u09cd\u09ae\u09c3\u09a4\u09bf\u09a4\u09c7 \u09a5\u09be\u0995\u09ac\u09c7\u0964 \u0986\u09b0 \u09b8\u09b0\u0995\u09be\u09b0\u09aa\u0995\u09cd\u09b7\u09c7\u09b0 \u09a8\u09c7\u09a4\u09be, \u09aa\u09cd\u09b0\u09a7\u09be\u09a8\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8 \u2014 \u09eb\u09ee \u09ac\u099b\u09b0 \u09ac\u09df\u09b8\u09c0 \u098f\u0987 \u09b0\u09be\u099c\u09a8\u09c0\u09a4\u09bf\u09ac\u09bf\u09a6 \u09aa\u09cd\u09b0\u099a\u09b2\u09bf\u09a4 \u0998\u09c3\u09a3\u09be\u09b0 \u09b0\u09be\u099c\u09a8\u09c0\u09a4\u09bf \u09aa\u09b0\u09bf\u09b9\u09be\u09b0 \u0995\u09b0\u09c7 \u2014 \u099c\u09a1\u09bc\u09a4\u09be \u0993 \u0986\u09a1\u09bc\u09b7\u09cd\u099f\u09a4\u09be \u099b\u09be\u09a1\u09bc\u09be\u0987 \u09aa\u09cd\u09b0\u09be\u09df \u09e7 \u0998\u09a8\u09cd\u099f\u09be\u09b0 \u09b8\u09be\u09ac\u09b2\u09c0\u09b2 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af\u09c7 \u0987\u09a8\u0995\u09cd\u09b2\u200d\u09cd\u09af\u09c1\u09b8\u09bf\u09ad \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u0997\u09a0\u09a8\u09c7\u09b0 \u09b2\u0995\u09cd\u09b7\u09cd\u09af\u09c7, \u09a4\u09be\u0981\u09b0 \u09a6\u09c3\u09a2\u09bc \u0985\u09ac\u09b8\u09cd\u09a5\u09be\u09a8 \u09b8\u09cd\u09aa\u09b7\u09cd\u099f\u09a4\u0987 \u09ab\u09c1\u099f\u09bf\u09df\u09c7 \u09a4\u09c1\u09b2\u09c7\u099b\u09c7\u09a8\u0964 \u0987\u09a8\u09b6\u09be\u0986\u09b2\u09cd\u09b2\u09be\u09b9 \u098f\u0987 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09aa\u09a5 \u09b9\u09be\u09b0\u09be\u09ac\u09c7\u09a8\u09be, \u09ae\u09be\u09a5\u09be\u0993 \u09a8\u09cb\u09df\u09be\u09ac\u09c7\u09a8\u09be\u0964",
