[
  {
    "title": "\u09a6\u09c7\u09b6\u09c7\u09b0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8\u09b8\u09cd\u09a5\u09be\u09a8 \u09a5\u09c7\u0995\u09c7 \u0989\u0997\u09cd\u09b0\u09ac\u09be\u09a6\u09c0 \u099a\u09be\u09b0 \u09a4\u09b0\u09c1\u09a3\u0995\u09c7 \u0997\u09cd\u09b0\u09c7\u09aa\u09cd\u09a4\u09be\u09b0 \u0995\u09b0\u09c7\u099b\u09c7 \u09a2\u09be\u0995\u09be \u09ae\u09b9\u09be\u09a8\u0997\u09b0 \u0997\u09cb\u09af\u09bc\u09c7\u09a8\u09cd\u09a6...",
    "description": "\u09a6\u09c7\u09b6\u09c7\u09b0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8\u09b8\u09cd\u09a5\u09be\u09a8 \u09a5\u09c7\u0995\u09c7 \u0989\u0997\u09cd\u09b0\u09ac\u09be\u09a6\u09c0 \u099a\u09be\u09b0 \u09a4\u09b0\u09c1\u09a3\u0995\u09c7 \u0997\u09cd\u09b0\u09c7\u09aa\u09cd\u09a4\u09be\u09b0 \u0995\u09b0\u09c7\u099b\u09c7 \u09a2\u09be\u0995\u09be \u09ae\u09b9\u09be\u09a8\u0997\u09b0 \u0997\u09cb\u09af\u09bc\u09c7\u09a8\u09cd\u09a6\u09be \u09aa\u09c1\u09b2\u09bf\u09b6 (\u09a1\u09bf\u09ac\u09bf)\u0964 \u099c\u09bf\u099c\u09cd\u099e\u09be\u09b8\u09be\u09ac\u09be\u09a6 \u0993 \u0989\u09a6\u09cd\u09a7\u09be\u09b0\u0995\u09c3\u09a4 \u0985\u09b8\u09cd\u09a4\u09cd\u09b0 \u098f\u09ac\u0982 \u09ac\u09bf\u09b8\u09cd\u09ab\u09cb\u09b0\u0995 \u09ac\u09bf\u09b6\u09cd\u09b2\u09c7\u09b7\u09a3 \u0995\u09b0\u09c7 \u098f\u09a6\u09c7\u09b0 \u09b8\u0995\u09b2\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09a4\u09c7\u09b9\u09b0\u09bf\u0995-\u0987-\u09a4\u09be\u09b2\u09c7\u09ac\u09be\u09a8 \u09aa\u09be\u0995\u09bf\u09b8\u09cd\u09a4\u09be\u09a8\u09c7\u09b0 (\u099f\u09bf\u099f\u09bf\u09aa\u09bf) \u09b8\u0982\u09b6\u09cd\u09b2\u09bf\u09b7\u09cd\u099f\u09a4\u09be \u09aa\u09be\u0993\u09af\u09bc\u09be \u0997\u09c7\u099b\u09c7 \u09ac\u09b2\u09c7 \u099c\u09be\u09a8\u09bf\u09af\u09bc\u09c7\u099b\u09c7 \u09a1\u09bf\u09ac\u09bf \u09aa\u09c1\u09b2\u09bf\u09b6\u09b8\u09b9 \u098f\u0995\u09be\u09a7\u09bf\u0995 \u0997\u09cb\u09af\u09bc\u09c7\u09a8\u09cd\u09a6\u09be \u09b8\u0982\u09b8\u09cd\u09a5\u09be\u0964 \u098f\u09a6\u09c7\u09b0 \u09ae\u09a7\u09cd\u09af\u09c7 \u099f\u09bf\u099f\u09bf\u09aa\u09bf \u09b8\u0982\u09b6\u09cd\u09b2\u09bf\u09b7\u09cd\u099f\u09a4\u09be\u09b0 \u09a4\u09a5\u09cd\u09af\u09c7 \u09a6\u09c7\u09b6 \u099b\u09c7\u09a1\u09bc\u09c7 \u09aa\u09be\u09b2\u09bf\u09af\u09bc\u09c7 \u09af\u09be\u0993\u09af\u09bc\u09be\u09b0 \u09aa\u09cd\u09b0\u09be\u0995\u09cd\u0995\u09be\u09b2\u09c7 \u09ac\u09bf\u09ae\u09be\u09a8\u09ac\u09a8\u09cd\u09a6\u09b0\u09c7 \u0986\u099f\u0995\u09c7 \u09a6\u09c7\u0993\u09af\u09bc\u09be \u09b9\u09af\u09bc \u0986\u09ac\u09c1 \u09ac\u0995\u09cd\u0995\u09b0\u0995\u09c7\u0964",
