  {
    "title": "\u09b8\u09cd\u09ac\u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u09ac\u09b2\u09c7\u09a8, \u201c\u0986\u09ae\u09bf \u0986\u09aa\u09a8\u09be\u09a6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09b6\u09cd\u09a8\u0997\u09c1\u09b2\u09cb \u09ac\u09c1\u099d\u09a4\u09c7 \u09aa\u09c7\u09b0\u09c7\u099b\u09bf, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u0986\u09ae\u09bf \u0993\u0987 \u09b6\u09ac\u09cd\u09a6...",
    "description": "\u09b8\u09cd\u09ac\u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u09ac\u09b2\u09c7\u09a8, \u201c\u0986\u09ae\u09bf \u0986\u09aa\u09a8\u09be\u09a6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09b6\u09cd\u09a8\u0997\u09c1\u09b2\u09cb \u09ac\u09c1\u099d\u09a4\u09c7 \u09aa\u09c7\u09b0\u09c7\u099b\u09bf, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u0986\u09ae\u09bf \u0993\u0987 \u09b6\u09ac\u09cd\u09a6\u0995\u09c7 \u09b0\u09bf\u0995\u0997\u09a8\u09be\u0987\u099c \u0995\u09b0\u09bf \u09a8\u09be\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09a6\u09c7\u09b6\u09c7 \u098f\u09b0\u0995\u09ae \u0995\u09cb\u09a8 \u09a4\u09ce\u09aa\u09b0\u09a4\u09be \u09a8\u09c7\u0987\u0964 \u0995\u09bf\u099b\u09c1 \u098f\u0995\u09cd\u09b8\u099f\u09cd\u09b0\u09bf\u09ae\u09bf\u09b8\u09cd\u099f \u0997\u09cd\u09b0\u09c1\u09aa \u09a5\u09be\u0995\u09c7\u0964 \u09aa\u09c3\u09a5\u09bf\u09ac\u09c0\u09b0 \u09b8\u09ac \u09a6\u09c7\u09b6\u09c7\u0987 \u098f\u09b0\u0995\u09ae \u098f\u0995\u099f\u09bf\u09ad \u09a5\u09be\u0995\u09c7\u0964 \u09b0\u200c\u09c7\u09a1\u09bf\u0995\u200d\u09cd\u09af\u09be\u09b2 \u0995\u09bf\u099b\u09c1 \u09ab\u09cb\u09b0\u09cd\u09b8 \u09a5\u09be\u0995\u09c7, \u09ab\u09be\u09a8\u09cd\u09a1\u09be\u09ae\u09c7\u09a8\u09cd\u099f\u09be\u09b2 \u0995\u09bf\u099b\u09c1 \u09aa\u09be\u09b0\u09cd\u099f\u09bf \u09a5\u09be\u0995\u09c7\u0964 \u098f\u0997\u09c1\u09b2\u09cb \u0986\u09ae\u09b0\u09be \u0987\u0989\u099c \u099f\u09c1, \u098f\u0997\u09c1\u09b2\u09cb \u09a5\u09be\u0995\u09c7\u0964\" \u09aa\u09cd\u09b0\u09a7\u09be\u09a8\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0\u09b0 \u0989\u09aa\u09a6\u09c7\u09b7\u09cd\u099f\u09be \u09ac\u09b2\u09b2\u09c7\u09a8, \u2018\u099c\u0999\u09cd\u0997\u09bf \u09a8\u09c7\u0987 \u098f\u099f\u09bf \u09ad\u09c1\u09b2 \u0995\u09a5\u09be\u2019 \"\u0987\u09a8\u09cd\u099f\u09c7\u09b0\u09bf\u09ae\u09c7\u09b0 \u09b8\u09ae\u09df\u09c7 \u098f\u0987 \u0986\u09b2\u09be\u09aa \u0995\u09c7\u0989 \u0995\u09c7\u0989 \u0995\u09b0\u09be\u09b0 \u099a\u09c7\u09b7\u09cd\u099f\u09be \u0995\u09b0\u09c7\u099b\u09c7 \u09af\u09c7, \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7 \u0995\u09cb\u09a8\u09cb \u099c\u0999\u09cd\u0997\u09bf \u09a8\u09c7\u0987\u0964 \u098f\u099f\u09be\u0993 \u0986\u09b0\u09c7\u0995\u099f\u09be \u098f\u0995\u09cd\u09b8\u099f\u09cd\u09b0\u09bf\u09ae\u0964 \u098f\u099f\u09be\u0993 \u09ad\u09c1\u09b2 \u0995\u09a5\u09be\u0964 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7 \u098f\u0995\u099f\u09be \u09aa\u09b0\u09cd\u09af\u09be\u09df\u09c7 \u09ae\u09bf\u09b2\u09bf\u099f\u09cd\u09af\u09be\u09a8\u09cd\u09b8\u09bf, \u099c\u0999\u09cd\u0997\u09bf\u09ac\u09be\u09a6 \u099b\u09bf\u09b2, \u0986\u099b\u09c7\u0964 \u09b8\u09c7\u099f\u09be\u0995\u09c7 \u0986\u09ae\u09b0\u09be \u0986\u09b8\u09b2\u09c7 \u0995\u09ae\u09ac\u09cd\u09af\u09be\u099f \u0995\u09b0\u09a4\u09c7 \u099a\u09be\u0987\u0964\u201d",
