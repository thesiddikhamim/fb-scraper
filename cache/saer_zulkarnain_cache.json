    "title": "\u09b2\u09be\u09ae\u09be \u0989\u09aa\u099c\u09c7\u09b2\u09be\u09b8\u09cd\u09a5 \u09b8\u09b0\u0987 \u0987\u0989\u09a8\u09bf\u09df\u09a8\u09c7 \u0985\u09ac\u09b8\u09cd\u09a5\u09bf\u09a4 \u0995\u09cb\u09af\u09bc\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09ae\u09c7\u09a5\u09a1 \u09b8\u09c7\u09a8\u09cd\u099f\u09be\u09b0\u09c7\u09b0 \u09ae\u09cc\u099c\u09be \u09ad\u09bf\u09a4\u09cd\u09a4\u09bf\u0995 \u09b8\u0995\u09b2 \u099c\u09ae...",
    "description": "\u09b2\u09be\u09ae\u09be \u0989\u09aa\u099c\u09c7\u09b2\u09be\u09b8\u09cd\u09a5 \u09b8\u09b0\u0987 \u0987\u0989\u09a8\u09bf\u09df\u09a8\u09c7 \u0985\u09ac\u09b8\u09cd\u09a5\u09bf\u09a4 \u0995\u09cb\u09af\u09bc\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09ae\u09c7\u09a5\u09a1 \u09b8\u09c7\u09a8\u09cd\u099f\u09be\u09b0\u09c7\u09b0 \u09ae\u09cc\u099c\u09be \u09ad\u09bf\u09a4\u09cd\u09a4\u09bf\u0995 \u09b8\u0995\u09b2 \u099c\u09ae\u09bf\u09b0 \u09a4\u09a5\u09cd\u09af \u09b9\u09be\u09a4\u09c7 \u098f\u09b8\u09c7\u099b\u09c7\u0964 \u09b8\u09c7\u09b8\u0995\u09b2 \u09a4\u09a5\u09cd\u09af \u09aa\u09b0\u09cd\u09af\u09be\u09b2\u09cb\u099a\u09a8\u09be \u0995\u09b0\u09c7 \u09a6\u09c7\u0996\u09be \u09af\u09be\u09df, \u09b2\u09be\u09ae\u09be \u0989\u09aa\u099c\u09c7\u09b2\u09be\u09a7\u09c0\u09a8 \u09b8\u09b0\u0987 \u0987\u0989\u09a8\u09bf\u09df\u09a8\u09c7 \u09ac\u09bf\u09a6\u09cd\u09af\u09ae\u09be\u09a8 \u0995\u09cb\u09af\u09bc\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09b8\u09c7\u09a8\u09cd\u099f\u09be\u09b0\u099f\u09bf \u09b6\u09b9\u09c0\u09a6 \u0986\u09b2 \u09ac\u09cb\u0996\u09be\u09b0\u09c0 \u0995\u09b0\u09cd\u09a4\u09c3\u0995 \u09e7\u09ef\u09ef\u09ef \u09b8\u09be\u09b2\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be \u0995\u09b0\u09be \u09b9\u09df\u0964 \u0989\u0995\u09cd\u09a4 \u09ae\u09c7\u09a1\u09bf\u099f\u09c7\u09b6\u09a8 \u09b8\u09c7\u09a8\u09cd\u099f\u09be\u09b0\u099f\u09bf\u09b0 \u09ae\u09c2\u09b2 \u0985\u0982\u09b6 \u09b8\u09b0\u0987 \u0987\u0989\u09a8\u09bf\u09df\u09a8\u09c7\u09b0 \u0985\u09a8\u09cd\u09a4\u09b0\u09cd\u0997\u09a4 \u09e9\u09e6\u09e9 \u09a8\u0982 \u09a1\u09c1\u09b2\u09c1\u099b\u09dc\u09bf \u098f\u09ac\u0982 \u0997\u099c\u09be\u09b2\u09bf\u09df\u09be \u0987\u0989\u09a8\u09bf\u09df\u09a8\u09c7\u09b0 \u09e9\u09e6\u09e6 \u09a8\u0982 \u09ac\u09dc\u09ac\u09ae\u09c1 \u09ae\u09cc\u099c\u09be\u09df \u0985\u09ac\u09b8\u09cd\u09a5\u09bf\u09a4\u0964 \u098f\u099b\u09be\u09dc\u09be\u0993 \u09ac\u09be\u09a8\u09cd\u09a6\u09b0\u09ac\u09be\u09a8 \u09b8\u09a6\u09b0 \u0987\u0989\u09a8\u09bf\u09df\u09a8\u09c7\u09b0 \u09e9\u09e7\u09ef \u09a8\u0982 \u09b0\u09be\u099c\u09ac\u09bf\u09b2\u09be \u09ae\u09cc\u099c\u09be\u09df \u09b8\u09b9\u09af\u09cb\u0997\u09c0/\u0985\u0999\u09cd\u0997\u09b8\u0982\u0997\u09a0\u09a8 \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u0995\u09cb\u09af\u09bc\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09ae\u09c7\u09a1\u09bf\u099f\u09c7\u09b6\u09a8 \u09b8\u09c7\u09a8\u09cd\u099f\u09be\u09b0\u099f\u09bf\u09b0 \u0986\u09b0\u0993 \u098f\u0995\u099f\u09bf \u09b6\u09be\u0996\u09be \u09b0\u09df\u09c7\u099b\u09c7\u0964 \u09ae\u09c2\u09b2 \u0995\u09cb\u09df\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09ab\u09be\u0989\u09a8\u09cd\u09a1\u09c7\u09b6\u09a8 \u09b9\u09a4\u09c7 \u09b0\u09be\u099c\u09ac\u09bf\u09b2\u09be \u09ae\u09cc\u099c\u09be\u09b0 \u09a6\u09c2\u09b0\u09a4\u09cd\u09ac \u0986\u09a8\u09c1\u09ae\u09be\u09a8\u09bf\u0995 \u09eb\u09e6 \u0995\u09bf\u09b2\u09cb\u09ae\u09bf\u099f\u09be\u09b0 \u098f\u09ac\u0982 \u09ac\u09be\u09a8\u09cd\u09a6\u09b0\u09ac\u09be\u09a8 \u099c\u09c7\u09b2\u09be \u09b8\u09a6\u09b0 \u09b9\u09a4\u09c7 \u09e7\u09ed \u0995\u09bf\u09b2\u09cb\u09ae\u09bf\u099f\u09be\u09b0\u0964 \u09b0\u09be\u099c\u09ac\u09bf\u09b2\u09be \u09ae\u09cc\u099c\u09be\u09af\u09bc \u0985\u09ac\u09b8\u09cd\u09a5\u09bf\u09a4 \u09ae\u09c2\u09b2 \u0995\u09cb\u09df\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09ab\u09be\u0989\u09a8\u09cd\u09a1\u09c7\u09b6\u09a8 \u098f\u09b0 \u0985\u0999\u09cd\u0997 \u09b8\u0982\u0997\u09a0\u09a8\u099f\u09bf \u0997\u09a4 \u09e7\u09ef \u09ae\u09be\u09b0\u09cd\u099a \u09e8\u09e6\u09e7\u09e8 \u09a4\u09be\u09b0\u09bf\u0996 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09bf\u09a4 \u09b9\u09df\u0964 \u0989\u0995\u09cd\u09a4 \u098f\u09b2\u09be\u0995\u09be\u09af\u09bc \u099c\u09ae\u09bf\u09b0 \u0995\u09be\u09b0\u09ac\u09be\u09b0\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u099c\u09a1\u09bc\u09bf\u09a4 \u09ac\u09cd\u09af\u0995\u09cd\u09a4\u09bf\u09ac\u09b0\u09cd\u0997, \u09a6\u09b2\u09bf\u09b2 \u09b2\u09c7\u0996\u0995 \u098f\u09ac\u0982 \u09b8\u09cd\u09a5\u09be\u09a8\u09c0\u09df\u09a6\u09c7\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u09ae\u09cc\u099c\u09be \u09b8\u09ae\u09c2\u09b9\u09c7\u09b0 \u099c\u09ae\u09bf \u09b8\u09ae\u09cd\u09aa\u09b0\u09cd\u0995\u09c7 \u09af\u09c7\u09b8\u0995\u09b2 \u09a4\u09a5\u09cd\u09af \u09aa\u09be\u0993\u09df\u09be \u09af\u09be\u09df \u09a4\u09be \u0985\u09a8\u09c7\u0995\u099f\u09be \u098f\u09ae\u09a8\u0964 \u098f \u09b8\u0995\u09b2 \u098f\u09b2\u09be\u0995\u09be\u09df \u09b0\u09be\u09b8\u09cd\u09a4\u09be\u09b0 \u09aa\u09be\u09b0\u09cd\u09b6\u09cd\u09ac\u09ac\u09b0\u09cd\u09a4\u09c0 \u09b8\u09ae\u09a4\u09b2 \u09ad\u09c2\u09ae\u09bf\u0995\u09c7 '\u09aa\u09cd\u09b0\u09a5\u09ae \u09b6\u09cd\u09b0\u09c7\u09a3\u09c0\u09b0' \u099c\u09ae\u09bf \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u0997\u09a8\u09cd\u09af \u0995\u09b0\u09be \u09b9\u09df\u0964 \u09b8\u09ae\u09a4\u09b2 \u098f\u09ac\u0982 \u09b8\u09be\u09ae\u09be\u09a8\u09cd\u09af \u0989\u099a\u09c1-\u09a8\u09bf\u099a\u09c1 \u099f\u09bf\u09b2\u09be\u09b0 \u09b8\u09ae\u09a8\u09cd\u09ac\u09df\u09c7 \u09ac\u09bf\u09a6\u09cd\u09af\u09ae\u09be\u09a8 \u09ad\u09c2\u09ae\u09bf\u0995\u09c7 '\u09a6\u09cd\u09ac\u09bf\u09a4\u09c0\u09df \u09b6\u09cd\u09b0\u09c7\u09a3\u09c0\u09b0' \u099c\u09ae\u09bf \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u0997\u09a8\u09cd\u09af \u0995\u09b0\u09be \u09b9\u09df\u0964 \u09aa\u09be\u09b9\u09be\u09dc/\u099f\u09bf\u09b2\u09be\u0995\u09c7 '\u09a4\u09c3\u09a4\u09c0\u09df \u09b6\u09cd\u09b0\u09c7\u09a3\u09c0\u09b0' \u099c\u09ae\u09bf \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u0997\u09a8\u09cd\u09af \u0995\u09b0\u09be \u09b9\u09df\u0964 \u09a1\u09c1\u09b2\u09c1\u099b\u09dc\u09bf \u09ae\u09cc\u099c\u09be\u09df \u09aa\u09cd\u09b0\u09a4\u09bf \u098f\u0995\u09b0 \u099c\u09ae\u09bf\u09b0 \u0986\u09a8\u09c1\u09ae\u09be\u09a8\u09bf\u0995 \u09ae\u09c2\u09b2\u09cd\u09af-\u09eb,\u09e6\u09e6,\u09e6\u09e6\u09e6/-\u09a5\u09c7\u0995\u09c7 \u09eb,\u09eb\u09e6,\u09e6\u09e6\u09e6/- \u099f\u09be\u0995\u09be\u0964 \u09ac\u09dc\u09ac\u09ae\u09c1 \u09ae\u09cc\u099c\u09be\u09df \u09aa\u09cd\u09b0\u09a4\u09bf \u098f\u0995\u09b0 \u099c\u09ae\u09bf\u09b0 \u0986\u09a8\u09c1\u09ae\u09be\u09a8\u09bf\u0995 \u09ae\u09c2\u09b2\u09cd\u09af-\u09ea,\u09e6\u09e6,\u09e6\u09e6\u09e6/-\u09a5\u09c7\u0995\u09c7 \u09ea,\u09eb\u09e6,\u09e6\u09e6\u09e6/-\u099f\u09be\u0995\u09be\u0964 \u09b0\u09be\u099c\u09ac\u09bf\u09b2\u09be \u09ae\u09cc\u099c\u09be\u09df \u09aa\u09cd\u09b0\u09a4\u09bf \u098f\u0995\u09b0 \u099c\u09ae\u09bf\u09b0 \u0986\u09a8\u09c1\u09ae\u09be\u09a8\u09bf\u0995 \u09ae\u09c2\u09b2\u09cd\u09af-\u09e7\u09eb,\u09e6\u09e6,\u09e6\u09e6\u09e6/-\u09a5\u09c7\u0995\u09c7 \u09e7\u09ec,\u09e6\u09e6,\u09e6\u09e6\u09e6/-\u099f\u09be\u0995\u09be\u0964 \u098f\u0987 \u09b8\u09c7\u09a8\u09cd\u099f\u09be\u09b0\u099f\u09bf\u09b0 \u0985\u09a7\u09bf\u0995\u09be\u0982\u09b6 \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09be\u09b0\u09cd\u09a1 \u099c\u09ae\u09bf \u09a6\u09cd\u09ac\u09bf\u09a4\u09c0\u09af\u09bc \u09b6\u09cd\u09b0\u09c7\u09a3\u09c0\u09b0 \u0985\u09a8\u09cd\u09a4\u09b0\u09cd\u0997\u09a4 \u09af\u09be \u0995\u09cb\u09af\u09bc\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09ab\u09be\u0989\u09a8\u09cd\u09a1\u09c7\u09b6\u09a8 \u09aa\u09b0\u09bf\u099a\u09be\u09b2\u09a8\u09be\u09b0 \u09b8\u09be\u09a5\u09c7 \u09af\u09c1\u0995\u09cd\u09a4 \u09b6\u09b9\u09c0\u09a6 \u0986\u09b2 \u09ac\u09cb\u0996\u09be\u09b0\u09c0 \u0993 \u09a4\u09be\u09b0 \u09b8\u09cd\u09a4\u09cd\u09b0\u09c0\u09b0 \u09a8\u09be\u09ae\u09c7 \u0995\u09cd\u09b0\u09df \u0995\u09b0\u09be \u09b9\u09df\u09c7\u099b\u09c7\u0964 \u098f \u09aa\u09b0\u09cd\u09af\u09a8\u09cd\u09a4 \u09ec\u09ea\u09e6.\u09ef\u09e9 \u098f\u0995\u09b0 \u099c\u09ae\u09bf\u09b0 \u09b8\u09a8\u09cd\u09a7\u09be\u09a8 \u09aa\u09be\u0993\u09af\u09bc\u09be \u0997\u09c7\u099b\u09c7 (\u09a1\u09c1\u09b2\u09c1\u099b\u09dc\u09bf \u09ae\u09cc\u099c\u09be-\u09e9\u09ec\u09e9.\u09e9\u09e9, \u09ac\u09dc\u09ac\u09ae\u09c1 \u09ae\u09cc\u099c\u09be-\u09e8\u09ea\u09ed.\u09ee\u09e6 \u0993 \u09b0\u09be\u099c\u09ac\u09bf\u09b2\u09be \u09ae\u09cc\u099c\u09be-\u09e8\u09ef.\u09ee\u09e6 \u098f\u0995\u09b0) \u09ac\u09c7\u09b6 \u0995\u09bf\u099b\u09c1 \u099c\u09ae\u09bf\u09b0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u099c\u099f\u09bf\u09b2\u09a4\u09be \u09a8\u09bf\u09df\u09c7 \u09ae\u09be\u09ae\u09b2\u09be \u099a\u09b2\u09ae\u09be\u09a8 \u09b0\u09df\u09c7\u099b\u09c7, \u0986\u09b0 \u098f\u09b8\u09ac \u099c\u09ae\u09bf\u09b0 \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8 \u09ac\u09be\u099c\u09be\u09b0 \u09ae\u09c2\u09b2\u09cd\u09af \u09ac\u09be\u099c\u09be\u09b0 \u09ae\u09c2\u09b2\u09cd\u09af \u09e9\u09ea,\u09e6\u09e6,\u09e6\u09e6,\u09e6\u09e6\u09e6/-(\u099a\u09cc\u09a4\u09cd\u09b0\u09bf\u09b6 \u0995\u09cb\u099f\u09bf) \u099f\u09be\u0995\u09be, \u09b9\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 \u09ac\u09b2\u09c7 \u09b8\u09cd\u09a5\u09be\u09a8\u09c0\u09af\u09bc \u09a6\u09b2\u09bf\u09b2 \u09b2\u09c7\u0996\u0995 \u0993 \u099c\u09ae\u09bf\u09b0 \u0995\u09be\u09b0\u09ac\u09be\u09b0\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09af\u09c1\u0995\u09cd\u09a4 \u09ac\u09cd\u09af\u0995\u09cd\u09a4\u09bf\u09b0\u09be \u09ae\u09a4\u09be\u09ae\u09a4 \u09a6\u09bf\u09df\u09c7\u099b\u09c7\u09a8\u0964 \u09a4\u09be\u09b0\u09be \u09a6\u09be\u09ac\u09bf \u0995\u09b0\u09c7\u099b\u09c7\u09a8 \u09ae\u09cc\u099c\u09be \u09ad\u09bf\u09a4\u09cd\u09a4\u09bf\u0995 \u099c\u09ae\u09bf\u09b0 \u09ae\u09c2\u09b2\u09cd\u09af\u09c7\u09b0 \u09aa\u09be\u09b0\u09cd\u09a5\u0995\u09cd\u09af\u09c7\u09b0 \u0995\u09be\u09b0\u09a3\u09c7 \u09ae\u09c2\u09b2\u09cd\u09af\u09c7\u09b0 \u09a4\u09be\u09b0\u09a4\u09ae\u09cd\u09af \u09b9\u09af\u09bc, \u09af\u09c7\u09ae\u09a8 \u09a1\u09c1\u09b2\u09c1\u099b\u09dc\u09bf \u09ae\u09cc\u099c\u09be\u09b0 \u099c\u09ae\u09bf \u09aa\u09be\u0981\u0995\u09be \u09b0\u09be\u09b8\u09cd\u09a4\u09be\u09b0 \u09aa\u09be\u09b0\u09cd\u09b6\u09cd\u09ac\u09ac\u09b0\u09cd\u09a4\u09c0 \u09b9\u0993\u09df\u09be\u09df \u098f\u09ac\u0982 \u09ac\u09b8\u09a4\u09ac\u09be\u09dc\u09c0 \u09a8\u09bf\u09b0\u09cd\u09ae\u09be\u09a3\u09c7 \u09b8\u09c1\u09ac\u09bf\u09a7\u09be \u09a5\u09be\u0995\u09be\u09df \u0989\u0995\u09cd\u09a4 \u099c\u09ae\u09bf\u09b0 \u09ae\u09c2\u09b2\u09cd\u09af \u09a4\u09c1\u09b2\u09a8\u09be\u09ae\u09c2\u09b2\u0995\u09ad\u09be\u09ac\u09c7 \u09ac\u09c7\u09b6\u09c0\u0964 \u09ac\u09dc\u09ac\u09ae\u09c1 \u09ae\u09cc\u099c\u09be\u09b0 \u099c\u09ae\u09bf \u09aa\u09be\u0981\u0995\u09be \u09b0\u09be\u09b8\u09cd\u09a4\u09be \u09b9\u09a4\u09c7 \u09a6\u09c2\u09b0\u09c7 \u098f\u09ac\u0982 \u09af\u09be\u09a4\u09be\u09df\u09be\u09a4 \u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be \u0995\u09bf\u099b\u09c1\u099f\u09be \u0985\u09a8\u09c1\u09a8\u09cd\u09a8\u09a4 \u09b9\u0993\u09df\u09be\u09df \u099c\u09ae\u09bf\u09b0 \u09ae\u09c2\u09b2\u09cd\u09af \u09a4\u09c1\u09b2\u09a8\u09be\u09ae\u09c2\u09b2\u0995\u09ad\u09be\u09ac\u09c7 \u0995\u09ae, \u0986\u09ac\u09be\u09b0 \u09b0\u09be\u099c\u09ac\u09bf\u09b2\u09be \u09ae\u09cc\u099c\u09be \u09ac\u09be\u09a8\u09cd\u09a6\u09b0\u09ac\u09be\u09a8 \u099c\u09c7\u09b2\u09be \u09b8\u09a6\u09b0\u09c7\u09b0 \u09a8\u09bf\u0995\u099f\u09ac\u09b0\u09cd\u09a4\u09c0 \u098f\u09ac\u0982 \u09b8\u09a6\u09b0 \u0987\u0989\u09a8\u09bf\u09af\u09bc\u09a8\u09c7\u09b0 \u0985\u09a8\u09cd\u09a4\u09b0\u09cd\u0997\u09a4 \u09b9\u0993\u09df\u09be\u09df \u099c\u09ae\u09bf\u09b0 \u09ae\u09c2\u09b2\u09cd\u09af \u09a1\u09c1\u09b2\u09c1\u099b\u09dc\u09bf \u098f\u09ac\u0982 \u09ac\u09dc\u09ac\u09ae\u09c1 \u09ae\u09cc\u099c\u09be \u09b9\u09a4\u09c7 \u0985\u09a8\u09c7\u0995 \u09ac\u09c7\u09b6\u09c0\u0964 \u0985\u09ac\u09b6\u09cd\u09af \u09b8\u09b0\u09c7\u099c\u09ae\u09bf\u09a8\u09c7 \u09aa\u09b0\u09bf\u09a6\u09b0\u09cd\u09b6\u09a8 \u0995\u09b0\u09c7 \u0995\u09cb\u09af\u09bc\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09ab\u09be\u0989\u09a8\u09cd\u09a1\u09c7\u09b6\u09a8 \u0995\u09b0\u09cd\u09a4\u09c3\u0995 \u0985\u09a7\u09bf\u0997\u09cd\u09b0\u09b9\u09a3\u0995\u09c3\u09a4 \u099c\u09ae\u09bf \u09aa\u09cd\u09b0\u09be\u09df \u09e9\u09e6\u09e6\u09e6 \u098f\u0995\u09b0 \u09ac\u09be \u09a4\u09be\u09b0 \u099a\u09be\u0987\u09a4\u09c7 \u09ac\u09c7\u09b6\u09bf \u09ac\u09b2\u09c7 \u09a7\u09be\u09b0\u09a3\u09be \u0995\u09b0\u09be \u09af\u09be\u09df\u0964 \u098f\u09b0 \u09ae\u09a7\u09cd\u09af\u09c7 \u09b8\u09b0\u0995\u09be\u09b0\u09c0 \u099c\u09ae\u09bf \u098f\u09ac\u0982 \u0985\u09a8\u09c7\u0995\u09c7\u09b0 \u09ac\u09cd\u09af\u0995\u09cd\u09a4\u09bf\u0997\u09a4 \u09b8\u09ae\u09cd\u09aa\u09a4\u09cd\u09a4\u09bf\u0993 \u09b0\u09df\u09c7\u099b\u09c7, \u09af\u09be \u09a8\u09bf\u09df\u09c7 \u09b8\u09cd\u09a5\u09be\u09a8\u09c0\u09af\u09bc \u09ac\u09be\u09b8\u09bf\u09a8\u09cd\u09a6\u09be\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u0995\u09cb\u09af\u09bc\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09ab\u09be\u0989\u09a8\u09cd\u09a1\u09c7\u09b6\u09a8\u09c7\u09b0 \u09ac\u09bf\u09b0\u09cb\u09a7 \u09a6\u09c0\u09b0\u09cd\u0998\u09a6\u09bf\u09a8\u09c7\u09b0\u0964 \u09b8\u09cd\u09aa\u09b0\u09cd\u09b6\u0995\u09be\u09a4\u09b0 \u098f\u0987 \u098f\u09b2\u09be\u0995\u09be\u09df \u0985\u09a8\u09cd\u09af \u0995\u09cb\u09a8 \u09ac\u09cd\u09af\u0995\u09cd\u09a4\u09bf \u09ac\u09be \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be\u09a8\u09c7\u09b0 \u09a6\u0996\u09b2\u09c7 \u098f\u09a4 \u09ac\u09bf\u09aa\u09c1\u09b2 \u09aa\u09b0\u09bf\u09ae\u09be\u09a3 \u099c\u09ae\u09bf \u09a8\u09c7\u0987 \u09ac\u09b2\u09c7\u0993 \u099c\u09be\u09a8\u09be \u0997\u09c7\u099b\u09c7\u0964 \u0995\u09bf\u09ad\u09be\u09ac\u09c7 \u09ac\u09be \u0995\u09be\u09a6\u09c7\u09b0 \u09b8\u09b9\u09be\u09af\u09bc\u09a4\u09be\u09af\u09bc \u09b6\u09b9\u09c0\u09a6 \u0986\u09b2 \u09ac\u09cb\u0996\u09be\u09b0\u09c0 \u098f\u09b8\u09ac \u099c\u09ae\u09bf \u0995\u09bf\u09a8\u09c7\u099b\u09c7\u09a8, \u09b8\u09c7\u09b8\u09ac \u09ac\u09bf\u09b7\u09af\u09bc\u09c7 \u0996\u09cb\u0981\u099c \u099a\u09b2\u099b\u09c7\u0964 \u0989\u09b2\u09cd\u09b2\u09c7\u0996\u09cd\u09af \u099a\u09b2\u09ae\u09be\u09a8 \u099c\u09cd\u09ac\u09be\u09b2\u09be\u09a8\u09c0 \u09b8\u0982\u0995\u099f\u09c7\u09b0 \u09ae\u09be\u099d\u09c7\u0993 \u0995\u09cb\u09af\u09bc\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09b2\u09be\u09ae\u09be \u09b8\u09c7\u09a8\u09cd\u099f\u09be\u09b0\u09c7 \u09ac\u09bf\u09aa\u09c1\u09b2 \u09aa\u09b0\u09bf\u09ae\u09be\u09a3 \u099c\u09cd\u09ac\u09be\u09b2\u09be\u09a8\u09bf \u09a4\u09c7\u09b2 \u09ae\u099c\u09c1\u09a6 \u0995\u09b0\u09be \u09b9\u09df\u09c7\u099b\u09c7 \u09ac\u09b2\u09c7 \u09ac\u09bf\u09b6\u09cd\u09ac\u09b8\u09cd\u09a4 \u09b8\u09c2\u09a4\u09cd\u09b0\u09c7 \u099c\u09be\u09a8\u09be \u0997\u09c7\u099b\u09c7 (\u099b\u09ac\u09bf \u09b8\u0982\u09af\u09c1\u0995\u09cd\u09a4)\u0964",
