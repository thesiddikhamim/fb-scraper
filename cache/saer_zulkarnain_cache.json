[
  {
    "title": "\u09a8\u09b0\u09b8\u09bf\u0982\u09a6\u09c0\u09b0 \u09b0\u09be\u09af\u09bc\u09aa\u09c1\u09b0\u09be \u0989\u09aa\u099c\u09c7\u09b2\u09be\u09b0 \u09a6\u09c1\u09b0\u09cd\u0997\u09ae \u099a\u09b0\u09be\u099e\u09cd\u099a\u09b2\u09c7 \u09b8\u0982\u0997\u09a0\u09bf\u09a4 \u09b9\u09df\u09c7\u099b\u09c7 \u09b8\u09cd\u09ac\u09af\u09bc\u0982\u0995\u09cd\u09b0\u09bf\u09af\u09bc \u0985\u09b8\u09cd\u09a4\u09cd\u09b0\u09c7 \u09b8\u099c\u09cd\u099c...",
    "description": "\u09a8\u09b0\u09b8\u09bf\u0982\u09a6\u09c0\u09b0 \u09b0\u09be\u09af\u09bc\u09aa\u09c1\u09b0\u09be \u0989\u09aa\u099c\u09c7\u09b2\u09be\u09b0 \u09a6\u09c1\u09b0\u09cd\u0997\u09ae \u099a\u09b0\u09be\u099e\u09cd\u099a\u09b2\u09c7 \u09b8\u0982\u0997\u09a0\u09bf\u09a4 \u09b9\u09df\u09c7\u099b\u09c7 \u09b8\u09cd\u09ac\u09af\u09bc\u0982\u0995\u09cd\u09b0\u09bf\u09af\u09bc \u0985\u09b8\u09cd\u09a4\u09cd\u09b0\u09c7 \u09b8\u099c\u09cd\u099c\u09bf\u09a4 \u09aa\u09cd\u09b0\u09be\u09df \u09e8\u09e6\u09e6 \u09b8\u09a8\u09cd\u09a4\u09cd\u09b0\u09be\u09b8\u09c0\u09b0 \u098f\u0995 \u09ac\u09be\u09b9\u09bf\u09a8\u09c0\u0964 \u099c\u09c1\u09b2\u09be\u0987-\u0986\u0997\u09b7\u09cd\u099f \u09e8\u09e6\u09e8\u09ea \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8 \u099a\u09b2\u09be\u0995\u09be\u09b2\u09c0\u09a8 \u0986\u0987\u09a8\u09b6\u09c3\u0999\u09cd\u0996\u09b2\u09be \u09ac\u09be\u09b9\u09bf\u09a8\u09c0\u09b0 \u09b2\u09c1\u099f \u09b9\u0993\u09af\u09bc\u09be \u0985\u09b8\u09cd\u09a4\u09cd\u09b0\u09c7\u09b0 \u0995\u09bf\u099b\u09c1 \u0985\u0982\u09b6 \u098f\u09a6\u09c7\u09b0 \u09b9\u09be\u09a4\u09c7 \u09aa\u09cc\u0981\u099b\u09c7\u099b\u09c7, \u09af\u09be \u09a8\u09bf\u09df\u09c7 \u09a8\u09bf\u099c\u09b8\u09cd\u09ac \u098f\u0995 \u0985\u09aa\u09b0\u09be\u09a7 \u099a\u0995\u09cd\u09b0 \u09a4\u09c8\u09b0\u09bf \u0995\u09b0\u09c7\u099b\u09c7 \u099a\u09bf\u09b9\u09cd\u09a8\u09bf\u09a4 \u0995\u09bf\u099b\u09c1 \u09b8\u09cd\u09a5\u09be\u09a8\u09c0\u09af\u09bc \u09b8\u09a8\u09cd\u09a4\u09cd\u09b0\u09be\u09b8\u09c0 \u0986\u09b0 \u098f\u09a4\u09c7 \u09ad\u09bf\u09a1\u09bc\u09c7\u099b\u09c7 \u09a8\u09bf\u09b2\u0995\u09cd\u09b7\u09be, \u09ae\u09bf\u09b0\u09cd\u099c\u09be\u09b0\u099a\u09b0 \u09b8\u09b9 \u0986\u09b0\u09cb \u0995\u09bf\u099b\u09c1 \u09a6\u09c1\u09b0\u09cd\u0997\u09ae \u099a\u09b0\u09be\u099e\u09cd\u099a\u09b2\u09c7\u09b0 \u0985\u09aa\u09b0\u09be\u09a7\u09c0\u09b0\u09be\u0964 \u09eb \u0986\u0997\u09b7\u09cd\u099f \u09aa\u09b0\u09ac\u09b0\u09cd\u09a4\u09c0 \u09b8\u09ae\u09df\u09c7 \u09ae\u09c7\u0998\u09a8\u09be \u09a8\u09a6\u09c0\u09b0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u09aa\u09df\u09c7\u09a8\u09cd\u099f\u09c7 \u09a1\u09cd\u09b0\u09c7\u099c\u09be\u09b0 \u09ac\u09b8\u09bf\u09af\u09bc\u09c7 \u0985\u09ac\u09c8\u09a7\u09ad\u09be\u09ac\u09c7 \u09ac\u09be\u09b2\u09bf \u0989\u09a4\u09cd\u09a4\u09cb\u09b2\u09a8\u09c7\u09b0 \u0995\u09be\u099c\u09c7 \u09b2\u09bf\u09aa\u09cd\u09a4 \u09b9\u09af\u09bc\u09c7 \u0985\u09a4\u09cd\u09b0 \u098f\u09b2\u09be\u0995\u09be\u09b0 \u09ad\u09df\u09be\u09ac\u09b9 \u0995\u09cd\u09b7\u09a4\u09bf \u09b8\u09be\u09a7\u09a3 \u0995\u09b0\u09c7\u099b\u09c7 \u098f\u0987 \u09b8\u09a8\u09cd\u09a4\u09cd\u09b0\u09be\u09b8\u09c0\u09b0\u09be\u0964 \u09a4\u09be\u09a6\u09c7\u09b0 \u09ac\u09c7\u09aa\u09b0\u09cb\u09af\u09bc\u09be \u0995\u09be\u09b0\u09cd\u09af\u0995\u09b2\u09be\u09aa\u09c7 \u0987\u09a4\u09cb\u09ae\u09a7\u09cd\u09af\u09c7\u0987 \u09ae\u09bf\u09b0\u09cd\u099c\u09be\u09b0\u099a\u09b0 \u0987\u0989\u09a8\u09bf\u09af\u09bc\u09a8\u09c7\u09b0 \u09b6\u09a4\u09be\u09a7\u09bf\u0995 \u09ac\u09b8\u09a4\u09ac\u09be\u09a1\u09bc\u09bf, \u09ab\u09b8\u09b2\u09bf \u099c\u09ae\u09bf, \u09ac\u09cd\u09af\u09ac\u09b8\u09be \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be\u09a8 \u09a8\u09a6\u09c0\u0997\u09b0\u09cd\u09ad\u09c7 \u09ac\u09bf\u09b2\u09c0\u09a8 \u09b9\u09af\u09bc\u09c7 \u0997\u09c7\u099b\u09c7\u0964 \u098f\u09a6\u09c7\u09b0 \u09b8\u09a8\u09cd\u09a4\u09cd\u09b0\u09be\u09b8\u09c0 \u0995\u09be\u09b0\u09cd\u09af\u0995\u09b2\u09be\u09aa\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u09ac\u09be\u09a6 \u0995\u09b0\u09a4\u09c7 \u0997\u09bf\u09df\u09c7 \u0986\u0995\u09cd\u09b0\u09be\u09a8\u09cd\u09a4 \u09b9\u09af\u09bc\u09c7\u099b\u09c7\u09a8 \u09b8\u09cd\u09a5\u09be\u09a8\u09c0\u09af\u09bc \u09ac\u09be\u09b8\u09bf\u09a8\u09cd\u09a6\u09be\u09b0\u09be \u2014 \u098f\u0987 \u099c\u09a8\u09aa\u09a6\u09c7\u09b0 \u09ae\u09be\u09a8\u09c1\u09b7 \u098f\u09a6\u09c7\u09b0 \u0995\u09be\u099b\u09c7 \u098f\u0995\u09aa\u09cd\u09b0\u0995\u09be\u09b0 \u099c\u09bf\u09ae\u09cd\u09ae\u09bf \u09b9\u09df\u09c7\u0987 \u09a6\u09bf\u09a8 \u0995\u09be\u099f\u09be\u099a\u09cd\u099b\u09c7\u09a8 \u09ac\u09b2\u09c7 \u09a4\u09be\u0981\u09b0\u09be \u099c\u09be\u09a8\u09bf\u09af\u09bc\u09c7\u099b\u09c7\u09a8\u0964 \u098f\u0987 \u0985\u09aa\u09b0\u09be\u09a7 \u099a\u0995\u09cd\u09b0\u09c7\u09b0 \u09ae\u09c2\u09b2 \u09b9\u09cb\u09a4\u09be \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u099a\u09bf\u09b9\u09cd\u09a8\u09bf\u09a4 \u0995\u09b0\u09be \u0997\u09c7\u099b\u09c7 \u099c\u09a8\u09c8\u0995 \u09ae\u09bf\u09a8\u09cd\u099f\u09c1 \u0995\u09ae\u09bf\u09b6\u09a8\u09be\u09b0, \u0986\u09ab\u099c\u09be\u09b2 \u09ae\u09c7\u09ae\u09cd\u09ac\u09be\u09b0 (\u09ab\u0995\u09bf\u09b0\u09c7\u09b0 \u099a\u09b0, \u09b6\u09cd\u09b0\u09c0\u09a8\u0997\u09b0 \u0987\u0989\u09a8\u09bf\u09af\u09bc\u09a8), \u09a8\u09c2\u09b0\u09c1\u09b2 \u0987\u09b8\u09b2\u09be\u09ae (\u09ae\u09bf\u09b0\u09cd\u099c\u09be\u09b0\u099a\u09b0)'\u0995\u09c7, \u098f\u0987 \u099a\u0995\u09cd\u09b0\u09c7\u09b0 \u0985\u09b8\u09cd\u09a4\u09cd\u09b0 \u0993 \u09ae\u09be\u09a6\u0995\u09c7\u09b0 \u09a8\u09bf\u09af\u09bc\u09a8\u09cd\u09a4\u09cd\u09b0\u09a3 \u0995\u09b0\u09c7\u09a8 \u0986\u09ac\u09bf\u09a6 \u09b9\u09be\u09b8\u09be\u09a8 \u09b0\u09c1\u09ac\u09c7\u09b2, \u0998\u09cb\u09a1\u09bc\u09be \u0995\u09be\u09ae\u09be\u09b2, \u0986\u099c\u09be\u09a8 \u099a\u09cc\u09a7\u09c1\u09b0\u09c0 (\u09b6\u09cd\u09b0\u09c0\u09a8\u0997\u09b0 \u0987\u0989\u09a8\u09bf\u09af\u09bc\u09a8\u09c7\u09b0 \u09b8\u09be\u09ac\u09c7\u0995 \u099a\u09c7\u09af\u09bc\u09be\u09b0\u09ae\u09cd\u09af\u09be\u09a8), \u0986\u09ac\u09c1 \u09a8\u09c2\u09b0 \u099a\u09c7\u09af\u09bc\u09be\u09b0\u09ae\u09cd\u09af\u09be\u09a8 (\u09af\u09bf\u09a8\u09bf \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8\u09c7\u09b0 \u0986\u0997\u09c7 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf\u09a4\u09c7 \u09af\u09cb\u0997 \u09a6\u09bf\u09af\u09bc\u09c7\u099b\u09c7\u09a8), \u0986\u09b6\u09b0\u09be\u09ab\u09c1\u09b2 \u09b9\u0995 (\u09ac\u09be\u0981\u09b6\u0997\u09be\u09a1\u09bc\u09bf \u0987\u0989\u09a8\u09bf\u09af\u09bc\u09a8\u09c7\u09b0 \u09b8\u09be\u09ac\u09c7\u0995 \u099a\u09c7\u09af\u09bc\u09be\u09b0\u09ae\u09cd\u09af\u09be\u09a8), \u09b0\u09be\u09a4\u09c1\u09b2 \u09b9\u09be\u09b8\u09be\u09a8 (\u09ac\u09be\u0981\u09b6\u0997\u09be\u09a1\u09bc\u09bf \u0987\u0989\u09a8\u09bf\u09af\u09bc\u09a8\u09c7\u09b0 \u09b8\u09be\u09ac\u09c7\u0995 \u099a\u09c7\u09af\u09bc\u09be\u09b0\u09ae\u09cd\u09af\u09be\u09a8), \u09b9\u09be\u09b0\u09c1\u09a8 \u09ae\u09bf\u09df\u09be, \u09a8\u099c\u09b0\u09c1\u09b2 \u0987\u09b8\u09b2\u09be\u09ae, \u09ae\u09cb\u0983 \u09b9\u09be\u09a8\u09cd\u09a8\u09be \u09b8\u09b9 \u0986\u09b0\u09cb \u09b6\u09a4\u09be\u09a7\u09bf\u0995 \u09b8\u09a6\u09b8\u09cd\u09af\u0964 \u099c\u09be\u09a8\u09be \u0997\u09c7\u099b\u09c7 \u09af\u09c7, \u0985\u09ac\u09c8\u09a7\u09ad\u09be\u09ac\u09c7 \u09ac\u09be\u09b2\u09c1 \u0989\u09a4\u09cd\u09a4\u09cb\u09b2\u09a8\u09c7\u09b0 \u09aa\u09be\u09b6\u09be\u09aa\u09be\u09b6\u09bf \u098f\u0987 \u099a\u0995\u09cd\u09b0 \u09a8\u09cc\u09aa\u09a5 \u09ac\u09cd\u09af\u09ac\u09b9\u09be\u09b0 \u0995\u09b0\u09c7 \u09ae\u09be\u09a6\u0995 \u0995\u09be\u09b0\u09ac\u09be\u09b0 \u0993 \u0985\u09b8\u09cd\u09a4\u09cd\u09b0\u09c7\u09b0 \u09ac\u09cd\u09af\u09ac\u09b8\u09be\u09a4\u09c7\u0993 \u09af\u09c1\u0995\u09cd\u09a4 \u09b9\u09df\u09c7\u099b\u09c7\u0964 \u09a6\u09cd\u09b0\u09c1\u09a4 \u098f\u0987 \u0985\u09aa\u09b0\u09be\u09a7\u09c0\u09a6\u09c7\u09b0 \u09ae\u09c2\u09b2\u09cb\u09ce\u09aa\u09be\u099f\u09a8\u09c7 \u09af\u09a5\u09be\u09af\u09a5 \u09aa\u09a6\u0995\u09cd\u09b7\u09c7\u09aa \u0997\u09cd\u09b0\u09b9\u09a3 \u099c\u09b0\u09c1\u09b0\u09bf\u0964",
