    "title": "\u09ac\u09be\u09a8\u09cd\u09a6\u09b0\u09ac\u09be\u09a8\u09c7\u09b0 \u09b2\u09be\u09ae\u09be\u09df \u0985\u09ac\u09b8\u09cd\u09a5\u09bf\u09a4 \u0995\u09cb\u09af\u09bc\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09ab\u09be\u0989\u09a8\u09cd\u09a1\u09c7\u09b6\u09a8\u09c7\u09b0 \u09ad\u09c7\u09a4\u09b0 \u09b8\u09ae\u09cd\u09aa\u09cd\u09b0\u09a4\u09bf \u098f\u0995\u099f\u09bf \u09a6\u09cd\u09ac\u09bf\u09a4\u09b2 '\u09a7\u09cd\u09af\u09be...",
    "description": "\u09ac\u09be\u09a8\u09cd\u09a6\u09b0\u09ac\u09be\u09a8\u09c7\u09b0 \u09b2\u09be\u09ae\u09be\u09df \u0985\u09ac\u09b8\u09cd\u09a5\u09bf\u09a4 \u0995\u09cb\u09af\u09bc\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09ab\u09be\u0989\u09a8\u09cd\u09a1\u09c7\u09b6\u09a8\u09c7\u09b0 \u09ad\u09c7\u09a4\u09b0 \u09b8\u09ae\u09cd\u09aa\u09cd\u09b0\u09a4\u09bf \u098f\u0995\u099f\u09bf \u09a6\u09cd\u09ac\u09bf\u09a4\u09b2 '\u09a7\u09cd\u09af\u09be\u09a8\u0998\u09b0' \u09a8\u09bf\u09b0\u09cd\u09ae\u09be\u09a3 \u0995\u09b0\u09be \u09b9\u09df\u09c7\u099b\u09c7\u0964 \u09b8\u0982\u09af\u09c1\u0995\u09cd\u09a4 \u099b\u09ac\u09bf\u099f\u09bf\u09a4\u09c7 \u09b2\u0995\u09cd\u09b7\u09cd\u09af \u0995\u09b0\u09c1\u09a8 \u09e8\u09e6\u09e8\u09e8 \u09b8\u09be\u09b2\u09c7\u09b0 \u09e7\u09eb \u09ab\u09c7\u09ac\u09cd\u09b0\u09c1\u09af\u09bc\u09be\u09b0\u09c0 \u09a5\u09c7\u0995\u09c7 \u09ea \u09ae\u09be\u09b0\u09cd\u099a \u09aa\u09b0\u09cd\u09af\u09a8\u09cd\u09a4 \u098f\u0987 \u09a7\u09cd\u09af\u09be\u09a8\u0998\u09b0 \u09a8\u09bf\u09b0\u09cd\u09ae\u09be\u09a3\u09c7\u09b0 \u0985\u09b0\u09cd\u09a5 \u09b8\u0982\u0997\u09cd\u09b0\u09b9 \u0995\u09b0\u09be \u09b9\u09df \u2014 \u09a6\u09c7\u09b6\u09c7\u09b0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u098f\u09b2\u09be\u0995\u09be \u09a5\u09c7\u0995\u09c7 \u09e8\u09e7 \u0995\u09cb\u099f\u09bf \u099f\u09be\u0995\u09be \u0989\u09a4\u09cd\u09a4\u09cb\u09b2\u09a8 \u0995\u09b0\u09be \u09b9\u09df \u09ab\u09be\u0989\u09a8\u09cd\u09a1\u09c7\u09b6\u09a8\u09c7\u09b0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u09b6\u09be\u0996\u09be\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7\u0964 \u09ab\u09be\u0989\u09a8\u09cd\u09a1\u09c7\u09b6\u09a8\u099f\u09bf \u09aa\u09b0\u09bf\u099a\u09be\u09b2\u09a8\u09be\u09b0 \u09b8\u09be\u09a5\u09c7 \u098f\u0995\u09b8\u09ae\u09af\u09bc \u09af\u09c1\u0995\u09cd\u09a4 \u099b\u09bf\u09b2\u09c7\u09a8 \u098f\u09ae\u09a8 \u0995\u09df\u09c7\u0995\u099c\u09a8 \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u0995\u09b0\u09c7\u099b\u09c7\u09a8 \u09af\u09c7 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u0989\u099b\u09bf\u09b2\u09be\u09af\u09bc \u0985\u09a8\u09c1\u09b8\u09be\u09b0\u09c0 \u09ac\u09be \u09ad\u0995\u09cd\u09a4\u09a6\u09c7\u09b0 \u09a8\u09bf\u0995\u099f \u09b9\u09a4\u09c7 \u0986\u09a6\u09be\u09df \u0995\u09b0\u09be \u0995\u09cb\u099f\u09bf-\u0995\u09cb\u099f\u09bf \u099f\u09be\u0995\u09be \u0986\u09b8\u09b2\u09c7 \u0995\u09cb\u09a8 \u0996\u09be\u09a4\u09c7 \u0996\u09b0\u099a \u09b9\u09df \u09b8\u09c7\u09b8\u09ac\u09c7\u09b0 \u0995\u09cb\u09a8 \u09b8\u09cd\u09aa\u09b7\u09cd\u099f \u09a4\u09a5\u09cd\u09af \u09aa\u09be\u0993\u09af\u09bc\u09be \u09af\u09be\u09df\u09a8\u09be \u0995\u0996\u09a8\u09cb\u0987\u0964 \u09af\u09a6\u09bf\u0993 \u0995\u09cb\u09af\u09bc\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09ab\u09be\u0989\u09a8\u09cd\u09a1\u09c7\u09b6\u09a8\u09c7\u09b0 \u099a\u09c7\u09af\u09bc\u09be\u09b0\u09ae\u09cd\u09af\u09be\u09a8 \u09b6\u09b9\u09c0\u09a6 \u0986\u09b2 \u09ac\u09cb\u0996\u09be\u09b0\u09bf (\u09af\u09bf\u09a8\u09bf \u0997\u09c1\u09b0\u09c1\u099c\u09c0 \u09a8\u09be\u09ae\u09c7 \u09aa\u09b0\u09bf\u099a\u09bf\u09a4) \u098f\u09ac\u0982 \u09a4\u09be\u09b0 \u09b8\u09cd\u09a4\u09cd\u09b0\u09c0 \u09a8\u09be\u09b9\u09be\u09b0 \u0986\u09b2 \u09ac\u09cb\u0996\u09be\u09b0\u09bf\u09b0 \u09a6\u09be\u09ac\u09bf \u09a4\u09be\u09a6\u09c7\u09b0 \u09b8\u0995\u09b2 \u0986\u09df-\u09ac\u09cd\u09af\u09be\u09df\u0987 \u09a8\u09be\u0995\u09bf \u09ac\u09c7\u09b6 \u099f\u09cd\u09b0\u09be\u09a8\u09cd\u09b8\u09aa\u09be\u09b0\u09c7\u09a8\u09cd\u099f, \u09a4\u09ac\u09c7 \u09a4\u09be\u09a6\u09c7\u09b0 \u098f\u0987 \u09a6\u09be\u09ac\u09bf\u09b0 \u09aa\u0995\u09cd\u09b7\u09c7 \u0995\u09cb\u09a8 \u0985\u09a1\u09bf\u099f \u09b0\u09bf\u09aa\u09cb\u09b0\u09cd\u099f \u0996\u09c1\u0981\u099c\u09c7 \u09aa\u09be\u0993\u09af\u09bc\u09be \u09af\u09be\u09df\u09a8\u09bf\u0964 \u09b8\u0982\u09af\u09c1\u0995\u09cd\u09a4 \u09b2\u09bf\u09ab\u09b2\u09c7\u099f\u099f\u09bf\u09b0 \u0989\u09aa\u09b0\u09c7 \u09a6\u09c7\u0996\u09c1\u09a8, \u09b2\u09bf\u0996\u09be \u09b9\u09df\u09c7\u099b\u09c7 '\u0987\u09a8\u09b6\u09be\u0986\u09b2\u09cd\u09b2\u09be\u09b9' \u0986\u09b0 \u09a4\u09be\u09b0 \u09a0\u09bf\u0995 \u09a8\u09bf\u099a\u09c7\u0987 '\u09a7\u09cd\u09af\u09be\u09a8\u0998\u09b0' \u09a8\u09bf\u09b0\u09cd\u09ae\u09be\u09a3\u09c7\u09b0 \u099c\u09a8\u09cd\u09af\u09c7 \u0985\u09b0\u09cd\u09a5 \u09b8\u0982\u0997\u09cd\u09b0\u09b9\u09c7\u09b0 '\u09ae\u09a8\u099b\u09ac\u09bf' \u099f\u09be\u0987\u09aa \u09b9\u09be\u09b8\u200d\u09cd\u09af\u0995\u09b0 \u0986\u09b2\u09be\u09aa\u0964 \u098f\u09a6\u09c7\u09b0 \u09ad\u09a8\u09cd\u09a1\u09be\u09ae\u09c0\u099f\u09be \u09ac\u09c1\u099d\u09a4\u09c7 \u098f\u0996\u09a8 \u0986\u09b0 \u09a4\u09c7\u09ae\u09a8 \u09ac\u09c7\u0997 \u09aa\u09c7\u09a4\u09c7 \u09b9\u099a\u09cd\u099b\u09c7\u09a8\u09be\u0964 \u0986\u09b6\u09be \u0995\u09b0\u099b\u09bf \u09aa\u09cd\u09b0\u099a\u09b2\u09bf\u09a4 \u09b8\u09cb\u09b8\u09be\u0987\u099f\u09bf \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u0993 \u099f\u09cd\u09b0\u09be\u09b8\u09cd\u099f \u0985\u09cd\u09af\u09be\u0995\u09cd\u099f\u09c7\u09b0 \u0986\u0993\u09a4\u09be\u09af\u09bc \u2014 \u0995\u09cb\u09af\u09bc\u09be\u09a8\u09cd\u099f\u09be\u09ae \u09ab\u09be\u0989\u09a8\u09cd\u09a1\u09c7\u09b6\u09a8\u09c7\u09b0 \u09b8\u0995\u09b2 \u0986\u09b0\u09cd\u09a5\u09bf\u0995 \u0995\u09be\u09b0\u09cd\u09af\u0995\u09cd\u09b0\u09ae \u09aa\u09c1\u0999\u09cd\u0996\u09be\u09a8\u09c1\u09aa\u09c1\u0999\u09cd\u0996\u09ad\u09be\u09ac\u09c7 \u09a8\u09bf\u09b0\u09c0\u0995\u09cd\u09b7\u09be\u09b0 \u09aa\u09a6\u0995\u09cd\u09b7\u09c7\u09aa \u09a6\u09cd\u09b0\u09c1\u09a4\u09a4\u09be\u09b0 \u09b8\u09be\u09a5\u09c7 \u0997\u09cd\u09b0\u09b9\u09a3 \u0995\u09b0\u09be \u09b9\u09ac\u09c7\u0964",
    "link": "https://www.facebook.com/saerzulkarnain/posts/pfbid02BjFN1ngjCDPsVZosb8Lw9vuGpKGeGaE6Ct1SFfBBmkyDF62YK4pEnwqz5UradmyNl",
