    "title": "\u098f\u0995\u099f\u09be \u0985\u09b8\u09b9\u09be\u09df \u0995\u09c1\u0995\u09c1\u09b0\u0995\u09c7 \u0995\u09c1\u09ae\u09bf\u09b0\u09c7\u09b0 \u09ae\u09c1\u0996\u09c7 \u09a0\u09c7\u09b2\u09c7 \u09a6\u09bf\u09df\u09c7 \u0995\u09bf\u099b\u09c1 \u09ae\u09be\u09a8\u09c1\u09b7 \u09ae\u099c\u09be \u09a8\u09bf\u099a\u09cd\u099b\u09c7, \u09b8\u09c7\u099f\u09be \u09ad\u09bf\u09a1\u09bf\u0993 \u0995\u09b0\u09c7 ...",
    "description": "\u098f\u0995\u099f\u09be \u0985\u09b8\u09b9\u09be\u09df \u0995\u09c1\u0995\u09c1\u09b0\u0995\u09c7 \u0995\u09c1\u09ae\u09bf\u09b0\u09c7\u09b0 \u09ae\u09c1\u0996\u09c7 \u09a0\u09c7\u09b2\u09c7 \u09a6\u09bf\u09df\u09c7 \u0995\u09bf\u099b\u09c1 \u09ae\u09be\u09a8\u09c1\u09b7 \u09ae\u099c\u09be \u09a8\u09bf\u099a\u09cd\u099b\u09c7, \u09b8\u09c7\u099f\u09be \u09ad\u09bf\u09a1\u09bf\u0993 \u0995\u09b0\u09c7 \u09aa\u09cd\u09b0\u0995\u09be\u09b6 \u0995\u09b0\u099b\u09c7, \u0995\u09c7\u0989 \u0986\u09ac\u09be\u09b0 \u09b9\u09be\u09a4\u09a4\u09be\u09b2\u09bf \u09a6\u09bf\u099a\u09cd\u099b\u09c7 \u2014 \u098f\u09ae\u09a8 \u098f\u0995\u099f\u09be \u09ad\u09bf\u09a1\u09bf\u0993 \u09b8\u09be\u09ae\u09be\u099c\u09bf\u0995 \u09af\u09cb\u0997\u09be\u09af\u09cb\u0997 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u099b\u09a1\u09bc\u09bf\u09af\u09bc\u09c7 \u09aa\u09a1\u09bc\u09c7\u099b\u09c7\u0964 \u0995\u09df\u09c7\u0995\u09ae\u09be\u09b8 \u0986\u0997\u09c7\u0987 \u098f\u0995\u09a6\u09b2 \u09b8\u09ac\u09b2 \u09ae\u09be\u09a8\u09c1\u09b7 \u09ae\u09c3\u09a4 \u098f\u0995 \u09ac\u09cd\u09af\u0995\u09cd\u09a4\u09bf\u09b0 \u09b2\u09be\u09b6 \u09a4\u09be\u0981\u09b0 \u0995\u09ac\u09b0 \u09a5\u09c7\u0995\u09c7 \u0989\u09a0\u09bf\u09df\u09c7 \u09aa\u09c1\u09dc\u09bf\u09df\u09c7 \u09a6\u09c7\u09df\u09be\u09b0 \u099a\u09c7\u09b7\u09cd\u099f\u09be \u0995\u09b0\u09c7\u099b\u09c7\u0964 \u0986\u09ae\u09b0\u09be \u0986\u09b0\u09cb \u09a6\u09c7\u0996\u09c7\u099b\u09bf \u09ae\u09be\u09b8'\u0996\u09be\u09a8\u09c7\u0995 \u0986\u0997\u09c7 \u09ae\u09df\u09ae\u09a8\u09b8\u09bf\u0982\u09b9\u09c7\u09b0 \u09ad\u09be\u09b2\u09c1\u0995\u09be\u09df \u09a6\u09c0\u09aa\u09c1 \u099a\u09a8\u09cd\u09a6\u09cd\u09b0 \u09a6\u09be\u09b8\u0995\u09c7 \u09aa\u09bf\u099f\u09bf\u09df\u09c7 \u09b9\u09a4\u09cd\u09af\u09be \u0995\u09b0\u09be \u09b9\u09df \u0993 \u09ac\u09c7\u09b6 \u0989\u09b2\u09cd\u09b2\u09be\u09b8 \u0995\u09b0\u09c7 \u09a4\u09be\u0981\u09b0 \u09b2\u09be\u09b6 \u09aa\u09c1\u09dc\u09bf\u09df\u09c7 \u09ab\u09c7\u09b2\u09be\u09b0 \u099a\u09c7\u09b7\u09cd\u099f\u09be \u0995\u09b0\u09be \u09b9\u09df\u0964 \u098f\u0987 \u09a4\u09cb \u0997\u09a4\u0995\u09be\u09b2 \u09ac\u09bf\u0995\u09c7\u09b2\u09c7 (\u09b6\u09c1\u0995\u09cd\u09b0\u09ac\u09be\u09b0) \u09a2\u09be\u0995\u09be\u09b0 \u09b6\u09be\u09b9\u09ac\u09be\u0997 \u098f\u09b2\u09be\u0995\u09be\u09af\u09bc \u09b8\u09ae\u0995\u09be\u09ae\u09c0\u09a4\u09be\u09b0 \u099f\u09cd\u09af\u09be\u0997 \u09a6\u09bf\u09df\u09c7 \u0995\u09df\u09c7\u0995\u099c\u09a8 \u09b8\u09be\u09a7\u09be\u09b0\u09a3 \u09a8\u09be\u0997\u09b0\u09bf\u0995\u09c7\u09b0 \u0989\u09aa\u09b0 \u099a\u09b0\u09ae \u0986\u0995\u09cd\u09b0\u09cb\u09b6\u09c7 \u09b9\u09be\u09ae\u09b2\u09c7 \u09aa\u09a1\u09bc\u09c7 \u099a\u09bf\u09b9\u09cd\u09a8\u09bf\u09a4 \u098f\u0995\u099f\u09bf \u0997\u09cb\u09b7\u09cd\u09a0\u09c0\u0964 \u098f\u099b\u09be\u09a1\u09bc\u09be\u0993 \u09ac\u09bf\u0997\u09a4 \u09a6\u09c7\u09a1\u09bc \u09ac\u099b\u09b0\u09c7 \u09aa\u09cd\u09b0\u0995\u09be\u09b6\u200d\u09cd\u09af\u09c7 \u09aa\u09bf\u099f\u09bf\u09df\u09c7 \u09ae\u09c7\u09b0\u09c7 \u09ab\u09c7\u09b2\u09be \u09b9\u09df\u09c7\u099b\u09c7 \u0995\u09df\u09c7\u0995\u09b6 \u09ae\u09be\u09a8\u09c1\u09b7\u0995\u09c7, \u09ac\u09c7\u09b6\u09bf\u09b0\u09ad\u09be\u0997 \u0995\u09cd\u09b7\u09c7\u09a4\u09cd\u09b0\u09c7\u0987 \u09ae\u09be\u09b0\u09be\u09b0 \u0998\u099f\u09a8\u09be\u09b0 \u09b8\u09ae\u09af\u09bc \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u09ac\u09cd\u09af\u0995\u09cd\u09a4\u09bf\u09b0\u09be \u09ac\u09bf\u09b7\u09df\u099f\u09be \u09ac\u09c7\u09b6 \u0986\u09a8\u09a8\u09cd\u09a6 \u09a8\u09bf\u09df\u09c7 \u09a6\u09c7\u0996\u09c7\u099b\u09c7\u09a8, \u0989\u09aa\u09ad\u09cb\u0997 \u0995\u09b0\u09c7\u099b\u09c7\u09a8\u0964 \u098f\u09b8\u09ac \u0998\u099f\u09a8\u09be\u0987 \u0998\u099f\u09c7\u099b\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7 \u2014 \u09a4\u09ac\u09c7 \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8 \u09ac\u09bf\u09b6\u09cd\u09ac \u09aa\u09b0\u09bf\u09b8\u09cd\u09a5\u09bf\u09a4\u09bf \u09ac\u09bf\u09ac\u09c7\u099a\u09a8\u09be\u09af\u09bc \u098f \u09a7\u09b0\u09a8\u09c7\u09b0 \u09ac\u09b0\u09cd\u09ac\u09b0\u09a4\u09be \u0986\u09aa\u09a8\u09bf \u0986\u09ae\u09be\u099c\u09a8 \u099c\u0999\u09cd\u0997\u09b2\u09c7\u09b0 \u0997\u09b9\u09c0\u09a8\u09c7 \u09a5\u09be\u0995\u09be \u0995\u09cb\u09a8 \u09ac\u09bf\u099a\u09cd\u099b\u09bf\u09a8\u09cd\u09a8 \u099c\u09a8\u0997\u09cb\u09b7\u09cd\u09a0\u09c0\u0995\u09c7\u0993 \u09b9\u09df\u09a4\u09cb \u0995\u09b0\u09a4\u09c7 \u09a6\u09c7\u0996\u09ac\u09c7\u09a8 \u09a8\u09be\u0964 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u0985\u09a4\u09bf \u09a6\u09b0\u09bf\u09a6\u09cd\u09b0 \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0, \u09ac\u09be \u0996\u09c1\u09ac\u0987 \u0985\u09a8\u09c1\u09a8\u09cd\u09a8\u09a4 \u098f\u0995\u099f\u09bf \u09a6\u09c7\u09b6, \u0985\u09a5\u09ac\u09be \u098f\u09a6\u09c7\u09b6\u09c7 \u09b8\u09ad\u09cd\u09af\u09a4\u09be\u09b0 \u099b\u09cb\u0981\u09af\u09bc\u09be \u09aa\u09a1\u09bc\u09c7\u09a8\u09bf \u2014 \u098f\u09b8\u09ac \u0995\u09bf\u099b\u09c1\u09b0 \u09a6\u09cb\u09b9\u09be\u0987 \u0986\u09aa\u09a8\u09bf \u09a6\u09bf\u09a4\u09c7 \u09aa\u09be\u09b0\u09ac\u09c7\u09a8 \u09a8\u09be\u0964 \u09ac\u09bf\u09b6\u09cd\u09ac\u09c7 \u098f\u09ae\u09a8 \u09ac\u09b9\u09c1 \u09a6\u09c7\u09b6 \u09b0\u09df\u09c7\u099b\u09c7 \u09af\u09be\u09a6\u09c7\u09b0 \u0985\u09ac\u09b8\u09cd\u09a5\u09be\u09a8 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09a5\u09c7\u0995\u09c7\u0993 \u09ac\u09b9\u09c1\u0997\u09c1\u09a3 \u0996\u09be\u09b0\u09be\u09aa\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09a4\u09be\u0981\u09a6\u09c7\u09b0\u0993 \u098f\u09a4\u099f\u09be \u0985\u09ae\u09be\u09a8\u09ac\u09bf\u0995 \u0986\u099a\u09b0\u09a3 \u0995\u09b0\u09a4\u09c7 \u09b8\u09b9\u09b8\u09be \u09a6\u09c7\u0996\u09be \u09af\u09be\u09df\u09a8\u09be\u0964 \u09a4\u09ac\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7 \u098f\u09ae\u09a8 \u0985\u09a8\u09c7\u0995\u09c7\u0987 \u09ac\u09b8\u09ac\u09be\u09b8 \u0995\u09b0\u09c7\u09a8, \u09af\u09be\u09b0\u09be \u09b8\u09ae\u09cd\u09ad\u09ac\u200d\u09a4 \u098f\u0987 \u09a7\u09be\u09b0\u09a3\u09be \u09aa\u09cb\u09b7\u09a3 \u0995\u09b0\u09c7 \u09af\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u099f\u09be\u0987 \u09b9\u09df\u09a4\u09cb \u098f\u0995\u099f\u09be \u09aa\u09c3\u09a5\u09bf\u09ac\u09c0\u0964 \u0986\u09ae\u09b0\u09be \u0995\u09bf \u09ae\u09be\u09a8\u09b8\u09bf\u0995\u09ad\u09be\u09ac\u09c7 \u09ac\u09bf\u0995\u09b2\u09be\u0999\u09cd\u0997 \u098f\u0995 \u099c\u09a8\u09aa\u09a6 \u09a4\u09c8\u09b0\u09bf \u0995\u09b0\u09c7\u099b\u09bf?",
    "link": "https://www.facebook.com/saerzulkarnain/posts/pfbid0suUmk6URx6BtHR8GJJW1anijdri9GHpYn5ujwEE6MGgSbYLz4DDXoLDDzXxpPH37l",
    "guid": "https://www.facebook.com/saerzulkarnain/posts/pfbid0suUmk6URx6BtHR8GJJW1anijdri9GHpYn5ujwEE6MGgSbYLz4DDXoLDDzXxpPH37l",
