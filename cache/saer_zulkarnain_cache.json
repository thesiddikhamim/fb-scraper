  {
    "title": "\u09ae\u09b9\u09bf\u09b2\u09be \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09af\u09bc \u0985\u09a7\u09cd\u09af\u09af\u09bc\u09a8\u09b0\u09a4 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09b0\u09be \u09b8\u09c7\u0996\u09be\u09a8\u09c7 \u09a8\u09bf\u09b0\u09be\u09aa\u09a6 \u0993 \u09b8\u09c1\u09b8\u09cd\u09a5 \u09b0\u09df\u09c7\u099b\u09c7\u09a8 \u0995\u09bf\u09a8\u09be, \u098f\u09b8\u09ac \u09a4...",
    "description": "\u09ae\u09b9\u09bf\u09b2\u09be \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09af\u09bc \u0985\u09a7\u09cd\u09af\u09af\u09bc\u09a8\u09b0\u09a4 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09b0\u09be \u09b8\u09c7\u0996\u09be\u09a8\u09c7 \u09a8\u09bf\u09b0\u09be\u09aa\u09a6 \u0993 \u09b8\u09c1\u09b8\u09cd\u09a5 \u09b0\u09df\u09c7\u099b\u09c7\u09a8 \u0995\u09bf\u09a8\u09be, \u098f\u09b8\u09ac \u09a4\u09a6\u09be\u09b0\u0995\u09bf \u0995\u09be\u09b0\u09be \u0995\u09b0\u09c7? \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0 \u098f\u09ae\u09a8 \u0995\u09cb\u09a8 \u09b8\u0982\u09b8\u09cd\u09a5\u09be \u0995\u09bf \u09b0\u09df\u09c7\u099b\u09c7 \u09af\u09be\u09b0\u09be \u09a6\u09c7\u09b6\u09c7\u09b0 \u09b8\u0995\u09b2 \u0986\u09ac\u09be\u09b8\u09bf\u0995 \u09b8\u09cd\u0995\u09c1\u09b2, \u0995\u09b2\u09c7\u099c, \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u0997\u09c1\u09b2\u09cb\u09a4\u09c7 \u09e7\u09ee \u09ac\u099b\u09b0 \u09ac\u09df\u09b8 \u09aa\u09b0\u09cd\u09af\u09a8\u09cd\u09a4 \u09af\u09c7\u09b8\u0995\u09b2 (\u0986\u09ac\u09be\u09b8\u09bf\u0995) \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09b0\u09be \u09aa\u09a1\u09bc\u09be\u09b6\u09cb\u09a8\u09be \u0995\u09b0\u099b\u09c7 \u09a4\u09be\u0981\u09a6\u09c7\u09b0 \u0986\u09ac\u09be\u09b8\u09a8, \u0996\u09be\u09a6\u200d\u09cd\u09af, \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be, \u09b8\u09c1\u09b8\u09cd\u09a5\u09a4\u09be \u0993 \u0985\u09a8\u09cd\u09af\u09be\u09a8\u09cd\u09af \u0986\u09a8\u09c1\u09b7\u0999\u09cd\u0997\u09bf\u0995 \u09ac\u09bf\u09b7\u09af\u09bc\u0997\u09c1\u09b2\u09cb \u09af\u09be\u099a\u09be\u0987 \u0995\u09b0\u09c7 \u09a5\u09be\u0995\u09c7?",
