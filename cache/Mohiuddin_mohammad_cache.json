    "title": "\u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6 \u00b7 \u099b\u09c7\u09b2\u09c7\u099f\u09be \u0986\u09ae\u09be\u09b0 \u099c\u09a8\u200d\u09cd\u09af \u0997\u09c7\u09a8\u09cd\u09a1\u09be\u09b0\u09bf\u09df\u09be \u09a5\u09c7\u0995\u09c7 \u09ac\u0987 \u09a8\u09bf\u09df\u09c7 \u0986\u09b8\u099b\u09c7\u0964 \u09a4\u09be\u09b0 \u099c\u09a8\u200d\u09cd\u09af \u098f...",
