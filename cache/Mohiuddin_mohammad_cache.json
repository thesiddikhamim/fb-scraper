[
  {
    "title": "\u09e9\u09e6 \u09ae\u09be\u09b0\u09cd\u099a \u09b8\u09cb\u09ae\u09ac\u09be\u09b0, \u09ac\u09bf\u0995\u09c7\u09b2 \u09e9\u099f\u09be \u09a5\u09c7\u0995\u09c7, \u099f\u09bf\u098f\u09b8\u09b8\u09bf \u0985\u09a1\u09bf\u099f\u09cb\u09b0\u09bf\u09df\u09be\u09ae \u0993 \u09ae\u09be\u09a0, \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u0964 \u09aa\u09cd...",
    "description": "\u09e9\u09e6 \u09ae\u09be\u09b0\u09cd\u099a \u09b8\u09cb\u09ae\u09ac\u09be\u09b0, \u09ac\u09bf\u0995\u09c7\u09b2 \u09e9\u099f\u09be \u09a5\u09c7\u0995\u09c7, \u099f\u09bf\u098f\u09b8\u09b8\u09bf \u0985\u09a1\u09bf\u099f\u09cb\u09b0\u09bf\u09df\u09be\u09ae \u0993 \u09ae\u09be\u09a0, \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u0964 \u09aa\u09cd\u09b0\u09a7\u09be\u09a8 \u0985\u09a4\u09bf\u09a5\u09bf: \u09ac\u09c0\u09b0 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09cb\u09a6\u09cd\u09a7\u09be \u09ab\u099c\u09b2\u09c1\u09b0 \u09b0\u09b9\u09ae\u09be\u09a8, \u098f\u09ae\u09aa\u09bf\u0964",
