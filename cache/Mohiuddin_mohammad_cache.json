    "title": "\u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6 \u098f\u09b0 \u09ac\u09be\u09a8\u09b0\u09c7\u09b0 \u0986\u09df\u09a8\u09be \u09b8\u09b9 \u09b8\u09ac \u0995\u09df\u099f\u09bf \u09ac\u0987 \u09b8\u09b0\u09cd\u09ac\u09cb\u099a\u09cd\u099a 30% \u099b\u09be\u09dc\u09c7 \u098f\u0996\u09a8\u09bf \u0993\u09b0\u09cd\u09a1\u09be\u09b0 \u0995\u09b0...",
