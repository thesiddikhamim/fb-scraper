    "title": "\u09aa\u09c3\u09b7\u09cd\u09a0\u09be: \u09e9\u09ea, \u09ac\u0987: \u099f\u09df\u09cb\u099f\u09be \u0995\u09b0\u09cb\u09b2\u09be, \u099b\u09cb\u099f\u0997\u09b2\u09cd\u09aa '\u09ad\u09a3\u09bf\u09a4\u09be'-\u09b0 \u0985\u0982\u09b6\u09ac\u09bf\u09b6\u09c7\u09b7\u0964",
    "description": "\u09aa\u09c3\u09b7\u09cd\u09a0\u09be: \u09e9\u09ea, \u09ac\u0987: \u099f\u09df\u09cb\u099f\u09be \u0995\u09b0\u09cb\u09b2\u09be, \u099b\u09cb\u099f\u0997\u09b2\u09cd\u09aa '\u09ad\u09a3\u09bf\u09a4\u09be'-\u09b0 \u0985\u0982\u09b6\u09ac\u09bf\u09b6\u09c7\u09b7\u0964",
