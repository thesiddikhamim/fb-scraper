[
  {
    "title": "\u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7\u09c7\u09b0 \u09aa\u0995\u09cd\u09b7\u09c7\u09b0 \u09b6\u0995\u09cd\u09a4\u09bf \u099a\u09c1\u09aa\u099a\u09be\u09aa \u09a5\u09be\u0995\u09be\u09df \u09b0\u09be\u099c\u09be\u0995\u09be\u09b0\u09b0\u09be \u09ad\u09c7\u09ac\u09c7\u099b\u09bf\u09b2\u09cb \u09a6\u09c7\u09b6\u099f\u09be \u09a4\u09be\u09a6\u09c7\u09b0\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u0986...",
    "description": "\u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7\u09c7\u09b0 \u09aa\u0995\u09cd\u09b7\u09c7\u09b0 \u09b6\u0995\u09cd\u09a4\u09bf \u099a\u09c1\u09aa\u099a\u09be\u09aa \u09a5\u09be\u0995\u09be\u09df \u09b0\u09be\u099c\u09be\u0995\u09be\u09b0\u09b0\u09be \u09ad\u09c7\u09ac\u09c7\u099b\u09bf\u09b2\u09cb \u09a6\u09c7\u09b6\u099f\u09be \u09a4\u09be\u09a6\u09c7\u09b0\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u0986\u099c \u09b6\u09be\u09b9\u09ac\u09be\u0997\u09c7 \u0997\u09a3\u09a7\u09cb\u09b2\u09be\u0987 \u0996\u09c7\u09df\u09c7 \u0986\u09b2\u09cd\u09b2\u09be\u09b9 \u0986\u09b2\u09cd\u09b2\u09be\u09b9 \u0995\u09b0\u099b\u09c7\u0964 \u09ad\u09be\u0997\u09cd\u09af \u09ad\u09be\u09b2\u09cb \u09af\u09c7, \u099b\u09be\u09a4\u09cd\u09b0\u09a6\u09b2 \u09a2\u09be\u09b2 \u09b9\u09df\u09c7 \u09a4\u09be\u09a6\u09c7\u09b0\u0995\u09c7 \u09ac\u09be\u0981\u099a\u09bf\u09df\u09c7\u099b\u09c7\u0964 \u0985\u09a8\u09cd\u09af\u09a5\u09be\u09df \u0995\u09cd\u09b7\u09c1\u09ac\u09cd\u09a7 \u099c\u09a8\u09a4\u09be \u09ae\u09c7\u09b0\u09c7\u0987 \u09ab\u09c7\u09b2\u09a4\u09cb\u0964 \u0997\u09a4 \u09e8 \u09ac\u099b\u09b0 \u098f\u09a6\u09c7\u09b0 \u0986\u09b8\u09cd\u0995\u09be\u09b0\u09be \u09a8\u09be \u09a6\u09bf\u09df\u09c7 \u09af\u09a6\u09bf \u0986\u0987\u09a8 \u0985\u09a8\u09c1\u09af\u09be\u09df\u09c0 \u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be \u09a8\u09c7\u0993\u09df\u09be \u09b9\u09a4\u09cb, \u09a4\u09be\u09b9\u09b2\u09c7 \u0986\u099c \u098f\u099f\u09be \u0998\u099f\u09a4\u09cb \u09a8\u09be\u0964 \u0986\u0987\u09a8\u09c7\u09b0 \u09aa\u09be\u0995\u09dc\u09be\u0993 \u09a2\u09bf\u09b2\u09be \u09b9\u09b2\u09c7 \u099c\u09a8\u09a4\u09be\u09b0 \u09aa\u09be\u0995\u09dc\u09be\u0993 \u09b6\u0995\u09cd\u09a4\u09bf\u09b6\u09be\u09b2\u09c0 \u09b9\u09df\u0964 \u098f\u09b0\u09be \u09e8 \u09ac\u099b\u09b0 \u09ad\u09be\u09b8\u09cd\u0995\u09b0\u09cd\u09af \u09ad\u09c7\u0999\u09c7\u099b\u09c7, \u09ae\u09be\u099c\u09be\u09b0 \u09ad\u09c7\u0999\u09c7\u099b\u09c7, \u0985\u09b8\u0982\u0996\u09cd\u09af \u09ae\u09be\u09a8\u09c1\u09b7\u0995\u09c7 \u09aa\u09bf\u099f\u09bf\u09df\u09c7 \u09ae\u09c7\u09b0\u09c7\u099b\u09c7, \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u09c7\u09b0 \u09ae\u09a4\u09cb \u099c\u09be\u09df\u0997\u09be\u09df \u09a4\u09cb\u09ab\u09be\u099c\u09cd\u099c\u09b2 \u09a8\u09be\u09ae\u0995 \u098f\u0995 \u0985\u09b8\u09b9\u09be\u09df \u09ae\u09be\u09a8\u09b8\u09bf\u0995 \u09ad\u09be\u09b0\u09b8\u09be\u09ae\u09cd\u09af\u09b9\u09c0\u09a8 \u09b2\u09cb\u0995\u0995\u09c7 \u09b9*\u09a4\u09cd\u09af\u09be \u0995\u09b0\u09c7\u099b\u09c7\u0964 \u09b0\u09be\u099c\u09a8\u09c0\u09a4\u09bf\u0995 \u09ae\u09a4\u09b2\u09ac\u09c7 \u0993\u09b8\u09ae\u09be\u09a8 \u09b9\u09be\u09a6\u09c0\u0995\u09c7 \u0996\u09c1\u09a8 \u0995\u09b0\u09c7 \u0995\u09ac\u09bf \u09a8\u099c\u09b0\u09c1\u09b2\u09c7\u09b0 \u09aa\u09be\u09b6\u09c7 \u09b6\u09c1\u09df\u09c7 \u09a6\u09bf\u09df\u09c7\u099b\u09c7\u0964 \u09aa\u09cd\u09b0\u0995\u09c3\u09a4\u09bf \u09a8\u09bf\u09b0\u09cd\u09ae\u09ae\u0964 \u09b6\u09be\u09b9\u09ac\u09be\u0997\u09c7 \u0986\u099c \u0998\u09c2\u09b0\u09cd\u09a3\u09bf\u09ac\u09be\u09df\u09c1\u09b0 \u09ae\u09a4\u09cb \u09aa\u09cd\u09b0\u0995\u09c3\u09a4\u09bf \u09ab\u09c1\u0981\u09b8\u09c7 \u0989\u09a0\u09c7\u099b\u09bf\u09b2\u09cb\u0964 \u09ad\u09be\u0997\u09cd\u09af \u09ad\u09be\u09b2\u09cb \u09af\u09c7 \u099b\u09be\u09a4\u09cd\u09b0\u09a6\u09b2 \u09b8\u09ad\u09be\u09aa\u09a4\u09bf \u09b0\u09be\u0995\u09bf\u09ac \u098f\u0995\u099c\u09a8 \u09ad\u09a6\u09cd\u09b0\u09b2\u09cb\u0995 \u09b8\u099c\u09cd\u099c\u09a8 \u09ae\u09be\u09a8\u09c1\u09b7\u0964 \u09a4\u09bf\u09a8\u09bf \u09ae\u09ac\u09b8\u09cd\u099f\u09be\u09b0\u09a6\u09c7\u09b0 \u09a8\u09bf\u099c \u099c\u09bf\u09ae\u09cd\u09ae\u09be\u09df \u09a8\u09bf\u09b0\u09be\u09aa\u09a6\u09c7 \u09ac\u09c7\u09b0 \u0995\u09b0\u09c7 \u09a8\u09be \u0986\u09a8\u09b2\u09c7 \u0995\u09cd\u09b7\u09c1\u09ac\u09cd\u09a7 \u099c\u09a8\u09a4\u09be \u0998\u099f\u09a8\u09be \u0998\u099f\u09bf\u09df\u09c7 \u09ab\u09c7\u09b2\u09a4\u09cb\u0964 \u09b0\u09be\u099c\u09be\u0995\u09be\u09b0\u09a6\u09c7\u09b0 \u0989\u099a\u09bf\u09a4 \u099b\u09be\u09a4\u09cd\u09b0\u09a6\u09b2\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u0995\u09c3\u09a4\u099c\u09cd\u099e \u09a5\u09be\u0995\u09be\u0964 \u09b8\u09be\u09b0\u09be \u09a6\u09c7\u09b6\u09c7\u09b0 \u09ae\u09be\u09a8\u09c1\u09b7 \u09af\u09c7\u09ad\u09be\u09ac\u09c7 \u099b\u09be\u09a4\u09cd\u09b0\u09a6\u09b2\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u098f\u0995\u09be\u09a4\u09cd\u09ae\u09a4\u09be \u0998\u09cb\u09b7\u09a3\u09be \u0995\u09b0\u09c7\u099b\u09c7, \u09a4\u09be \u09a8\u099c\u09bf\u09b0\u09ac\u09bf\u09b9\u09c0\u09a8\u0964",
    "link": "https://www.facebook.com/oiraboti.book/posts/pfbid02YQHdaduPk1YVqJEThvnsQiz51rf9qhzht8sez1uv3sEpyRGM3fhy7XGnTNVuXv8Cl",
    "guid": "https://www.facebook.com/oiraboti.book/posts/pfbid02YQHdaduPk1YVqJEThvnsQiz51rf9qhzht8sez1uv3sEpyRGM3fhy7XGnTNVuXv8Cl",
    "pubDate": "2026-04-24T04:02:27.143306+00:00",
