    "title": "\u099c\u09a8\u0997\u09a8\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a7\u09be\u09a8 \u0995\u09be\u099c-- \u09b0\u09be\u099c\u09be\u09b0 \u0995\u09be\u0981\u09a0\u09be\u09b2 \u09ad\u09be\u0999\u09cd\u0997\u09be\u09b0 \u09aa\u09be\u09a4\u09cd\u09b0 \u09b9\u09bf\u09b6\u09c7\u09ac\u09c7 \u09ac\u09cd\u09af\u09ac\u09b9\u09c3\u09a4 \u09b9\u0993\u09df\u09be\u0964 \u099c\u09a8\u0997\u09a3 \u09a8\u09be \u09a5\u09be\u0995\u09b2...",
    "description": "\u099c\u09a8\u0997\u09a8\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a7\u09be\u09a8 \u0995\u09be\u099c-- \u09b0\u09be\u099c\u09be\u09b0 \u0995\u09be\u0981\u09a0\u09be\u09b2 \u09ad\u09be\u0999\u09cd\u0997\u09be\u09b0 \u09aa\u09be\u09a4\u09cd\u09b0 \u09b9\u09bf\u09b6\u09c7\u09ac\u09c7 \u09ac\u09cd\u09af\u09ac\u09b9\u09c3\u09a4 \u09b9\u0993\u09df\u09be\u0964 \u099c\u09a8\u0997\u09a3 \u09a8\u09be \u09a5\u09be\u0995\u09b2\u09c7 \u09b0\u09be\u099c\u09be \u09a4\u09be\u0981\u09b0 \u0995\u09be\u0981\u09a0\u09be\u09b2 \u09a8\u09bf\u09df\u09c7 \u09ac\u09a8\u09c7 \u09ac\u09a8\u09c7 \u0998\u09c1\u09b0\u09a4\u09c7\u09a8, \u098f\u09ac\u0982 \u0995\u09cd\u09b2\u09be\u09a8\u09cd\u09a4 \u09b9\u09df\u09c7 \u09a8\u09bf\u099c\u09c7\u0987 \u099c\u09a8\u0997\u09a3 \u09b9\u09df\u09c7 \u0989\u09a0\u09a4\u09c7\u09a8\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09aa\u09be\u09b2\u09ac\u09a6\u09cd\u09a7 \u09ae\u09be\u09a8\u09c1\u09b7\u09c7\u09b0 \u09a6\u09df\u09be\u09df \u09b0\u09be\u099c\u09be \u09b8\u09ac\u09b8\u09ae\u09df \u09b0\u09be\u099c\u09be\u0987 \u09a5\u09be\u0995\u09c7\u09a8\u0964 \u0986\u09a7\u09c1\u09a8\u09bf\u0995 \u0997\u09b0\u09c1-\u09b0\u099a\u09a8\u09be \u09b8\u09ae\u0997\u09cd\u09b0\u0964 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6\u0964",
