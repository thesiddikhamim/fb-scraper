[
  {
    "title": "\u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7 \u0993 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u0995\u09c7 \u09a7\u09be\u09b0\u09a3 \u0995\u09b0\u09c7\u09a8, \u098f\u09ae\u09a8 \u09b8\u09ac\u09be\u0987 \u0986\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09bf\u09a4\u0964 \u09ac\u09be\u09ac\u09be-\u09ae\u09be, \u09ad\u09be\u0987-\u09ac\u09cb\u09a8, \u09ac\u09a8\u09cd\u09a7\u09c1-...",
    "description": "\u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7 \u0993 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u0995\u09c7 \u09a7\u09be\u09b0\u09a3 \u0995\u09b0\u09c7\u09a8, \u098f\u09ae\u09a8 \u09b8\u09ac\u09be\u0987 \u0986\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09bf\u09a4\u0964 \u09ac\u09be\u09ac\u09be-\u09ae\u09be, \u09ad\u09be\u0987-\u09ac\u09cb\u09a8, \u09ac\u09a8\u09cd\u09a7\u09c1-\u09ac\u09be\u09a8\u09cd\u09a7\u09ac, \u09aa\u09cd\u09b0\u09c7\u09ae\u09bf\u0995-\u09aa\u09cd\u09b0\u09c7\u09ae\u09bf\u0995\u09be, \u09b8\u09cd\u09ac\u09be\u09ae\u09c0-\u09b8\u09cd\u09a4\u09cd\u09b0\u09c0, \u0993 \u09aa\u09b0\u09bf\u099a\u09bf\u09a4 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09cb\u09a6\u09cd\u09a7\u09be \u09a5\u09be\u0995\u09b2\u09c7, \u09b8\u09be\u09a5\u09c7 \u0995\u09b0\u09c7 \u09a8\u09bf\u09df\u09c7 \u0986\u09b8\u09ac\u09c7\u09a8\u0964 \u09b6\u09c1\u09b0\u09c1 \u09b9\u09ac\u09c7 \u09ac\u09bf\u0995\u09c7\u09b2 \u09e9\u099f\u09be \u09a5\u09c7\u0995\u09c7\u0964 \u09ac\u09c0\u09b0 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09cb\u09a6\u09cd\u09a7\u09be \u09ab\u099c\u09b2\u09c1\u09b0 \u09b0\u09b9\u09ae\u09be\u09a8 \u098f\u09ae\u09aa\u09bf \u099b\u09be\u09dc\u09be\u0993 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u09a5\u09be\u0995\u09ac\u09c7\u09a8 \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u09c7\u09b0 \u09b8\u09ae\u09cd\u09ae\u09be\u09a8\u09c0\u09a4 \u0989\u09aa\u09be\u099a\u09be\u09b0\u09cd\u09af \u0985\u09a7\u09cd\u09af\u09be\u09aa\u0995 \u099c\u09a8\u09be\u09ac \u0993\u09ac\u09be\u09df\u09a6\u09c1\u09b2 \u0987\u09b8\u09b2\u09be\u09ae \u0993 \u0985\u09a8\u09cd\u09af\u09be\u09a8\u09cd\u09af \u09b6\u09bf\u0995\u09cd\u09b7\u0995\u09ac\u09c3\u09a8\u09cd\u09a6\u0964 \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u09c7 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7\u0995\u09c7 \u0985\u09aa\u09ae\u09be\u09a8 \u0995\u09b0\u09be\u09b0 \u09b6\u09c1\u09b0\u09c1 \u09b9\u09df\u09c7\u099b\u09bf\u09b2\u09cb \u09ac\u09c0\u09b0 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09cb\u09a6\u09cd\u09a7\u09be \u09ab\u099c\u09b2\u09c1\u09b0 \u09b0\u09b9\u09ae\u09be\u09a8\u09c7\u09b0 \u099b\u09ac\u09bf\u09a4\u09c7 \u099c\u09c1\u09a4\u09be \u09ae\u09c7\u09b0\u09c7\u0964 \u0986\u09aa\u09a8\u09be\u09a6\u09c7\u09b0 \u09b8\u0995\u09b2\u09c7\u09b0 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4\u09bf\u09a4\u09c7 \u098f \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8 \u09b0\u09be\u099c\u09be\u0995\u09be\u09b0\u09a6\u09c7\u09b0 \u09ae\u09c1\u0996\u09c7 \u09ac\u09dc \u099a\u09aa\u09c7\u099f\u09be\u0998\u09be\u09a4 \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u0995\u09be\u099c \u0995\u09b0\u09c1\u0995, \u098f \u0995\u09be\u09ae\u09a8\u09be \u0995\u09b0\u09bf\u0964 \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u09a4\u09be\u0995\u09c7 \u0985\u09aa\u09ae\u09be\u09a8 \u0995\u09b0\u09be \u09b9\u09df\u09c7\u099b\u09bf\u09b2\u09cb, \u09b8\u09c7\u0996\u09be\u09a8\u09c7\u0987 \u09a4\u09bf\u09a8\u09bf \u09ac\u09c0\u09b0\u09c7\u09b0 \u09ac\u09c7\u09b6\u09c7 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af \u09b0\u09be\u0996\u09ac\u09c7\u09a8\u0964 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7 \u099c\u09c0\u09ac\u09bf\u09a4 \u09b0\u09a3\u09be\u0999\u09cd\u0997\u09a8\u09c7\u09b0 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09cb\u09a6\u09cd\u09a7\u09be \u09ac\u09c7\u09b6\u09bf \u09a8\u09c7\u0987\u0964 \u09af\u09c7-\u0995\u09df\u099c\u09a8 \u0986\u099b\u09c7\u09a8, \u09a4\u09be\u09a6\u09c7\u09b0 \u09ae\u09be\u099d\u09c7 \u09ab\u099c\u09b2\u09c1\u09b0 \u09b0\u09b9\u09ae\u09be\u09a8 \u0985\u09a8\u09cd\u09af\u09a4\u09ae\u0964 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u0993 \u09ac\u09be\u0999\u09be\u09b2\u09bf \u09b8\u0982\u09b8\u09cd\u0995\u09c3\u09a4\u09bf\u0995\u09c7 \u09a7\u09be\u09b0\u09a3\u09c7\u09b0 \u0995\u09cd\u09b7\u09c7\u09a4\u09cd\u09b0\u09c7\u0993 \u09a4\u09bf\u09a8\u09bf \u0986\u09aa\u09b7\u09b9\u09c0\u09a8\u0964 \u09a4\u09be\u09b0 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af \u09b6\u09c1\u09a8\u09a4\u09c7 \u099a\u09b2\u09c7 \u0986\u09b8\u09c1\u09a8\u0964 \u0986\u09aa\u09a8\u09be\u09b0\u09be \u09af\u09c7 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09cb\u09a6\u09cd\u09a7\u09be\u09a6\u09c7\u09b0 \u09aa\u09be\u09b6\u09c7 \u0986\u099b\u09c7\u09a8, \u09a4\u09be \u099c\u09be\u09a8\u09bf\u09df\u09c7 \u09a6\u09bf\u09a4\u09c7 \u099a\u09b2\u09c7 \u0986\u09b8\u09c1\u09a8\u0964 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u098f\u0995\u099f\u09bf \u09a8\u09a4\u09c1\u09a8 \u09b8\u09ae\u09df \u09aa\u09be\u09b0 \u0995\u09b0\u099b\u09c7\u0964 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7\u0995\u09c7\u09a8\u09cd\u09a6\u09cd\u09b0\u09c0\u0995 \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8 \u09aa\u09cd\u09b0\u09be\u09df \u09a8\u09be\u0987 \u09b9\u09a4\u09c7 \u099a\u09b2\u09c7\u099b\u09c7\u0964 \u098f\u099f\u09be \u09b9\u09a4\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u09af\u09be\u09ac\u09c7 \u09a8\u09be\u0964 \u0986\u09aa\u09a8\u09be\u09b0\u09be \u09a8\u09bf\u099c \u09a8\u09bf\u099c \u0985\u09ac\u09b8\u09cd\u09a5\u09be\u09a8 \u09a5\u09c7\u0995\u09c7 \u09b8\u09b0\u09ac \u09a8\u09be \u09b9\u09b2\u09c7, \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7\u0995\u09c7 \u098f\u0995\u09be\u09a4\u09cd\u09a4\u09b0\u09c7\u09b0 \u09aa\u09b0\u09be\u099c\u09bf\u09a4 \u0985\u09a8\u09cd\u09a7\u0995\u09be\u09b0 \u09b6\u0995\u09cd\u09a4\u09bf \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0995\u09be\u09b2\u09c7\u0995\u09cd\u099f\u09bf\u09ad \u09ae\u09c7\u09ae\u09cb\u09b0\u09bf \u09a5\u09c7\u0995\u09c7 \u09ae\u09c1\u099b\u09c7 \u09a6\u09c7\u09ac\u09c7\u0964 \u098f\u09b0\u09be\u0987 \u09eb \u0986\u0997\u09b8\u09cd\u099f\u09c7\u09b0 \u09aa\u09b0 \u099c\u09a8\u0997\u09a3\u09c7\u09b0 \u09ad\u09c0\u09dc\u09c7 \u0998\u09be\u09aa\u099f\u09bf \u09ae\u09c7\u09b0\u09c7 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7\u09c7\u09b0 \u09b8\u0995\u09b2 \u09ad\u09be\u09b8\u09cd\u0995\u09b0\u09cd\u09af \u0993 \u09b8\u09cd\u09ae\u09c3\u09a4\u09bf\u099a\u09bf\u09b9\u09cd\u09a8\u09c7 \u09aa\u09c8\u09b6\u09be\u099a\u09bf\u0995 \u09a4\u09be\u09a3\u09cd\u09a1\u09ac \u099a\u09be\u09b2\u09bf\u09df\u09c7\u099b\u09c7\u0964 \u09ac\u09c7\u0997\u09ae \u09b0\u09cb\u0995\u09c7\u09df\u09be\u09b0 \u099b\u09ac\u09bf\u09a4\u09c7 \u0995\u09be\u09b2\u09bf \u09ae\u09c7\u09b0\u09c7\u099b\u09c7\u0964 \u0986\u09aa\u09a8\u09bf \u09af\u09a6\u09bf \u09a8\u09c0\u09b0\u09ac \u09a5\u09be\u0995\u09c7\u09a8, \u098f\u0997\u09c1\u09b2\u09cb \u09b8\u09b9\u09cd\u09af \u0995\u09b0\u09a4\u09c7 \u09a5\u09be\u0995\u09c7\u09a8, \u09a4\u09be\u09b9\u09b2\u09c7 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09cb\u09a6\u09cd\u09a7\u09be\u09b0\u09be \u09af\u09c7-\u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u0993 \u09a4\u09cd\u09af\u09be\u0997 \u09a8\u09bf\u09df\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u099c\u09a8\u09cd\u09ae \u09a6\u09bf\u09df\u09c7\u099b\u09bf\u09b2\u09c7\u09a8, \u09a4\u09be \u09a6\u09cd\u09b0\u09c1\u09a4 \u09a8\u09b8\u09cd\u09af\u09be\u09ce \u09b9\u09df\u09c7 \u09af\u09be\u09ac\u09c7\u0964 \u098f \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8 \u0986\u09aa\u09a8\u09be\u09a6\u09c7\u09b0\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0\u0964 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0\u0964 \u0986\u09aa\u09a8\u09bf \u09af\u09c7 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7 \u0993 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u0995\u09c7 \u09a7\u09be\u09b0\u09a3 \u0995\u09b0\u09c7\u09a8, \u09a4\u09be\u09b0 \u09b8\u09b0\u09ac \u099c\u09be\u09a8\u09be\u09a8 \u09a6\u09bf\u09a4\u09c7 \u0985\u09ac\u09b6\u09cd\u09af\u0987 \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09c7 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u09a5\u09be\u0995\u09ac\u09c7\u09a8\u0964 \u0995\u09a5\u09be \u09ac\u09b2\u09ac\u09c7\u09a8\u0964 \u0985\u09a8\u09cd\u09af\u09a6\u09c7\u09b0\u0995\u09c7\u0993 \u09b8\u09be\u09a5\u09c7 \u0986\u09a8\u09ac\u09c7\u09a8\u0964 \u0986\u09aa\u09a8\u09be\u09a6\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u0986\u09ae\u09b0\u09be \u09b8\u09be\u09a7\u09cd\u09af \u0985\u09a8\u09c1\u09af\u09be\u09df\u09c0 \u0996\u09be\u09ac\u09be\u09b0\u09c7\u09b0 \u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be \u0995\u09b0\u09a4\u09c7 \u099a\u09be\u0987\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u098f \u099c\u09a8\u09cd\u09af \u098f\u0995\u099f\u09bf \u0985\u09a8\u09c1\u09ae\u09be\u09a8 \u09a6\u09b0\u0995\u09be\u09b0\u0964 \u09a4\u09be\u0987 \u09af\u09be\u09b0\u09be \u0986\u09b8\u09ac\u09c7\u09a8, \u0985\u09a8\u09c1\u0997\u09cd\u09b0\u09b9 \u0995\u09b0\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0\u09bf \u098f\u0987 \u09aa\u09c7\u0987\u099c\u09c7 \u098f\u0995\u099f\u09bf \u09ae\u09c7\u09b8\u09c7\u099c \u09a6\u09bf\u09df\u09c7 \u09a8\u09bf\u09ac\u09a8\u09cd\u09a7\u09a8 \u0995\u09b0\u09c7 \u09a8\u09c7\u09ac\u09c7\u09a8\u0964 \u09ae\u09c7\u09b8\u09c7\u099c\u09c7 \u0986\u09aa\u09a8\u09be\u09b0 \u09a8\u09be\u09ae, \u09ae\u09cb\u09ac\u09be\u0987\u09b2 \u09a8\u09be\u09ae\u09cd\u09ac\u09be\u09b0, \u0993 \u09b8\u09be\u09a5\u09c7 \u0995\u09c7\u0989 \u0986\u09b8\u09b2\u09c7 \u09a4\u09be\u09b0 \u09a8\u09be\u09ae \u0993 \u09b8\u0982\u0996\u09cd\u09af\u09be \u09b2\u09bf\u0996\u09c7 \u09aa\u09be\u09a0\u09be\u09ac\u09c7\u09a8\u0964 \u098f\u09ac\u0982 \u09aa\u09be\u09b0\u09b2\u09c7, \u09b8\u09be\u09a7\u09cd\u09af \u0985\u09a8\u09c1\u09af\u09be\u09df\u09c0 \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8 \u0986\u09df\u09cb\u099c\u09a8 \u09a4\u09b9\u09ac\u09bf\u09b2\u09c7 \u0986\u09b0\u09cd\u09a5\u09bf\u0995 \u0985\u09a8\u09c1\u09a6\u09be\u09a8 \u09aa\u09be\u09a0\u09be\u09ac\u09c7\u09a8\u0964 \u09ae\u09c7\u09b8\u09c7\u099c\u09c7 \u0985\u09a8\u09c1\u09a6\u09be\u09a8\u09c7\u09b0 \u09aa\u09b0\u09bf\u09ae\u09be\u09a3 \u09b2\u09bf\u0996\u09c7 \u09aa\u09be\u09a0\u09be\u09b2\u09c7 \u0986\u09aa\u09a8\u09be\u0995\u09c7 \u09ac\u09bf\u0995\u09be\u09b6 \u09a8\u09be\u09ae\u09cd\u09ac\u09be\u09b0 \u09a6\u09bf\u09df\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u09b9\u09ac\u09c7\u0964 \u0995\u09cb\u09a8\u09cb \u09aa\u09b0\u09ae\u09be\u09b0\u09cd\u09b6 \u09a5\u09be\u0995\u09b2\u09c7 \u099c\u09be\u09a8\u09be\u09ac\u09c7\u09a8\u0964 \u09b8\u0995\u09b2\u09c7\u09b0 \u09b8\u09c1\u09b8\u09cd\u09ac\u09be\u09b8\u09cd\u09a5\u09cd\u09af \u0995\u09be\u09ae\u09a8\u09be \u0995\u09b0\u099b\u09bf\u0964 \u09a7\u09a8\u09cd\u09af\u09ac\u09be\u09a6\u09be\u09a8\u09cd\u09a4\u09c7, \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09aa\u09be\u09ac\u09b2\u09bf\u0995 \u098f\u0995\u09be\u09a1\u09c7\u09ae\u09bf, \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df \u09b6\u09be\u0996\u09be \u0993 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6 \u09aa\u09be\u09a0\u0995 \u09aa\u09b0\u09bf\u09ac\u09be\u09b0, \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df \u09b6\u09be\u0996\u09be\u0964",
