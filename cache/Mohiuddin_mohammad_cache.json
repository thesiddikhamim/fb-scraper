    "title": "\"\u09a4\u09bf\u09a8\u09bf\u0987 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09cb\u09a6\u09cd\u09a7\u09be, \u09af\u09bf\u09a8\u09bf \u09aa\u09b0\u09be\u099c\u09bf\u09a4 \u0985\u09a8\u09cd\u09a7\u0995\u09be\u09b0 \u09b6\u0995\u09cd\u09a4\u09bf\u09b0 \u09b9\u09be\u09a4 \u09a5\u09c7\u0995\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6, \u09ac\u09be\u0982\u09b2\u09be \u09ad\u09be\u09b7\u09be, \u0993...",
    "description": "\"\u09a4\u09bf\u09a8\u09bf\u0987 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09cb\u09a6\u09cd\u09a7\u09be, \u09af\u09bf\u09a8\u09bf \u09aa\u09b0\u09be\u099c\u09bf\u09a4 \u0985\u09a8\u09cd\u09a7\u0995\u09be\u09b0 \u09b6\u0995\u09cd\u09a4\u09bf\u09b0 \u09b9\u09be\u09a4 \u09a5\u09c7\u0995\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6, \u09ac\u09be\u0982\u09b2\u09be \u09ad\u09be\u09b7\u09be, \u0993 \u09ac\u09be\u0999\u09be\u09b2\u09bf \u09b8\u0982\u09b8\u09cd\u0995\u09c3\u09a4\u09bf\u0995\u09c7 \u09b0\u0995\u09cd\u09b7\u09be\u09df \u09b8\u09b0\u09cd\u09ac\u09a6\u09be \u09b8\u0995\u09cd\u09b0\u09bf\u09df \u09a5\u09be\u0995\u09c7\u09a8\u0964 \u0995\u09c7\u09ac\u09b2 \u098f\u0995\u09be\u09a4\u09cd\u09a4\u09b0\u09c7 \u09ac** \u09a8\u09cd\u09a6\u09c1\u0995 \u09a7\u09b0\u09c7\u0987 \u0995\u09c7\u0989 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09cb\u09a6\u09cd\u09a7\u09be \u09b9\u09df \u09a8\u09be\u0964 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7 \u098f\u0995\u09a7\u09b0\u09a3\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b6\u09cd\u09b0\u09c1\u09a4\u09bf, \u09af\u09c7\u099f\u09bf \u09b0\u0995\u09cd\u09b7\u09be\u09df \u0986\u09ae\u09c3\u09a4\u09cd\u09af\u09c1 \u09a6\u09be\u09df\u09bf\u09a4\u09cd\u09ac \u09aa\u09be\u09b2\u09a8 \u0995\u09b0\u09a4\u09c7 \u09b9\u09df\u0964\" \u2014 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6",
