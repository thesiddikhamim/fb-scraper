    "title": "\u09b8\u09cd\u09a5\u09be\u09a8: \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u0964 \u099b\u09ac\u09bf: \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09aa\u09be\u09ac\u09b2\u09bf\u0995 \u098f\u0995\u09be\u09a1\u09c7\u09ae\u09bf",
    "description": "\u09b8\u09cd\u09a5\u09be\u09a8: \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u0964 \u099b\u09ac\u09bf: \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09aa\u09be\u09ac\u09b2\u09bf\u0995 \u098f\u0995\u09be\u09a1\u09c7\u09ae\u09bf",
