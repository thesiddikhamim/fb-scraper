  {
    "title": "\"\u09ae\u09be\u09ae\u09b2\u09be \u0995\u09b0\u09c7 \u09b8\u09b0\u0995\u09be\u09b0 \u0986\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09bf\u0995\u09ad\u09be\u09ac\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be \u0995\u09b0\u09b2\u09cb, \u09ed-\u0987 \u09ae\u09be\u09b0\u09cd\u099a\u09c7\u09b0 \u09ad\u09be\u09b7\u09a3 \u09ac\u09be\u099c\u09be\u09a8\u09cb \u0995\u09c7\u09ac\u09b2 \u0985\u09aa\u09b0...",
    "description": "\"\u09ae\u09be\u09ae\u09b2\u09be \u0995\u09b0\u09c7 \u09b8\u09b0\u0995\u09be\u09b0 \u0986\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09bf\u0995\u09ad\u09be\u09ac\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be \u0995\u09b0\u09b2\u09cb, \u09ed-\u0987 \u09ae\u09be\u09b0\u09cd\u099a\u09c7\u09b0 \u09ad\u09be\u09b7\u09a3 \u09ac\u09be\u099c\u09be\u09a8\u09cb \u0995\u09c7\u09ac\u09b2 \u0985\u09aa\u09b0\u09be\u09a7 \u09a8\u09df, \u09b8\u09a8\u09cd\u09a4\u09cd\u09b0\u09be\u09b8\u09c0 \u0995\u09b0\u09cd\u09ae\u0995\u09be\u09a3\u09cd\u09a1! \u0986\u09a6\u09be\u09b2\u09a4\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u099a\u09be\u09b2\u09be\u09a8\u09aa\u09a4\u09cd\u09b0\u09c7 \u09aa\u09c1\u09b2\u09bf\u09b6 \u09b2\u09bf\u0996\u09c7\u099b\u09c7\u2014 \"\u09a4\u0996\u09a8 \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u09c7\u09b0 \u09a1\u09be\u0995\u09b8\u09c1 \u09aa\u09cd\u09b0\u09a4\u09bf\u09a8\u09bf\u09a7\u09bf \u098f\u09ac\u09bf \u099c\u09c1\u09ac\u09be\u09df\u09c7\u09b0, \u098f\u09ac\u0982 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6 \u09ae\u09cb\u09b8\u09be\u09a6\u09cd\u09a6\u09c7\u0995 \u098f\u09b0 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u09c7 \u0995\u09bf\u099b\u09c1 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0 \u09a7\u09c3\u09a4 \u09e8 \u0993 \u09e9 \u09a8\u0982 \u0986\u09b8\u09be\u09ae\u09c0\u0995\u09c7 \u09ed\u0987 \u09ae\u09be\u09b0\u09cd\u099a\u09c7\u09b0 \u09ad\u09be\u09b7\u09a3 \u09ac\u09be\u099c\u09be\u09a8\u09cb\u09b0 \u0995\u09be\u09b0\u09a3\u09c7 \u0986\u099f\u0995 \u0995\u09b0\u09bf\u09df\u09be \u09aa\u09c1\u09b2\u09bf\u09b6 \u09b9\u09c7\u09ab\u09be\u099c\u09a4\u09c7 \u09aa\u09cd\u09b0\u09a6\u09be\u09a8 \u0995\u09b0\u09c7\u09a8\u0964\" \u0995\u09b2\u09cd\u09aa\u09a8\u09be \u0995\u09b0\u09c1\u09a8 \u09ac\u09bf\u09b7\u09df\u099f\u09be\u0964 \u0995\u09cd\u09b7\u09ae\u09a4\u09be\u09df \u09ac\u09bf\u098f\u09a8\u09aa\u09bf, \u09ed\u0987 \u09ae\u09be\u09b0\u09cd\u099a\u09c7\u09b0 \u09ad\u09be\u09b7\u09a3 \u09ac\u09be\u099c\u09be\u099a\u09cd\u099b\u09c7 \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u09c7\u09b0 \u0995\u09df\u09c7\u0995\u099c\u09a8 \u099b\u09be\u09a4\u09cd\u09b0 \u09af\u09c7\u099f\u09bf\u09b0 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u09c7 \u099b\u09bf\u09b2\u09c7\u09a8 \u098f\u0995\u099c\u09a8 \u09a8\u09be\u09b0\u09c0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0 \u09b6\u09c7\u0996 \u09a4\u09be\u09b8\u09a8\u09bf\u09ae \u0986\u09ab\u09b0\u09cb\u099c \u0987\u09ae\u09bf, \u09af\u09c7\u0987 \u0987\u09ae\u09bf \u09aa\u09c1\u09b0\u09cb \u099b\u09be\u09a4\u09cd\u09b0\u099c\u09c0\u09ac\u09a8\u09c7 \u09b6\u09c7\u0996 \u09b9\u09be\u09b8\u09bf\u09a8\u09be\u09b0 \u09ac\u09bf\u09b0\u09c1\u09a6\u09cd\u09a7\u09c7 \u09aa\u09cd\u09b0\u0995\u09be\u09b6\u09cd\u09af\u09c7 \u09b0\u09be\u099c\u09aa\u09a5\u09c7 \u09b6\u09cd\u09b2\u09cb\u0997\u09be\u09a8 \u09a6\u09bf\u09df\u09c7\u099b\u09c7\u09a8, \u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae \u0995\u09b0\u09c7\u099b\u09c7\u09a8! \u098f\u09ac\u0982 \u09a4\u09be\u09a6\u09c7\u09b0\u0995\u09c7 \u0995\u09c7\u09ac\u09b2 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7\u09c7\u09b0 \u0985\u09ac\u09bf\u099a\u09cd\u099b\u09c7\u09a6\u09cd\u09af \u0985\u0982\u09b6 \u09ed\u0987 \u09ae\u09be\u09b0\u09cd\u099a\u09c7\u09b0 \u09ad\u09be\u09b7\u09a3 \u09ac\u09be\u099c\u09be\u09a8\u09cb\u09b0 \u0995\u09be\u09b0\u09a3\u09c7 \u09b8\u09a8\u09cd\u09a4\u09cd\u09b0\u09be\u09b8 \u09a6\u09ae\u09a8 \u0986\u0987\u09a8\u09c7 \u09ae\u09be\u09ae\u09b2\u09be \u09a6\u09bf\u09df\u09c7 \u0995\u09be\u09b0\u09be\u0997\u09be\u09b0\u09c7 \u09aa\u09be\u09a0\u09be\u09a8\u09cb \u09b9\u09b2\u09cb! \u09aa\u09c1\u09b2\u09bf\u09b6\u09c7 \u09a6\u09c7\u09df\u09be \u09b9\u09b2\u09cb \u09b0\u09be\u099c\u09be\u0995\u09be\u09b0\u09a6\u09c7\u09b0 \u09a6\u09bf\u09df\u09c7! \u0995\u09c0 \u09ac\u09b2\u09ac\u09cb? \u0995\u09cd\u09b7\u09ae\u09a4\u09be\u09df \u0995\u09c7? \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u09a8\u09be\u0995\u09bf \u09b0\u09be\u099c\u09be\u0995\u09be\u09b0\u09b0\u09be? \u09af\u09c7-\u099b\u09c7\u09b2\u09c7\u099f\u09be\u0995\u09c7 \u099b\u09be\u09a4\u09cd\u09b0\u09b2\u09c0\u0997\u09c7\u09b0 \u09a2\u09be\u09ac\u09bf \u09b9\u09b2 \u09b6\u09be\u0996\u09be\u09b0 \u0985\u0996\u09cd\u09af\u09be\u09a4 \u0995\u09b0\u09cd\u09ae\u09b8\u0982\u09b8\u09cd\u09a5\u09be\u09a8 \u09ac\u09bf\u09b7\u09df\u0995 \u09b8\u09ae\u09cd\u09aa\u09be\u09a6\u0995 \u09a6\u09c7\u0996\u09be\u09a8\u09cb \u09b9\u099a\u09cd\u099b\u09c7, \u09aa\u09a6 \u09a6\u09c7\u0996\u09c7 \u09ac\u09c1\u099c\u09c7 \u09a8\u09bf\u09a8 \u0995\u09a4\u09cb \u09ac\u09dc \u09a8\u09c7\u09a4\u09be! \u098f\u0996\u09a8 \u098f\u09a8\u09b8\u09bf\u09aa\u09bf \u0993 \u09b6\u09bf\u09ac\u09bf\u09b0\u09c7\u09b0 \u09aa\u09a6\u09a7\u09be\u09b0\u09c0 \u099b\u09be\u09a4\u09cd\u09b0\u09b2\u09c0\u0997\u09be\u09b0\u09a6\u09c7\u09b0 \u09af\u09a6\u09bf \u099c\u09a8\u0997\u09a3 \u098f\u09ad\u09be\u09ac\u09c7 \u09a7\u09b0\u09c7 \u09aa\u09c1\u09b2\u09bf\u09b6\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u09b6\u09c1\u09b0\u09c1 \u0995\u09b0\u09c7? \u09b6\u09bf\u09ac\u09bf\u09b0 \u09b6\u09c7\u0996 \u09ae\u09c1\u099c\u09bf\u09ac\u0995\u09c7 \u0986\u09ac\u09cd\u09ac\u09be \u09a1\u09be\u0995\u09c7 \u09a8\u09be\u0987? \u099b\u09be\u09a4\u09cd\u09b0\u09b2\u09c0\u0997\u09c7\u09b0 \u0995\u09ae\u09bf\u099f\u09bf\u09a4\u09c7 \u09a4\u09be\u09b0\u09be \u099b\u09bf\u09b2\u09cb \u09a8\u09be? \u09b6\u09c7\u0996 \u09b9\u09be\u09b8\u09bf\u09a8\u09be\u0995\u09c7 \u09ae\u09ae\u09a4\u09be\u09ae\u09df\u09c0 \u09ae\u09be \u09a1\u09be\u0995\u09c7 \u09a8\u09be\u0987? \u099c\u09a8\u0997\u09a3 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf\u0995\u09c7 \u0995\u09cd\u09b7\u09ae\u09a4\u09be\u09df \u09aa\u09be\u09a0\u09bf\u09df\u09c7\u099b\u09c7, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u09ae\u09a8\u09c7 \u09b9\u099a\u09cd\u099b\u09c7 \u0995\u09cd\u09b7\u09ae\u09a4\u09be\u09df \u09a5\u09be\u0995\u09a4\u09c7 \u099a\u09be\u099a\u09cd\u099b\u09c7 \u09a8\u09be\u0964 \u09e7\u09e8 \u09a4\u09be\u09b0\u09bf\u0996 \u09af\u09c7-\u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7\u09c7\u09b0 \u0989\u09aa\u09b0 \u09ad\u09b0 \u0995\u09b0\u09c7 \u09ac\u09bf\u09aa\u09a6 \u09aa\u09be\u09b0 \u0995\u09b0\u09b2\u09cb, \u09b8\u09c7-\u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u0995\u09cd\u09b7\u09ae\u09a4\u09be\u09df \u0997\u09bf\u09df\u09c7\u0987 \u09ed\u0987 \u09ae\u09be\u09b0\u09cd\u099a\u09c7\u09b0 \u09ad\u09be\u09b7\u09a3 \u09ac\u09be\u099c\u09be\u09a8\u09cb\u0995\u09c7 \u09b8\u09a8\u09cd\u09a4\u09cd\u09b0\u09be\u09b8\u09c0 \u0995\u09b0\u09cd\u09ae\u0995\u09be\u09a3\u09cd\u09a1 \u09ac\u09b2\u09c7 \u09ae\u09be\u09ae\u09b2\u09be \u09a6\u09bf\u09b2\u09cb! \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09cb\u09a6\u09cd\u09a7\u09be \u099c\u09bf\u09df\u09be\u0989\u09b0 \u09b0\u09b9\u09ae\u09be\u09a8\u09c7\u09b0 \u09b8\u09a8\u09cd\u09a4\u09be\u09a8 \u09aa\u09cd\u09b0\u09a7\u09be\u09a8\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u09a5\u09be\u0995\u09be \u0985\u09ac\u09b8\u09cd\u09a5\u09be\u09df \u098f\u099f\u09be \u0998\u099f\u09b2\u09cb! \u099c\u09bf\u09df\u09be\u0989\u09b0 \u09b0\u09b9\u09ae\u09be\u09a8 \u0995\u09bf \u099c\u09c0\u09ac\u09a6\u09cd\u09a6\u09b6\u09be\u09df \u09ed\u0987 \u09ae\u09be\u09b0\u09cd\u099a\u09c7\u09b0 \u09ad\u09be\u09b7\u09a3 \u09ac\u09be\u099c\u09be\u09a8 \u09a8\u09bf? \u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8 \u098f\u0995\u099f\u09be \u0995\u09be\u099c \u0995\u09b0\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u09a8, \u09a4\u09be\u09b0 \u09ac\u09be\u09ac\u09be\u0995\u09c7 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7\u09c7 \u09af\u09be\u0993\u09df\u09be\u09b0 \u099c\u09a8\u09cd\u09af, \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be\u09b0 \u0998\u09cb\u09b7\u09a3\u09be \u09aa\u09cd\u09b0\u099a\u09be\u09b0 \u0995\u09b0\u09be\u09b0 \u099c\u09a8\u09cd\u09af, \u098f\u09ac\u0982 \u099c\u09c0\u09ac\u09a8\u09c7 \u0995\u09cb\u09a8\u09cb \u09a8\u09be \u0995\u09cb\u09a8\u09cb \u09b8\u09ae\u09df \u09ed\u0987 \u09ae\u09be\u09b0\u09cd\u099a\u09c7\u09b0 \u09ad\u09be\u09b7\u09a3 \u09ac\u09be\u099c\u09be\u09a8\u09cb\u09b0 \u099c\u09a8\u09cd\u09af \u0995\u09ac\u09b0 \u09a5\u09c7\u0995\u09c7 \u09a4\u09c1\u09b2\u09c7 \u098f\u09a8\u09c7 \u098f\u0995\u099f\u09be \u09ae\u09be\u09ae\u09b2\u09be \u09a6\u09bf\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u09a8\u0964\"",
