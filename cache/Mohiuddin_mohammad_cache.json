[
  {
    "title": "\u09eb \u0986\u0997\u09b8\u09cd\u099f\u09c7\u09b0 \u09aa\u09b0 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09aa\u09c7\u0987\u099c\u09c7 \u0995\u09a4\u09cb \u09ae\u09be\u09a8\u09c1\u09b7 \u09af\u09c7 \u0995\u09a4\u09cb \u09b8\u09be\u09b9\u09be\u09af\u09cd\u09af \u099a\u09c7\u09df\u09c7 \u09ae\u09c7\u09b8\u09c7\u099c \u09aa\u09be\u09a0\u09bf\u09df\u09c7\u099b\u09c7 \u0987\u09df\u09a4\u09cd\u09a4\u09be \u09a8\u09c7...",
    "description": "\u09eb \u0986\u0997\u09b8\u09cd\u099f\u09c7\u09b0 \u09aa\u09b0 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09aa\u09c7\u0987\u099c\u09c7 \u0995\u09a4\u09cb \u09ae\u09be\u09a8\u09c1\u09b7 \u09af\u09c7 \u0995\u09a4\u09cb \u09b8\u09be\u09b9\u09be\u09af\u09cd\u09af \u099a\u09c7\u09df\u09c7 \u09ae\u09c7\u09b8\u09c7\u099c \u09aa\u09be\u09a0\u09bf\u09df\u09c7\u099b\u09c7 \u0987\u09df\u09a4\u09cd\u09a4\u09be \u09a8\u09c7\u0987\u0964 \u0986\u09ae\u09b0\u09be\u0993 \u09b8\u09be\u09a7\u09cd\u09af \u0985\u09a8\u09c1\u09af\u09be\u09df\u09c0 \u09b8\u09be\u09b9\u09be\u09af\u09cd\u09af \u0995\u09b0\u09c7\u099b\u09bf \u0985\u09b8\u09b9\u09be\u09df \u0993 \u09a8\u09bf\u09b0\u09c2\u09aa\u09be\u09df \u09ae\u09be\u09a8\u09c1\u09b7\u09a6\u09c7\u09b0\u0964 \u0997\u09a4\u0995\u09be\u09b2 \u098f\u0987 \u09ae\u09c7\u09b8\u09c7\u099c\u099f\u09be \u09a6\u09c7\u0996\u09c7 \u0996\u09c1\u09ac \u0996\u09be\u09b0\u09be\u09aa \u09b2\u09c7\u0997\u09c7\u099b\u09bf\u09b2\u09cb\u0964 \u09b8\u099c\u09bf\u09ac \u0993\u09df\u09be\u099c\u09c7 \u099c\u09df \u09ac\u09be \u09b6\u09c7\u0996 \u09b9\u09be\u09b8\u09bf\u09a8\u09be \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u098f\u0987 \u09ac\u09bf\u09aa\u09a6\u0997\u09cd\u09b0\u09b8\u09cd\u09a4 \u09ae\u09be\u09a8\u09c1\u09b7\u0997\u09c1\u09b2\u09be\u09b0 \u0995\u09cb\u09a8\u09cb \u0996\u09cb\u0981\u099c\u0996\u09ac\u09b0 \u09a8\u09c7\u09df \u09a8\u09be\u0964 \u09b2\u09c1\u099f\u09aa\u09be\u099f\u0995\u09be\u09b0\u09c0 \u09b6\u09c7\u0996\u099a\u0995\u09cd\u09b0 \u098f\u0987 \u09ae\u09be\u09a8\u09c1\u09b7\u0997\u09c1\u09b2\u09cb\u0995\u09c7 \u09ac\u09bf\u09aa\u09a6\u09c7 \u09b0\u09c7\u0996\u09c7 \u09aa\u09be\u09b2\u09bf\u09df\u09c7 \u0997\u09c7\u099b\u09c7\u0964 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6 \u09a4\u09cb \u09ac\u09bf\u098f\u09a8\u09aa\u09bf\u09b0 \u09a6\u09be\u09b2\u09be\u09b2, \u09a4\u09be\u09b9\u09b2\u09c7 \u098f\u0987 \u0985\u09b8\u09b9\u09be\u09df \u09ae\u09be\u09a8\u09c1\u09b7\u0997\u09c1\u09b2\u09cb \u0995\u09c0 \u09ae\u09a8\u09c7 \u0995\u09b0\u09c7 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6 \u09b8\u09cd\u09af\u09be\u09b0\u09c7\u09b0 \u09a8\u09bf\u0995\u099f \u0986\u09b8\u09c7\u09a8? \u09ab\u09c7\u09b8\u09ac\u09c1\u0995\u09b2\u09c0\u0997\u09c7\u09b0 \u09ac\u09be\u099f\u09aa\u09be\u09b0\u09a6\u09c7\u09b0 \u09b0\u09c7\u0996\u09c7 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6\u09c7\u09b0 \u0989\u09aa\u09b0 \u09b8\u09ac\u09be\u09b0 \u098f\u09a4\u09cb \u0986\u09b8\u09cd\u09a5\u09be \u0993 \u09ad\u09b0\u09b8\u09be \u0995\u09c7\u09a8? \u09af\u09be\u0987\u09b9\u09cb\u0995 \u0986\u09ae\u09b0\u09be \u09eb\u09e6\u09e6 \u099f\u09be\u0995\u09be \u09aa\u09be\u09a0\u09bf\u09df\u09c7\u099b\u09bf\u09b2\u09be\u09ae \u0989\u09a8\u09be\u0995\u09c7\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8 \u09aa\u09cb\u09b8\u09cd\u099f)",
    "link": "https://www.facebook.com/oiraboti.book/posts/pfbid036RpSmt1VCi85BkJv1nUc6E6ncHkEVYcq4beU2JdbtvEAF5E6ohNG5N5P59nLe7K7l",
    "guid": "https://www.facebook.com/oiraboti.book/posts/pfbid036RpSmt1VCi85BkJv1nUc6E6ncHkEVYcq4beU2JdbtvEAF5E6ohNG5N5P59nLe7K7l",
