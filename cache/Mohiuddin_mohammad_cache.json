    "title": "'\u09ac\u09be\u09a8\u09b0\u09c7\u09b0 \u0986\u09df\u09a8\u09be' \u09ac\u0987\u09ae\u09c7\u09b2\u09be\u09df \u09aa\u09be\u0993\u09df\u09be \u09af\u09be\u09ac\u09c7 \u0986\u0997\u09be\u09ae\u09c0\u0995\u09be\u09b2, \u0985\u09b0\u09cd\u09a5\u09be\u09ce \u09b6\u09c1\u0995\u09cd\u09b0\u09ac\u09be\u09b0 \u09a5\u09c7\u0995\u09c7\u0964 \u09b8\u09cd\u099f\u09b2 \u09ee\u09ec\u09eb - \u09ee\u09ec\u09ee,...",
    "description": "'\u09ac\u09be\u09a8\u09b0\u09c7\u09b0 \u0986\u09df\u09a8\u09be' \u09ac\u0987\u09ae\u09c7\u09b2\u09be\u09df \u09aa\u09be\u0993\u09df\u09be \u09af\u09be\u09ac\u09c7 \u0986\u0997\u09be\u09ae\u09c0\u0995\u09be\u09b2, \u0985\u09b0\u09cd\u09a5\u09be\u09ce \u09b6\u09c1\u0995\u09cd\u09b0\u09ac\u09be\u09b0 \u09a5\u09c7\u0995\u09c7\u0964 \u09b8\u09cd\u099f\u09b2 \u09ee\u09ec\u09eb - \u09ee\u09ec\u09ee, \u09a8\u09be\u09b2\u09a8\u09cd\u09a6\u09be\u0964 \u09ac\u09be\u0995\u09bf \u09ac\u0987\u0997\u09c1\u09b2\u09cb \u099c\u09cd\u099e\u09be\u09a8\u0995\u09cb\u09b7\u09c7\u0964",
