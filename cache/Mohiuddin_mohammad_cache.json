  {
    "title": "\"\u09aa\u09cd\u09b0\u09be\u09a3\u09c0\u09b0 \u09ae\u09be\u0982\u09b8, \u09a4\u09c3\u09a3\u09c7\u09b0 \u09a6\u09c7\u09b9, \u098f\u0987 \u0996\u09be\u0987\u09df\u09be \u09ac\u09be\u0981\u099a\u09bf\u09df\u09be \u0986\u099b\u09bf\u0964 \u09af\u09c7-\u09b6\u09b0\u09c0\u09b0 \u09ac\u09b9\u09bf\u09df\u09be \u09ac\u09c7\u09dc\u09be\u0987\u09a4\u09c7\u099b\u09bf, \u0989\u09b9\u09be\u09b0 \u0995\u09a4...",
    "description": "\"\u09aa\u09cd\u09b0\u09be\u09a3\u09c0\u09b0 \u09ae\u09be\u0982\u09b8, \u09a4\u09c3\u09a3\u09c7\u09b0 \u09a6\u09c7\u09b9, \u098f\u0987 \u0996\u09be\u0987\u09df\u09be \u09ac\u09be\u0981\u099a\u09bf\u09df\u09be \u0986\u099b\u09bf\u0964 \u09af\u09c7-\u09b6\u09b0\u09c0\u09b0 \u09ac\u09b9\u09bf\u09df\u09be \u09ac\u09c7\u09dc\u09be\u0987\u09a4\u09c7\u099b\u09bf, \u0989\u09b9\u09be\u09b0 \u0995\u09a4\u09cb \u0986\u09a8\u09be \u0997\u09b0\u09c1\u09b0, \u0995\u09a4\u09cb \u0986\u09a8\u09be \u09ae\u09c1\u09b0\u0997\u09c0\u09b0, \u099c\u09be\u09a8\u09bf\u09ac\u09be\u09b0 \u0989\u09aa\u09be\u09df \u0995\u09c0? \u09af\u09c7-\u09ae\u09be\u099b \u09b8\u09be\u0997\u09b0 \u09b8\u09be\u0981\u09a4\u09b0\u09be\u0987\u09df\u09be \u09a8\u09a6\u09c0\u09a4\u09c7 \u0986\u09b8\u09c7, \u0989\u09b9\u09be \u09af\u09c7 \u09ae\u09be\u09a8\u09ac\u09a6\u09c7\u09b9\u09c7\u09b0 \u09a6\u0996\u09b2 \u09b2\u0987\u09a4\u09c7\u0987 \u099c\u09c7\u09b2\u09c7\u09b0 \u099c\u09be\u09b2\u09c7 \u09a7\u09b0\u09be \u09aa\u09dc\u09c7 \u09a8\u09be\u0987, \u09a4\u09be\u09b9\u09be \u0995\u09c7 \u09ac\u09b2\u09bf\u09ac\u09c7? \u09b2\u09be\u09b2\u09b6\u09be\u0995 \u0995\u09be\u0981\u099a\u09be\u0995\u09b2\u09be \u099a\u09bf\u0982\u09dc\u09bf\u09b0 \u09ad\u09be\u0997 \u09a6\u09be\u09ac\u09bf \u0995\u09b0\u09bf\u09a4\u09c7\u0987 \u09af\u09c7 \u09ae\u09b6\u09be \u0985\u09ae\u09a8 \u09ac\u09bf\u09a8\u09be \u099f\u09be\u0995\u09be\u09df \u09b9\u09c1\u09b2 \u09ab\u09cb\u0981\u099f\u09be\u0987\u09a4\u09c7\u099b\u09c7\u2014 \u098f\u0987 \u09b8\u09a8\u09cd\u09a6\u09c7\u09b9 \u0995\u09be\u09b9\u09be\u09b0 \u09a8\u09be\u0987? \u09aa\u09c7\u099f\u09c7 \u09af\u09c7\u0987\u09b8\u09ac \u09aa\u09dc\u09bf\u09a4\u09c7\u099b\u09c7, \u099a\u09cb\u0996\u09c7 \u09af\u09be\u09b9\u09be \u09a2\u09c1\u0995\u09bf\u09a4\u09c7\u099b\u09c7, \u09a4\u09be\u09b9\u09be\u09b0\u09be\u0987 \u09af\u09c7 \u09ae\u09bf\u09b2\u09bf\u09a4 \u09af\u09c1\u09a6\u09cd\u09a7\u09c7 \u0986\u09ae\u09be\u0995\u09c7 \u0986\u09ae\u09bf \u09ac\u09be\u09a8\u09be\u0987\u09df\u09be \u0986\u09aa\u09a8 \u0996\u09be\u09b8\u09b2\u09a4 \u09aa\u09cd\u09b0\u0995\u09be\u09b6 \u0995\u09b0\u09bf\u09a4\u09c7\u099b\u09c7, \u09b8\u09c7\u0987 \u09b8\u09a4\u09cd\u09af \u0985\u09b8\u09cd\u09ac\u09c0\u0995\u09be\u09b0\u09c7\u09b0 \u099c\u09cb \u0995\u0987? \u09ae\u09c1\u0996\u09c7\u09b0 \u0996\u09be\u09a6\u09cd\u09af\u09c7 \u09ac\u09bf\u09b7 \u099a\u09c7\u0995 \u0995\u09b0\u09bf\u09a4\u09c7 \u0995\u09a4\u09cb \u09a4\u09ce\u09aa\u09b0\u09a4\u09be, \u0986\u09a6\u09be\u09b2\u09a4 \u0985\u09a7\u09bf\u09a6\u09aa\u09cd\u09a4\u09b0 \u0995\u09c7\u09ae\u09bf\u09b8\u09cd\u099f, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09ae\u09a8\u09c7\u09b0 \u0996\u09be\u09a6\u09cd\u09af\u09c7\u09b0 \u09ac\u09bf\u09b7 \u09b2\u0987\u09df\u09be \u0995\u09c7\u09b9\u0987 \u099a\u09bf\u09a8\u09cd\u09a4\u09bf\u09a4 \u09a8\u09b9\u09c7\u0964 \u099a\u09cb\u0996-\u0995\u09be\u09a8 \u09a6\u09bf\u09df\u09be\u0993 \u09af\u09c7 \u09b8\u09c0\u09b8\u09be \u0995\u09be\u09b0\u09cd\u09ac\u09be\u0987\u09a1 \u09a8\u09bf\u09b0\u09a8\u09cd\u09a4\u09b0 \u09a2\u09c1\u0995\u09bf\u09a4\u09c7\u099b\u09c7, \u09a6\u09c7\u09b9 \u09aa\u09be\u09dc\u09be\u0987\u09df\u09be \u0987\u0989\u09ad\u09bf \u0997\u09be\u09ae\u09be \u09ae\u09a8\u09c7\u09b0 \u09ad\u09c7\u09a4\u09b0 \u09ae\u09bf\u0989\u099f\u09c7\u09b6\u09a8 \u0998\u099f\u09be\u0987\u09a4\u09c7\u099b\u09c7, \u09b8\u09c7\u0987 \u0996\u09ac\u09b0 \u09b0\u09be\u0996\u09bf\u09ac\u09c7 \u0995\u09c7? \u09af\u09c7\u0987 \u0995\u09cd\u09af\u09be\u09a8\u09cd\u09b8\u09be\u09b0 \u09a1\u09be\u0995\u09cd\u09a4\u09be\u09b0\u09bf \u09af\u09a8\u09cd\u09a4\u09cd\u09b0\u09c7 \u09a6\u09c3\u09b6\u09cd\u09af\u09ae\u09be\u09a8, \u0989\u09b9\u09be \u0995\u09c7\u09ae\u09cb \u09a6\u09bf\u09df\u09be \u09b8\u09be\u09b0\u09be\u0987\u09a4\u09c7 \u09aa\u09be\u09b0\u09bf, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8\u09c7\u09b0 \u0995\u09cd\u09af\u09be\u09a8\u09cd\u09b8\u09be\u09b0 \u0995\u09be\u099f\u09bf\u09ac\u09c7 \u0995\u09c7? \u0993\u0987\u0996\u09be\u09a8\u09c7 \u09ac\u09be\u09df\u09cb\u09aa\u09b8\u09bf \u0995\u09b0\u09bf\u09ac\u09be\u09b0 \u09af\u09a8\u09cd\u09a4\u09cd\u09b0 \u0995\u0987? \u099c\u09a8\u09cd\u09ae \u09b2\u0987\u09df\u09be\u0987 \u09af\u09c7-\u09b6\u09bf\u09b6\u09c1 \u09b6\u09c1\u09a8\u09bf\u09a4\u09c7 \u09aa\u09be\u09df\u2014 \u0995\u09bf\u09a4\u09be\u09ac\u09c7\u09b0 \u09ac\u09be\u09b9\u09bf\u09b0\u09c7 \u09af\u09be\u0993\u09df\u09be \u09af\u09be\u0987\u09ac\u09c7 \u09a8\u09be, \u09a4\u09be\u09b9\u09be\u0995\u09c7 \u09b8\u09c1\u09b8\u09cd\u09a5 \u0995\u09b0\u09bf\u09ac\u09be\u09b0 \u09b8\u09be\u09a7\u09cd\u09af \u0995\u09be\u09b9\u09be\u09b0? \u09aa\u09c7\u099f\u09c7\u09b0 \u0997\u09dc\u09b2 \u0989\u0997\u09b0\u09be\u09a8\u09cb \u09af\u09be\u09df, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09ae\u09a8\u09c7\u09b0 \u0997\u09dc\u09b2 \u09af\u09c7 \u09ac\u09ae\u09a8\u09c7\u09b0 \u0985\u09a4\u09c0\u09a4, \u0989\u09b9\u09be \u0995\u09cb\u09a8\u09cb \u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u09c7\u0987 \u09b6\u09c7\u0996\u09be\u09a8\u09cb \u09b9\u0987\u09a4\u09c7\u099b\u09c7 \u09a8\u09be\u0964 \u099a\u09be\u09b0\u09bf\u09a6\u09bf\u0995\u09c7 \u09ad\u09be\u09a4\u09c7\u09b0 \u09b9\u09cb\u099f\u09c7\u09b2\u0964 \u0996\u09be\u0987 \u0996\u09be\u0987 \u0996\u09be\u0987\u0964 \u0997\u09cb\u09b8, \u0986\u09b2\u09c1, \u09a1\u09be\u09b2 \u09a7\u09c1\u09ae\u09b8\u09c7 \u0989\u09a6\u09b0\u09c7 \u09a2\u09c1\u0995\u09bf\u09a4\u09c7\u099b\u09c7\u0964 \u099a\u09bf\u0995\u09a8\u09be \u09b2\u09cb\u0995 \u09a6\u09c7\u0996\u09bf\u09a8\u09be \u09ac\u09b2\u09bf\u09b2\u09c7 \u099a\u09b2\u09c7\u0964 \u09b2\u09be\u09ad \u0995\u09c0? \u09ae\u09a8\u09c7\u09b0 \u09b9\u09cb\u099f\u09c7\u09b2 \u098f\u0995\u0996\u09be\u09a8\u09be\u0993 \u09a8\u09be\u0987\u0964 \u09b8\u09bf\u09a8\u09c7\u09ae\u09be? \u09b9\u09be\u09b0\u09be\u09ae\u0964 \u0997\u09be\u09a8? \u09b9\u09be\u09b0\u09be\u09ae\u0964 \u09aa\u09cd\u09b0\u09c7\u09ae? \u09b9\u09be\u09b0\u09be\u09ae\u0964 \u09af\u09be\u09b9\u09be\u0987 \u09ae\u09a8\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u09a6\u09b0\u0995\u09be\u09b0\u09bf \u09aa\u09a5\u09cd\u09af, \u0993\u09b7\u09c1\u09a7, \u0989\u09b9\u09be \u09b9\u09be\u09b0\u09be\u09ae\u0964 \u09b6\u09b0\u09c0\u09b0 \u0996\u09be\u09ac\u09be\u09b0 \u09a8\u09be \u09aa\u09be\u0987\u09b2\u09c7 \u09a8\u09bf\u09b8\u09cd\u09a4\u09c7\u099c \u09b9\u09df, \u09aa\u09be\u0995-\u09ac\u09bf\u09aa\u09be\u0995 \u0995\u09ae\u09be\u0987\u09df\u09be \u09a6\u09c7\u09df, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09ae\u09a8 \u09aa\u09be\u0997\u09b2\u09be \u0997\u09b0\u09c1 \u09b9\u0987\u09df\u09be \u09a6\u09bf\u0997\u09cd\u09ac\u09bf\u09a6\u09bf\u0995 \u099b\u09c1\u099f\u09bf\u09a4\u09c7 \u09a5\u09be\u0995\u09c7\u0964 \u09a6\u09c1\u09b0\u09cd\u09ad\u09bf\u0995\u09cd\u09b7\u09c7 \u0985\u0996\u09be\u09a6\u09cd\u09af\u0987 \u0996\u09be\u09a6\u09cd\u09af, \u09aa\u09b6\u09c1 \u098f\u0987 \u09b8\u09c2\u09a4\u09cd\u09b0 \u09ae\u09be\u09a8\u09bf\u09df\u09be \u099a\u09b2\u09c7\u0964 \u0986\u099a\u09be\u09b0\u09c7\u09b0 \u0985\u09ad\u09be\u09ac\u0987 \u09af\u09c7 \u0985\u09a8\u09be\u099a\u09be\u09b0\u09c7\u09b0 \u09b6\u0995\u09cd\u09a4\u09bf, \u0995\u09be\u099c\u09c7\u09b0 \u0985\u09ad\u09be\u09ac\u0987 \u09af\u09c7 \u0995\u09c1\u0995\u09be\u099c\u09c7\u09b0 \u099a\u09be\u0995\u09be \u09b8\u099a\u09b2 \u09b0\u09be\u0996\u09c7\u2014 \u098f\u0987 \u09ac\u09cb\u09a7 \u09b8\u09ae\u09be\u099c\u09aa\u09a4\u09bf\u09a6\u09c7\u09b0 \u0986\u09b8\u09bf\u09ac\u09c7 \u0995\u09ac\u09c7? \u09ae\u09a8\u09c7\u09b0 \u09a4\u09cb \u0997\u09b2\u09be \u09a8\u09be\u0987 \u09af\u09c7 \u0989\u09b9\u09be\u0995\u09c7 \u09b0\u09b6\u09bf \u09aa\u09b0\u09be\u0987\u09df\u09be \u09ab\u09be\u0981\u09b8\u09bf\u09b0 \u09ad\u09df \u09a6\u09c7\u0996\u09be\u0987\u09ac\u09cb! \u09ae\u09c1\u0996\u0993 \u09a8\u09be\u0987 \u09af\u09c7 \u0996\u09c1\u09aa\u09be \u09b2\u09be\u0997\u09be\u0987\u09df\u09be \u0985\u09ac\u09b2\u09be \u0995\u09b0\u09bf\u09ac\u09cb!\" . \u2014\u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6 \u09aa\u09c3\u09b7\u09cd\u09a0\u09be \u09e7\u09ee, \u09ac\u0987: \u09a1\u09b2\u09bf\u09b0 \u0997\u09cd\u09b0\u09be\u09ae",
