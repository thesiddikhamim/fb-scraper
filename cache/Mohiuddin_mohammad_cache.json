    "title": "\u09ac\u09be\u09a8\u09b0\u09c7\u09b0 \u0986\u09df\u09a8\u09be \u09e9\u09e6% \u09b9\u09cb\u09b2\u09b8\u09c7\u09b2 \u099b\u09be\u09dc\u09c7 \u09a6\u09bf\u099a\u09cd\u099b\u09c7 \u098f\u0987 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be\u09a8\u0964 \u09a4\u09be\u09a6\u09c7\u09b0\u0995\u09c7 \u09ae\u09c7\u09b8\u09c7\u099c \u09aa\u09be\u09a0\u09be\u09a8\u0964",
    "description": "\u09ac\u09be\u09a8\u09b0\u09c7\u09b0 \u0986\u09df\u09a8\u09be \u09e9\u09e6% \u09b9\u09cb\u09b2\u09b8\u09c7\u09b2 \u099b\u09be\u09dc\u09c7 \u09a6\u09bf\u099a\u09cd\u099b\u09c7 \u098f\u0987 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be\u09a8\u0964 \u09a4\u09be\u09a6\u09c7\u09b0\u0995\u09c7 \u09ae\u09c7\u09b8\u09c7\u099c \u09aa\u09be\u09a0\u09be\u09a8\u0964",
