[
  {
    "title": "\u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09b0 \u099b\u09be\u09a4\u09cd\u09b0\u09b0\u09be\u0993 \u0997\u09ad\u09c0\u09b0 \u0986\u0997\u09cd\u09b0\u09b9 \u09a8\u09bf\u09df\u09c7 \u0995\u09bf\u09a8\u099b\u09c7\u09a8 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6\u2013\u098f\u09b0 \u09ac\u0987\u0964 \u09a4\u09be\u0981\u09b0 \u099a\u09bf\u09a8\u09cd\u09a4\u09be\u09b6...",
    "description": "\u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09b0 \u099b\u09be\u09a4\u09cd\u09b0\u09b0\u09be\u0993 \u0997\u09ad\u09c0\u09b0 \u0986\u0997\u09cd\u09b0\u09b9 \u09a8\u09bf\u09df\u09c7 \u0995\u09bf\u09a8\u099b\u09c7\u09a8 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6\u2013\u098f\u09b0 \u09ac\u0987\u0964 \u09a4\u09be\u0981\u09b0 \u099a\u09bf\u09a8\u09cd\u09a4\u09be\u09b6\u09c0\u09b2 \u09b2\u09c7\u0996\u09a8\u09c0, \u09af\u09c1\u0995\u09cd\u09a4\u09bf\u09a8\u09bf\u09b0\u09cd\u09ad\u09b0 \u09ac\u09bf\u09b6\u09cd\u09b2\u09c7\u09b7\u09a3 \u0993 \u09b8\u09ae\u09be\u099c\u09b8\u099a\u09c7\u09a4\u09a8 \u09a6\u09c3\u09b7\u09cd\u099f\u09bf\u09ad\u0999\u09cd\u0997\u09bf \u0987\u09a4\u09cb\u09ae\u09a7\u09cd\u09af\u09c7\u0987 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u09b6\u09cd\u09b0\u09c7\u09a3\u09bf-\u09aa\u09c7\u09b6\u09be\u09b0 \u09aa\u09be\u09a0\u0995\u09b0\u09be \u0985\u09a4\u09cd\u09af\u09a8\u09cd\u09a4 \u0986\u0997\u09cd\u09b0\u09b9\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u0997\u09cd\u09b0\u09b9\u09a3 \u0995\u09b0\u09c7\u099b\u09c7\u09a8\u0964 \u098f\u0996\u09a8 \u09aa\u09b0\u09cd\u09af\u09a8\u09cd\u09a4 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6\u2013\u098f\u09b0 \u09aa\u09cd\u09b0\u0995\u09be\u09b6\u09bf\u09a4 \u09ac\u0987\u09df\u09c7\u09b0 \u09b8\u0982\u0996\u09cd\u09af\u09be \u09ec\u099f\u09bf\u0964 \u09b8\u09ac\u0997\u09c1\u09b2\u09cb \u09ac\u0987-\u0987 \u09b8\u09ae\u09be\u09a8\u09ad\u09be\u09ac\u09c7 \u0997\u09c1\u09b0\u09c1\u09a4\u09cd\u09ac\u09aa\u09c2\u09b0\u09cd\u09a3 \u0964 \u09ac\u0987\u09ae\u09c7\u09b2\u09be\u09df \u09af\u09be\u09a8, \u099c\u09cd\u099e\u09be\u09a8\u0995\u09cb\u09b7 \u09aa\u09cd\u09b0\u0995\u09be\u09b6\u09a8\u09c0\u2013\u098f\u09b0 (\u09b8\u09cd\u099f\u09b2 \u09a8\u0982- \u09ed\u09ea\u09eb-\u09ed\u09ea\u09ef) \u09b8\u09cd\u099f\u09b2 \u09a5\u09c7\u0995\u09c7 \u09b8\u0982\u0997\u09cd\u09b0\u09b9 \u0995\u09b0\u09c1\u09a8 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6\u2013\u098f\u09b0 \u09ec\u099f\u09bf \u09ae\u09c2\u09b2\u09cd\u09af\u09ac\u09be\u09a8 \u09ac\u0987\u0964 \u09a8\u09bf\u099c\u09c7 \u09aa\u09dc\u09c1\u09a8, \u09aa\u09b0\u09bf\u09ac\u09be\u09b0-\u09aa\u09b0\u09bf\u099c\u09a8 \u0993 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0\u0993 \u09aa\u09dc\u09a4\u09c7 \u0989\u09ce\u09b8\u09be\u09b9\u09bf\u09a4 \u0995\u09b0\u09c1\u09a8\u0964 \u2014\u098f\u09a1\u09ae\u09bf\u09a8",
    "link": "https://www.facebook.com/oiraboti.book/posts/pfbid02aD6k3yK63bRqAxndHwUXrCaugfDnCmDPcYUhmgnDh8mzUaGyzja8LthWqbFCxXpSl",
