    "title": "\"\u09b6\u09c1\u09a8\u09bf\u09af\u09bc\u09be \u0985\u09ac\u09be\u0995 \u09b9\u0987\u09ac\u09c7\u09a8, \u09ae\u09c2\u09a2\u09bc\u0997\u09c1\u09b2\u09bf\u0995\u09c7 \u09ad\u09c3\u09a4\u09cd\u09af \u09b8\u09be\u099c\u09bf\u09ac\u09be\u09b0 \u0995\u09cb\u09a8\u09cb \u09a8\u09bf\u09b0\u09cd\u09a6\u09c7\u09b6\u09a8\u09be \u0986\u09ae\u09bf \u09aa\u09cd\u09b0\u09a6\u09be\u09a8 \u0995\u09b0\u09bf \u09a8\u09be\u0987,...",
    "description": "\"\u09b6\u09c1\u09a8\u09bf\u09af\u09bc\u09be \u0985\u09ac\u09be\u0995 \u09b9\u0987\u09ac\u09c7\u09a8, \u09ae\u09c2\u09a2\u09bc\u0997\u09c1\u09b2\u09bf\u0995\u09c7 \u09ad\u09c3\u09a4\u09cd\u09af \u09b8\u09be\u099c\u09bf\u09ac\u09be\u09b0 \u0995\u09cb\u09a8\u09cb \u09a8\u09bf\u09b0\u09cd\u09a6\u09c7\u09b6\u09a8\u09be \u0986\u09ae\u09bf \u09aa\u09cd\u09b0\u09a6\u09be\u09a8 \u0995\u09b0\u09bf \u09a8\u09be\u0987, \u09b8\u09c8\u09a8\u09bf\u0995 \u09b9\u0987\u09af\u09bc\u09be \u0986\u09ae\u09be\u09b0 \u09aa\u0995\u09cd\u09b7\u09c7 \u09af\u09c1\u09a6\u09cd\u09a7 \u0995\u09b0\u09bf\u09ac\u09be\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09a8 \u098f\u0995\u09ac\u09be\u09b0\u0993 \u099c\u09be\u09a8\u09be\u0987 \u09a8\u09be\u0987, \u09a4\u09a5\u09be\u09aa\u09bf \u0986\u09b9\u09be\u09ae\u09cd\u09ae\u0995\u0997\u09c1\u09b2\u09bf \u09a8\u09bf\u099c \u0989\u09a6\u09cd\u09af\u09cb\u0997\u09c7 \u0997\u09b2\u09be\u09af\u09bc \u09b6\u09c7\u0995\u09b2 \u09aa\u09b0\u09bf\u09af\u09bc\u09be \u0986\u09ae\u09be\u09b0 \u09a8\u09be\u09ae\u09c7 \u09ae\u09be\u09b0\u09be\u09ae\u09be\u09b0\u09bf \u0995\u09be\u099f\u09be\u0995\u09be\u099f\u09bf \u0995\u09b0\u09bf\u09a4\u09c7\u099b\u09c7; \u0986\u09ae\u09be\u0995\u09c7 \u09a4\u09c1\u09b7\u09cd\u099f \u0995\u09b0\u09bf\u09ac\u09be\u09b0 \u09a8\u09be\u09ae\u09c7 \u09b0\u09c1\u09b7\u09cd\u099f \u09ac\u09be\u09a8\u09be\u0987\u09a4\u09c7\u099b\u09c7\u0964 \u09a8\u09bf\u09b0\u09cd\u09ac\u09cb\u09a7\u09c7\u09b0\u09be \u09a4\u09be\u09b9\u09be\u09a6\u09c7\u09b0 \u09ae\u09a4\u09cb\u0987 \u0986\u09ae\u09be\u0995\u09c7 \u09ae\u09be\u09a8\u09c1\u09b7 \u09ae\u09a8\u09c7 \u0995\u09b0\u09bf\u09af\u09bc\u09be\u099b\u09c7\u0964 \u09ad\u09be\u09ac\u09bf\u09a4\u09c7\u099b\u09c7, \u09aa\u09c3\u09a5\u09bf\u09ac\u09c0\u09a4\u09c7 \u0988\u09b6\u09cd\u09ac\u09b0\u09c7\u09b0 \u09b6\u09be\u09b8\u09a8 \u0995\u09be\u09af\u09bc\u09c7\u09ae \u0995\u09b0\u09be \u09a6\u09b0\u0995\u09be\u09b0\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u098f \u09af\u09c7 \u0986\u09ae\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u0995\u09a4\u09cb \u09ac\u09a1\u09bc \u0985\u09aa\u09ae\u09be\u09a8, \u0995\u09a4\u09cb \u09ac\u09bf\u0995\u099f \u09b2\u09be\u09a8\u09a4, \u09a4\u09be\u09b9\u09be \u0985\u09a8\u09c1\u09ad\u09ac \u0995\u09b0\u09bf\u09ac\u09be\u09b0 \u0985\u09ac\u09b8\u09b0 \u0989\u09b9\u09be\u09a6\u09c7\u09b0 \u09a8\u09be\u0987\u0964 \u09a6\u09c2\u09b0\u09cd\u09ac\u09be \u09b2\u09a4\u09be \u09af\u0996\u09a8 \u09ae\u09b9\u09c0\u09b0\u09c1\u09b9\u09c7\u09b0 \u09ae\u09c2\u09b2\u09cd\u09af\u09be\u09af\u09bc\u09a8 \u0995\u09b0\u09c7, \u09a4\u0996\u09a8 \u098f\u0987\u09b0\u09c2\u09aa \u09ac\u09bf\u09aa\u09b0\u09cd\u09af\u09af\u09bc \u0998\u099f\u09c7\u0964 \u0988\u09b6\u09cd\u09ac\u09b0 \u09b9\u0987\u09af\u09bc\u09be \u0993\u09a0\u09c7\u09a8 \u09b6\u09be\u09b8\u0995! \u09af\u09a6\u09bf \u098f\u0995 \u09ae\u09c1\u09b9\u09c2\u09b0\u09cd\u09a4\u0993 \u0987\u09b9\u09be\u09b0\u09be \u0986\u09ae\u09be\u0995\u09c7 \u09b2\u0987\u09af\u09bc\u09be \u099a\u09bf\u09a8\u09cd\u09a4\u09be \u0995\u09b0\u09bf\u09a4\u09cb, \u09a7\u09cd\u09af\u09be\u09a8\u09c7 \u09ac\u09b8\u09bf\u09a4\u09cb, \u0985\u09a8\u09cd\u09af\u09c7\u09b0 \u099a\u09bf\u09a8\u09cd\u09a4\u09be\u09b0 \u09b8\u09be\u09a5\u09c7 \u09a8\u09bf\u099c\u09c7\u09b0 \u099a\u09bf\u09a8\u09cd\u09a4\u09be \u09ae\u09bf\u09b2\u09be\u0987\u09af\u09bc\u09be \u09a6\u09c7\u0996\u09bf\u09a4\u09cb, \u09a4\u09be \u09b9\u0987\u09b2\u09c7 \u09ac\u09c1\u099d\u09bf\u09a4\u09cb\u2014 \u0986\u09ae\u09be\u0995\u09c7 \u09af\u09c7-\u09b0\u09c2\u09aa\u09c7 \u0995\u09b2\u09cd\u09aa\u09a8\u09be \u0995\u09b0\u09be \u09b9\u0987\u09a4\u09c7\u099b\u09c7, \u09b8\u09c7-\u09b0\u09c2\u09aa \u0986\u09ae\u09be\u09b0 \u09a8\u09b9\u09c7\u0964 \u0986\u09ae\u09be\u0995\u09c7 \u0995\u09b2\u09cd\u09aa\u09a8\u09be \u0995\u09b0\u09bf\u09ac\u09be\u09b0 \u0995\u09b2\u09cd\u09aa\u09a8\u09be \u0995\u09be\u0989\u0995\u09c7 \u09a6\u09bf\u0987 \u09a8\u09be\u0987\u0964 \u0986\u09ae\u09bf \u09af\u09c7 \u09a8\u09be\u09b0\u09c0\u09b0 \u09aa\u09cb\u09b6\u09be\u0995 \u09b2\u0987\u09af\u09bc\u09be \u09ae\u09be\u09a5\u09be \u0998\u09be\u09ae\u09be\u0987 \u09a8\u09be, \u0997\u09be\u09a8-\u09ac\u09be\u099c\u09a8\u09be\u09b0 \u0986\u0993\u09af\u09bc\u09be\u099c \u09b6\u09c1\u09a8\u09bf\u09af\u09bc\u09be \u09ae\u09c3\u09a4\u09cd\u09af\u09c1\u09ac\u09b0\u09a3 \u0995\u09b0\u09bf \u09a8\u09be, \u0986\u09ae\u09bf \u09af\u09c7 \u09ae\u09be\u09a8\u09c1\u09b7\u09c7\u09b0 \u09ae\u09a4\u09cb \u0995\u09cd\u09b7\u09c1\u09a6\u09cd\u09b0 \u09a8\u0987, \u0997\u09b0\u09bf\u09ac \u09a8\u0987, \u0986\u09ae\u09bf \u09af\u09c7 \u09ae\u09b9\u09be\u09a7\u09a8\u09c0 \u09ae\u09b9\u09be\u099c\u09a8, \u0986\u09ae\u09bf \u09af\u09c7 \u0986\u09ae\u09bf \u0995\u09a5\u09be\u099f\u09bf\u09b0 \u0986\u09ae\u09bf \u09a8\u0987, \u098f\u09b8\u09ac \u098f\u0987 \u0995\u09c2\u09aa\u09ae\u09a3\u09cd\u09a1\u09c2\u0995\u0997\u09a3 \u09ac\u09c1\u099d\u09bf\u09af\u09bc\u09be\u0993 \u09ac\u09c1\u099d\u09bf\u09a4\u09c7\u099b\u09c7 \u09a8\u09be\u0964 \u0995\u09c7 \u0995\u09cb\u09a5\u09be\u09af\u09bc \u0995\u09cb\u09a8 \u09a7\u09b0\u09cd\u09ae \u09b2\u0987\u09af\u09bc\u09be \u099c\u09a8\u09cd\u09ae\u0997\u09cd\u09b0\u09b9\u09a3 \u0995\u09b0\u09bf\u09b2\u09cb, \u0995\u09c7 \u0995\u09cb\u09a8 \u0985\u099e\u09cd\u099a\u09b2\u09c7 \u09a8\u09bf\u099c\u09c7\u0995\u09c7 \u09b8\u09be\u09a7\u09c1, \u09b8\u09a8\u09cd\u09a4, \u09af\u09cb\u0997\u09c0, \u09aa\u09c0\u09b0, \u09ab\u0995\u09bf\u09b0, \u09aa\u09cd\u09b0\u09cb\u09ab\u09c7\u099f \u0998\u09cb\u09b7\u09a3\u09be \u09a6\u09bf\u09af\u09bc\u09be \u0986\u09ae\u09be\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u09a8\u09bf\u09a7\u09bf \u09b8\u09be\u099c\u09bf\u09af\u09bc\u09be \u0997\u09c7\u09b2\u09cb, \u0986\u09ae\u09be\u09b0 \u09a8\u09be\u09ae\u09c7 \u0986\u099c\u09c7\u09ac\u09be\u099c\u09c7 \u09ac\u0987 \u09b2\u09bf\u0996\u09bf\u09af\u09bc\u09be \u09ae\u09be\u09a8\u09c1\u09b7\u09c7\u09b0 \u0995\u09be\u0981\u09a7\u09c7 \u0985\u09a8\u09bf\u09b7\u09cd\u09a0\u0995\u09be\u09a8\u09c1\u09a8 \u099a\u09be\u09aa\u09be\u0987\u09af\u09bc\u09be \u09a6\u09bf\u09b2\u09cb, \u09b8\u09c7\u09b8\u09ac \u099c\u09b2\u09ac\u09bf\u09a8\u09cd\u09a6\u09c1 \u09b2\u0987\u09af\u09bc\u09be \u09ad\u09be\u09ac\u09bf\u09ac\u09be\u09b0 \u09ab\u09c1\u09b0\u09b8\u09a4 \u09af\u09c7 \u0986\u09ae\u09be\u09b0 \u09a8\u09be\u0987, \u0986\u09ae\u09be\u09b0 \u099a\u09cb\u0996 \u09a6\u09bf\u09af\u09bc\u09be \u09a6\u09c7\u0996\u09bf\u09b2\u09c7 \u09b8\u09cc\u09b0\u099c\u0997\u09ce\u099f\u09bf\u0995\u09c7\u0993 \u09af\u09c7 \u09a7\u09c2\u09b2\u09bf\u0995\u09a3\u09be \u09ae\u09a8\u09c7 \u09b9\u09af\u09bc, \u09a4\u09be\u09b9\u09be \u098f\u0987 \u09ae\u09be\u0995\u09be\u09b2\u09aa\u09bf\u09a3\u09cd\u09a1\u0997\u09c1\u09b2\u09bf \u098f\u0995\u09ac\u09be\u09b0\u0993 \u09ad\u09be\u09ac\u09bf\u09b2\u09cb \u09a8\u09be\u0964 \u0986\u09ae\u09be\u09b0 \u09a8\u09be\u09ae \u09ad\u09be\u0999\u09be\u0987\u09af\u09bc\u09be \u09af\u09a4\u09cd\u09b0\u09a4\u09a4\u09cd\u09b0 \u09a6\u09cb\u09af\u0996\u09c7\u09b0 \u099a\u09be\u09b7\u09be\u09ac\u09be\u09a6 \u0995\u09b0\u09bf\u09af\u09bc\u09be \u0997\u09c7\u09b2\u09cb\u0964 \u098f\u09b0 \u0993\u09b0 \u0997\u09b2\u09be \u0995\u09be\u099f\u09bf\u09b2\u09cb\u0964 \u09a8\u09bf\u09b0\u09c0\u09b9\u09c7\u09b0 \u09aa\u09bf\u09a0\u09c7 \u099b\u09c1\u09b0\u09bf \u09ae\u09be\u09b0\u09bf\u09b2\u09cb\u0964 \u09a7\u09b0\u09bf\u09a4\u09cd\u09b0\u09c0\u09b0 \u09ac\u09c1\u0995\u09c7 \u0986\u09a8\u09a8\u09cd\u09a6-\u0989\u09b2\u09cd\u09b2\u09be\u09b8 \u09a8\u09bf\u09b7\u09bf\u09a6\u09cd\u09a7 \u0995\u09b0\u09bf\u09af\u09bc\u09be \u09a6\u09bf\u09b2\u09cb\u0964 \u0985\u09a5\u099a \u0986\u09a8\u09a8\u09cd\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u0986\u09ae\u09be\u09b0 \u098f\u0995 \u09ac\u09bf\u09a8\u09cd\u09a6\u09c1\u0993 \u09b6\u09a4\u09cd\u09b0\u09c1\u09a4\u09be \u09a8\u09be\u0987\u0964\u201d . \u2014 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6 \u09aa\u09c3\u09b7\u09cd\u09a0\u09be \u09ea\u09ef-\u09eb\u09e6, \u09ac\u0987: \u099f\u09df\u09cb\u099f\u09be \u0995\u09b0\u09cb\u09b2\u09be \u099b\u09cb\u099f\u0997\u09b2\u09cd\u09aa \u2018\u0988\u09b6\u09cd\u09ac\u09b0\u09c7\u09b0 \u099f\u09c7\u09b2\u09bf\u09ab\u09cb\u09a8\u2019 \u09a5\u09c7\u0995\u09c7 \u09a8\u09c7\u09df\u09be",
    "link": "https://www.facebook.com/oiraboti.book/posts/pfbid0e4Et5wgFUUMFfjPSLruMoFKtngnmGgYHudXVgReMZmeyz6iF7vFa85YrDk3nJVPql",
