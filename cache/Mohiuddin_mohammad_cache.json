[
  {
    "title": "\u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8 \u0995\u09bf \u099c\u09be\u09a8\u09c7\u09a8 \u09af\u09c7, \u09a4\u09bf\u09a8\u09bf \u09af\u0996\u09a8 \u09b8\u09cd\u09a4\u09cd\u09b0\u09c0\u09b0 \u09b9\u09be\u09a4 \u09a7\u09b0\u09c7 \u09b9\u09be\u0981\u099f\u099b\u09c7\u09a8, \u09ac\u09be \u09ae\u09c7\u09df\u09c7 \u099c\u09be\u0987\u09ae\u09be\u0995\u09c7 \u09a8\u09bf\u09df\u09c7 ...",
    "description": "\u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8 \u0995\u09bf \u099c\u09be\u09a8\u09c7\u09a8 \u09af\u09c7, \u09a4\u09bf\u09a8\u09bf \u09af\u0996\u09a8 \u09b8\u09cd\u09a4\u09cd\u09b0\u09c0\u09b0 \u09b9\u09be\u09a4 \u09a7\u09b0\u09c7 \u09b9\u09be\u0981\u099f\u099b\u09c7\u09a8, \u09ac\u09be \u09ae\u09c7\u09df\u09c7 \u099c\u09be\u0987\u09ae\u09be\u0995\u09c7 \u09a8\u09bf\u09df\u09c7 \u0998\u09c1\u09b0\u099b\u09c7\u09a8, \u09a0\u09bf\u0995 \u09a4\u0996\u09a8 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u0995\u09cb\u09a8\u09cb \u09a8\u09be \u0995\u09cb\u09a8\u09cb \u09aa\u09cd\u09b0\u09be\u09a8\u09cd\u09a4\u09c7 \u099c\u09be\u0987\u09ae\u09be\u09b0 \u09a4\u09bf\u09a8 \u09ad\u09be\u0997\u09c7\u09b0 \u098f\u0995 \u09ad\u09be\u0997 \u09ac\u09df\u09b8\u09c0 \u09ae\u09c7\u09df\u09c7\u09b0\u09be \u09a7\u09b0\u09cd\u09b7\u09bf\u09a4 \u09b9\u099a\u09cd\u099b\u09c7\u2014 \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be \u09b6\u09bf\u0995\u09cd\u09b7\u0995\u09a6\u09c7\u09b0 \u09a6\u09cd\u09ac\u09be\u09b0\u09be? \u099b\u09be\u09a4\u09cd\u09b0\u09b0\u09be \u09b6\u09bf\u0995\u09be\u09b0 \u09b9\u099a\u09cd\u099b\u09c7 \u09ac\u09b2\u09be\u09ce\u0995\u09be\u09b0\u09c7\u09b0? \u09af\u09c7-\u09ae\u09c7\u09df\u09c7\u099f\u09be \u0997\u09b0\u09cd\u09ad\u09ac\u09a4\u09c0 \u09b9\u09df\u09c7\u099b\u09c7, \u09a4\u09be\u09b0 \u09ac\u09df\u09b8 \u098f\u09a4\u09cb \u0995\u09ae \u09af\u09c7 \u09b8\u09c7 \u09eb \u09ae\u09be\u09b8 \u09a7\u09b0\u09c7 \u09ac\u09c1\u099d\u09a4\u09c7\u0987 \u09aa\u09be\u09b0\u09c7\u09a8\u09bf \u09aa\u09c7\u099f\u09c7 \u09ac\u09be\u099a\u09cd\u099a\u09be \u0986\u099b\u09c7\u0964 \u09aa\u09c7\u099f\u09c7 \u0995\u09bf\u099b\u09c1 \u098f\u0995\u099f\u09be\u09b0 \u09a8\u09dc\u09be\u099a\u09dc\u09be \u099f\u09c7\u09b0 \u09aa\u09c7\u09df\u09c7 \u09b8\u09c7 \u09ae\u09be\u0995\u09c7 \u09ac\u09b2\u09c7 \u09af\u09c7 \u09a4\u09be\u09b0 \u09aa\u09c7\u099f\u09c7 \u0995\u09c0 \u09af\u09c7\u09a8 \u09a8\u09dc\u09c7\u0964 \u09a4\u0996\u09a8 \u09aa\u09b0\u09bf\u09ac\u09be\u09b0\u09c7\u09b0 \u09ac\u09cb\u09a7\u09cb\u09a6\u09af\u09bc \u09b9\u09df\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ac\u09be\u09ac\u09be-\u09ae\u09be\u09b0\u09be \u0995\u09c7\u09a8 \u099c\u09be\u09a8\u09bf \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09b0 \u09a8\u09be\u09ae \u09b6\u09c1\u09a8\u09b2\u09c7\u0987 \u09aa\u09be\u0997\u09b2 \u09b9\u09df\u09c7 \u09af\u09be\u09df\u0964 \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be \u09a8\u09be\u09ae\u0995 \u09a6\u09cb\u09af\u0996\u09c7 \u0986\u09aa\u09a8\u09be\u09b0 \u0986\u09a6\u09b0\u09c7\u09b0 \u09b8\u09a8\u09cd\u09a4\u09be\u09a8\u0995\u09c7 \u09aa\u09be\u09a0\u09be\u09a4\u09c7 \u09ac\u09bf\u09ac\u09c7\u0995\u09c7 \u09ac\u09be\u09a7\u09c7 \u09a8\u09be? \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be \u09b6\u09bf\u0995\u09cd\u09b7\u09be \u09a8\u09bf\u09df\u09c7 \u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8\u09c7\u09b0 \u09aa\u09b0\u09bf\u0995\u09b2\u09cd\u09aa\u09a8\u09be \u0995\u09c0? \u09a8\u09be\u0995\u09bf \u09a4\u09be\u09b0 \u09a8\u09bf\u099c\u09c7\u09b0 \u09b8\u09cd\u09a4\u09cd\u09b0\u09c0-\u09b8\u09a8\u09cd\u09a4\u09be\u09a8 \u09a8\u09bf\u09b0\u09be\u09aa\u09a6 \u09a5\u09be\u0995\u09b2\u09c7\u0987 \u09b9\u09b2\u09cb?",
