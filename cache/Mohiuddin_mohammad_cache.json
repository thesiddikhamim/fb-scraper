    "title": "\u098f\u0981\u0995\u09c7\u099b\u09c7\u09a8 \u09ac\u09b0\u09c7\u09a3\u09cd\u09af \u099a\u09bf\u09a4\u09cd\u09b0\u09b6\u09bf\u09b2\u09cd\u09aa\u09c0 \u099c\u09be\u09b9\u09c7\u09a6 \u09b0\u09ac\u09bf\u09a8\u0964 \u09ea\u09ee \u0987\u099e\u09cd\u099a\u09bf X \u09ea\u09e8 \u0987\u099e\u09cd\u099a\u09bf \u0995\u09cd\u09af\u09be\u09a8\u09ad\u09be\u09b8\u0964 (\u09b2\u09c7\u0996\u0995\u09c7\u09b0 \u09ac\u09cd\u09af...",
    "description": "\u098f\u0981\u0995\u09c7\u099b\u09c7\u09a8 \u09ac\u09b0\u09c7\u09a3\u09cd\u09af \u099a\u09bf\u09a4\u09cd\u09b0\u09b6\u09bf\u09b2\u09cd\u09aa\u09c0 \u099c\u09be\u09b9\u09c7\u09a6 \u09b0\u09ac\u09bf\u09a8\u0964 \u09ea\u09ee \u0987\u099e\u09cd\u099a\u09bf X \u09ea\u09e8 \u0987\u099e\u09cd\u099a\u09bf \u0995\u09cd\u09af\u09be\u09a8\u09ad\u09be\u09b8\u0964 (\u09b2\u09c7\u0996\u0995\u09c7\u09b0 \u09ac\u09cd\u09af\u0995\u09cd\u09a4\u09bf\u0997\u09a4 \u0986\u0987\u09a1\u09bf \u09a5\u09c7\u0995\u09c7 \u0995\u09aa\u09bf)",
