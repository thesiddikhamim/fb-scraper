    "guid": "https://www.facebook.com/oiraboti.book/posts/pfbid02RyXZxpcYqkRmtrx7MQXRuGfkTp4mKJMQFGfqPm59Rx4KwYAJ1CCAhi61JEBNhX5Cl",
