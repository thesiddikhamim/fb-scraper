  {
    "title": "\"\u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8 \u099f\u09c1\u09aa\u09bf \u099b\u09be\u09dc\u09be \u09a8\u09be\u09ae\u09be\u099c \u09aa\u09dc\u09c7\u099b\u09c7\u09a8\u0964 \u098f\u099f\u09be \u09ad\u09be\u09b2\u09cb\u0964 \u09a8\u09be\u09ae\u09be\u099c \u09aa\u09dc\u09a4\u09c7 \u099f\u09c1\u09aa\u09bf\u09b0 \u09aa\u09cd\u09b0\u09df\u09cb\u099c\u09a8 \u09a8\u09c7\u0987, \u09a4\u09ac\u09c7...",
    "description": "\"\u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8 \u099f\u09c1\u09aa\u09bf \u099b\u09be\u09dc\u09be \u09a8\u09be\u09ae\u09be\u099c \u09aa\u09dc\u09c7\u099b\u09c7\u09a8\u0964 \u098f\u099f\u09be \u09ad\u09be\u09b2\u09cb\u0964 \u09a8\u09be\u09ae\u09be\u099c \u09aa\u09dc\u09a4\u09c7 \u099f\u09c1\u09aa\u09bf\u09b0 \u09aa\u09cd\u09b0\u09df\u09cb\u099c\u09a8 \u09a8\u09c7\u0987, \u09a4\u09ac\u09c7 \u09a8\u09be\u09ae\u09be\u099c \u09a6\u09c7\u0996\u09be\u09a4\u09c7 \u099f\u09c1\u09aa\u09bf\u09b0 \u09a6\u09b0\u0995\u09be\u09b0 \u0986\u099b\u09c7\u0964 \u0987\u0989\u09a8\u09c2\u09b8\u0995\u09c7 \u099c\u09be\u09a4\u09bf \u0995\u0996\u09a8\u09cb \u09a8\u09be\u09ae\u09be\u099c \u09aa\u09dc\u09a4\u09c7 \u09a6\u09c7\u0996\u09c7\u09a8\u09bf, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09aa\u09cd\u09b0\u09a7\u09be\u09a8 \u0989\u09aa\u09a6\u09c7\u09b7\u09cd\u099f\u09be \u09b8\u09c7\u099c\u09c7 \u09a8\u09cc\u0995\u09be\u099f\u09c1\u09aa\u09bf \u09b2\u09be\u0997\u09bf\u09df\u09c7 \u09b8\u09be\u09b0\u09be\u09ac\u099b\u09b0 \u09a8\u09be\u09ae\u09be\u099c \u09a6\u09c7\u0996\u09bf\u09df\u09c7\u099b\u09c7\u0964 \u09a8\u09ac\u09c0 \u099f\u09c1\u09aa\u09bf \u09aa\u09b0\u09a4\u09c7\u09a8 \u09a8\u09be, \u09ae\u09be\u099d\u09c7\u09ae\u09a7\u09cd\u09af\u09c7 \u0989\u09dc\u09a8\u09be \u09aa\u09c7\u0981\u099a\u09be\u09a4\u09c7\u09a8, \u09b0\u09cb\u09a6 \u09a5\u09c7\u0995\u09c7 \u09ac\u09be\u0981\u099a\u09a4\u09c7\u0964 \u098f\u0996\u09a8 \u09a7\u09b0\u09cd\u09ae\u09ac\u09cd\u09af\u09ac\u09b8\u09be\u09df\u09c0\u09b0\u09be \u098f\u09b8\u09bf \u09ae\u09b8\u099c\u09bf\u09a6\u09c7\u0993 \u0986\u09b2\u0996\u09be\u09b2\u09cd\u09b2\u09be \u09b2\u09be\u0997\u09bf\u09df\u09c7 \u09a2\u09c1\u0995\u099b\u09c7\u0964 \u0995\u09be\u09b0\u09a3\u2014 \u09a8\u09be\u09ae\u09be\u099c \u09a6\u09c7\u0996\u09be\u09a4\u09c7 \u09b9\u09ac\u09c7\u0964 \u098f\u0987 \u09a6\u09c7\u0996\u09be\u09a8\u09cb\u099f\u09be\u0987 \u09a7\u09b0\u09cd\u09ae\u09ac\u09cd\u09af\u09ac\u09b8\u09be\u09b0 \u09aa\u09c1\u0981\u099c\u09bf\u0964\"",
