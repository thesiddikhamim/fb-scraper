  {
    "title": "\u09b2\u09c7\u0996\u0995\u09c7\u09b0 \u09ac\u09cd\u09af\u0995\u09cd\u09a4\u09bf\u0997\u09a4 \u09ab\u09c7\u09b8\u09ac\u09c1\u0995 \u0986\u0987\u09a1\u09bf\u09b0 \u09b2\u09bf\u0982\u0995 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u09b9\u09b2\u09cb\u0964",
    "description": "\u09b2\u09c7\u0996\u0995\u09c7\u09b0 \u09ac\u09cd\u09af\u0995\u09cd\u09a4\u09bf\u0997\u09a4 \u09ab\u09c7\u09b8\u09ac\u09c1\u0995 \u0986\u0987\u09a1\u09bf\u09b0 \u09b2\u09bf\u0982\u0995 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u09b9\u09b2\u09cb\u0964",
