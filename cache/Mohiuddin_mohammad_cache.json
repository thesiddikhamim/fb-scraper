[
  {
    "title": "\u0986\u09aa\u09a1\u09c7\u099f: \u09ae\u09be\u09ae\u09b2\u09be \u09a4\u09c1\u09b2\u09c7 \u09a8\u09c7\u0993\u09df\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u09aa\u09be\u09ad\u09c7\u09b2\u09c7\u09b0 \u09aa\u09b0\u09bf\u09ac\u09be\u09b0\u0995\u09c7 \u09a8\u09be\u09a8\u09be \u09aa\u09cd\u09b0\u09b2\u09cb\u09ad\u09a8 \u09a6\u09c7\u0996\u09be\u09a8\u09cb \u09b9\u099a\u09cd\u099b\u09c7\u0964 \u09b2\u09be\u0996 \u09b2\u09be...",
    "description": "\u0986\u09aa\u09a1\u09c7\u099f: \u09ae\u09be\u09ae\u09b2\u09be \u09a4\u09c1\u09b2\u09c7 \u09a8\u09c7\u0993\u09df\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u09aa\u09be\u09ad\u09c7\u09b2\u09c7\u09b0 \u09aa\u09b0\u09bf\u09ac\u09be\u09b0\u0995\u09c7 \u09a8\u09be\u09a8\u09be \u09aa\u09cd\u09b0\u09b2\u09cb\u09ad\u09a8 \u09a6\u09c7\u0996\u09be\u09a8\u09cb \u09b9\u099a\u09cd\u099b\u09c7\u0964 \u09b2\u09be\u0996 \u09b2\u09be\u0996 \u099f\u09be\u0995\u09be\u09b0 \u0986\u09aa\u09b7 \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09be\u09ac \u09a6\u09c7\u0993\u09df\u09be \u09b9\u099a\u09cd\u099b\u09c7\u0964 \u0985\u09a8\u09cd\u09af \u0995\u09be\u09df\u09a6\u09be\u09df\u0993 \u099a\u09c7\u09b7\u09cd\u099f\u09be \u099a\u09b2\u099b\u09c7\u0964 \u09ae\u09be\u09ab \u099a\u09be\u0993\u09df\u09be \u09b9\u099a\u09cd\u099b\u09c7\u0964 \u09aa\u09cd\u09b0\u09bf\u09df \u09a6\u09c7\u09b6\u09ac\u09be\u09b8\u09c0, \u0986\u099c \u09ac\u09be\u09aa-\u09ae\u09b0\u09be \u098f\u09a4\u09bf\u09ae \u099b\u09c7\u09b2\u09c7 \u09aa\u09be\u09ad\u09c7\u09b2\u0995\u09c7 \u09b8\u09c7\u09b9\u09b0\u09bf \u0996\u09be\u0993\u09df\u09be\u09b0 \u099f\u09c7\u09ac\u09bf\u09b2 \u09a5\u09c7\u0995\u09c7 \u0989\u09a0\u09bf\u09df\u09c7 \u09a8\u09bf\u09df\u09c7 \u09e9 \u0998\u09a8\u09cd\u099f\u09be \u09af\u09be\u09ac\u09a4 \u09aa\u09be\u09b6\u09ac\u09bf\u0995 \u0995\u09be\u09df\u09a6\u09be\u09df \u09a8\u09bf\u09b0\u09cd\u09af\u09be\u09a4\u09a8 \u0995\u09b0\u09c7\u099b\u09c7\u0964 \u09b2\u09cb\u09b9\u09be\u09b0 \u09b0\u09a1, \u09ae\u09cb\u099f\u09b0\u09b8\u09be\u0987\u0995\u09c7\u09b2\u09c7\u09b0 \u099a\u09c7\u0987\u09a8, \u098f\u09b8\u09ac \u09a6\u09bf\u09df\u09c7 \u09aa\u09bf\u099f\u09bf\u09df\u09c7 \u0985\u09b0\u09cd\u09a7\u09ae\u09c3\u09a4 \u0995\u09b0\u09c7 \u09b6\u09be\u09b9\u09ac\u09be\u0997 \u09a5\u09be\u09a8\u09be\u09df \u09ab\u09c7\u09b2\u09c7 \u0997\u09c7\u099b\u09c7\u0964 \u0986\u0997\u09be\u09ae\u09c0\u0995\u09be\u09b2 \u098f\u099f\u09be \u0986\u09aa\u09a8\u09be\u09b0 \u09b8\u09a8\u09cd\u09a4\u09be\u09a8\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u0998\u099f\u09ac\u09c7\u0964 \u0995\u09be\u09b0\u09a3 \u0986\u09aa\u09a8\u09be\u09b0 \u09b8\u09a8\u09cd\u09a4\u09be\u09a8 \u09aa\u09be\u09ad\u09c7\u09b2\u09c7\u09b0 \u09ae\u09a4\u09cb\u0987 \u0995\u09cb\u09a8\u09cb \u09a8\u09be \u0995\u09cb\u09a8\u09cb \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u09c7 \u09ad\u09b0\u09cd\u09a4\u09bf \u09b9\u09ac\u09c7\u0964 \u09aa\u09be\u09ad\u09c7\u09b2 \u0986\u09aa\u09a8\u09be\u09a6\u09c7\u09b0\u0987 \u09b8\u09a8\u09cd\u09a4\u09be\u09a8\u0964 \u09b8\u09b0\u0995\u09be\u09b0\u0995\u09c7 \u09ac\u09be\u09a7\u09cd\u09af \u0995\u09b0\u09a4\u09c7 \u09b9\u09ac\u09c7 \u09ae\u09be\u09ae\u09b2\u09be\u09b0 \u0986\u09b8\u09be\u09ae\u09c0\u09a6\u09c7\u09b0 \u09a6\u09cd\u09b0\u09c1\u09a4 \u0997\u09cd\u09b0\u09c7\u09aa\u09cd\u09a4\u09be\u09b0 \u0995\u09b0\u09a4\u09c7\u0964 \u09b8\u09ac\u09be\u0987 \u09af\u09be\u09b0 \u09af\u09be\u09b0 \u0985\u09ac\u09b8\u09cd\u09a5\u09be\u09a8 \u09a5\u09c7\u0995\u09c7 \u09b8\u09b0\u09cd\u09ac\u09cb\u099a\u09cd\u099a \u09aa\u09cd\u09b0\u09a4\u09bf\u09ac\u09be\u09a6 \u099c\u09be\u09a8\u09be\u09a8\u0964 \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u09c7 \u099a\u09b2\u09c7 \u0986\u09b8\u09c1\u09a8\u0964 \u09b6\u09be\u09b9\u09ac\u09be\u0997 \u09a5\u09be\u09a8\u09be\u09b0 \u09b8\u09be\u09ae\u09a8\u09c7 \u0985\u09ac\u09b8\u09cd\u09a5\u09be\u09a8 \u09a8\u09bf\u09a8\u0964 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7 \u0986\u09aa\u09a8\u09be\u09b0 \u09b8\u09a8\u09cd\u09a4\u09be\u09a8 \u09af\u09c7\u09a8 \u098f\u09ae\u09a8 \u0998\u099f\u09a8\u09be\u09b0 \u09b6\u09bf\u0995\u09be\u09b0 \u09a8\u09be \u09b9\u09df, \u09a4\u09be \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u0995\u09b0\u200d\u09a4\u09c7\u0987 \u0986\u09aa\u09a8\u09be\u0995\u09c7 \u09aa\u09be\u09ad\u09c7\u09b2\u09c7\u09b0 \u09a8\u09cd\u09af\u09be\u09df\u09ac\u09bf\u099a\u09be\u09b0 \u09aa\u09cd\u09b0\u09be\u09aa\u09cd\u09a4\u09bf \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u0995\u09b0\u09a4\u09c7 \u09b9\u09ac\u09c7\u0964 \u09aa\u09be\u09ad\u09c7\u09b2\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09af\u09be \u0998\u099f\u09c7\u099b\u09c7 \u09a4\u09be \u0985\u09a4\u09cd\u09af\u09a8\u09cd\u09a4 \u0997\u09c1\u09b0\u09c1\u09a4\u09b0 \u0995\u0997\u09a8\u09bf\u099c\u09bf\u09ac\u09b2 \u0985\u09ab\u09c7\u09a8\u09cd\u09b8\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u09a8\u09cd\u09a4\u09be\u09a8\u09a6\u09c7\u09b0\u0995\u09c7 \u09ab\u09c7\u09b8\u09ac\u09c1\u0995\u09c7 \u09aa\u09cb\u09b8\u09cd\u099f \u09a6\u09c7\u0993\u09df\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u0995\u09c7\u0989 \u098f\u09ad\u09be\u09ac\u09c7 \u09aa\u09bf\u099f\u09bf\u09df\u09c7 \u0986\u09a7\u09ae\u09b0\u09be \u0995\u09b0\u09ac\u09c7, \u098f\u099f\u09be \u0995\u09cb\u09a8\u09cb\u09ad\u09be\u09ac\u09c7\u0987 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7 \u09b9\u09a4\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u09af\u09be\u09ac\u09c7 \u09a8\u09be\u0964 \u09aa\u09be\u09ad\u09c7\u09b2\u09c7\u09b0 \u0985\u09a7\u09bf\u0995\u09be\u09b0\u0987 \u0986\u09aa\u09a8\u09be\u09b0 \u0985\u09a7\u09bf\u0995\u09be\u09b0\u0964 \u09aa\u09be\u09ad\u09c7\u09b2\u09c7\u09b0 \u0985\u09a7\u09bf\u0995\u09be\u09b0 \u09b8\u09c1\u09b0\u0995\u09cd\u09b7\u09bf\u09a4 \u09a8\u09be \u09a5\u09be\u0995\u09b2\u09c7 \u0986\u09aa\u09a8\u09be\u09b0 \u0985\u09a7\u09bf\u0995\u09be\u09b0\u0993 \u09b8\u09c1\u09b0\u0995\u09cd\u09b7\u09bf\u09a4 \u09a5\u09be\u0995\u09ac\u09c7 \u09a8\u09be\u0964 \u0986\u099c \u09aa\u09be\u09ad\u09c7\u09b2, \u0986\u0997\u09be\u09ae\u09c0\u0995\u09be\u09b2 \u0986\u09aa\u09a8\u09be\u09b0 \u09b8\u09a8\u09cd\u09a4\u09be\u09a8\u0964 \u0986\u09aa\u09a8\u09be\u09b0 \u09b8\u09a8\u09cd\u09a4\u09be\u09a8 \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u09c7 \u0997\u09bf\u09df\u09c7 \u098f\u09ad\u09be\u09ac\u09c7 \u09ae\u09be\u09b0 \u0996\u09be\u0995, \u098f\u099f\u09be \u0986\u09aa\u09a8\u09bf \u099a\u09be\u09a8 \u0995\u09bf \u09a8\u09be? \u098f\u099f\u09be \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u0986\u0993\u09df\u09be\u09ae\u09c0 \u09b2\u09c0\u0997\u09c7\u09b0 \u09ac\u09bf\u09b7\u09df \u09a8\u09df\u0964 \u098f\u099f\u09be \u0986\u09aa\u09a8\u09be\u09b0 \u09b8\u09a8\u09cd\u09a4\u09be\u09a8\u09c7\u09b0 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7\u09b0 \u09ac\u09bf\u09b7\u09df\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u0995\u09b2\u09c7\u09b0 \u09ae\u09be\u09a5\u09be \u09a4\u09c1\u09b2\u09c7 \u09ac\u09be\u0981\u099a\u09be\u09b0 \u09ac\u09bf\u09b7\u09df\u0964",
    "link": "https://www.facebook.com/oiraboti.book/posts/pfbid099r1TQiCDc8yTkTX1mqxrtrL2YdVdeka3Ynmb23MVrxHK6DP6boo78Khswsj3ytYl",
