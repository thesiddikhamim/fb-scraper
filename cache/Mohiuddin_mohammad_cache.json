    "title": "\u09ab\u099f\u09cb\u0995\u09be\u09b0\u09cd\u09a1 \u0995\u09be\u09b0\u09cd\u099f\u09c7\u09b8\u09bf: \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df \u09b0\u0995\u09cd\u09b7\u09be \u0986\u09a8\u09cd\u09a6\u09cb\u09b2\u09a8",
    "description": "\u09ab\u099f\u09cb\u0995\u09be\u09b0\u09cd\u09a1 \u0995\u09be\u09b0\u09cd\u099f\u09c7\u09b8\u09bf: \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df \u09b0\u0995\u09cd\u09b7\u09be \u0986\u09a8\u09cd\u09a6\u09cb\u09b2\u09a8",
