[
  {
    "title": "\u09ac\u09be\u09a8\u09b0\u09c7\u09b0 \u0986\u09df\u09a8\u09be \u0985\u09a8\u09b2\u09be\u0987\u09a8\u09c7 \u09aa\u09be\u0993\u09df\u09be \u09af\u09be\u099a\u09cd\u099b\u09c7 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u09b2\u09bf\u0982\u0995\u09c7\u0964",
    "description": "\u09ac\u09be\u09a8\u09b0\u09c7\u09b0 \u0986\u09df\u09a8\u09be \u0985\u09a8\u09b2\u09be\u0987\u09a8\u09c7 \u09aa\u09be\u0993\u09df\u09be \u09af\u09be\u099a\u09cd\u099b\u09c7 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u09b2\u09bf\u0982\u0995\u09c7\u0964",
    "link": "https://www.facebook.com/oiraboti.book/posts/pfbid02CZ5dwchcTcaKCJrkixUHajrJghSHXuyoRFB7kXmegqczAVi5Jb7LKo3tqyKMhpLEl",
    "guid": "https://www.facebook.com/oiraboti.book/posts/pfbid02CZ5dwchcTcaKCJrkixUHajrJghSHXuyoRFB7kXmegqczAVi5Jb7LKo3tqyKMhpLEl",
    "pubDate": "2026-03-14T06:30:18.299471+00:00",
    "image": null
  },
  {
    "title": "\"\u098f\u0987 \u09ae\u09be\u09a8\u09c1\u09b7\u099f\u09be\u09b0 \u09b8\u09be\u09a5\u09c7 \u09a6\u09c1\u0987\u09ac\u09be\u09b0 \u09a6\u09c7\u0996\u09be \u09b9\u09df\u09c7\u099b\u09bf\u09b2\u09cb\u0964 \u098f\u0995\u09ac\u09be\u09b0 \u0986\u099c\u09bf\u09ae\u09aa\u09c1\u09b0\u09c7, \u0986\u09b0\u09c7\u0995\u09ac\u09be\u09b0 \u09aa\u09cd\u09b0\u09c7\u09b8 \u0995\u09cd\u09b2\u09be\u09ac\u09c7\u09b0 \u0995\u09be\u099b...",
    "description": "\"\u098f\u0987 \u09ae\u09be\u09a8\u09c1\u09b7\u099f\u09be\u09b0 \u09b8\u09be\u09a5\u09c7 \u09a6\u09c1\u0987\u09ac\u09be\u09b0 \u09a6\u09c7\u0996\u09be \u09b9\u09df\u09c7\u099b\u09bf\u09b2\u09cb\u0964 \u098f\u0995\u09ac\u09be\u09b0 \u0986\u099c\u09bf\u09ae\u09aa\u09c1\u09b0\u09c7, \u0986\u09b0\u09c7\u0995\u09ac\u09be\u09b0 \u09aa\u09cd\u09b0\u09c7\u09b8 \u0995\u09cd\u09b2\u09be\u09ac\u09c7\u09b0 \u0995\u09be\u099b\u09c7\u0964 \u0986\u099c\u09bf\u09ae\u09aa\u09c1\u09b0\u09c7 \u098f\u0995\u099f\u09bf \u098f\u09a4\u09bf\u09ae\u0996\u09be\u09a8\u09be \u09a5\u09c7\u0995\u09c7 \u09ac\u09c7\u09b0 \u09b9\u099a\u09cd\u099b\u09bf\u09b2\u09c7\u09a8\u0964 \u098f\u09a4\u09bf\u09ae\u0996\u09be\u09a8\u09be\u09b0 \u09aa\u09b0\u09bf\u099a\u09be\u09b2\u0995 \u099c\u09be\u09a8\u09be\u09b2\u09c7\u09a8, \u09ae\u09bf\u09b0\u09cd\u099c\u09be \u0986\u09ac\u09cd\u09ac\u09be\u09b8 \u09a2\u09be\u0995\u09be\u09df \u098f\u09b0\u0995\u09ae \u09ee-\u09e7\u09e6\u099f\u09be \u098f\u09a4\u09bf\u09ae\u0996\u09be\u09a8\u09be \u09a8\u09bf\u099c \u0996\u09b0\u099a\u09c7 \u099a\u09be\u09b2\u09be\u09a8\u0964 \u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8 \u09af\u0996\u09a8 \u09b2\u09a8\u09cd\u09a1\u09a8\u09c7, \u09a4\u0996\u09a8 \u099b\u09be\u09a4\u09cd\u09b0\u09a6\u09b2\u09c7\u09b0 \u099b\u09c7\u09b2\u09c7\u09aa\u09c7\u09b2\u09c7\u09b0\u09be \u09aa\u09c7\u099f\u09c7 \u09ad\u09c1\u0996 \u09b2\u09be\u0997\u09b2\u09c7 \u09ae\u09bf\u09b0\u09cd\u099c\u09be \u0986\u09ac\u09cd\u09ac\u09be\u09b8\u09c7\u09b0 \u09ac\u09be\u09dc\u09bf\u09a4\u09c7 \u0996\u09c7\u09a4\u09c7 \u09af\u09c7\u09a4\u09cb\u0964 \u0989\u09a8\u09be\u09b0 \u09ac\u09be\u09dc\u09bf \u0985\u09a8\u09c7\u0995\u099f\u09be \u09b2\u0999\u09cd\u0997\u09b0\u0996\u09be\u09a8\u09be\u09b0 \u09ae\u09a4\u09cb, \u098f\u0996\u09a8\u0993\u0964 \u09a2\u09be\u0995\u09be \u09ac\u09be\u09b0 \u098f\u09b8\u09cb\u09b8\u09bf\u09df\u09c7\u09b6\u09a8\u09c7 \u0985\u09a8\u09cd\u09a4\u09a4 \u09e7\u09e6 \u099c\u09a8 \u0986\u0987\u09a8\u099c\u09c0\u09ac\u09c0\u0995\u09c7 \u099c\u09be\u09a8\u09bf, \u09af\u09be\u09a6\u09c7\u09b0 \u0995\u09be\u099c\u0987 \u099b\u09bf\u09b2\u09cb \u09ac\u09bf\u098f\u09a8\u09aa\u09bf, \u099b\u09be\u09a4\u09cd\u09b0\u09a6\u09b2, \u0993 \u09af\u09c1\u09ac\u09a6\u09b2\u09c7\u09b0 \u0997\u09b0\u09bf\u09ac \u0995\u09b0\u09cd\u09ae\u09c0\u09a6\u09c7\u09b0 \u09ae\u09be\u09ae\u09b2\u09be \u09a6\u09c7\u0996\u09be\u09b6\u09cb\u09a8\u09be \u0995\u09b0\u09be, \u0996\u09b0\u099a \u09a6\u09bf\u09a4\u09c7\u09a8 \u09ae\u09bf\u09b0\u09cd\u099c\u09be \u0986\u09ac\u09cd\u09ac\u09be\u09b8\u0964 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf'\u09b0 \u09a6\u09c1\u0983\u09b8\u09ae\u09df\u09c7 \u0989\u09a8\u09be\u09b0 \u09ae\u09a4\u09cb \u0986\u09b6\u09cd\u09b0\u09df \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u0995\u09b0\u09cd\u09ae\u09c0\u09a6\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u0986\u09b0 \u09a4\u09c7\u09ae\u09a8 \u099b\u09bf\u09b2\u09cb \u09a8\u09be\u0964 \u098f\u09ae\u09a8\u0995\u09bf \u099c\u09be\u09ae\u09be\u09a4-\u09b6\u09bf\u09ac\u09bf\u09b0 \u0995\u09b0\u09cd\u09ae\u09c0\u09b0\u09be\u0993 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u09aa\u09b0\u09bf\u099a\u09df\u09c7 \u09ae\u09bf\u09b0\u09cd\u099c\u09be \u0986\u09ac\u09cd\u09ac\u09be\u09b8 \u09a5\u09c7\u0995\u09c7 \u09b8\u09c1\u09ac\u09bf\u09a7\u09be \u09a8\u09bf\u09df\u09c7\u099b\u09c7\u0964 \u098f\u0987 \u0986\u09aa\u09a6\u09ae\u09b8\u09cd\u09a4\u0995 \u09b0\u09be\u099c\u09a8\u09c0\u09a4\u09bf\u09ac\u09bf\u09a6 \u09b2\u09cb\u0995\u099f\u09be\u09b0 \u09b8\u09be\u09a5\u09c7 \u099c\u09be\u09ae\u09be\u09a4 \u09af\u09c7-\u09a8\u09cb\u0982\u09b0\u09be\u09ae\u09c0 \u0995\u09b0\u09b2\u09cb, \u099a\u09be\u09a8\u09cd\u09a6\u09be\u09ac\u09cd\u09ac\u09be\u09b8 \u099a\u09be\u09a8\u09cd\u09a6\u09be\u09ac\u09cd\u09ac\u09be\u09b8 \u09ac\u09b2\u09c7, \u09a4\u09be \u0986\u09a8\u09aa\u09cd\u09b0\u09bf\u09b8\u09bf\u09a1\u09c7\u09a8\u09cd\u099f\u09c7\u09a1\u0964 \u09b9\u09be\u0981\u099f\u09c1\u09b0 \u09ac\u09df\u09b8\u09c0 \u098f\u0995\u099f\u09be \u099b\u09c7\u09b2\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u09a6\u09bf\u09a8 \u0985\u0995\u09a5\u09cd\u09af \u09ad\u09be\u09b7\u09be\u09df \u0986\u0995\u09cd\u09b0\u09ae\u09a3 \u0995\u09b0\u09c7\u099b\u09c7\u0964 \u0995\u09b0\u09ac\u09c7\u0987 \u09a8\u09be \u0995\u09c7\u09a8? \u09a4\u09be\u09b0 \u09a8\u09bf\u099c\u09c7\u09b0 \u09a6\u09b2 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf'\u0987 \u098f\u0997\u09c1\u09b2\u09cb\u09b0 \u0986\u09b8\u09cd\u0995\u09be\u09b0\u09be \u09a6\u09bf\u09df\u09c7\u099b\u09c7\u0964 \u099b\u09be\u09a4\u09cd\u09b0\u09a6\u09b2, \u09af\u09c1\u09ac\u09a6\u09b2, \u0995\u09be\u0989\u0995\u09c7 \u09a6\u09c7\u0996\u09bf\u09a8\u09bf \u09ae\u09bf\u09b0\u09cd\u099c\u09be \u0986\u09ac\u09cd\u09ac\u09be\u09b8\u09c7\u09b0 \u09aa\u0995\u09cd\u09b7\u09c7 \u09b6\u0995\u09cd\u09a4 \u099c\u09ac\u09be\u09ac \u09a6\u09bf\u09a4\u09c7\u0964 \u09b0\u09be\u099c\u09be\u0995\u09be\u09b0\u09a6\u09c7\u09b0 \u0986\u0995\u09cd\u09b0\u09ae\u09a3\u09c7 \u09aa\u09b0\u09cd\u09af\u09c1\u09a6\u09b8\u09cd\u09a4 \u09ae\u09bf\u09b0\u09cd\u099c\u09be \u0986\u09ac\u09cd\u09ac\u09be\u09b8 \u099c\u09c0\u09ac\u09a8-\u09ae\u09c3\u09a4\u09cd\u09af\u09c1\u09b0 \u09b8\u09a8\u09cd\u09a7\u09bf\u0995\u09cd\u09b7\u09a3\u09c7\u0964 \u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8 \u0995\u09cb\u09a8\u09cb \u0995\u09be\u09b0\u09a3\u09c7 \u09a4\u09be\u0995\u09c7 \u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u09ac\u09be\u09a8\u09be\u09a8 \u09a8\u09bf\u0964 \u0998\u09cb\u09b2 \u0996\u09be\u0987\u09df\u09c7 \u09ac\u09c1\u099d \u09a6\u09bf\u09a4\u09c7 \u09b0\u09be\u099c\u09a8\u09c8\u09a4\u09bf\u0995 \u0989\u09aa\u09a6\u09c7\u09b7\u09cd\u099f\u09be \u09ac\u09be\u09a8\u09bf\u09df\u09c7\u099b\u09c7\u09a8, \u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0\u09b0 \u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be\u09df\u0964 \u09af\u09be\u0995\u09c7 \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8\u09c7 \u09b9\u09be\u09b0\u09be\u09a4\u09c7 \u09b0\u09be\u099c\u09be\u0995\u09be\u09b0\u09b0\u09be \u09b8\u09ac\u099a\u09c7\u09df\u09c7 \u09ac\u09c7\u09b6\u09bf \u09b6\u0995\u09cd\u09a4\u09bf \u09a8\u09bf\u09df\u09cb\u099c\u09bf\u09a4 \u0995\u09b0\u09c7\u099b\u09bf\u09b2\u09cb, \u09a4\u09be\u0995\u09c7 \u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8 \u09aa\u09cd\u09b0\u09a7\u09be\u09a8\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u09b9\u09df\u09c7 \u09b8\u09be\u0987\u09a1-\u09ac\u09c7\u099e\u09cd\u099a\u09c7 \u09ac\u09b8\u09bf\u09df\u09c7 \u09a6\u09bf\u09df\u09c7\u099b\u09c7\u09a8! \u0995\u09be\u0995\u09c7 \u0996\u09c1\u09b6\u09bf \u0995\u09b0\u09a4\u09c7? \u09b0\u09be\u099c\u09be\u0995\u09be\u09b0\u09a6\u09c7\u09b0? \u09b0\u09be\u099c\u09be\u0995\u09be\u09b0\u09b0\u09be \u098f\u0995\u099f\u09be \u09aa\u09cb\u0982\u099f\u09be \u099b\u09c7\u09b2\u09c7\u0995\u09c7 \u0995\u09c0 \u0995\u09be\u09b0\u09a3\u09c7 \u09b8\u09c7\u0987 \u0986\u09b8\u09a8\u09c7 \u09a8\u09be\u09ae\u09bf\u09df\u09c7\u099b\u09bf\u09b2\u09cb, \u09b8\u09c7-\u09b9\u09bf\u09b8\u09be\u09ac \u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8 \u09ac\u09cb\u099d\u09c7\u09a8? \u09a2\u09be\u0995\u09be\u09df \u09ac\u09bf\u098f\u09a8\u09aa\u09bf'\u09b0 \u09b0\u09be\u099c\u09a8\u09c0\u09a4\u09bf \u0985\u09b0\u09cd\u09a7\u09c7\u0995 \u099f\u09bf\u0995\u09c7 \u0986\u099b\u09c7 \u0986\u09ac\u09cd\u09ac\u09be\u09b8\u09c7\u09b0 \u0995\u09be\u09b0\u09a3\u09c7\u0964 \u0986\u099c \u09ae\u09be\u09b0\u09be \u09af\u09be\u0995, \u0995\u09be\u09b2 \u09ac\u09c1\u099d\u09ac\u09c7 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u0995\u09c0 \u09b9\u09be\u09b0\u09bf\u09df\u09c7\u099b\u09c7\u0964 \u09ae\u09bf\u09b0\u09cd\u099c\u09be \u0986\u09ac\u09cd\u09ac\u09be\u09b8\u09a6\u09c7\u09b0 \u0995\u09be\u09b0\u09a3\u09c7\u0987 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf\u0995\u09c7 \u0985\u09a8\u09c7\u0995 \u099a\u09c7\u09b7\u09cd\u099f\u09be\u09b0 \u09aa\u09b0\u0993 \u099f\u09c1\u0995\u09b0\u09cb \u099f\u09c1\u0995\u09b0\u09cb \u0995\u09b0\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u09a8\u09bf\u0964 \u09ae\u09bf\u09b0\u09cd\u099c\u09be \u0986\u09ac\u09cd\u09ac\u09be\u09b8 \u09b0\u09be\u099c\u09be\u0995\u09be\u09b0\u09ac\u09bf\u09b0\u09cb\u09a7\u09c0 \u09ae\u09be\u09a8\u09c1\u09b7\u0964 \u09a4\u09bf\u09a8\u09bf \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09aa\u0995\u09cd\u09b7\u09c7\u09b0 \u09ae\u09be\u09a8\u09c1\u09b7\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ae\u09be\u09a8\u09c1\u09b7\u0964 \u09b8\u0995\u09b2\u09c7\u09b0 \u09ae\u09be\u09a8\u09c1\u09b7\u0964 \u09a4\u09bf\u09a8\u09bf \u09ab\u09c7\u09b0\u09a4 \u0986\u09b8\u09c1\u09a8, \u098f\u0987 \u0995\u09be\u09ae\u09a8\u09be \u0995\u09b0\u09bf\u0964 \u098f\u09ac\u0982 \u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8\u0995\u09c7 \u09ac\u09b2\u09bf, \u09ae\u09bf\u09b0\u09cd\u099c\u09be \u0986\u09ac\u09cd\u09ac\u09be\u09b8\u0995\u09c7 \u0986\u09aa\u09a8\u09bf \u0985\u09aa\u09ae\u09be\u09a8 \u0995\u09b0\u09c7\u099b\u09c7\u09a8\u0964 \u09a4\u09be\u09b0 \u09ae\u09be\u09a8\u09b8\u09bf\u0995 \u09ac\u09bf\u09aa\u09b0\u09cd\u09af\u09df\u09c7\u09b0 \u0985\u09a8\u09c7\u0995\u099f\u09be \u09ac\u09dc \u0995\u09be\u09b0\u09a3 \u0986\u09aa\u09a8\u09bf\u0964 \u09b0\u09be\u099c\u09be\u0995\u09be\u09b0\u09b0\u09be \u09ae\u09bf\u09b0\u09cd\u099c\u09be \u0986\u09ac\u09cd\u09ac\u09be\u09b8\u0995\u09c7 \u09a6\u09c1\u09b0\u09cd\u09ac\u09b2 \u0995\u09b0\u09be\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf\u0995\u09c7 \u09a6\u09c1\u09b0\u09cd\u09ac\u09b2 \u0995\u09b0\u09a4\u09c7 \u099a\u09c7\u09df\u09c7\u099b\u09bf\u09b2\u09cb, \u0986\u09aa\u09a8\u09bf \u09b8\u09c7\u0987 \u099a\u09be\u0993\u09df\u09be \u09aa\u09c2\u09b0\u09a3 \u0995\u09b0\u09c7\u099b\u09c7\u09a8\u0964 \u0986\u09b0 \u0995\u09df\u09a6\u09bf\u09a8\u0987 \u09ac\u09be \u09ac\u09be\u0981\u099a\u09ac\u09c7\u09a8 \u09ae\u09bf\u09b0\u09cd\u099c\u09be \u0986\u09ac\u09cd\u09ac\u09be\u09b8? \u098f\u0996\u09a8 \u09a4\u09be\u0995\u09c7 \u09b9\u09be\u09b8\u09aa\u09be\u09a4\u09be\u09b2\u09c7 \u09a6\u09c7\u0996\u09a4\u09c7 \u0997\u09bf\u09df\u09c7\u099b\u09c7\u09a8, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09b8\u09c1\u09b8\u09cd\u09a5 \u09b9\u09b2\u09c7 \u0986\u09b8\u09b2 \u0995\u09be\u099c\u099f\u09be \u0995\u09b0\u09c1\u09a8\u0964 \u09ad\u09be\u09b2\u09cb \u098f\u0995\u099f\u09be \u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09a3\u09be\u09b2\u09df \u09a6\u09bf\u09a8\u0964 \u09a4\u09be\u0995\u09c7 \u0995\u09be\u099c\u09c7\u09b0 \u09ae\u09be\u099d\u09c7 \u09b0\u09be\u0996\u09c1\u09a8\u0964 \u09a4\u09bf\u09a8\u09bf \u09aa\u09cd\u09b0\u09ab\u09c1\u09b2\u09cd\u09b2 \u09a5\u09be\u0995\u09ac\u09c7\u09a8\u0964 \u09a4\u09be\u09b0 \u09b9\u09be\u09a4\u09c7 \u09af\u09be\u09a6\u09c7\u09b0 \u09b0\u09be\u099c\u09a8\u09c0\u09a4\u09bf\u0995 \u09a6\u09c0\u0995\u09cd\u09b7\u09be, \u09a4\u09be\u09a6\u09c7\u09b0 \u0985\u09a8\u09c7\u0995\u0995\u09c7\u0987 \u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u09ac\u09be\u09a8\u09bf\u09df\u09c7\u099b\u09c7\u09a8, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09b0\u09be\u099c\u09be\u0995\u09be\u09b0\u09a6\u09c7\u09b0 \u099a\u09be\u0993\u09df\u09be \u0985\u09a8\u09c1\u09af\u09be\u09df\u09c0 \u09b8\u09cd\u09ac\u09df\u0982 \u09a4\u09be\u0995\u09c7 \u09b0\u09be\u099c\u09a8\u09c8\u09a4\u09bf\u0995 \u0989\u09aa\u09a6\u09c7\u09b7\u09cd\u099f\u09be \u09a8\u09be\u09ae\u0995 \u09ad\u09c1\u099c\u09c1\u0982 \u09ad\u09be\u099c\u09c1\u0982 \u09b9\u09be\u09a4\u09c7 \u09a7\u09b0\u09bf\u09df\u09c7 \u09a6\u09bf\u09df\u09c7\u099b\u09c7\u09a8\u0964 \u0995\u09c7\u09a8, \u0989\u09a8\u09bf \u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u09b9\u09b2\u09c7 \u0995\u09bf \u0986\u09aa\u09a8\u09be\u0995\u09c7 \u09b0\u09be\u099c\u09a8\u09c0\u09a4\u09bf\u0995 \u0989\u09aa\u09a6\u09c7\u09b6 \u09a6\u09bf\u09a4\u09c7 \u0985\u09b8\u09ae\u09b0\u09cd\u09a5 \u09b9\u09a4\u09c7\u09a8? \u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0\u09b0\u09be \u09aa\u09cd\u09b0\u09a7\u09be\u09a8\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0\u0995\u09c7 \u09b0\u09be\u099c\u09a8\u09c0\u09a4\u09bf\u0995 \u0989\u09aa\u09a6\u09c7\u09b6 \u09a6\u09c7\u09a8 \u09a8\u09be?\" (\u09b2\u09c7\u0996\u0995 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6\u09c7\u09b0 \u09ac\u09cd\u09af\u09be\u0995\u09cd\u09a4\u09bf\u0997\u09a4 \u09ab\u09c7\u09b8\u09ac\u09c1\u0995 \u0986\u0987\u09a1\u09bf \u09a5\u09c7\u0995\u09c7 \u0995\u09aa\u09bf)",
