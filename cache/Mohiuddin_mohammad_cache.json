    "title": "\u09b2\u09c7\u0996\u0995 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6\u09c7\u09b0 \u09aa\u0995\u09cd\u09b7 \u09a5\u09c7\u0995\u09c7 \u09b8\u09ac\u09be\u0987\u0995\u09c7 \u0988\u09a6\u09c7\u09b0 \u09b6\u09c1\u09ad\u09c7\u099a\u09cd\u099b\u09be\u0964",
    "description": "\u09b2\u09c7\u0996\u0995 \u09ae\u09b9\u09bf\u0989\u09a6\u09cd\u09a6\u09bf\u09a8 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6\u09c7\u09b0 \u09aa\u0995\u09cd\u09b7 \u09a5\u09c7\u0995\u09c7 \u09b8\u09ac\u09be\u0987\u0995\u09c7 \u0988\u09a6\u09c7\u09b0 \u09b6\u09c1\u09ad\u09c7\u099a\u09cd\u099b\u09be\u0964",
