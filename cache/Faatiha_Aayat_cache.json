[
  {
    "title": "#\u09a8\u09b0\u09b8\u09bf\u0982\u09a6\u09c0'\u09b0 \u09ae\u09be\u099f\u09bf\u09a4\u09c7 \u09a6\u09be\u0981\u09dc\u09bf\u09df\u09c7 \u09af\u0996\u09a8 \u0986\u09ae\u09b0\u09be \u0989\u09af\u09bc\u09be\u09b0\u09c0-\u09ac\u099f\u09c7\u09b6\u09cd\u09ac\u09b0 \u098f\u09b0 \u09a6\u09bf\u0995\u09c7 \u09a4\u09be\u0995\u09be\u0987, \u09a4\u0996\u09a8 \u09ae\u09a8\u09c7 \u09b9\u09df \u098f\u099f\u09be ...",
    "description": "#\u09a8\u09b0\u09b8\u09bf\u0982\u09a6\u09c0'\u09b0 \u09ae\u09be\u099f\u09bf\u09a4\u09c7 \u09a6\u09be\u0981\u09dc\u09bf\u09df\u09c7 \u09af\u0996\u09a8 \u0986\u09ae\u09b0\u09be \u0989\u09af\u09bc\u09be\u09b0\u09c0-\u09ac\u099f\u09c7\u09b6\u09cd\u09ac\u09b0 \u098f\u09b0 \u09a6\u09bf\u0995\u09c7 \u09a4\u09be\u0995\u09be\u0987, \u09a4\u0996\u09a8 \u09ae\u09a8\u09c7 \u09b9\u09df \u098f\u099f\u09be \u09b6\u09c1\u09a7\u09c1 \u098f\u0995\u099f\u09bf \u09aa\u09cd\u09b0\u09a4\u09cd\u09a8\u09a4\u09be\u09a4\u09cd\u09a4\u09cd\u09ac\u09bf\u0995 \u09b8\u09cd\u09a5\u09be\u09a8 \u09a8\u09df, \u098f\u099f\u09bf \u09af\u09c7\u09a8 \u09b9\u09be\u099c\u09be\u09b0 \u09ac\u099b\u09b0\u09c7\u09b0 \u0987\u09a4\u09bf\u09b9\u09be\u09b8\u09c7\u09b0 \u09a8\u09c0\u09b0\u09ac \u09b8\u09cd\u09aa\u09a8\u09cd\u09a6\u09a8\u0964 \u0986\u09dc\u09be\u0987 \u09b9\u09be\u099c\u09be\u09b0 \u09ac\u099b\u09b0\u09c7\u09b0\u0993 \u09ac\u09c7\u09b6\u09bf \u09aa\u09c1\u09b0\u09a8\u09cb \u098f\u0987 \u09aa\u09cd\u09b0\u09be\u099a\u09c0\u09a8 \u09a8\u0997\u09b0\u09c0\u09b0 \u09ae\u09be\u099f\u09bf\u09a4\u09c7 \u098f\u0995\u09a6\u09bf\u09a8 \u09aa\u09be \u09ab\u09c7\u09b2\u09c7\u099b\u09bf\u09b2 \u09b8\u09c7\u0987\u09b8\u09ac \u09ae\u09be\u09a8\u09c1\u09b7, \u09af\u09be\u09b0\u09be \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u09a6\u09c7\u0996\u09c7\u099b\u09bf\u09b2 \u0989\u09a8\u09cd\u09a8\u09a4 \u09b8\u09ae\u09be\u099c\u09c7\u09b0, \u0997\u09dc\u09c7\u099b\u09bf\u09b2 \u09b8\u09ad\u09cd\u09af\u09a4\u09be\u09b0 \u09ad\u09bf\u09a4\u09cd\u09a4\u09bf\u0964 \u0986\u099c \u09b8\u09c7\u0987 \u098f\u0995\u0987 \u09ae\u09be\u099f\u09bf\u09a4\u09c7 \u09af\u0996\u09a8 \u09b6\u09c1\u09b0\u09c1 \u09b9\u09df #ZeroOlympiad \u098f\u09b0 \u0995\u09cd\u09af\u09be\u09ae\u09cd\u09aa\u09c7\u0987\u09a8, \u09a4\u0996\u09a8 \u09ae\u09a8\u09c7 \u09b9\u09df \u0987\u09a4\u09bf\u09b9\u09be\u09b8 \u0986\u09b0 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09ce \u09af\u09c7\u09a8 \u09b9\u09be\u09a4 \u09a7\u09b0\u09be\u09a7\u09b0\u09bf \u0995\u09b0\u09c7 \u09b9\u09be\u0981\u099f\u099b\u09c7\u0964 \u09a8\u09b0\u09b8\u09bf\u0982\u09a6\u09c0\u09b0 \u098f\u0987 \u0997\u09cc\u09b0\u09ac\u09ae\u09df \u09ad\u09c2\u09ae\u09bf\u09a4\u09c7 \u09a6\u09be\u0981\u09dc\u09bf\u09df\u09c7, \u09b6\u09a4\u09be\u09ac\u09cd\u09a6\u09c0\u09b0 \u0987\u09a4\u09bf\u09b9\u09be\u09b8\u0995\u09c7 \u09b8\u09be\u0995\u09cd\u09b7\u09c0 \u09b0\u09c7\u0996\u09c7 #ScholasticaModelCollege, #NationalCollegeOfEducation \u098f\u09ac\u0982 #NarsingdiModelCollege \u098f\u09b0 \u09a4\u09b0\u09c1\u09a3\u09a6\u09c7\u09b0 \u0995\u09a3\u09cd\u09a0\u09c7 \u0989\u099a\u09cd\u099a\u09be\u09b0\u09bf\u09a4 \u09b9\u099a\u09cd\u099b\u09c7 \u098f\u0995 \u09a8\u09a4\u09c1\u09a8 \u09aa\u09cd\u09b0\u09a4\u09bf\u099c\u09cd\u099e\u09be \u2014 \u09b6\u09c2\u09a8\u09cd\u09af \u09a5\u09c7\u0995\u09c7 \u09b6\u09c1\u09b0\u09c1 \u0995\u09b0\u09c7 \u09aa\u09c2\u09b0\u09cd\u09a3\u09a4\u09be\u09b0 \u09aa\u09a5\u09c7, \u09b8\u09ae\u09b8\u09cd\u09af\u09be\u09b0 \u0985\u09a8\u09cd\u09a7\u0995\u09be\u09b0 \u09ad\u09c7\u09a6 \u0995\u09b0\u09c7 \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be\u09b0 \u0986\u09b2\u09cb\u09df, \u0985\u09a4\u09c0\u09a4\u09c7\u09b0 \u0997\u09cc\u09b0\u09ac\u0995\u09c7 \u09b8\u0999\u09cd\u0997\u09c7 \u09a8\u09bf\u09df\u09c7 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7\u09b0 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac \u0997\u09dc\u09be\u09b0 \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09df\u09c7\u0964 Organized by #UnitedNarsingdiAlliance",
    "link": "https://www.facebook.com/FaatihaAayatOfficial/posts/pfbid0WKPkHWK3U58bBzqh7911qcAkQSJf6NKMKsLkxAZhgiq5SY2KNvFQzpRjUn9z56oSl",
    "guid": "https://www.facebook.com/FaatihaAayatOfficial/posts/pfbid0WKPkHWK3U58bBzqh7911qcAkQSJf6NKMKsLkxAZhgiq5SY2KNvFQzpRjUn9z56oSl",
    "pubDate": "2026-04-24T08:06:04.348482+00:00",
