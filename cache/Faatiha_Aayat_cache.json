  },
  {
    "title": "\u09b0\u09cb\u09b9\u09bf\u0999\u09cd\u0997\u09be \u09b6\u09b0\u09a3\u09be\u09b0\u09cd\u09a5\u09c0 \u09b6\u09bf\u09ac\u09bf\u09b0\u09c7\u09b0 \u09b8\u09c0\u09ae\u09be\u09ac\u09a6\u09cd\u09a7\u09a4\u09be\u09b0 \u09ad\u09c7\u09a4\u09b0 \u09a5\u09c7\u0995\u09c7\u0993 \u09af\u09c7 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u09a5\u09c7\u09ae\u09c7 \u09a5\u09be\u0995\u09c7 \u09a8\u09be, \u09a4\u09be\u09b0 \u098f\u0995 ...",
    "description": "\u09b0\u09cb\u09b9\u09bf\u0999\u09cd\u0997\u09be \u09b6\u09b0\u09a3\u09be\u09b0\u09cd\u09a5\u09c0 \u09b6\u09bf\u09ac\u09bf\u09b0\u09c7\u09b0 \u09b8\u09c0\u09ae\u09be\u09ac\u09a6\u09cd\u09a7\u09a4\u09be\u09b0 \u09ad\u09c7\u09a4\u09b0 \u09a5\u09c7\u0995\u09c7\u0993 \u09af\u09c7 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u09a5\u09c7\u09ae\u09c7 \u09a5\u09be\u0995\u09c7 \u09a8\u09be, \u09a4\u09be\u09b0 \u098f\u0995 \u099c\u09c0\u09ac\u09a8\u09cd\u09a4 \u09aa\u09cd\u09b0\u09ae\u09be\u09a3 \u0986\u099c \u098f\u0987 \u09a4\u09b0\u09c1\u09a3\u09b0\u09be\u0964 Zero Olympiad \u098f \u0985\u0982\u09b6\u0997\u09cd\u09b0\u09b9\u09a3 \u0995\u09b0\u09c7 \u09a4\u09be\u09b0\u09be \u09b6\u09c1\u09a7\u09c1 \u098f\u0995\u099f\u09bf \u09aa\u09cd\u09b0\u09a4\u09bf\u09af\u09cb\u0997\u09bf\u09a4\u09be\u09df \u0985\u0982\u09b6 \u09a8\u09c7\u09df\u09a8\u09bf, \u09a4\u09be\u09b0\u09be \u09a8\u09bf\u099c\u09c7\u09b0 \u09ad\u09be\u0997\u09cd\u09af \u09ac\u09a6\u09b2\u09c7\u09b0 \u098f\u0995 \u09b8\u09be\u09b9\u09b8\u09c0 \u09af\u09be\u09a4\u09cd\u09b0\u09be \u09b6\u09c1\u09b0\u09c1 \u0995\u09b0\u09c7\u099b\u09c7\u0964 United Nations \u09b8\u09cd\u09ac\u09c0\u0995\u09c3\u09a4 \u09b8\u09a8\u09a6 \u0985\u09b0\u09cd\u099c\u09a8 \u0995\u09b0\u09c7 \u09a4\u09be\u09b0\u09be \u0986\u099c \u09ac\u09c8\u09a7 \u09aa\u09a5\u09c7 \u0989\u099a\u09cd\u099a\u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0 \u09a6\u09cd\u09ac\u09be\u09b0 \u0989\u09a8\u09cd\u09ae\u09c1\u0995\u09cd\u09a4 \u0995\u09b0\u099b\u09c7\u0964 \u09a4\u09c1\u09b0\u09b8\u09cd\u0995, \u09ae\u09be\u09b2\u09df\u09c7\u09b6\u09bf\u09df\u09be, \u09b8\u09cc\u09a6\u09bf \u0986\u09b0\u09ac\u09c7\u09b0 \u09ae\u09a4\u09cb \u09a6\u09c7\u09b6\u0997\u09c1\u09b2\u09cb\u09a4\u09c7 \u098f\u0997\u09bf\u09df\u09c7 \u09af\u09be\u099a\u09cd\u099b\u09c7 \u09a8\u09a4\u09c1\u09a8 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7\u09b0 \u09b8\u09a8\u09cd\u09a7\u09be\u09a8\u09c7\u0964 \u0985\u09a8\u09cd\u09a7\u0995\u09be\u09b0 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09a4\u09be\u09b0 \u09ad\u09c7\u09a4\u09b0 \u09a5\u09c7\u0995\u09c7\u0993 \u09a4\u09be\u09b0\u09be \u09aa\u09cd\u09b0\u09ae\u09be\u09a3 \u0995\u09b0\u09c7\u099b\u09c7\u09ae \u09aa\u09b0\u09bf\u099a\u09df \u09a8\u09df, \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u0987 \u09ae\u09be\u09a8\u09c1\u09b7\u0995\u09c7 \u098f\u0997\u09bf\u09df\u09c7 \u09a8\u09c7\u09df\u0964 \u09a4\u09be\u09a6\u09c7\u09b0 \u098f\u0987 \u09aa\u09a5\u099a\u09b2\u09be \u09b8\u09a4\u09cd\u09af\u09bf\u0987 \u0985\u09a8\u09c1\u09aa\u09cd\u09b0\u09c7\u09b0\u09a3\u09be\u09b0 \u098f\u0995 \u0989\u099c\u09cd\u099c\u09cd\u09ac\u09b2 \u0986\u09b2\u09cb\u0995\u09ac\u09b0\u09cd\u09a4\u09bf\u0995\u09be \u09af\u09be \u0986\u0997\u09be\u09ae\u09c0 \u09aa\u09cd\u09b0\u099c\u09a8\u09cd\u09ae\u0995\u09c7 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u09a6\u09c7\u0996\u09a4\u09c7 \u09b6\u09c7\u0996\u09be\u09ac\u09c7, \u098f\u09ac\u0982 \u09b8\u09c7\u0987 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u09aa\u09c2\u09b0\u09a3\u09c7\u09b0 \u09b8\u09be\u09b9\u09b8 \u099c\u09cb\u0997\u09be\u09ac\u09c7\u0964",
    "link": "https://www.facebook.com/FaatihaAayatOfficial/posts/pfbid02idcJPZS1q4mrLyrJwu1rELN7ba3pA63wQFTtZZEsHQHZQTvgh8FTNLuqJJ8Kc7hrl",
    "guid": "https://www.facebook.com/FaatihaAayatOfficial/posts/pfbid02idcJPZS1q4mrLyrJwu1rELN7ba3pA63wQFTtZZEsHQHZQTvgh8FTNLuqJJ8Kc7hrl",
    "pubDate": "2026-03-25T15:53:38.991106+00:00",
