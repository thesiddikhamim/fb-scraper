[
  {
    "title": "\u09aa\u09cd\u09b0\u09a5\u09ae \u09aa\u09a6\u0995\u09cd\u09b7\u09c7\u09aa\u099f\u09be\u0987 \u09b9\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 \u0986\u09aa\u09a8\u09be\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u09aa\u09c2\u09b0\u09a3\u09c7\u09b0 \u09b8\u09c2\u099a\u09a8\u09be\u0964 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u09b2\u09bf\u0982\u0995\u09c7 \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09cd...",
    "description": "\u09aa\u09cd\u09b0\u09a5\u09ae \u09aa\u09a6\u0995\u09cd\u09b7\u09c7\u09aa\u099f\u09be\u0987 \u09b9\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 \u0986\u09aa\u09a8\u09be\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u09aa\u09c2\u09b0\u09a3\u09c7\u09b0 \u09b8\u09c2\u099a\u09a8\u09be\u0964 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u09b2\u09bf\u0982\u0995\u09c7 \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u0995\u09b0\u09c7 \u09af\u09c1\u0995\u09cd\u09a4 \u09b9\u09df\u09c7 \u09af\u09be\u09a8 Zero Olympiad \u098f\u09b0 \u09aa\u09cd\u09b0\u09a5\u09ae \u09b0\u09be\u0989\u09a8\u09cd\u09a1\u09c7. \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u0986\u09aa\u09a8\u09be\u09b0 \u099a\u09bf\u09a8\u09cd\u09a4\u09be, \u09b8\u09c3\u099c\u09a8\u09b6\u09c0\u09b2\u09a4\u09be \u0986\u09b0 \u09b8\u09be\u09b9\u09b8 \u09aa\u09be\u09ac\u09c7 \u098f\u0995 \u09a8\u09a4\u09c1\u09a8 \u09a6\u09bf\u0997\u09a8\u09cd\u09a4\u0964 \u09a4\u09be\u09b0\u09aa\u09b0? \u09aa\u09cd\u09b0\u09a5\u09ae \u09a7\u09be\u09aa \u09aa\u09c7\u09b0\u09bf\u09df\u09c7 \u0995\u09c0\u09ad\u09be\u09ac\u09c7 \u09aa\u09cc\u0981\u099b\u09c7 \u09af\u09be\u09ac\u09c7\u09a8 \u0986\u09b0\u0993 \u098f\u0995 \u09a7\u09be\u09aa \u09b8\u09be\u09ae\u09a8\u09c7 - \u09a6\u09cd\u09ac\u09bf\u09a4\u09c0\u09df \u09b0\u09be\u0989\u09a8\u09cd\u09a1\u09c7, \u09b8\u09c7\u0987 \u09af\u09be\u09a4\u09cd\u09b0\u09be\u09b0 \u09aa\u09a5\u09a8\u09bf\u09b0\u09cd\u09a6\u09c7\u09b6\u09a8\u09be \u099c\u09be\u09a8\u09a4\u09c7 \u099a\u09cb\u0996 \u09b0\u09be\u0996\u09c1\u09a8 \u098f\u0987 \u09ad\u09bf\u09a1\u09bf\u0993\u09a4\u09c7\u0964 \u0995\u09be\u09b0\u09a3 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09ac\u09dc \u0985\u09b0\u09cd\u099c\u09a8\u09c7\u09b0 \u09b6\u09c1\u09b0\u09c1 \u09b9\u09df \u098f\u0995\u099f\u09bf \u099b\u09cb\u099f, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09a6\u09c3\u09dd \u09aa\u09a6\u0995\u09cd\u09b7\u09c7\u09aa \u09a5\u09c7\u0995\u09c7\u0987\u0964",
