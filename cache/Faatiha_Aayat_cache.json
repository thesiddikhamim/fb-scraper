[
  {
    "title": "\u098f\u0995\u099f\u09bf \u099a\u09bf\u09a0\u09bf\u2026 \u098f\u0995\u099f\u09bf \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u09c7\u09b0 \u0997\u09b2\u09cd\u09aa\u2026 \u0995\u09bf\u09b6\u09cb\u09b0\u0997\u099e\u09cd\u099c\u09c7\u09b0 \u098f\u0995 \u09a8\u09bf\u09ad\u09c3\u09a4 \u0995\u09cb\u09a3 \u09a5\u09c7\u0995\u09c7 \u0989\u09a0\u09c7 \u0986\u09b8\u09be \u098f\u0995 \u09a4\u09b0\u09c1\u09a3\u09c0\u0964 \u09b8...",
    "description": "\u098f\u0995\u099f\u09bf \u099a\u09bf\u09a0\u09bf\u2026 \u098f\u0995\u099f\u09bf \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u09c7\u09b0 \u0997\u09b2\u09cd\u09aa\u2026 \u0995\u09bf\u09b6\u09cb\u09b0\u0997\u099e\u09cd\u099c\u09c7\u09b0 \u098f\u0995 \u09a8\u09bf\u09ad\u09c3\u09a4 \u0995\u09cb\u09a3 \u09a5\u09c7\u0995\u09c7 \u0989\u09a0\u09c7 \u0986\u09b8\u09be \u098f\u0995 \u09a4\u09b0\u09c1\u09a3\u09c0\u0964 \u09b8\u09cb\u09b9\u09be\u09a6\u09be \u0986\u0996\u09a4\u09be\u09b0\u0964 \u0995\u0993\u09ae\u09c0 \u09ae\u09b9\u09bf\u09b2\u09be \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0 \u09b9\u09df\u09c7\u0993 \u09a4\u09bf\u09a8\u09bf \u09a5\u09c7\u09ae\u09c7 \u09a5\u09be\u0995\u09c7\u09a8\u09a8\u09bf \u09a8\u09bf\u099c\u09c7\u09b0 \u0997\u09a3\u09cd\u09a1\u09bf\u09a4\u09c7\u0964 \u09ac\u09b0\u0982 \u099c\u09cd\u099e\u09be\u09a8, \u09b8\u09be\u09b9\u09b8 \u0986\u09b0 \u0986\u09a4\u09cd\u09ae\u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8\u0995\u09c7 \u09b8\u0999\u09cd\u0997\u09c0 \u0995\u09b0\u09c7 \u099b\u09c1\u0981\u09df\u09c7 \u09ab\u09c7\u09b2\u09c7\u099b\u09c7\u09a8 \u09ac\u09c8\u09b6\u09cd\u09ac\u09bf\u0995 \u09aa\u09b0\u09bf\u09b8\u09b0\u0964 Zero Olympiad \u098f\u09b0 \u09b8\u09be\u09a5\u09c7 \u09af\u09c1\u0995\u09cd\u09a4 \u09b9\u09df\u09c7 \u09a4\u09bf\u09a8\u09bf \u09b6\u09c1\u09a7\u09c1 \u098f\u0995\u099f\u09bf \u09aa\u09cd\u09b0\u09a4\u09bf\u09af\u09cb\u0997\u09bf\u09a4\u09be\u09df \u0985\u0982\u09b6 \u09a8\u09c7\u09a8\u09a8\u09bf, \u09a4\u09bf\u09a8\u09bf \u09a8\u09bf\u099c\u09c7\u0995\u09c7 \u0997\u09dc\u09c7 \u09a4\u09c1\u09b2\u09c7\u099b\u09c7\u09a8 \u098f\u0995\u099c\u09a8 \u09b8\u099a\u09c7\u09a4\u09a8 \u0997\u09cd\u09b2\u09cb\u09ac\u09be\u09b2 \u09b8\u09bf\u099f\u09bf\u099c\u09c7\u09a8 \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7\u0964 \u201cClimate Change International Legal Regime\u201d \u0995\u09cb\u09b0\u09cd\u09b8 \u09b8\u09ae\u09cd\u09aa\u09a8\u09cd\u09a8 \u0995\u09b0\u09c7 \u0985\u09b0\u09cd\u099c\u09a8 \u0995\u09b0\u09c7\u099b\u09c7\u09a8 \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09b8\u09cd\u09ac\u09c0\u0995\u09c3\u09a4\u09bf \u09af\u09be \u09a4\u09be\u09b0 \u09aa\u09b0\u09bf\u09b6\u09cd\u09b0\u09ae, \u098f\u0995\u09be\u0997\u09cd\u09b0\u09a4\u09be \u0986\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u09c7\u09b0\u0987 \u09aa\u09cd\u09b0\u09a4\u09bf\u09ab\u09b2\u09a8\u0964 \u098f\u0987 \u099a\u09bf\u09a0\u09bf \u09b6\u09c1\u09a7\u09c1 \u0995\u09c3\u09a4\u099c\u09cd\u099e\u09a4\u09be\u09b0 \u09a8\u09df\u0964 \u098f\u099f\u09bf \u0985\u09a8\u09c1\u09aa\u09cd\u09b0\u09c7\u09b0\u09a3\u09be\u09b0\u0993 \u09ac\u099f\u09c7\u0964 \u098f\u099f\u09bf \u09ac\u09b2\u09c7 \u09a6\u09c7\u09df, \u09b8\u09c1\u09af\u09cb\u0997 \u09aa\u09c7\u09b2\u09c7 \u098f\u09ac\u0982 \u09b8\u09be\u09b9\u09b8 \u09a5\u09be\u0995\u09b2\u09c7 \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09b0 \u099a\u09be\u09b0 \u09a6\u09c7\u09df\u09be\u09b2\u0993 \u09b9\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 \u09ac\u09bf\u09b6\u09cd\u09ac\u09ae\u099e\u09cd\u099a\u09c7 \u09aa\u09cc\u0981\u099b\u09be\u09a8\u09cb\u09b0 \u09b8\u09bf\u0981\u09dc\u09bf\u0964 \u09b8\u09cb\u09b9\u09be\u09a6\u09be\u09b0 \u0995\u09a3\u09cd\u09a0\u09c7 \u09af\u09c7\u09a8 \u09b6\u09cb\u09a8\u09be \u09af\u09be\u09df \u09b9\u09be\u099c\u09be\u09b0\u09cb \u09ae\u09c7\u09df\u09c7\u09b0 \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be\u09b0 \u09a1\u09be\u0995, \u201c\u09aa\u09bf\u099b\u09bf\u09df\u09c7 \u09a5\u09c7\u0995\u09cb \u09a8\u09be, \u09a4\u09cb\u09ae\u09b0\u09be\u0993 \u09aa\u09be\u09b0\u09cb\u0964\u201d \u099a\u09b2\u09c1\u09a8, \u0986\u09ae\u09b0\u09be \u09b8\u09ac\u09be\u0987 \u09ae\u09bf\u09b2\u09c7 \u098f\u09ae\u09a8 \u0997\u09b2\u09cd\u09aa\u0997\u09c1\u09b2\u09cb \u099b\u09dc\u09bf\u09df\u09c7 \u09a6\u09bf\u0987\u0964 \u09af\u09be\u09a4\u09c7 \u0986\u09b0\u0993 \u0985\u09a8\u09c7\u0995 \u09b8\u09cb\u09b9\u09be\u09a6\u09be \u099c\u09a8\u09cd\u09ae \u09a8\u09c7\u09df, \u0986\u09b0\u0993 \u0985\u09a8\u09c7\u0995 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u0986\u09b2\u09cb\u09b0 \u09ae\u09c1\u0996 \u09a6\u09c7\u0996\u09c7\u0964 \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u09b2\u09bf\u0982\u0995 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09c7\u0964",
    "link": "https://www.facebook.com/FaatihaAayatOfficial/posts/pfbid02kFK2qSzeNU7Mdtyt78JfBWQjwCLvAVsaqUCNsBb4Tn5GyNbWdVyT6Xe1QtT4zBnbl",
    "guid": "https://www.facebook.com/FaatihaAayatOfficial/posts/pfbid02kFK2qSzeNU7Mdtyt78JfBWQjwCLvAVsaqUCNsBb4Tn5GyNbWdVyT6Xe1QtT4zBnbl",
    "pubDate": "2026-03-25T11:26:11.483745+00:00",
