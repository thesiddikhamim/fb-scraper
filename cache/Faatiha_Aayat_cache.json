[
  {
    "title": "\u099f\u09c7\u0995\u09b8\u0987 \u0989\u09a8\u09cd\u09a8\u09af\u09bc\u09a8 \u09b2\u0995\u09cd\u09b7\u09cd\u09af\u09ae\u09be\u09a4\u09cd\u09b0\u09be #SDG4 \u2014 #QualityEducation \u0995\u09c7\u09ac\u09b2 \u098f\u0995\u099f\u09bf \u09b2\u0995\u09cd\u09b7\u09cd\u09af \u09a8\u09af\u09bc\u0964 \u098f\u099f\u09bf \u09ae...",
    "description": "\u099f\u09c7\u0995\u09b8\u0987 \u0989\u09a8\u09cd\u09a8\u09af\u09bc\u09a8 \u09b2\u0995\u09cd\u09b7\u09cd\u09af\u09ae\u09be\u09a4\u09cd\u09b0\u09be #SDG4 \u2014 #QualityEducation \u0995\u09c7\u09ac\u09b2 \u098f\u0995\u099f\u09bf \u09b2\u0995\u09cd\u09b7\u09cd\u09af \u09a8\u09af\u09bc\u0964 \u098f\u099f\u09bf \u09ae\u09be\u09a8\u09ac\u099c\u09be\u09a4\u09bf\u09b0 \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be\u09b0 \u09a6\u09b0\u099c\u09be \u0996\u09c1\u09b2\u09c7 \u09a6\u09c7\u0993\u09af\u09bc\u09be\u09b0 \u098f\u0995 \u09ae\u09b9\u09ce \u09aa\u09cd\u09b0\u09a4\u09bf\u09b6\u09cd\u09b0\u09c1\u09a4\u09bf\u0964 \u098f\u09ae\u09a8 \u098f\u0995\u099f\u09bf \u09aa\u09c3\u09a5\u09bf\u09ac\u09c0\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8, \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09b6\u09bf\u09b6\u09c1\u09b0 \u09b9\u09be\u09a4\u09c7 \u09a5\u09be\u0995\u09ac\u09c7 \u099c\u09cd\u099e\u09be\u09a8\u09c7\u09b0 \u0986\u09b2\u09cb, \u0986\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be \u09b9\u09ac\u09c7 \u09b8\u09ae\u09a4\u09be, \u09a8\u09cd\u09af\u09be\u09af\u09bc \u098f\u09ac\u0982 \u09ae\u09be\u09a8\u09ac\u09bf\u0995 \u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be\u09b0 \u09ad\u09bf\u09a4\u09cd\u09a4\u09bf\u0964 \u098f\u0987 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u0995\u09c7\u0987 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09c7\u09b0 \u09aa\u09a5\u09c7 \u098f\u0997\u09bf\u09af\u09bc\u09c7 \u09a8\u09bf\u09a4\u09c7 \u099c\u09a8\u09cd\u09ae \u09a8\u09bf\u09af\u09bc\u09c7\u099b\u09c7 Zero Olympiad\u0964 \u098f\u0995\u099f\u09bf \u09ae\u099e\u09cd\u099a, \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u09b6\u09bf\u0995\u09cd\u09b7\u09be \u0995\u09c7\u09ac\u09b2 \u09ac\u0987\u09af\u09bc\u09c7\u09b0 \u09aa\u09be\u09a4\u09be\u09af\u09bc \u09b8\u09c0\u09ae\u09be\u09ac\u09a6\u09cd\u09a7 \u09a5\u09be\u0995\u09c7 \u09a8\u09be\u0964 \u09ac\u09b0\u0982 \u09a4\u09be \u09b9\u09af\u09bc\u09c7 \u0993\u09a0\u09c7 \u099a\u09bf\u09a8\u09cd\u09a4\u09be, \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac, \u09ae\u09be\u09a8\u09ac\u09bf\u0995\u09a4\u09be \u098f\u09ac\u0982 \u09aa\u09b0\u09bf\u09ac\u09b0\u09cd\u09a4\u09a8\u09c7\u09b0 \u09b6\u0995\u09cd\u09a4\u09bf\u0964 \u098f\u0996\u09be\u09a8\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0 \u0995\u09c7\u09ac\u09b2 \u09aa\u09cd\u09b0\u09a4\u09bf\u09af\u09cb\u0997\u09c0 \u09a8\u09af\u09bc, \u09ac\u09b0\u0982 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7\u09b0 \u09a8\u09bf\u09b0\u09cd\u09ae\u09be\u09a4\u09be\u0964 \u09af\u09be\u09b0\u09be \u099c\u09cd\u099e\u09be\u09a8\u0995\u09c7 \u09ac\u09cd\u09af\u09ac\u09b9\u09be\u09b0 \u0995\u09b0\u09ac\u09c7 \u09a6\u09be\u09b0\u09bf\u09a6\u09cd\u09b0\u09cd\u09af, \u09ac\u09c8\u09b7\u09ae\u09cd\u09af \u0993 \u0985\u099c\u09cd\u099e\u09a4\u09be\u09b0 \u0985\u09a8\u09cd\u09a7\u0995\u09be\u09b0 \u09a6\u09c2\u09b0 \u0995\u09b0\u09a4\u09c7\u0964 #ZeroOlympiad \u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8 \u0995\u09b0\u09c7, \u098f\u0995\u099f\u09bf \u0986\u09b2\u09cb\u0995\u09bf\u09a4 \u09ae\u09a8\u0987 \u09aa\u09be\u09b0\u09c7 \u09aa\u09c3\u09a5\u09bf\u09ac\u09c0\u0995\u09c7 \u09ac\u09a6\u09b2\u09c7 \u09a6\u09bf\u09a4\u09c7\u0964 \u09a4\u09be\u0987 \u098f\u0987 \u0989\u09a6\u09cd\u09af\u09cb\u0997 \u09a4\u09b0\u09c1\u09a3\u09a6\u09c7\u09b0 \u0995\u09a3\u09cd\u09a0\u0995\u09c7 \u09b6\u0995\u09cd\u09a4\u09bf\u09b6\u09be\u09b2\u09c0 \u0995\u09b0\u09c7, \u09a4\u09be\u09a6\u09c7\u09b0 \u099a\u09bf\u09a8\u09cd\u09a4\u09be\u0995\u09c7 \u09b8\u09be\u09b9\u09b8\u09c0 \u0995\u09b0\u09c7 \u098f\u09ac\u0982 \u09a4\u09be\u09a6\u09c7\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u0995\u09c7 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09c7\u09b0 \u09aa\u09a5\u09c7 \u09b9\u09be\u0981\u099f\u09a4\u09c7 \u09b6\u09c7\u0996\u09be\u09af\u09bc\u0964 \u0986\u099c\u0987 \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u0995\u09b0\u0964 \u09b2\u09bf\u0982\u0995 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09c7\u0964",
