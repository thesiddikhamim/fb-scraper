[
  {
    "title": "\u09b6\u09c1\u0995\u09cd\u09b0\u09ac\u09be\u09b0\u0964 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u099c\u09c1\u09ae\u0986'\u09b0 \u09a6\u09bf\u09a8\u0964 \u09b0\u09b9\u09ae\u09a4, \u09a8\u09c2\u09b0 \u0993 \u0986\u09a4\u09cd\u09ae\u09b6\u09c1\u09a6\u09cd\u09a7\u09bf\u09b0 \u098f\u0995 \u0985\u09a8\u09a8\u09cd\u09af \u09ae\u09c1\u09b9\u09c2\u09b0\u09cd\u09a4\u0964 \u098f\u0987 \u09ac\u09b0\u0995\u09a4\u09ae\u09df...",
    "description": "\u09b6\u09c1\u0995\u09cd\u09b0\u09ac\u09be\u09b0\u0964 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u099c\u09c1\u09ae\u0986'\u09b0 \u09a6\u09bf\u09a8\u0964 \u09b0\u09b9\u09ae\u09a4, \u09a8\u09c2\u09b0 \u0993 \u0986\u09a4\u09cd\u09ae\u09b6\u09c1\u09a6\u09cd\u09a7\u09bf\u09b0 \u098f\u0995 \u0985\u09a8\u09a8\u09cd\u09af \u09ae\u09c1\u09b9\u09c2\u09b0\u09cd\u09a4\u0964 \u098f\u0987 \u09ac\u09b0\u0995\u09a4\u09ae\u09df \u09a6\u09bf\u09a8\u09c7 \u0986\u09ae\u09bf \u09a6\u09c3\u09b7\u09cd\u099f\u09bf \u0986\u0995\u09b0\u09cd\u09b7\u09a3 \u0995\u09b0\u09a4\u09c7 \u099a\u09be\u0987 #\u0986\u09b2\u09bf\u09df\u09be \u0993 #\u0995\u0993\u09ae\u09bf \u099c\u0997\u09a4\u09c7\u09b0 \u09b8\u09c7\u0987 \u09a4\u09b0\u09c1\u09a3 \u09ae\u09c7\u09a7\u09be\u09ac\u09c0\u09a6\u09c7\u09b0 \u09a6\u09bf\u0995\u09c7 \u09af\u09be\u09a6\u09c7\u09b0 \u0995\u09be\u0981\u09a7\u09c7\u0987 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7\u09b0 \u0989\u09ae\u09cd\u09ae\u09be\u09b9\u09b0 \u0986\u09b6\u09be, \u09af\u09be\u09a6\u09c7\u09b0 \u099a\u09bf\u09a8\u09cd\u09a4\u09be\u09df \u09b2\u09c1\u0995\u09bf\u09df\u09c7 \u0986\u099b\u09c7 \u098f\u0995 \u09a8\u09a4\u09c1\u09a8 \u09ac\u09bf\u09b6\u09cd\u09ac \u0997\u09dc\u09be\u09b0 \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be\u0964 \u0990\u09a4\u09bf\u09b9\u09cd\u09af\u09ac\u09be\u09b9\u09c0 #\u09a2\u09be\u0995\u09be_\u0986\u09b2\u09bf\u09df\u09be \u098f\u09ac\u0982 \u0997\u09cc\u09b0\u09ac\u09cb\u099c\u09cd\u099c\u09cd\u09ac\u09b2 #\u09a6\u09cb\u09b2\u09c7\u09b6\u09cd\u09ac\u09b0_\u0987\u09b8\u09b2\u09be\u09ae\u09bf\u09df\u09be \u098f\u09b0 \u099b\u09be\u09a4\u09cd\u09b0 \u09ae\u09cb\u09b9\u09be\u09ae\u09cd\u09ae\u09a6 \u0986\u09ac\u09cd\u09a6\u09c1\u09b2 \u09ae\u09cb\u09ae\u09bf\u09a8 \u098f\u0995\u099c\u09a8 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u09ac\u09be\u099c \u09a4\u09b0\u09c1\u09a3\u0964 \u09a4\u09be\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u09b6\u09c1\u09a7\u09c1 \u09a8\u09bf\u099c\u09c7\u09b0 \u09ae\u09be\u099d\u09c7 \u09b8\u09c0\u09ae\u09be\u09ac\u09a6\u09cd\u09a7 \u09a8\u09df\u0964 \u09ac\u09b0\u0982 \u09ac\u09bf\u09b8\u09cd\u09a4\u09c3\u09a4 \u09aa\u09c1\u09b0\u09cb \u09ac\u09bf\u09b6\u09cd\u09ac \u09ae\u09c1\u09b8\u09b2\u09bf\u09ae \u099c\u09be\u09b9\u09be\u09a8 \u0993 \u09ac\u09c3\u09b9\u09a4\u09cd\u09a4\u09b0 \u0989\u09ae\u09cd\u09ae\u09be\u09b9\u09b0 \u0995\u09b2\u09cd\u09af\u09be\u09a3\u09c7\u0964 \u09b8\u09c7 \u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8 \u0995\u09b0\u09c7, \u0986\u099c\u0995\u09c7\u09b0 \u099b\u09be\u09a4\u09cd\u09b0\u09b0\u09be\u0987 \u0986\u0997\u09be\u09ae\u09c0 \u09a6\u09bf\u09a8\u09c7\u09b0 \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09af\u09be\u09b0\u09be \u099c\u09cd\u099e\u09be\u09a8, \u09ae\u09c2\u09b2\u09cd\u09af\u09ac\u09cb\u09a7 \u0993 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u09c7\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u0997\u09cb\u099f\u09be \u0987\u09b8\u09b2\u09be\u09ae\u09bf \u09ac\u09bf\u09b6\u09cd\u09ac\u0995\u09c7 \u0986\u09b2\u09cb\u0995\u09bf\u09a4 \u0995\u09b0\u09ac\u09c7\u0964 \u0986\u09b0 \u09b8\u09c7\u0987 \u09aa\u09a5\u09c7\u0987 \u098f\u0995 \u0997\u09c1\u09b0\u09c1\u09a4\u09cd\u09ac\u09aa\u09c2\u09b0\u09cd\u09a3 \u09aa\u09a6\u0995\u09cd\u09b7\u09c7\u09aa \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u09b8\u09c7 \u09ac\u09c7\u099b\u09c7 \u09a8\u09bf\u09df\u09c7\u099b\u09c7 Zero Olympiad\u0964 \u098f\u0995\u099f\u09bf \u098f\u09ae\u09a8 \u09aa\u09cd\u09b2\u09cd\u09af\u09be\u099f\u09ab\u09b0\u09cd\u09ae, \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u09b6\u09bf\u0995\u09cd\u09b7\u09be \u09b6\u09c1\u09a7\u09c1 \u09ac\u0987\u09df\u09c7\u09b0 \u09aa\u09be\u09a4\u09be\u09df \u09b8\u09c0\u09ae\u09be\u09ac\u09a6\u09cd\u09a7 \u09a8\u09df, \u09ac\u09b0\u0982 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac \u09aa\u09c3\u09a5\u09bf\u09ac\u09c0\u09b0 \u09b8\u09ae\u09b8\u09cd\u09af\u09be\u09b0 \u09b8\u09ae\u09be\u09a7\u09be\u09a8\u09c7 \u09b0\u09c2\u09aa \u09a8\u09c7\u09df\u0964 \u0997\u09a4\u09ac\u09be\u09b0 \u0986\u09ae\u09b0\u09be \u09a6\u09c7\u0996\u09c7\u099b\u09bf, Markazul Fiqhil islami \u098f\u09b0 \u099b\u09be\u09a4\u09cd\u09b0 #\u09ae\u09bf\u09a8\u09b9\u09be\u099c_\u09b9\u09cb\u09b8\u09c7\u0987\u09a8 \u099f\u09aa \u09a5\u09cd\u09b0\u09bf\u09a4\u09c7 \u099c\u09be\u09df\u0997\u09be \u0995\u09b0\u09c7 \u09a8\u09bf\u09df\u09c7 \u09aa\u09cd\u09b0\u09ae\u09be\u09a3 \u0995\u09b0\u09c7\u099b\u09c7 \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09b0\u09be\u0993 \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09ae\u099e\u09cd\u099a\u09c7 \u09a8\u09bf\u099c\u09c7\u09a6\u09c7\u09b0 \u09ae\u09c7\u09a7\u09be \u0993 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u09c7\u09b0 \u09b8\u09cd\u09ac\u09be\u0995\u09cd\u09b7\u09b0 \u09b0\u09be\u0996\u09a4\u09c7 \u09b8\u0995\u09cd\u09b7\u09ae\u0964 \u098f\u099f\u09bf \u09b6\u09c1\u09a7\u09c1 \u098f\u0995\u099f\u09bf \u0985\u09b0\u09cd\u099c\u09a8 \u09a8\u09df, \u098f\u099f\u09bf \u098f\u0995\u099f\u09bf \u09ac\u09be\u09b0\u09cd\u09a4\u09be\u0964 \u09af\u09c7, \u09b8\u09a0\u09bf\u0995 \u09a6\u09bf\u0995\u09a8\u09bf\u09b0\u09cd\u09a6\u09c7\u09b6\u09a8\u09be \u0993 \u09b8\u09c1\u09af\u09cb\u0997 \u09aa\u09c7\u09b2\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09a4\u09b0\u09c1\u09a3\u09c7\u09b0\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ae\u099e\u09cd\u099a\u09c7 \u09ae\u09be\u09a5\u09be \u0989\u0981\u099a\u09c1 \u0995\u09b0\u09c7 \u09a6\u09be\u0981\u09dc\u09be\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u0964 \u0986\u09ae\u09bf \u09a6\u09c3\u09dd\u09ad\u09be\u09ac\u09c7 \u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8 \u0995\u09b0\u09bf, \u098f \u09ac\u099b\u09b0\u0993 \u0986\u09b2\u09bf\u09df\u09be \u0993 \u0995\u0993\u09ae\u09bf \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09b0 \u099b\u09be\u09a4\u09cd\u09b0\u09b0\u09be \u098f\u0997\u09bf\u09df\u09c7 \u0986\u09b8\u09ac\u09c7\u0964 \u09a4\u09be\u09b0\u09be \u0985\u09b0\u09cd\u099c\u09a8 \u0995\u09b0\u09ac\u09c7 United Nations \u0993 Commonwealth \u098f\u09b0 \u09b8\u09cd\u09ac\u09c0\u0995\u09c3\u09a4\u09bf, \u09a8\u09bf\u099c\u09c7\u09a6\u09c7\u09b0 \u099c\u09be\u09df\u0997\u09be \u0995\u09b0\u09c7 \u09a8\u09c7\u09ac\u09c7 \u09ac\u09c8\u09b6\u09cd\u09ac\u09bf\u0995 \u0985\u0999\u09cd\u0997\u09a8\u09c7, \u098f\u09ac\u0982 \u09aa\u09cd\u09b0\u09ae\u09be\u09a3 \u0995\u09b0\u09ac\u09c7 \u0987\u09b2\u09ae, \u0987\u09ae\u09be\u09a8 \u0993 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac \u098f\u0995\u09b8\u09be\u09a5\u09c7 \u09ae\u09bf\u09b2\u09c7\u0987 \u09a4\u09c8\u09b0\u09bf \u0995\u09b0\u09c7 \u09aa\u09cd\u09b0\u0995\u09c3\u09a4 \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09a8\u09be\u0997\u09b0\u09bf\u0995\u0964 Madrasah-E-Alia, Dhaka \u098f\u09ac\u0982 Doleshwar Islamia Madrasah",
    "link": "https://www.facebook.com/FaatihaAayatOfficial/posts/pfbid02WA72vhs2jDWou1Zku11q9ioe5omgs7hNeN9MHfvwCHvtLrASQrb5y6hWFjrCkTSpl",
