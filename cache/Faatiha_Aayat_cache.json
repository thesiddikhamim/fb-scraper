  {
    "title": "\u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u09a6\u09c7\u0996\u09be\u09b0 \u09b8\u09be\u09b9\u09b8 \u09af\u09be\u09b0\u09be \u09b0\u09be\u0996\u09c7, \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09ce \u09a4\u09be\u09b0\u09be\u0987 \u0997\u09dc\u09c7\u0964 #ZeroOlympiad \u098f \u09a8\u09bf\u099c\u09c7\u09b0 \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be\u0995\u09c7...",
    "description": "\u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u09a6\u09c7\u0996\u09be\u09b0 \u09b8\u09be\u09b9\u09b8 \u09af\u09be\u09b0\u09be \u09b0\u09be\u0996\u09c7, \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09ce \u09a4\u09be\u09b0\u09be\u0987 \u0997\u09dc\u09c7\u0964 #ZeroOlympiad \u098f \u09a8\u09bf\u099c\u09c7\u09b0 \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be\u0995\u09c7 \u099b\u09c1\u0981\u09df\u09c7 \u09a6\u09c7\u0996\u09be\u09b0 \u09b8\u09c7\u0987 \u09b8\u09c1\u09af\u09cb\u0997 \u09b6\u09c7\u09b7 \u09b9\u09df\u09c7 \u0986\u09b8\u099b\u09c7 \u09a7\u09c0\u09b0\u09c7 \u09a7\u09c0\u09b0\u09c7\u2026 \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8\u09c7\u09b0 \u0986\u09b0 \u09ae\u09be\u09a4\u09cd\u09b0 \u09ee \u09a6\u09bf\u09a8 \u09ac\u09be\u0995\u09bf! \u0986\u099c\u0987 \u098f\u0997\u09bf\u09df\u09c7 \u0986\u09b8\u09c1\u09a8\u0964 \u09a8\u09bf\u099c\u09c7\u0995\u09c7 \u09aa\u09cd\u09b0\u09ae\u09be\u09a3 \u0995\u09b0\u09be\u09b0 \u098f\u0987 \u09af\u09be\u09a4\u09cd\u09b0\u09be\u09df \u0985\u0982\u09b6 \u09a8\u09bf\u09a8, \u0995\u09be\u09b0\u09a3 \u09b9\u09df\u09a4\u09cb \u098f\u0987 \u098f\u0995\u099f\u09bf \u09b8\u09bf\u09a6\u09cd\u09a7\u09be\u09a8\u09cd\u09a4\u0987 \u09ac\u09a6\u09b2\u09c7 \u09a6\u09bf\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 \u0986\u09aa\u09a8\u09be\u09b0 \u0986\u0997\u09be\u09ae\u09c0\u09b0 \u0997\u09b2\u09cd\u09aa\u0964",
