[
  {
    "title": "\u09b8\u09cc\u09a6\u09bf \u0986\u0995\u09be\u09b6\u09c7 \u098f\u0996\u09a8\u09cb \u0993\u09a0\u09c7\u09a8\u09bf \u09b8\u09c7\u0987 \u09aa\u09cd\u09b0\u09a4\u09c0\u0995\u09cd\u09b7\u09bf\u09a4 \u099a\u09be\u0981\u09a6\u0964 \u09a4\u09be\u0987 \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7 \u0988\u09a6\u09c7\u09b0 \u099a\u09be\u0981\u09a6 \u0989\u09a0\u09ac\u09c7 ...",
    "description": "\u09b8\u09cc\u09a6\u09bf \u0986\u0995\u09be\u09b6\u09c7 \u098f\u0996\u09a8\u09cb \u0993\u09a0\u09c7\u09a8\u09bf \u09b8\u09c7\u0987 \u09aa\u09cd\u09b0\u09a4\u09c0\u0995\u09cd\u09b7\u09bf\u09a4 \u099a\u09be\u0981\u09a6\u0964 \u09a4\u09be\u0987 \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7 \u0988\u09a6\u09c7\u09b0 \u099a\u09be\u0981\u09a6 \u0989\u09a0\u09ac\u09c7 \u09b6\u09c1\u0995\u09cd\u09b0\u09ac\u09be\u09b0\u09c7\u09b0 \u09b8\u09a8\u09cd\u09a7\u09cd\u09af\u09be\u09b0 \u0986\u0995\u09be\u09b6\u09c7\u0964 \u098f\u0995\u099f\u09c1 \u09a5\u09be\u09ae\u09cb\u2026 \u09a4\u09be\u09b9\u09b2\u09c7 \u0995\u09bf \u098f\u09b0 \u09ae\u09be\u09a8\u09c7 \u2014 #RamadanReward \u098f\u09b0 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u0985\u09a7\u09cd\u09af\u09be\u09df \u09b6\u09c7\u09b7 \u09b9\u09df\u09c7 \u09af\u09be\u09ac\u09c7 \u09b6\u09c1\u0995\u09cd\u09b0\u09ac\u09be\u09b0 \u09b0\u09be\u09a4\u09c7\u0987? \u09b9\u09cd\u09af\u09be\u0981, \u09a0\u09bf\u0995 \u09a4\u09be\u0987\u0964 \u09b9\u09be\u09a4\u09c7 \u0986\u09b0 \u09ae\u09be\u09a4\u09cd\u09b0 \u0997\u09cb\u09a8\u09be \u0995\u09bf\u099b\u09c1 \u09b8\u09ae\u09df \u2014 \u09aa\u09cd\u09b0\u09be\u09df \u09ea\u09ee \u0998\u09a3\u09cd\u099f\u09be! \u098f\u0987 \u0985\u09ae\u09c2\u09b2\u09cd\u09af \u09ae\u09c1\u09b9\u09c2\u09b0\u09cd\u09a4\u0997\u09c1\u09b2\u09cb \u0986\u09b0 \u09ab\u09bf\u09b0\u09c7 \u0986\u09b8\u09ac\u09c7 \u09a8\u09be\u0964 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09a8\u09bf\u0983\u09b6\u09cd\u09ac\u09be\u09b8, \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09b8\u09c7\u0995\u09c7\u09a8\u09cd\u09a1 \u098f\u0996\u09a8 \u098f\u0995 \u098f\u0995\u099f\u09bf \u09b8\u09c1\u09af\u09cb\u0997 \u2014 \u09a8\u09bf\u099c\u09c7\u0995\u09c7 \u0997\u09dc\u09be\u09b0, \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09ce\u0995\u09c7 \u0986\u09b2\u09cb\u0995\u09bf\u09a4 \u0995\u09b0\u09be\u09b0\u0964 \u09a4\u09be\u0987 \u0986\u09b0 \u09a6\u09c7\u09b0\u09bf \u0995\u09c7\u09a8? \u09a8\u09bf\u099c\u09c7\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u0995\u09c7 \u0986\u09b0\u09c7\u0995 \u09a7\u09be\u09aa \u098f\u0997\u09bf\u09df\u09c7 \u09a8\u09bf\u09a4\u09c7, \u09ac\u09bf\u09b6\u09cd\u09ac\u09ae\u09be\u09a8\u09c7\u09b0 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u09c7\u09b0 \u09aa\u09a5\u09c7 \u09aa\u09cd\u09b0\u09a5\u09ae \u09aa\u09a6\u0995\u09cd\u09b7\u09c7\u09aa \u09b0\u09be\u0996\u09a4\u09c7 \u0986\u099c\u0987 \u09af\u09c1\u0995\u09cd\u09a4 \u09b9\u0993 Zero Olympiad \u098f\u0964 \u09b8\u09ae\u09df \u0985\u09aa\u09c7\u0995\u09cd\u09b7\u09be \u0995\u09b0\u09c7 \u09a8\u09be\u2026 \u09a4\u09c1\u09ae\u09bf\u0993 \u09a5\u09c7\u09ae\u09c7 \u09a5\u09c7\u0995\u09cb \u09a8\u09be\u0964",
