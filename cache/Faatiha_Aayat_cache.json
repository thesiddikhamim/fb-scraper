[
  {
    "title": "\u099c\u09c1\u09ae\u09cd\u09ae\u09be \u09ae\u09cb\u09ac\u09be\u09b0\u0995 - \u062c\u0645\u0639\u0629 \u0645\u0628\u0627\u0631\u0643\u0629 \u0987\u09b8\u09b2\u09be\u09ae \u098f\u09ae\u09a8 \u099c\u09cd\u099e\u09be\u09a8 \u0985\u09b0\u09cd\u099c\u09a8\u09c7\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09a8 \u099c\u09be\u09a8\u09be\u09df, \u09af\u09be \u09ae\u09be\u09a8\u09ac\u09a4\u09be\u09b0 \u0995\u09b2\u09cd...",
    "description": "\u099c\u09c1\u09ae\u09cd\u09ae\u09be \u09ae\u09cb\u09ac\u09be\u09b0\u0995 - \u062c\u0645\u0639\u0629 \u0645\u0628\u0627\u0631\u0643\u0629 \u0987\u09b8\u09b2\u09be\u09ae \u098f\u09ae\u09a8 \u099c\u09cd\u099e\u09be\u09a8 \u0985\u09b0\u09cd\u099c\u09a8\u09c7\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09a8 \u099c\u09be\u09a8\u09be\u09df, \u09af\u09be \u09ae\u09be\u09a8\u09ac\u09a4\u09be\u09b0 \u0995\u09b2\u09cd\u09af\u09be\u09a3\u09c7 \u0995\u09be\u099c\u09c7 \u09b2\u09be\u0997\u09c7 \u098f\u09ac\u0982 \u09aa\u09c3\u09a5\u09bf\u09ac\u09c0\u0995\u09c7 \u0986\u09b0\u0993 \u09a8\u09cd\u09af\u09be\u09df\u09ad\u09bf\u09a4\u09cd\u09a4\u09bf\u0995 \u0993 \u09b6\u09be\u09a8\u09cd\u09a4\u09bf\u09ae\u09df \u0995\u09b0\u09c7\u0964 \u098f\u0987 \u099a\u09c7\u09a4\u09a8\u09be \u09a5\u09c7\u0995\u09c7\u0987 \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u099c\u09a8\u09cd\u09af\u0993 Zero Olympiad \u0996\u09c1\u09b2\u09c7 \u09a6\u09bf\u099a\u09cd\u099b\u09c7 \u09a8\u09a4\u09c1\u09a8 \u098f\u0995 \u09a6\u09bf\u0997\u09a8\u09cd\u09a4\u0964 \u098f\u0996\u09be\u09a8\u09c7 \u0985\u0982\u09b6\u0997\u09cd\u09b0\u09b9\u09a3\u09c7\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u09a4\u09be\u09b0\u09be \u098f\u09ae\u09a8 \u098f\u0995\u099f\u09bf \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09ae\u09c2\u09b2\u0995 \u09af\u09be\u09a4\u09cd\u09b0\u09be\u09df \u09af\u09c1\u0995\u09cd\u09a4 \u09b9\u0993\u09df\u09be\u09b0 \u09b8\u09c1\u09af\u09cb\u0997 \u09aa\u09be\u099a\u09cd\u099b\u09c7, \u09af\u09be \u09a4\u09be\u09a6\u09c7\u09b0 \u099a\u09bf\u09a8\u09cd\u09a4\u09be-\u09ad\u09be\u09ac\u09a8\u09be\u0995\u09c7 \u09ac\u09bf\u09b6\u09cd\u09ac\u09ae\u09c1\u0996\u09c0 \u0995\u09b0\u09c7 \u09a4\u09c1\u09b2\u09ac\u09c7 \u098f\u09ac\u0982 \u098f\u0995\u0987 \u09b8\u0999\u09cd\u0997\u09c7 \u09ac\u09bf\u09b6\u09cd\u09ac \u09ae\u09c1\u09b8\u09b2\u09bf\u09ae \u099c\u09be\u09b9\u09be\u09a8 \u0993 \u09ac\u09c3\u09b9\u09a4\u09cd\u09a4\u09b0 \u0989\u09ae\u09cd\u09ae\u09be\u09b9\u09b0 \u0995\u09b2\u09cd\u09af\u09be\u09a3\u09c7 \u0995\u09be\u099c \u0995\u09b0\u09be\u09b0 \u09aa\u09cd\u09b0\u09c7\u09b0\u09a3\u09be \u09a6\u09c7\u09ac\u09c7\u0964 \u0986\u099c\u0995\u09c7\u09b0 \u09aa\u09c3\u09a5\u09bf\u09ac\u09c0\u09a4\u09c7 \u0989\u09ae\u09cd\u09ae\u09be\u09b9\u09b0 \u09aa\u09cd\u09b0\u09df\u09cb\u099c\u09a8 \u098f\u09ae\u09a8 \u09a4\u09b0\u09c1\u09a3, \u09af\u09be\u09b0\u09be \u0995\u09c1\u09b0\u0986\u09a8\u09c7\u09b0 \u09a8\u09c8\u09a4\u09bf\u0995\u09a4\u09be \u0993 \u099c\u09cd\u099e\u09be\u09a8\u09c7\u09b0 \u0986\u09b2\u09cb\u0995\u09c7 \u09ac\u09bf\u09b6\u09cd\u09ac\u0995\u09c7 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac \u09a6\u09bf\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u0964 \u0985\u09a8\u09cd\u09af\u09be\u09df\u09c7\u09b0 \u09ac\u09bf\u09b0\u09c1\u09a6\u09cd\u09a7\u09c7 \u09a6\u09be\u0981\u09dc\u09be\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7, \u09ae\u09be\u09a8\u09ac\u09a4\u09be\u09b0 \u09aa\u09be\u09b6\u09c7 \u09a5\u09be\u0995\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7, \u098f\u09ac\u0982 \u09b6\u09be\u09a8\u09cd\u09a4\u09bf \u0993 \u0995\u09b2\u09cd\u09af\u09be\u09a3\u09c7\u09b0 \u09ac\u09be\u09b0\u09cd\u09a4\u09be \u099b\u09dc\u09bf\u09df\u09c7 \u09a6\u09bf\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u0964 #ZeroOlympiad \u09b8\u09c7\u0987 \u09aa\u09a5\u09c7\u0987 \u09a4\u09b0\u09c1\u09a3\u09a6\u09c7\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09a8 \u099c\u09be\u09a8\u09be\u099a\u09cd\u099b\u09c7 \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u098f\u0995\u099c\u09a8 \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u0993 \u099c\u09cd\u099e\u09be\u09a8\u09c7\u09b0 \u0986\u09b2\u09cb \u09b9\u09be\u09a4\u09c7 \u09a8\u09bf\u09df\u09c7 \u098f\u0997\u09bf\u09df\u09c7 \u09af\u09c7\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7, \u09a8\u09bf\u099c\u09c7\u09b0 \u09aa\u09b0\u09bf\u099a\u09df\u0995\u09c7 \u0997\u09b0\u09cd\u09ac\u09c7\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u09a7\u09be\u09b0\u09a3 \u0995\u09b0\u09c7 \u0989\u09ae\u09cd\u09ae\u09be\u09b9 \u0993 \u09b8\u09ae\u0997\u09cd\u09b0 \u09ae\u09be\u09a8\u09ac\u099c\u09be\u09a4\u09bf\u09b0 \u0995\u09b2\u09cd\u09af\u09be\u09a3\u09c7 \u0995\u09be\u099c \u0995\u09b0\u09be \u098f\u0995 \u0986\u09b2\u09cb\u0995\u09bf\u09a4 \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09b9\u09df\u09c7 \u0989\u09a0\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u0964",
