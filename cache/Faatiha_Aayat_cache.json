[
  {
    "title": "National Institute of Engineering & Technology-NIET \u098f\u09b0 \u09ae\u09c7\u09a7\u09be\u09ac\u09c0 \u099b\u09be\u09a4\u09cd\u09b0\u09c0 Sanjida Jam...",
    "description": "National Institute of Engineering & Technology-NIET \u098f\u09b0 \u09ae\u09c7\u09a7\u09be\u09ac\u09c0 \u099b\u09be\u09a4\u09cd\u09b0\u09c0 Sanjida Jamal, \u09af\u09bf\u09a8\u09bf \u0995\u09ae\u09cd\u09aa\u09bf\u0989\u099f\u09be\u09b0 \u09b8\u09be\u09af\u09bc\u09c7\u09a8\u09cd\u09b8 \u0985\u09cd\u09af\u09be\u09a8\u09cd\u09a1 \u099f\u09c7\u0995\u09a8\u09cb\u09b2\u099c\u09bf \u09a8\u09bf\u09af\u09bc\u09c7 \u098f\u0997\u09bf\u09af\u09bc\u09c7 \u099a\u09b2\u09c7\u099b\u09c7\u09a8 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7\u09b0 \u09aa\u09a5\u09c7, \u09a4\u09be\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u09b8\u09c0\u09ae\u09be\u09ac\u09a6\u09cd\u09a7 \u09a8\u09af\u09bc \u09a6\u09c7\u09b6\u09c7\u09b0 \u0997\u09a3\u09cd\u09a1\u09bf\u09a4\u09c7; \u09a4\u09bf\u09a8\u09bf \u099b\u09c1\u0981\u09a4\u09c7 \u099a\u09be\u09a8 \u09ac\u09c8\u09b6\u09cd\u09ac\u09bf\u0995 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0 \u09a6\u09bf\u0997\u09a8\u09cd\u09a4\u0964 \u09a4\u09be\u09b0 \u098f\u0987 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u09af\u09be\u09a4\u09cd\u09b0\u09be\u09af\u09bc \u098f\u0995 \u09b6\u0995\u09cd\u09a4\u09bf\u09b6\u09be\u09b2\u09c0 \u09b8\u0982\u09af\u09cb\u099c\u09a8 \u09b9\u09af\u09bc\u09c7\u099b\u09c7\u0964 \u0993\u09ad\u09be\u09b0\u09b8\u09bf\u099c \u0985\u09cd\u09af\u09be\u09a1\u09ae\u09bf\u09b6\u09a8\u09c7\u09b0 \u09aa\u09a5\u09c7 \u09af\u0996\u09a8 \u09b9\u09be\u099c\u09be\u09b0\u09cb \u0986\u09ac\u09c7\u09a6\u09a8\u09aa\u09a4\u09cd\u09b0\u09c7\u09b0 \u09ad\u09bf\u09a1\u09bc\u09c7 \u09a8\u09bf\u099c\u09c7\u0995\u09c7 \u0986\u09b2\u09be\u09a6\u09be \u0995\u09b0\u09c7 \u09a4\u09c1\u09b2\u09c7 \u09a7\u09b0\u09be\u09b0 \u09b2\u09a1\u09bc\u09be\u0987, \u09a4\u0996\u09a8 \u098f\u0987 #ECA - Extra Curricular Activity \u09b9\u09af\u09bc\u09c7 \u0989\u09a0\u09ac\u09c7 \u09a4\u09be\u09b0 \u0986\u09a4\u09cd\u09ae\u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8\u09c7\u09b0 \u09ad\u09bf\u09a4\u09cd\u09a4\u09bf\u0964 \u09b9\u09df\u09c7 \u0989\u09a0\u09ac\u09c7 \u09a4\u09be\u09b0 \u0985\u09a7\u09cd\u09af\u09ac\u09b8\u09be\u09af\u09bc, \u09b8\u099a\u09c7\u09a4\u09a8\u09a4\u09be \u098f\u09ac\u0982 \u09ac\u09c8\u09b6\u09cd\u09ac\u09bf\u0995 \u09a6\u09be\u09af\u09bc\u09ac\u09a6\u09cd\u09a7\u09a4\u09be\u09b0 \u098f\u0995 \u0989\u099c\u09cd\u099c\u09cd\u09ac\u09b2 \u09b8\u09cd\u09ac\u09be\u0995\u09cd\u09b7\u09b0\u0964 \u098f\u0987 \u0985\u09b0\u09cd\u099c\u09a8 \u09a4\u09be\u0995\u09c7 \u098f\u09a8\u09c7 \u09a6\u09bf\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09b8\u09cd\u0995\u09b2\u09be\u09b0\u09b6\u09bf\u09aa\u09c7\u09b0 \u09a6\u09cd\u09ac\u09be\u09b0, \u0985\u09ad\u09bf\u099c\u09cd\u099e \u09ae\u09c7\u09a8\u09cd\u099f\u09b0\u09a6\u09c7\u09b0 \u09b8\u09be\u09a8\u09cd\u09a8\u09bf\u09a7\u09cd\u09af, \u0986\u09b0 \u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be\u09aa\u09c2\u09b0\u09cd\u09a3 \u09ab\u09c7\u09b2\u09cb\u09b6\u09bf\u09aa\u09c7\u09b0 \u09b8\u09c1\u09af\u09cb\u0997\u0964 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u09af\u0996\u09a8 \u09a6\u09c3\u09a2\u09bc \u09b9\u09af\u09bc \u0986\u09b0 \u09aa\u09b0\u09bf\u09b6\u09cd\u09b0\u09ae \u09af\u0996\u09a8 \u09b8\u0999\u09cd\u0997\u09c0 \u09b9\u09df, \u09a4\u0996\u09a8 \u09aa\u09a5 \u09a8\u09bf\u099c\u09c7\u0987 \u09a4\u09c8\u09b0\u09bf \u09b9\u09df\u09c7 \u09af\u09be\u09df\u0964 \u09b8\u09be\u09a8\u099c\u09bf\u09a6\u09be \u099c\u09be\u09ae\u09be\u09b2\u09c7\u09b0 \u098f\u0987 \u0985\u0997\u09cd\u09b0\u09af\u09be\u09a4\u09cd\u09b0\u09be \u09b9\u09cb\u0995 \u0986\u09b0\u09cb \u0985\u09a8\u09c7\u0995 \u09a4\u09b0\u09c1\u09a3\u09c7\u09b0 \u0985\u09a8\u09c1\u09aa\u09cd\u09b0\u09c7\u09b0\u09a3\u09be, \u0986\u09b0 \u09a4\u09be\u09b0 \u09b8\u09be\u09ab\u09b2\u09cd\u09af \u099b\u09a1\u09bc\u09bf\u09af\u09bc\u09c7 \u09aa\u09a1\u09bc\u09c1\u0995 \u09b8\u09c0\u09ae\u09be\u09a8\u09cd\u09a4 \u09aa\u09c7\u09b0\u09bf\u09af\u09bc\u09c7 \u09ac\u09bf\u09b6\u09cd\u09ac\u09ae\u099e\u09cd\u099a\u09c7\u0964 \u09b2\u09bf\u0982\u0995 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09c7\u0964",
    "link": "https://www.facebook.com/FaatihaAayatOfficial/posts/pfbid032vuwvKawZdX7XnW1r1YoAeW5bxyFHx7Ef7LUZQ9ii76QTJYEFJhwVstqHaZZyXGRl",
    "guid": "https://www.facebook.com/FaatihaAayatOfficial/posts/pfbid032vuwvKawZdX7XnW1r1YoAeW5bxyFHx7Ef7LUZQ9ii76QTJYEFJhwVstqHaZZyXGRl",
