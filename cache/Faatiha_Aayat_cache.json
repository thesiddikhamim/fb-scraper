[
  {
    "title": "\u0986\u09b2\u09c0 \u0987\u09ae\u09be\u09ae \u09b8\u09bf\u09ab\u09be\u09a4\u0964 \u098f\u0995\u099f\u09bf \u09a8\u09be\u09ae, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09a4\u09be\u09b0 \u09ad\u09c7\u09a4\u09b0\u09c7 \u09b2\u09c1\u0995\u09bf\u09df\u09c7 \u0986\u099b\u09c7 \u098f\u0995 \u0986\u09b2\u09cb\u0995\u09ac\u09b0\u09cd\u09a4\u09bf\u0995\u09be\u09b0 \u0997\u09b2\u09cd\u09aa\u0964 \u09e8\u09e6\u09e7\u09ed...",
    "description": "\u0986\u09b2\u09c0 \u0987\u09ae\u09be\u09ae \u09b8\u09bf\u09ab\u09be\u09a4\u0964 \u098f\u0995\u099f\u09bf \u09a8\u09be\u09ae, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09a4\u09be\u09b0 \u09ad\u09c7\u09a4\u09b0\u09c7 \u09b2\u09c1\u0995\u09bf\u09df\u09c7 \u0986\u099b\u09c7 \u098f\u0995 \u0986\u09b2\u09cb\u0995\u09ac\u09b0\u09cd\u09a4\u09bf\u0995\u09be\u09b0 \u0997\u09b2\u09cd\u09aa\u0964 \u09e8\u09e6\u09e7\u09ed \u09b8\u09be\u09b2\u09c7 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u0995\u09c1\u09b0\u0986\u09a8\u09c7\u09b0 \u09b9\u09bf\u09ab\u099c \u09b8\u09ae\u09cd\u09aa\u09a8\u09cd\u09a8 \u0995\u09b0\u09c7 \u09a4\u09bf\u09a8\u09bf \u09a8\u09bf\u099c\u09c7\u09b0 \u099c\u09c0\u09ac\u09a8\u09c7\u09b0 \u09ad\u09bf\u09a4 \u0997\u09dc\u09c7 \u09a4\u09c1\u09b2\u09c7\u099b\u09c7\u09a8 \u0988\u09ae\u09be\u09a8 \u0993 \u099c\u09cd\u099e\u09be\u09a8\u09c7\u09b0 \u09a6\u09c3\u09dd \u09ad\u09bf\u09a4\u09cd\u09a4\u09bf\u09b0 \u0989\u09aa\u09b0\u0964 \u098f\u0996\u09a8 \u09a4\u09bf\u09a8\u09bf \u0986\u09b2\u09bf\u09ae \u09aa\u09b0\u09c0\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0, \u098f\u0995\u0987 \u09b8\u09be\u09a5\u09c7 \u0995\u0993\u09ae\u09bf \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09b0 \u099c\u09be\u09b2\u09be\u09b2\u09be\u0987\u09a8 \u099c\u09be\u09ae\u09be\u09a4\u09c7\u09b0 \u098f\u0995\u099c\u09a8 \u0985\u09a7\u09cd\u09af\u09ac\u09b8\u09be\u09df\u09c0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u0964 \u09a6\u09cd\u09ac\u09c0\u09a8\u09bf \u099c\u09cd\u099e\u09be\u09a8\u09c7\u09b0 \u0997\u09ad\u09c0\u09b0 \u09b8\u09be\u0997\u09b0\u09c7 \u09a8\u09bf\u09b0\u09a8\u09cd\u09a4\u09b0 \u09a1\u09c1\u09ac \u09a6\u09bf\u099a\u09cd\u099b\u09c7\u09a8\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u098f\u0996\u09be\u09a8\u09c7\u0987 \u09a5\u09c7\u09ae\u09c7 \u09a5\u09be\u0995\u09c7\u09a8\u09a8\u09bf \u09a4\u09bf\u09a8\u09bf\u0964 \u09b8\u09ae\u09df\u09c7\u09b0 \u09aa\u09cd\u09b0\u09df\u09cb\u099c\u09a8 \u09ac\u09c1\u099d\u09c7, \u09a8\u09bf\u099c\u09c7\u0995\u09c7 \u0997\u09dc\u09c7 \u09a4\u09c1\u09b2\u099b\u09c7\u09a8 \u09ac\u09b9\u09c1\u09ae\u09be\u09a4\u09cd\u09b0\u09bf\u0995 \u09a6\u0995\u09cd\u09b7\u09a4\u09be\u09df\u0964 \u098f\u0995\u09a6\u09bf\u0995\u09c7 \u09a1\u09bf\u09aa\u09cd\u09b2\u09cb\u09ae\u09be \u0987\u09a8 \u0987\u09b2\u09c7\u0995\u099f\u09cd\u09b0\u09bf\u0995\u09cd\u09af\u09be\u09b2 \u0987\u099e\u09cd\u099c\u09bf\u09a8\u09bf\u09df\u09be\u09b0\u09bf\u0982, \u0985\u09a8\u09cd\u09af\u09a6\u09bf\u0995\u09c7 \u09a1\u09bf\u09aa\u09cd\u09b2\u09cb\u09ae\u09be \u0987\u09a8 \u0987\u0989\u09a8\u09be\u09a8\u09c0 \u09ae\u09c7\u09a1\u09bf\u09b8\u09bf\u09a8 \u0985\u09cd\u09af\u09be\u09a8\u09cd\u09a1 \u09b8\u09be\u09b0\u09cd\u099c\u09be\u09b0\u09bf\u0964 \u098f\u09b0\u0987 \u09ae\u09be\u099d\u09c7 \u09af\u09cb\u0997 \u09a6\u09bf\u09df\u09c7\u099b\u09c7\u09a8 Zero Olympiad \u098f\u0964 \u09a4\u09be\u0987 \u09aa\u09cd\u09b0\u09b6\u09cd\u09a8 \u099c\u09be\u0997\u09c7, \u09af\u09c7 \u09a6\u09c7\u09b6\u09c7\u09b0 \u09a4\u09b0\u09c1\u09a3\u09a6\u09c7\u09b0 \u09b9\u09c3\u09a6\u09df\u09c7 \u0995\u09c1\u09b0\u0986\u09a8\u09c7\u09b0 \u0986\u09b2\u09cb, \u09ae\u09b8\u09cd\u09a4\u09bf\u09b7\u09cd\u0995\u09c7 \u099c\u09cd\u099e\u09be\u09a8\u09c7\u09b0 \u09a6\u09c0\u09aa\u09cd\u09a4\u09bf, \u0986\u09b0 \u09b9\u09be\u09a4\u09c7 \u09a6\u0995\u09cd\u09b7\u09a4\u09be\u09b0 \u09b6\u0995\u09cd\u09a4\u09bf, \u09b8\u09c7\u0987 \u09a6\u09c7\u09b6 \u0995\u09bf \u0995\u0996\u09a8\u09cb \u09aa\u09bf\u099b\u09bf\u09df\u09c7 \u09a5\u09be\u0995\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7?",
    "link": "https://www.facebook.com/FaatihaAayatOfficial/posts/pfbid0jcBKYMSq7vW5RSZzVAZ6v8NtoU2EXDJyC137bLj7xxCdmvGxLKWETvTho7F24hRMl",
    "guid": "https://www.facebook.com/FaatihaAayatOfficial/posts/pfbid0jcBKYMSq7vW5RSZzVAZ6v8NtoU2EXDJyC137bLj7xxCdmvGxLKWETvTho7F24hRMl",
