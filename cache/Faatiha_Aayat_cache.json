[
  {
    "title": "\u09ae\u09c2\u09b2\u09a7\u09be\u09b0\u09be\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be \u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be\u09b0 \u09ad\u09c7\u09a4\u09b0\u09c7\u0987 \u09aa\u09a5\u099a\u09b2\u09be\u0964 \u09a4\u09ac\u09c1\u0993 \u09af\u09c7\u09a8 \u0995\u09cb\u09a5\u09be\u0993 \u098f\u0995 \u0985\u09a6\u09c3\u09b6\u09cd\u09af \u09ab\u09be\u0981\u0995 \u09a5\u09c7\u0995\u09c7 \u09af\u09be\u09df\u0964 ...",
    "description": "\u09ae\u09c2\u09b2\u09a7\u09be\u09b0\u09be\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be \u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be\u09b0 \u09ad\u09c7\u09a4\u09b0\u09c7\u0987 \u09aa\u09a5\u099a\u09b2\u09be\u0964 \u09a4\u09ac\u09c1\u0993 \u09af\u09c7\u09a8 \u0995\u09cb\u09a5\u09be\u0993 \u098f\u0995 \u0985\u09a6\u09c3\u09b6\u09cd\u09af \u09ab\u09be\u0981\u0995 \u09a5\u09c7\u0995\u09c7 \u09af\u09be\u09df\u0964 \u0985\u09a8\u09cd\u09af\u09be\u09a8\u09cd\u09af \u09aa\u09b2\u09bf\u099f\u09c7\u0995\u09a8\u09bf\u0995 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u09ae\u09a4\u09cb\u0987 Pabna Polytechnic Institute, \u098f\u09b0 \u099b\u09be\u09a4\u09cd\u09b0 \u098f\u09ac\u09bf\u098f\u09ae \u09ae\u09be\u09b9\u09bf \u0985\u09a8\u09c1\u09ad\u09ac \u0995\u09b0\u09c7\u09a8, \u09a4\u09bf\u09a8\u09bf \u09af\u09c7\u09a8 \u09ae\u09c2\u09b2 \u09b8\u09cd\u09b0\u09cb\u09a4 \u09a5\u09c7\u0995\u09c7 \u098f\u0995\u099f\u09c1 \u09ac\u09bf\u099a\u09cd\u099b\u09bf\u09a8\u09cd\u09a8, \u098f\u0995\u099f\u09c1 \u09aa\u09cd\u09b0\u09be\u09a8\u09cd\u09a4\u09bf\u0995\u0964 \u09af\u09c7\u09a8 \u0985\u09aa\u09cd\u09b0\u0995\u09be\u09b6\u09bf\u09a4 \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be \u0986\u09b0 \u0985\u09aa\u09c2\u09b0\u09cd\u09a3\u09a4\u09be\u09b0 \u098f\u0995 \u09a8\u09c0\u09b0\u09ac \u09ad\u09be\u09b0 \u09ac\u09df\u09c7 \u09ac\u09c7\u09dc\u09be\u099a\u09cd\u099b\u09c7\u09a8\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u098f\u0987 \u0985\u09aa\u09c2\u09b0\u09cd\u09a3\u09a4\u09be\u09b0 \u09ac\u09cb\u09a7\u0987 \u09a4\u09be\u0995\u09c7 \u09a5\u09be\u09ae\u09bf\u09df\u09c7 \u09a6\u09c7\u09df\u09a8\u09bf\u0964 \u09ac\u09b0\u0982 \u098f\u099f\u09be\u0987 \u09b9\u09df\u09c7 \u0989\u09a0\u09c7\u099b\u09c7 \u09a4\u09be\u09b0 \u098f\u0997\u09bf\u09df\u09c7 \u09af\u09be\u0993\u09df\u09be\u09b0 \u09aa\u09cd\u09b0\u09c7\u09b0\u09a3\u09be, \u09a8\u09bf\u099c\u09c7\u0995\u09c7 \u09a8\u09a4\u09c1\u09a8\u09ad\u09be\u09ac\u09c7 \u0986\u09ac\u09bf\u09b7\u09cd\u0995\u09be\u09b0\u09c7\u09b0 \u09b6\u0995\u09cd\u09a4\u09bf\u0964 \u09b8\u09c7\u0987 \u0985\u09aa\u09c2\u09b0\u09cd\u09a3\u09a4\u09be\u0995\u09c7 \u09b6\u0995\u09cd\u09a4\u09bf\u09a4\u09c7 \u09b0\u09c2\u09aa \u09a6\u09bf\u09a4\u09c7, \u09a8\u09bf\u099c\u09c7\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u0995\u09c7 \u09a8\u09a4\u09c1\u09a8 \u09a6\u09bf\u0997\u09a8\u09cd\u09a4\u09c7 \u0989\u09a8\u09cd\u09ae\u09c1\u0995\u09cd\u09a4 \u0995\u09b0\u09a4\u09c7 \u09a4\u09bf\u09a8\u09bf \u09af\u09c1\u0995\u09cd\u09a4 \u09b9\u09df\u09c7\u099b\u09c7\u09a8 Zero Olympiad \u098f\u09b0 \u09ae\u09a4\u09cb \u098f\u0995 \u09ac\u09c8\u09b6\u09cd\u09ac\u09bf\u0995 \u09aa\u09cd\u09b2\u09cd\u09af\u09be\u099f\u09ab\u09b0\u09cd\u09ae\u09c7\u0964 United Nations \u098f\u09b0 \u0995\u09cb\u09b0\u09cd\u09b8 \u09b8\u09ae\u09cd\u09aa\u09a8\u09cd\u09a8 \u0995\u09b0\u09c7 \u0985\u09b0\u09cd\u099c\u09a8 \u0995\u09b0\u09c7\u099b\u09c7\u09a8 \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09b8\u09cd\u09ac\u09c0\u0995\u09c3\u09a4\u09bf\u0964 \u09b8\u09be\u09ae\u09a8\u09c7 \u0985\u09b0\u09cd\u099c\u09a8 \u0995\u09b0\u09ac\u09c7\u09a8 Commonwealth #CSA \u098f\u09b0 \"Young SDG Fellow\" \u09b8\u09a8\u09a6\u0993\u0964 \u09af\u09be \u0995\u09c7\u09ac\u09b2 \u098f\u0995\u099f\u09bf \u09b8\u09be\u09b0\u09cd\u099f\u09bf\u09ab\u09bf\u0995\u09c7\u099f \u09a8\u09df, \u09ac\u09b0\u0982 \u09a4\u09be\u09b0 \u0986\u09a4\u09cd\u09ae\u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8, \u0985\u09a7\u09cd\u09af\u09ac\u09b8\u09be\u09df \u0993 \u0985\u09a6\u09ae\u09cd\u09af \u0987\u099a\u09cd\u099b\u09be\u09b6\u0995\u09cd\u09a4\u09bf\u09b0 \u09aa\u09cd\u09b0\u09a4\u09c0\u0995\u0964 \u098f\u099f\u09be \u09a4\u09be\u09b0 \u0986\u09a4\u09cd\u09ae\u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8\u0995\u09c7 \u0995\u09b0\u09c7\u099b\u09c7 \u0986\u09b0\u0993 \u09a6\u09c3\u09dd, \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u0995\u09c7 \u09a6\u09bf\u09df\u09c7\u099b\u09c7 \u09a8\u09a4\u09c1\u09a8 \u09a1\u09be\u09a8\u09be\u0964 \u0986\u099c \u09a4\u09be\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u0986\u09b0\u0993 \u09b8\u09c1\u09b8\u09cd\u09aa\u09b7\u09cd\u099f\u0964 \u098f\u0987 \u09b8\u09cd\u09ac\u09c0\u0995\u09c3\u09a4\u09bf\u0995\u09c7 \u09b8\u09cb\u09aa\u09be\u09a8 \u09ac\u09be\u09a8\u09bf\u09df\u09c7 \u0989\u099a\u09cd\u099a\u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u09aa\u09be\u09dc\u09bf \u099c\u09ae\u09be\u09a8\u09cb \u09ac\u09bf\u09a6\u09c7\u09b6\u09c7, \u0986\u09b0 \u098f\u0995\u09a6\u09bf\u09a8 \u09ab\u09bf\u09b0\u09c7 \u098f\u09b8\u09c7 \u09a8\u09bf\u099c\u09c7\u09b0 \u0985\u09b0\u09cd\u099c\u09a8\u09c7 \u09ac\u09a6\u09b2\u09c7 \u09a6\u09bf\u09a4\u09c7 \u099a\u09be\u09a8 \u09b8\u09c7\u0987 \u09ae\u09c2\u09b2\u09a7\u09be\u09b0\u09be\u09b0 \u09b8\u0982\u099c\u09cd\u099e\u09be\u099f\u09bf\u0995\u09c7\u0987\u0964 \u0986\u09aa\u09a8\u09bf\u0993 \u09af\u09a6\u09bf \u09b9\u09a8 \u098f\u0995\u099c\u09a8 #Polytechnic \u098f\u09b0 \u099b\u09be\u09a4\u09cd\u09b0\u0964 \u098f\u0987 \u09af\u09c1\u09a6\u09cd\u09a7 \u0986\u09aa\u09a8\u09a8\u09be\u09b0\u0993\u0964 \u09af\u09c1\u09a6\u09cd\u09a7\u09be\u09b8\u09cd\u09a4\u09cd\u09b0 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09c7\u09b0 \u09b2\u09bf\u0982\u0995\u09c7\u0964",
