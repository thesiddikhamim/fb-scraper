[
  {
    "title": "\u0995\u09be\u09b0\u09be \u0985\u0982\u09b6 \u09a8\u09bf\u09a4\u09c7 \u09aa\u09be\u09b0\u09ac\u09c7? \u09ac\u09be\u0982\u09b2\u09be \u09ac\u09be \u0987\u0982\u09b0\u09c7\u099c\u09c0 \u09ae\u09be\u09a7\u200d\u09cd\u09af\u09ae, \u09b8\u09cd\u0995\u09c1\u09b2 \u0995\u09b2\u09c7\u099c \u09ac\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09af\u09bc, \u0986\u09b2\u09bf\u09df...",
    "description": "\u0995\u09be\u09b0\u09be \u0985\u0982\u09b6 \u09a8\u09bf\u09a4\u09c7 \u09aa\u09be\u09b0\u09ac\u09c7? \u09ac\u09be\u0982\u09b2\u09be \u09ac\u09be \u0987\u0982\u09b0\u09c7\u099c\u09c0 \u09ae\u09be\u09a7\u200d\u09cd\u09af\u09ae, \u09b8\u09cd\u0995\u09c1\u09b2 \u0995\u09b2\u09c7\u099c \u09ac\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09af\u09bc, \u0986\u09b2\u09bf\u09df\u09be \u09ac\u09be \u0995\u09be\u0993\u09ae\u09bf \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be \u2014 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u0999\u09cd\u0997\u09a8\u09c7\u09b0 \u09aa\u099e\u09cd\u099a\u09ae \u09b6\u09cd\u09b0\u09c7\u09a3\u09c0 \u09a5\u09c7\u0995\u09c7 \u09b8\u09cd\u09a8\u09be\u09a4\u0995\u09cb\u09a4\u09cd\u09a4\u09b0 \u09aa\u09b0\u09cd\u09af\u09a8\u09cd\u09a4 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0 #ZeroOlympiad \u098f\u09b0 \u09a8\u09bf\u09b0\u09cd\u09a7\u09be\u09b0\u09bf\u09a4 \u0995\u09cd\u09af\u09be\u099f\u09be\u0997\u09b0\u09bf \u0985\u09a8\u09c1\u09af\u09be\u09df\u09c0 \u0985\u0982\u09b6 \u09a8\u09bf\u09a4\u09c7 \u09aa\u09be\u09b0\u09ac\u09c7\u09a8\u0964 \u0995\u09bf\u09ad\u09be\u09ac\u09c7 \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u0995\u09b0\u09ac? Zero Olympiad \u098f\u09b0 \u0993\u09df\u09c7\u09ac\u09b8\u09be\u0987\u099f\u09c7 \u0997\u09c7\u09b2\u09c7\u0987 \u0986\u09aa\u09a8\u09bf \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u09b2\u09bf\u0982\u0995 \u0993 \u0985\u09a8\u09cd\u09af\u09be\u09a8\u09cd\u09af \u0986\u09a8\u09c1\u09b7\u09be\u0999\u09cd\u0997\u09bf\u0995 \u09a4\u09a5\u09cd\u09af \u09aa\u09c7\u09df\u09c7 \u09af\u09be\u09ac\u09c7\u09a8\u0964 \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u098f\u09b0 \u09aa\u09b0\u09c7\u09b0 \u09a7\u09be\u09aa \u0995\u09bf? \u09b8\u09be\u09b0\u09cd\u099f\u09bf\u09ab\u09bf\u0995\u09c7\u099f \u0995\u09ac\u09c7 \u0995\u09bf\u09ad\u09be\u09ac\u09c7 \u09aa\u09be\u09ac? \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8\u09c7\u09b0 \u09aa\u09b0 \u0986\u09aa\u09a8\u09be\u09b0 \u09a1\u09cd\u09af\u09be\u09b6\u09ac\u09cb\u09b0\u09cd\u09a1\u09c7 United Nations \u09b8\u09cd\u09ac\u09c0\u0995\u09c3\u09a4 \u0995\u09cb\u09b0\u09cd\u09b8 \u098f\u09b0 \u09b2\u09bf\u0982\u0995 \u09a6\u09c7\u09df\u09be \u09a5\u09be\u0995\u09ac\u09c7\u0964 \u0995\u09cb\u09b0\u09cd\u09b8\u0997\u09c1\u09b2\u09cb \u0985\u09a8\u09b2\u09be\u0987\u09a8\u09c7 \u09a8\u09bf\u099c\u09c7\u09b0 \u09b8\u09c1\u09ac\u09bf\u09a7\u09be\u09ae\u09a4 \u09b8\u09ae\u09df\u09c7 \u0995\u09b0\u09be \u09af\u09be\u09ac\u09c7\u0964 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09be \u0995\u09cb\u09b0\u09cd\u09b8 \u09b8\u09ae\u09cd\u09aa\u09a8\u09cd\u09a8 \u0995\u09b0\u09be\u09b0 \u09b8\u09be\u09a5\u09c7 \u09b8\u09be\u09a5\u09c7 \u0995\u09cb\u09b0\u09cd\u09b8\u09c7\u09b0 \u09b6\u09c7\u09b7 \u09a7\u09be\u09aa\u09c7 United Nations \u098f\u09b0 \u0993\u09df\u09c7\u09ac\u09b8\u09be\u0987\u099f \u09a5\u09c7\u0995\u09c7\u0987 \u0986\u09aa\u09a8\u09be\u09b0 \u09b8\u09be\u09b0\u09cd\u099f\u09bf\u09ab\u09bf\u0995\u09c7\u099f \u09a1\u09be\u0989\u09a8\u09b2\u09cb\u09a1 \u0995\u09b0\u09c7 \u09a8\u09bf\u09a4\u09c7 \u09aa\u09be\u09b0\u09ac\u09c7\u09a8\u0964 Commonwealth \u098f\u09b0 \u09b8\u09be\u09b0\u09cd\u099f\u09bf\u09ab\u09bf\u0995\u09c7\u099f \u0995\u0996\u09a8 \u0995\u09bf\u09ad\u09be\u09ac\u09c7 \u09aa\u09be\u09ac? \u09e7\u09ae \u09b0\u09be\u0989\u09a3\u09cd\u09a1\u09c7\u09b0 \u09aa\u09b0\u09c0\u0995\u09cd\u09b7\u09be \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09bf\u09a4 \u09b9\u09ac\u09c7 \u0985\u09a8\u09b2\u09be\u0987\u09a8\u09c7 \u099c\u09bf\u09b0\u09cb \u0985\u09b2\u09bf\u09ae\u09cd\u09aa\u09bf\u09df\u09be\u09a1\u09c7\u09b0 \u0993\u09df\u09c7\u09ac\u09b8\u09be\u0987\u099f\u09c7\u0964 \u09e9\u09e6\u099f\u09bf MCQ \u09aa\u09cd\u09b0\u09b6\u09cd\u09a8 \u09a5\u09be\u0995\u09ac\u09c7\u0964 \u09b8\u09ae\u09df \u09e9\u09e6 \u09ae\u09bf\u09a8\u09bf\u099f\u0964 \u099c\u09be\u09a4\u09bf\u09b8\u0982\u0998 \u09a5\u09c7\u0995\u09c7 \u09af\u09c7\u0987 \u0995\u09cb\u09b0\u09cd\u09b8 \u0986\u09aa\u09a8\u09be\u09b0\u09be \u0995\u09b0\u09ac\u09c7\u09a8, \u09b8\u09c7\u09a5\u09be\u09a8 \u09a5\u09c7\u0995\u09c7\u0987 \u09aa\u09cd\u09b0\u09b6\u09cd\u09a8 \u09a5\u09be\u0995\u09ac\u09c7\u0964 \u09aa\u09b0\u09c0\u0995\u09cd\u09b7\u09be\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u09b8\u0999\u09cd\u0997\u09c7\u0987 \u0986\u09aa\u09a8\u09be\u09b0 \u09aa\u09cd\u09b0\u09be\u09aa\u09cd\u09a4 \u09a8\u09ae\u09cd\u09ac\u09b0 \u0993\u09df\u09c7\u09ac\u09b8\u09be\u0987\u099f\u09c7\u0987 \u099c\u09c7\u09a8\u09c7 \u09af\u09be\u09ac\u09c7\u09a8\u0964 \u09aa\u09cd\u09b0\u09a4\u09bf SDG \u09a5\u09c7\u0995\u09c7 \u09b8\u09b0\u09cd\u09ac\u09cb\u099a\u09cd\u099a \u09a8\u09ae\u09cd\u09ac\u09b0\u09aa\u09cd\u09b0\u09be\u09aa\u09cd\u09a4 \u09e8\u09e6\u09e6 \u099c\u09a8 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0 \u09e8\u09df \u09b0\u09be\u0989\u09a3\u09cd\u09a1\u09c7 \u0989\u09a4\u09cd\u09a4\u09c0\u09b0\u09cd\u09a3 \u09b9\u09ac\u09c7\u09a8\u0964 \u09e7\u09ae \u09b0\u09be\u0989\u09a3\u09cd\u09a1\u09c7\u09b0 \u09aa\u09b0\u09c0\u0995\u09cd\u09b7\u09be \u09b6\u09c7\u09b7\u09c7 \u09e8\u09df \u09b0\u09be\u0989\u09a8\u09cd\u09a1\u09c7 \u0989\u09a4\u09cd\u09a4\u09c0\u09b0\u09cd\u09a3 \u09b9\u09a8 \u09ac\u09be \u09a8\u09be \u09b9\u09a8, \u09a1\u09cd\u09af\u09be\u09b6\u09ac\u09cb\u09b0\u09cd\u09a1\u09c7 \u09e7\u09ae \u09b0\u09be\u0989\u09a3\u09cd\u09a1\u09c7\u09b0 \u09b8\u09be\u09b0\u09cd\u099f\u09bf\u09ab\u09bf\u0995\u09c7\u099f \u098f\u09b0 \u09b8\u09be\u09a5\u09c7 \u0995\u09ae\u09a8\u0993\u09df\u09c7\u09b2\u09c7\u09a5\u09c7\u09b0 \u09b8\u09be\u09b0\u09cd\u099f\u09bf\u09ab\u09bf\u0995\u09c7\u099f \u09aa\u09c7\u09df\u09c7 \u09af\u09be\u09ac\u09c7\u09a8\u0964",
