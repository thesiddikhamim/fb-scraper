    "title": "\u09ac\u09a8\u09cd\u09a7\u09c1\u09ae\u09b9\u09b2 \u09ac\u09cd\u09b2\u09be\u09a1 \u09a1\u09cb\u09a8\u09be\u09b0 \u09b8\u09cb\u09b8\u09be\u0987\u099f\u09bf'\u09b0 \u275d\u09ea\u09b0\u09cd\u09a5 \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09ad\u09be\u0997\u09c0\u09df \u09b8\u09ae\u09cd\u09ae\u09c7\u09b2\u09a8-\u09e8\u09e6\u09e8\u09ec\u275e \u098f \u09b8\u09cd\u09ac\u09c7\u099a\u09cd\u099b\u09be\u09b8\u09c7\u09ac\u09c0\u09a6\u09c7...",
    "description": "\u09ac\u09a8\u09cd\u09a7\u09c1\u09ae\u09b9\u09b2 \u09ac\u09cd\u09b2\u09be\u09a1 \u09a1\u09cb\u09a8\u09be\u09b0 \u09b8\u09cb\u09b8\u09be\u0987\u099f\u09bf'\u09b0 \u275d\u09ea\u09b0\u09cd\u09a5 \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09ad\u09be\u0997\u09c0\u09df \u09b8\u09ae\u09cd\u09ae\u09c7\u09b2\u09a8-\u09e8\u09e6\u09e8\u09ec\u275e \u098f \u09b8\u09cd\u09ac\u09c7\u099a\u09cd\u099b\u09be\u09b8\u09c7\u09ac\u09c0\u09a6\u09c7\u09b0 \u0985\u09a8\u09c1\u09aa\u09cd\u09b0\u09be\u09a3\u09bf\u09a4 \u0995\u09b0\u09a4\u09c7 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u09a5\u09be\u0995\u09ac\u09c7\u09a8, \u09ab\u09be\u09a4\u09bf\u09b9\u09be \u0986\u09df\u09be\u09a4 \u099a\u09be\u0987\u09b2\u09cd\u09a1 \u09b0\u09be\u0987\u099f\u09b8 \u0985\u09cd\u09af\u09be\u0995\u09cd\u099f\u09bf\u09ad\u09bf\u09b8\u09cd\u099f \u0985\u09cd\u09af\u09be\u09a8\u09cd\u09a1 \u0995\u09cd\u09b2\u09be\u0987\u09ae\u09c7\u099f \u0995\u09cd\u09af\u09be\u09ae\u09cd\u09aa\u09c7\u0987\u09a8\u09be\u09b0\u0964 \u09b8\u09cd\u09ac\u09c7\u099a\u09cd\u099b\u09be\u09b8\u09c7\u09ac\u09c0\u09a6\u09c7\u09b0 \u098f\u0987 \u09ae\u09b9\u09be\u09ae\u09bf\u09b2\u09a8\u09ae\u09c7\u09b2\u09be\u09df \u0986\u09aa\u09a8\u09bf\u0993 \u0986\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09bf\u09a4\u0964 \u09aa\u09cd\u09b0\u09cb\u0997\u09cd\u09b0\u09be\u09ae \u09b0\u09c7\u099c\u09bf\u09b7\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u099a\u09b2\u099b\u09c7\u0964 \u09b0\u09c7\u099c\u09bf\u09b7\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u09b2\u09bf\u0982\u0995 \u0995\u09ae\u09c7\u09a8\u09cd\u099f, #\u09ea\u09b0\u09cd\u09a5_\u09a2\u09be\u0995\u09be_\u09ac\u09bf\u09ad\u09be\u0997\u09c0\u09df_\u09b8\u09ae\u09cd\u09ae\u09c7\u09b2\u09a8_\u09e8\u09e6\u09e8\u09ec #\u09a2\u09be\u0995\u09be_\u09ac\u09bf\u09ad\u09be\u0997\u09c0\u09af\u09bc_\u09b8\u09ae\u09cd\u09ae\u09c7\u09b2\u09a8_\u0989\u09ce\u09af\u09be\u09aa\u09a8 #\u09ac\u09a8\u09cd\u09a7\u09c1\u09ae\u09b9\u09b2_\u09ac\u09cd\u09b2\u09be\u09a1_\u09a1\u09cb\u09a8\u09be\u09b0_\u09b8\u09cb\u09b8\u09be\u0987\u099f\u09bf_\u09a2\u09be\u0995\u09be_\u09ac\u09bf\u09ad\u09be\u0997",
