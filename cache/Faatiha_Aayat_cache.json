[
  {
    "title": "\u09ac\u09c7\u09dc\u09bf\u09df\u09c7 \u0986\u09b8\u0964 \u09a8\u09bf\u099c\u09c7\u09b0 \u09b8\u09c0\u09ae\u09be\u09b0\u09c7\u0996\u09be \u09ad\u09c7\u0999\u09c7, \u09a8\u09bf\u099c\u09c7\u09b0 \u09ad\u09c7\u09a4\u09b0\u09c7\u09b0 \u0985\u09a6\u09c7\u0996\u09be \u09b6\u0995\u09cd\u09a4\u09bf\u099f\u09be\u0995\u09c7 \u099c\u09be\u0997\u09bf\u09df\u09c7\u0964 \u0985\u09a8\u09c1\u09a7\u09be\u09ac\u09a8 \u0995\u09b0\u09c7...",
    "description": "\u09ac\u09c7\u09dc\u09bf\u09df\u09c7 \u0986\u09b8\u0964 \u09a8\u09bf\u099c\u09c7\u09b0 \u09b8\u09c0\u09ae\u09be\u09b0\u09c7\u0996\u09be \u09ad\u09c7\u0999\u09c7, \u09a8\u09bf\u099c\u09c7\u09b0 \u09ad\u09c7\u09a4\u09b0\u09c7\u09b0 \u0985\u09a6\u09c7\u0996\u09be \u09b6\u0995\u09cd\u09a4\u09bf\u099f\u09be\u0995\u09c7 \u099c\u09be\u0997\u09bf\u09df\u09c7\u0964 \u0985\u09a8\u09c1\u09a7\u09be\u09ac\u09a8 \u0995\u09b0\u09c7 \u09af\u09c7 \u09a4\u09c1\u09ae\u09bf \u09a8\u09bf\u099c\u09c7\u0987 \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be\u09b0 \u098f\u0995 \u0985\u09a8\u09a8\u09cd\u09a4 \u09ae\u09b9\u09be\u0995\u09be\u09ac\u09cd\u09af\u0964 \u098f\u0995\u099f\u09be \u0995\u09a3\u09cd\u09a0, \u09af\u0996\u09a8 \u09b8\u09be\u09b9\u09b8 \u09aa\u09be\u09df \u09b8\u09c7\u099f\u09be \u0986\u09b0 \u09b6\u09c1\u09a7\u09c1 \u0995\u09a3\u09cd\u09a0 \u09a5\u09be\u0995\u09c7 \u09a8\u09be, \u09b9\u09df\u09c7 \u0993\u09a0\u09c7 \u0986\u09a8\u09cd\u09a6\u09cb\u09b2\u09a8\u0964 \u098f\u0995\u099f\u09be \u09aa\u09a6\u0995\u09cd\u09b7\u09c7\u09aa, \u09af\u0996\u09a8 \u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8\u09c7 \u09ad\u09b0\u09c7 \u0993\u09a0\u09c7 \u09b8\u09c7\u099f\u09be \u0986\u09b0 \u09b6\u09c1\u09a7\u09c1 \u09b9\u09be\u0981\u099f\u09be \u09a5\u09be\u0995\u09c7 \u09a8\u09be, \u09b9\u09df\u09c7 \u0993\u09a0\u09c7 \u0987\u09a4\u09bf\u09b9\u09be\u09b8\u09c7\u09b0 \u09b6\u09c1\u09b0\u09c1\u0964 Zero Olympiad \u09b8\u09c7\u0987 \u09a6\u09b0\u099c\u09be, \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u09a4\u09cb\u09ae\u09be\u09b0 \u201c\u0986\u09ae\u09bf \u09aa\u09be\u09b0\u09bf \u09a4\u09cb?\u201d \u09ac\u09a6\u09b2\u09c7 \u09af\u09be\u09df \u201c\u0986\u09ae\u09bf \u09aa\u09be\u09b0\u09ac\u0987\u201d-\u09a4\u09c7\u0964 \u098f\u0996\u09be\u09a8\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09aa\u09cd\u09b0\u09b6\u09cd\u09a8 \u09a4\u09cb\u09ae\u09be\u0995\u09c7 \u099a\u09cd\u09af\u09be\u09b2\u09c7\u099e\u09cd\u099c \u0995\u09b0\u09c7, \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u0989\u09a4\u09cd\u09a4\u09b0 \u09a4\u09cb\u09ae\u09be\u0995\u09c7 \u09a8\u09a4\u09c1\u09a8 \u0995\u09b0\u09c7 \u0997\u09dc\u09c7\u0964 \u098f\u099f\u09be \u09b6\u09c1\u09a7\u09c1 \u098f\u0995\u099f\u09be \u09aa\u09cd\u09b0\u09a4\u09bf\u09af\u09cb\u0997\u09bf\u09a4\u09be \u09a8\u09be\u0964 \u098f\u099f\u09be \u09a8\u09bf\u099c\u09c7\u0995\u09c7 \u0985\u09a4\u09bf\u0995\u09cd\u09b0\u09ae \u0995\u09b0\u09be\u09b0 \u098f\u0995 \u09af\u09be\u09a4\u09cd\u09b0\u09be, \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u09a4\u09c1\u09ae\u09bf \u09b9\u09be\u09b0\u09be\u0993 \u09a8\u09be, \u09a4\u09c1\u09ae\u09bf \u09a4\u09c8\u09b0\u09bf \u09b9\u0993\u0964 \u09a4\u09c1\u09ae\u09bf \u0995\u09bf \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09c1\u09a4 \u09a8\u09bf\u099c\u09c7\u0995\u09c7 \u099b\u09be\u09aa\u09bf\u09df\u09c7 \u09af\u09c7\u09a4\u09c7? \u09a4\u09c1\u09ae\u09bf \u0995\u09bf \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09c1\u09a4 \u09b8\u09c7\u0987 \u09b8\u0982\u09b8\u09cd\u0995\u09b0\u09a3\u099f\u09be\u0995\u09c7 \u099c\u09be\u0997\u09be\u09a4\u09c7, \u09af\u09be\u0995\u09c7 \u098f\u0996\u09a8\u09cb \u0995\u09c7\u0989 \u09a6\u09c7\u0996\u09c7\u09a8\u09bf? \u09a4\u09c1\u09ae\u09bf\u0993 \u09a8\u09be? \u09a4\u09be\u09b9\u09b2\u09c7 \u09a6\u09be\u0981\u09dc\u09bf\u09df\u09c7 \u09a5\u09c7\u0995\u09cb \u09a8\u09be\u0964 \u09ad\u09bf\u09dc\u09c7\u09b0 \u09ae\u09be\u099d\u09c7 \u09b9\u09be\u09b0\u09bf\u09df\u09c7 \u09af\u09c7\u0993 \u09a8\u09be\u0964 \u09a8\u09bf\u099c\u09c7\u09b0 \u0997\u09b2\u09cd\u09aa\u099f\u09be \u09a8\u09bf\u099c\u09c7\u0987 \u09b2\u09bf\u0996\u09cb\u0964 \u0986\u099c\u0987 \u09af\u09c1\u0995\u09cd\u09a4 \u09b9\u0993 #ZeroOlympiad \u098f\u0964",
