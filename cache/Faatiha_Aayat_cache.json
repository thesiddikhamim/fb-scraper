[
  {
    "title": "\u0990\u09a4\u09bf\u09b9\u09cd\u09af\u09ac\u09be\u09b9\u09c0 #DhakaPolytechnicInstitutte \u098f\u09b0 \u09ae\u09c7\u09a7\u09be\u09ac\u09c0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u0989\u099a\u09cd\u099b\u09cd\u09ac\u09be\u09b8, \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 ...",
    "description": "\u0990\u09a4\u09bf\u09b9\u09cd\u09af\u09ac\u09be\u09b9\u09c0 #DhakaPolytechnicInstitutte \u098f\u09b0 \u09ae\u09c7\u09a7\u09be\u09ac\u09c0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u0989\u099a\u09cd\u099b\u09cd\u09ac\u09be\u09b8, \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u0986\u09b0 \u0989\u09a6\u09cd\u09af\u09ae\u09c7 \u09ad\u09b0 \u0995\u09b0\u09c7 \u09b8\u09ab\u09b2\u09ad\u09be\u09ac\u09c7 \u09b8\u09ae\u09cd\u09aa\u09a8\u09cd\u09a8 \u09b9\u09b2\u09cb #ZeroOlympiad \u098f\u09b0 \u098f\u0995 \u0985\u09a8\u09a8\u09cd\u09af \u0993 \u09aa\u09cd\u09b0\u09c7\u09b0\u09a3\u09be\u09ae\u09c2\u09b2\u0995 \u0993\u09df\u09be\u09b0\u09cd\u0995\u09b6\u09aa\u0964 \u099c\u09cd\u099e\u09be\u09a8\u099a\u09b0\u09cd\u099a\u09be\u09b0 \u0986\u09b2\u09cb\u0995\u09bf\u09a4 \u09aa\u09cd\u09b0\u09be\u0999\u09cd\u0997\u09a3\u09c7 \u09a4\u09b0\u09c1\u09a3\u09a6\u09c7\u09b0 \u0995\u09cc\u09a4\u09c2\u09b9\u09b2, \u099a\u09bf\u09a8\u09cd\u09a4\u09be\u09b0 \u09a6\u09c0\u09aa\u09cd\u09a4\u09bf \u0986\u09b0 \u09aa\u09b0\u09bf\u09ac\u09b0\u09cd\u09a4\u09a8\u09c7\u09b0 \u0985\u09a6\u09ae\u09cd\u09af \u0986\u0995\u09be\u0999\u09cd\u0995\u09cd\u09b7\u09be \u09af\u09c7\u09a8 \u098f\u0995 \u09a8\u09a4\u09c1\u09a8 \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be\u09b0 \u09a6\u09c1\u09df\u09be\u09b0 \u0996\u09c1\u09b2\u09c7 \u09a6\u09bf\u09b2\u0964 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u0985\u0982\u09b6\u0997\u09cd\u09b0\u09b9\u09a3\u0995\u09be\u09b0\u09c0\u09b0 \u099a\u09cb\u0996\u09c7 \u099b\u09bf\u09b2 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09ce \u0997\u09dc\u09be\u09b0 \u09a6\u09c3\u09dd \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09df, \u0986\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09ae\u09c1\u09b9\u09c2\u09b0\u09cd\u09a4\u09c7 \u099b\u09dc\u09bf\u09df\u09c7 \u09aa\u09dc\u099b\u09bf\u09b2 \u09b6\u09c7\u0996\u09be\u09b0 \u0986\u09a8\u09a8\u09cd\u09a6 \u0993 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u09c7\u09b0 \u09ac\u09c0\u099c\u0964 \u098f\u0987 \u0993\u09df\u09be\u09b0\u09cd\u0995\u09b6\u09aa \u09b6\u09c1\u09a7\u09c1 \u098f\u0995\u099f\u09bf \u0986\u09df\u09cb\u099c\u09a8 \u099b\u09bf\u09b2 \u09a8\u09be\u0964 \u098f\u099f\u09bf \u099b\u09bf\u09b2 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u09a6\u09c7\u0996\u09be\u09b0, \u09a8\u09bf\u099c\u09c7\u0995\u09c7 \u0986\u09ac\u09bf\u09b7\u09cd\u0995\u09be\u09b0 \u0995\u09b0\u09be\u09b0, \u098f\u09ac\u0982 \u098f\u0995\u099f\u09bf \u0989\u09a8\u09cd\u09a8\u09a4 \u09ac\u09bf\u09b6\u09cd\u09ac \u0997\u09a0\u09a8\u09c7\u09b0 \u09aa\u09a5\u09c7 \u098f\u0995 \u09b6\u0995\u09cd\u09a4\u09bf\u09b6\u09be\u09b2\u09c0 \u09aa\u09a6\u0995\u09cd\u09b7\u09c7\u09aa\u0964",
