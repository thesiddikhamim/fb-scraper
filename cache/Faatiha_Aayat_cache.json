[
  {
    "title": "\u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09aa\u09b2\u09bf\u099f\u09c7\u0995\u09a8\u09bf\u0995 \u0987\u09a8\u09b8\u09cd\u099f\u09bf\u099f\u09bf\u0989\u099f\u09c7\u09b0 \u09b9\u09be\u099c\u09be\u09b0\u09cb \u09ae\u09c7\u09a7\u09be\u09ac\u09c0 \u099b\u09be\u09a4\u09cd\u09b0\u099b\u09be\u09a4\u09cd\u09b0\u09c0 \u0986\u099c\u0993 \u09ae\u09c2\u09b2\u09a7\u09be\u09b0\u09be\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0...",
    "description": "\u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09aa\u09b2\u09bf\u099f\u09c7\u0995\u09a8\u09bf\u0995 \u0987\u09a8\u09b8\u09cd\u099f\u09bf\u099f\u09bf\u0989\u099f\u09c7\u09b0 \u09b9\u09be\u099c\u09be\u09b0\u09cb \u09ae\u09c7\u09a7\u09be\u09ac\u09c0 \u099b\u09be\u09a4\u09cd\u09b0\u099b\u09be\u09a4\u09cd\u09b0\u09c0 \u0986\u099c\u0993 \u09ae\u09c2\u09b2\u09a7\u09be\u09b0\u09be\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0 \u0986\u09b2\u09cb \u09a5\u09c7\u0995\u09c7 \u0985\u09a8\u09c7\u0995\u099f\u09be\u0987 \u09a6\u09c2\u09b0\u09c7\u0964 \u09a4\u09be\u09a6\u09c7\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u0986\u099b\u09c7, \u09b8\u0995\u09cd\u09b7\u09ae\u09a4\u09be \u0986\u099b\u09c7, \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09b8\u09c1\u09af\u09cb\u0997\u09c7\u09b0 \u09a6\u09b0\u099c\u09be \u0985\u09a8\u09c7\u0995 \u09b8\u09ae\u09df\u0987 \u09a4\u09be\u09a6\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u0985\u09b0\u09cd\u09a7\u09c7\u0995 \u0996\u09cb\u09b2\u09be \u09a5\u09be\u0995\u09c7\u0964 \u098f\u0987 \u09a8\u09c0\u09b0\u09ac \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be\u09b0 \u09ad\u09c7\u09a4\u09b0\u09c7\u0987 \u09b2\u09c1\u0995\u09bf\u09df\u09c7 \u0986\u099b\u09c7 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7\u09b0 \u0989\u09a6\u09cd\u09ad\u09be\u09ac\u0995, \u09a8\u09bf\u09b0\u09cd\u09ae\u09be\u09a4\u09be \u0993 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u09a6\u09be\u09a4\u09be\u0964 \u098f\u0987 \u0985\u09ac\u09b9\u09c7\u09b2\u09bf\u09a4 \u0985\u09a5\u099a \u09aa\u09cd\u09b0\u09a4\u09bf\u09ad\u09be\u09ac\u09be\u09a8 \u09a4\u09b0\u09c1\u09a3\u09a6\u09c7\u09b0 \u09aa\u09be\u09b6\u09c7 \u09a6\u09be\u0981\u09dc\u09bf\u09df\u09c7\u099b\u09c7 Polytechnic Notice \u098f\u09ac\u0982 Zero Olympiad - \u098f\u0995\u099f\u09bf \u09b6\u0995\u09cd\u09a4\u09bf\u09b6\u09be\u09b2\u09c0 \u09b8\u09b9\u09af\u09cb\u0997\u09bf\u09a4\u09be\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7\u0964 \u098f\u0996\u09be\u09a8\u09c7 \u09aa\u09b2\u09bf\u099f\u09c7\u0995\u09a8\u09bf\u0995\u09c7\u09b0 \u099b\u09be\u09a4\u09cd\u09b0\u099b\u09be\u09a4\u09cd\u09b0\u09c0\u09b0\u09be \u09aa\u09cd\u09b0\u09a5\u09ae\u09ac\u09be\u09b0\u09c7\u09b0 \u09ae\u09a4\u09cb \u09a8\u09bf\u099c\u09c7\u09a6\u09c7\u09b0 \u099a\u09bf\u09a8\u09cd\u09a4\u09be, \u0989\u09a6\u09cd\u09ad\u09be\u09ac\u09a8\u09c0 \u09b6\u0995\u09cd\u09a4\u09bf \u098f\u09ac\u0982 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u09c7\u09b0 \u0995\u09cd\u09b7\u09ae\u09a4\u09be\u0995\u09c7 \u09ac\u09bf\u09b6\u09cd\u09ac\u09ae\u09c1\u0996\u09c0 \u09ae\u099e\u09cd\u099a\u09c7 \u09a4\u09c1\u09b2\u09c7 \u09a7\u09b0\u09be\u09b0 \u09b8\u09c1\u09af\u09cb\u0997 \u09aa\u09be\u099a\u09cd\u099b\u09c7\u0964 #PolytechnicNotice \u098f\u09b0 \u09b8\u09b9\u09be\u09df\u09a4\u09be\u09df #ZeroOlympiad \u09aa\u09cc\u0981\u099b\u09c7 \u09af\u09be\u099a\u09cd\u099b\u09c7 \u09b8\u09c7\u0987\u09b8\u09ac \u09a4\u09b0\u09c1\u09a3\u09a6\u09c7\u09b0 \u0995\u09be\u099b\u09c7, \u09af\u09be\u09a6\u09c7\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u098f\u09a4\u09a6\u09bf\u09a8 \u09aa\u09cd\u09b0\u09be\u09a8\u09cd\u09a4\u09bf\u0995\u09a4\u09be\u09b0 \u09a6\u09c7\u09df\u09be\u09b2\u09c7 \u0986\u099f\u0995\u09c7 \u099b\u09bf\u09b2\u0964 \u098f\u0996\u09a8 \u09a4\u09be\u09b0\u09be \u09b6\u09bf\u0996\u099b\u09c7 \u09ac\u09c8\u09b6\u09cd\u09ac\u09bf\u0995 \u09b8\u09ae\u09b8\u09cd\u09af\u09be\u09b0 \u09b8\u09ae\u09be\u09a7\u09be\u09a8 \u09a8\u09bf\u09df\u09c7 \u09ad\u09be\u09ac\u09a4\u09c7, \u09ae\u09be\u09a8\u09ac\u09a4\u09be \u0993 \u099f\u09c7\u0995\u09b8\u0987 \u0989\u09a8\u09cd\u09a8\u09df\u09a8\u09c7\u09b0 \u09aa\u09cd\u09b0\u09b6\u09cd\u09a8\u09c7 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac \u09a6\u09bf\u09a4\u09c7, \u098f\u09ac\u0982 \u09a8\u09bf\u099c\u09c7\u09a6\u09c7\u09b0 \u09a6\u0995\u09cd\u09b7\u09a4\u09be\u0995\u09c7 \u09ac\u09bf\u09b6\u09cd\u09ac\u09ae\u09be\u09a8\u09c7\u09b0 \u0986\u09b2\u09cb\u099a\u09a8\u09be\u09df \u09af\u09c1\u0995\u09cd\u09a4 \u0995\u09b0\u09a4\u09c7\u0964 \u0986\u09aa\u09a8\u09bf\u0993 \u09af\u09a6\u09bf \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u0995\u09cb\u09a8 \u09a8\u09be \u0995\u09cb\u09a8 \u09aa\u09b2\u09bf\u099f\u09c7\u0995\u09a8\u09bf\u0995 \u0987\u09a8\u09b8\u09cd\u099f\u09bf\u099f\u09bf\u0989\u099f\u09c7\u09b0 \u09b8\u09cd\u099f\u09c1\u09a1\u09c7\u09a8\u09cd\u099f \u09b9\u09a8, \u09b0\u09c7\u099c\u09bf\u09b8\u09cd\u099f\u09cd\u09b0\u09c7\u09b6\u09a8 \u0995\u09b0\u09c1\u09a8 \u0986\u099c\u0987\u0964 \u09b2\u09bf\u0982\u0995 \u0995\u09ae\u09c7\u09a8\u09cd\u099f\u09c7\u0964",
