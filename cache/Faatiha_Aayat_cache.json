[
  {
    "title": "\u0986\u099c \u099c\u09c1\u09ae\u09be\u09b0 \u09a6\u09bf\u09a8\u0964 \u09b0\u09b9\u09ae\u09a4, \u09ac\u09b0\u0995\u09a4 \u0986\u09b0 \u0986\u09a4\u09cd\u09ae\u09b6\u09c1\u09a6\u09cd\u09a7\u09bf\u09b0 \u098f\u0995 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09a8\u0964 \u09ae\u09bf\u09b6\u09b0\u09c7\u09b0 \u0986\u09b2 \u0986\u09af\u09b9\u09be\u09b0 \u0987\u0989\u09a8\u09bf\u09ad\u09be...",
    "description": "\u0986\u099c \u099c\u09c1\u09ae\u09be\u09b0 \u09a6\u09bf\u09a8\u0964 \u09b0\u09b9\u09ae\u09a4, \u09ac\u09b0\u0995\u09a4 \u0986\u09b0 \u0986\u09a4\u09cd\u09ae\u09b6\u09c1\u09a6\u09cd\u09a7\u09bf\u09b0 \u098f\u0995 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09a8\u0964 \u09ae\u09bf\u09b6\u09b0\u09c7\u09b0 \u0986\u09b2 \u0986\u09af\u09b9\u09be\u09b0 \u0987\u0989\u09a8\u09bf\u09ad\u09be\u09b0\u09cd\u09b8\u09bf\u099f\u09bf\u09b0 \u099b\u09be\u09a4\u09cd\u09b0 \u0986\u09ae\u09af\u09be\u09a6 \u09b9\u09cb\u09b8\u09c7\u09a8\u0964 \u09a4\u09be\u09b0 \u09aa\u09a5\u099a\u09b2\u09be\u099f\u09be \u09a0\u09bf\u0995 \u098f\u09ae\u09a8\u0987 \u098f\u0995 \u0985\u09a8\u09c1\u09aa\u09cd\u09b0\u09c7\u09b0\u09a3\u09be\u0964 \u099c\u09bf\u09b0\u09cb \u0985\u09b2\u09bf\u09ae\u09cd\u09aa\u09bf\u09df\u09be\u09a1\u09c7 \u0985\u0982\u09b6\u0997\u09cd\u09b0\u09b9\u09a3 \u0995\u09b0\u09c7, \u099c\u09be\u09a4\u09bf\u09b8\u0982\u0998 \u09b8\u09cd\u09ac\u09c0\u0995\u09c3\u09a4 \u0995\u09cb\u09b0\u09cd\u09b8 \u09b8\u09ae\u09cd\u09aa\u09a8\u09cd\u09a8 \u0995\u09b0\u09c7 \u09b8\u09c7 \u09aa\u09cd\u09b0\u09ae\u09be\u09a3 \u0995\u09b0\u09c7\u099b\u09c7, \u0987\u099a\u09cd\u099b\u09be \u09a5\u09be\u0995\u09b2\u09c7 \u09b8\u09c0\u09ae\u09be \u09ac\u09b2\u09c7 \u0995\u09bf\u099b\u09c1 \u09a5\u09be\u0995\u09c7 \u09a8\u09be\u0964 \u0986\u099c\u0995\u09c7\u09b0 \u098f\u0987 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u09a6\u09bf\u09a8\u09c7 \u098f\u0995\u099f\u09be \u09aa\u09cd\u09b0\u09b6\u09cd\u09a8 \u09a8\u09c0\u09b0\u09ac\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ae\u09a8\u09c7\u0993 \u099c\u09be\u0997\u09c7\u0964 \u0986\u09ae\u09b0\u09be \u0995\u09bf \u09a8\u09bf\u099c\u09c7\u09a6\u09c7\u09b0 \u09b8\u09c7\u0987 \u099c\u09be\u09df\u0997\u09be\u09df \u09a8\u09bf\u09df\u09c7 \u09af\u09c7\u09a4\u09c7 \u09aa\u09be\u09b0\u099b\u09bf, \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u099c\u09cd\u099e\u09be\u09a8, \u09ae\u09c2\u09b2\u09cd\u09af\u09ac\u09cb\u09a7 \u0986\u09b0 \u09ac\u09c8\u09b6\u09cd\u09ac\u09bf\u0995 \u09a6\u09be\u09df\u09bf\u09a4\u09cd\u09ac \u098f\u0995\u09b8\u09be\u09a5\u09c7 \u09ae\u09bf\u09b2\u09bf\u09a4 \u09b9\u09df? \u09b9\u09df\u09a4\u09cb \u0986\u099c\u0987 \u09b8\u09c7\u0987 \u09a6\u09bf\u09a8, \u098f\u0995\u099f\u09bf \u099b\u09cb\u099f \u09b8\u09bf\u09a6\u09cd\u09a7\u09be\u09a8\u09cd\u09a4 \u09a8\u09c7\u0993\u09df\u09be\u09b0, \u09af\u09be \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7\u09b0 \u09ac\u09dc \u09aa\u09b0\u09bf\u09ac\u09b0\u09cd\u09a4\u09a8\u09c7\u09b0 \u09b8\u09c2\u099a\u09a8\u09be \u09b9\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u0964",
    "link": "https://www.facebook.com/FaatihaAayatOfficial/posts/pfbid0cnXgDfptRAWp1qn2N7GwRKrejyr2LaLKwxTxByCx1ny5XnsgsefivX8Zp4Hg4LdJl",
    "guid": "https://www.facebook.com/FaatihaAayatOfficial/posts/pfbid0cnXgDfptRAWp1qn2N7GwRKrejyr2LaLKwxTxByCx1ny5XnsgsefivX8Zp4Hg4LdJl",
