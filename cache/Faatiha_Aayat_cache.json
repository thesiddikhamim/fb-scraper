[
  {
    "title": "\u0986\u099c \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09a8\u09be\u09b0\u09c0 \u09a6\u09bf\u09ac\u09b8\u0964 \u0985\u09a8\u09c7\u0995\u09c7\u0987 \u09ac\u09b2\u09c7\u09a8, \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09ae\u09c7\u09df\u09c7\u09b0\u09be \u098f\u0996\u09a8\u0993 \u09aa\u09bf\u099b\u09bf\u09df\u09c7\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09a4\u09be\u09b0...",
    "description": "\u0986\u099c \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09a8\u09be\u09b0\u09c0 \u09a6\u09bf\u09ac\u09b8\u0964 \u0985\u09a8\u09c7\u0995\u09c7\u0987 \u09ac\u09b2\u09c7\u09a8, \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09ae\u09c7\u09df\u09c7\u09b0\u09be \u098f\u0996\u09a8\u0993 \u09aa\u09bf\u099b\u09bf\u09df\u09c7\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u09a4\u09be\u09b0\u09be \u09af\u09a6\u09bf \u098f\u0995\u09ac\u09be\u09b0 \u098f\u09b8\u09c7 Zero Olympiad \u098f\u09b0 \u0985\u0982\u09b6\u0997\u09cd\u09b0\u09b9\u09a3\u0995\u09be\u09b0\u09c0 \u09ae\u09be\u09a4\u09cd\u09b0 \u0985\u09b7\u09cd\u099f\u09ae \u09b6\u09cd\u09b0\u09c7\u09a3\u09bf\u09b0 \u099b\u09be\u09a4\u09cd\u09b0\u09c0 \u09b8\u09be\u09ae\u09bf\u09b9\u09be \u09b0\u09be\u0987\u09b8\u09be \u0986\u09a6\u09bf\u09ac\u09be\u0995\u09c7 \u09a6\u09c7\u0996\u09c7, \u09a4\u09be\u09b9\u09b2\u09c7 \u09b9\u09df\u09a4\u09cb \u09b8\u09c7\u0987 \u09a7\u09be\u09b0\u09a3\u09be \u09ae\u09c1\u09b9\u09c2\u09b0\u09cd\u09a4\u09c7\u0987 \u09ac\u09a6\u09b2\u09c7 \u09af\u09be\u09ac\u09c7\u0964 \u098f\u0987 \u099b\u09cb\u099f\u09cd\u099f \u09ac\u09df\u09b8\u09c7\u0987 \u09a4\u09be\u09b0 \u099a\u09cb\u0996\u09c7 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8, \u0995\u09a3\u09cd\u09a0\u09c7 \u0986\u09a4\u09cd\u09ae\u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8, \u0986\u09b0 \u09b9\u09c3\u09a6\u09df\u09c7 \u09a6\u09c7\u09b6\u0995\u09c7 \u09ac\u09a6\u09b2\u09c7 \u09a6\u09c7\u0993\u09df\u09be\u09b0 \u0985\u09a6\u09ae\u09cd\u09af \u09b8\u09be\u09b9\u09b8\u0964 \u098f\u09ae\u09a8 \u09ae\u09c7\u09df\u09c7\u09b0\u09be\u0987 \u09a4\u09cb \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09aa\u09cd\u09b0\u0995\u09c3\u09a4 \u09b6\u0995\u09cd\u09a4\u09bf\u0964 \u09af\u09be\u09b0\u09be \u0986\u0997\u09be\u09ae\u09c0 \u09a6\u09bf\u09a8\u09c7\u09b0 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac, \u09aa\u09b0\u09bf\u09ac\u09b0\u09cd\u09a4\u09a8 \u0986\u09b0 \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be\u09b0 \u09aa\u09cd\u09b0\u09a4\u09c0\u0995\u0964 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09ae\u09c7\u09df\u09c7\u09b0\u09be \u09aa\u09bf\u099b\u09bf\u09df\u09c7 \u09a8\u09c7\u0987\u0964 \u09b0\u0982 \u09a4\u09be\u09b0\u09be\u0987 \u098f\u0997\u09bf\u09df\u09c7 \u09a8\u09bf\u09df\u09c7 \u09af\u09be\u099a\u09cd\u099b\u09c7 \u098f\u0987 \u09a6\u09c7\u09b6\u09c7\u09b0 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09ce\u0995\u09c7, \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u09c7\u09b0 \u0986\u09b2\u09cb\u09df \u0986\u09b2\u09cb\u0995\u09bf\u09a4 \u0995\u09b0\u09c7 \u09a4\u09c1\u09b2\u099b\u09c7 \u0986\u0997\u09be\u09ae\u09c0\u09b0 \u09aa\u09a5\u0964 \u09b8\u09be\u09ae\u09bf\u09b9\u09be \u09b0\u09be\u0987\u09b8\u09be \u0986\u09a6\u09bf\u09ac\u09be\u09b0 \u09ae\u09a4\u09cb \u09ae\u09c7\u09df\u09c7\u09b0\u09be\u0987 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0986\u09b6\u09be\u09b0 \u09a6\u09c0\u09aa\u09b6\u09bf\u0996\u09be, \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0997\u09b0\u09cd\u09ac, \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0986\u0997\u09be\u09ae\u09c0\u0964",
