  {
    "title": "\u09a7\u09b0\u09cd\u09ae\u09c0\u09df \u0993 \u09b8\u09be\u09ae\u09be\u099c\u09bf\u0995 \u09b8\u09ae\u09cd\u09aa\u09cd\u09b0\u09c0\u09a4\u09bf \u09b8\u09c1\u09a6\u09c3\u09dd \u0995\u09b0\u09a4\u09c7 \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8 \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0 \u0985\u09a8\u09cd\u09af\u09a4\u09ae \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8\u09c0 \u0985\u0999\u09cd\u0997\u09c0\u0995\u09be\u09b0 ...",
    "description": "\u09a7\u09b0\u09cd\u09ae\u09c0\u09df \u0993 \u09b8\u09be\u09ae\u09be\u099c\u09bf\u0995 \u09b8\u09ae\u09cd\u09aa\u09cd\u09b0\u09c0\u09a4\u09bf \u09b8\u09c1\u09a6\u09c3\u09dd \u0995\u09b0\u09a4\u09c7 \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8 \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0 \u0985\u09a8\u09cd\u09af\u09a4\u09ae \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8\u09c0 \u0985\u0999\u09cd\u0997\u09c0\u0995\u09be\u09b0 \u09ae\u09b8\u099c\u09bf\u09a6\u09c7\u09b0 \u0987\u09ae\u09be\u09ae, \u09ae\u09c1\u09df\u09be\u099c\u09cd\u099c\u09bf\u09a8, \u0996\u09be\u09a6\u09c7\u09ae \u0993 \u0985\u09a8\u09cd\u09af\u09be\u09a8\u09cd\u09af \u09a7\u09b0\u09cd\u09ae\u09c0\u09df \u09a8\u09c7\u09a4\u09c3\u09ac\u09c3\u09a8\u09cd\u09a6\u09c7\u09b0 \u09ae\u09be\u09b8\u09bf\u0995 \u09b8\u09ae\u09cd\u09ae\u09be\u09a8\u09c0 \u09aa\u09cd\u09b0\u09a6\u09be\u09a8 \u0995\u09be\u09b0\u09cd\u09af\u0995\u09cd\u09b0\u09ae\u09c7\u09b0 \u09b6\u09c1\u09ad \u0989\u09a6\u09cd\u09ac\u09cb\u09a7\u09a8\u0964 \u09aa\u09cd\u09b0\u09a7\u09be\u09a8 \u0985\u09a4\u09bf\u09a5\u09bf: \u099c\u09a8\u09be\u09ac \u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8, \u098f\u09ae\u09aa\u09bf \u09ae\u09be\u09a8\u09a8\u09c0\u09df \u09aa\u09cd\u09b0\u09a7\u09be\u09a8\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0, \u0997\u09a3\u09aa\u09cd\u09b0\u099c\u09be\u09a4\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u09b8\u09b0\u0995\u09be\u09b0 \u0993\u09b8\u09ae\u09be\u09a8\u09c0 \u09b8\u09cd\u09ae\u09c3\u09a4\u09bf \u09ae\u09bf\u09b2\u09a8\u09be\u09df\u09a4\u09a8, \u09a2\u09be\u0995\u09be \u09a5\u09c7\u0995\u09c7 \u09b8\u09b0\u09be\u09b8\u09b0\u09bf \u09e7\u09ea \u09ae\u09be\u09b0\u09cd\u099a \u09e8\u09e6\u09e8\u09ec, \u09b6\u09a8\u09bf\u09ac\u09be\u09b0 #PM #TariqueRahman #BNP",
