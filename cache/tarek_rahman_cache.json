    "title": "\u09a8\u09bf\u099c \u09b9\u09be\u09a4\u09c7 \u0996\u09be\u09b2 \u0995\u09c7\u099f\u09c7 \u09a6\u09c7\u09b6\u09ac\u09cd\u09af\u09be\u09aa\u09c0 \u09a8\u09a6\u09c0-\u09a8\u09be\u09b2\u09be-\u0996\u09be\u09b2 \u0993 \u099c\u09b2\u09be\u09a7\u09be\u09b0 \u0996\u09a8\u09a8 \u098f\u09ac\u0982 \u09aa\u09c1\u09a8\u0983\u0996\u09a8\u09a8 \u0995\u09b0\u09cd\u09ae\u09b8\u09c2\u099a\u09bf\u09b0 \u09b6\u09c1\u09ad ...",
    "description": "\u09a8\u09bf\u099c \u09b9\u09be\u09a4\u09c7 \u0996\u09be\u09b2 \u0995\u09c7\u099f\u09c7 \u09a6\u09c7\u09b6\u09ac\u09cd\u09af\u09be\u09aa\u09c0 \u09a8\u09a6\u09c0-\u09a8\u09be\u09b2\u09be-\u0996\u09be\u09b2 \u0993 \u099c\u09b2\u09be\u09a7\u09be\u09b0 \u0996\u09a8\u09a8 \u098f\u09ac\u0982 \u09aa\u09c1\u09a8\u0983\u0996\u09a8\u09a8 \u0995\u09b0\u09cd\u09ae\u09b8\u09c2\u099a\u09bf\u09b0 \u09b6\u09c1\u09ad \u0989\u09a6\u09cd\u09ac\u09cb\u09a7\u09a8 \u0995\u09b0\u09b2\u09c7\u09a8 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u099a\u09c7\u09af\u09bc\u09be\u09b0\u09ae\u09cd\u09af\u09be\u09a8 \u0993 \u09aa\u09cd\u09b0\u09a7\u09be\u09a8\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u099c\u09a8\u09be\u09ac \u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8\u0964 PM #TariqueRahman #BNP",
