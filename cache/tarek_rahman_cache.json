    "title": "\u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u099a\u09c7\u09df\u09be\u09b0\u09ae\u09cd\u09af\u09be\u09a8 \u0993 \u09aa\u09cd\u09b0\u09a7\u09be\u09a8\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u099c\u09a8\u09be\u09ac \u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8 \u098f\u09b0 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af | \u09a8\u09be\u09b0\u09c0\u09b0 \u0995\u09cd\u09b7\u09ae\u09a4\u09be\u09df\u09a8\u09c7\u09b0...",
    "description": "\u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u099a\u09c7\u09df\u09be\u09b0\u09ae\u09cd\u09af\u09be\u09a8 \u0993 \u09aa\u09cd\u09b0\u09a7\u09be\u09a8\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u099c\u09a8\u09be\u09ac \u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8 \u098f\u09b0 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af | \u09a8\u09be\u09b0\u09c0\u09b0 \u0995\u09cd\u09b7\u09ae\u09a4\u09be\u09df\u09a8\u09c7\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u09aa\u09b0\u09bf\u09ac\u09be\u09b0\u09c7\u09b0 \u099c\u09c0\u09ac\u09a8\u09ae\u09be\u09a8\u09c7\u09b0 \u09b8\u09be\u09b0\u09cd\u09ac\u09bf\u0995 \u0989\u09a8\u09cd\u09a8\u09df\u09a8\u09c7 \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8 \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0 \u0985\u09a8\u09cd\u09af\u09a4\u09ae \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8\u09c0 \u0985\u0999\u09cd\u0997\u09c0\u0995\u09be\u09b0 \u2018\u09ab\u09cd\u09af\u09be\u09ae\u09bf\u09b2\u09bf \u0995\u09be\u09b0\u09cd\u09a1\u2019 \u098f\u09b0 \u09aa\u09be\u0987\u09b2\u099f\u09bf\u0982 \u09aa\u09b0\u09cd\u09af\u09be\u09df\u09c7 \u09ac\u09bf\u09a4\u09b0\u09a3 \u0995\u09be\u09b0\u09cd\u09af\u0995\u09cd\u09b0\u09ae\u09c7\u09b0 \u09b6\u09c1\u09ad \u0989\u09a6\u09cd\u09ac\u09cb\u09a7\u09a8\u0964 \u099f\u09bf\u0985\u09cd\u09af\u09be\u09a8\u09cd\u09a1\u099f\u09bf \u0996\u09c7\u09b2\u09be\u09b0 \u09ae\u09be\u09a0, \u09ac\u09a8\u09be\u09a8\u09c0, \u09a2\u09be\u0995\u09be \u09a5\u09c7\u0995\u09c7 \u09b8\u09b0\u09be\u09b8\u09b0\u09bf \u09e7\u09e6 \u09ae\u09be\u09b0\u09cd\u099a \u09e8\u09e6\u09e8\u09ec, \u09ae\u0999\u09cd\u0997\u09b2\u09ac\u09be\u09b0 #PM #TariqueRahman #BNP",
