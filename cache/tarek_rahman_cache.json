    "title": "\u09a1\u09c7\u0999\u09cd\u0997\u09c1 \u0995\u09bf\u0982\u09ac\u09be \u099a\u09bf\u0995\u09c1\u09a8\u0997\u09c1\u09a8\u09bf\u09df\u09be \u09a5\u09c7\u0995\u09c7 \u09b0\u0995\u09cd\u09b7\u09be \u09aa\u09c7\u09a4\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b0\u09cb\u09a7\u09ae\u09c2\u09b2\u0995 \u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be \u0997\u09cd\u09b0\u09b9\u09a3\u09c7\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09a8 \u099c\u09be...",
    "description": "\u09a1\u09c7\u0999\u09cd\u0997\u09c1 \u0995\u09bf\u0982\u09ac\u09be \u099a\u09bf\u0995\u09c1\u09a8\u0997\u09c1\u09a8\u09bf\u09df\u09be \u09a5\u09c7\u0995\u09c7 \u09b0\u0995\u09cd\u09b7\u09be \u09aa\u09c7\u09a4\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b0\u09cb\u09a7\u09ae\u09c2\u09b2\u0995 \u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be \u0997\u09cd\u09b0\u09b9\u09a3\u09c7\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09a8 \u099c\u09be\u09a8\u09bf\u09df\u09c7 \u09a6\u09c7\u09b6\u09ac\u09be\u09b8\u09c0\u09b0 \u0989\u09a6\u09cd\u09a6\u09c7\u09b6\u09cd\u09af\u09c7 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u099a\u09c7\u09df\u09be\u09b0\u09ae\u09cd\u09af\u09be\u09a8 \u0993 \u09aa\u09cd\u09b0\u09a7\u09be\u09a8\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09c0 \u099c\u09a8\u09be\u09ac \u09a4\u09be\u09b0\u09c7\u0995 \u09b0\u09b9\u09ae\u09be\u09a8 \u098f\u09b0 \u09ac\u09bf\u09b6\u09c7\u09b7 \u09ad\u09bf\u09a1\u09bf\u0993 \u09ac\u09be\u09b0\u09cd\u09a4\u09be: \u09e7\u09e7 \u09ae\u09be\u09b0\u09cd\u099a \u09e8\u09e6\u09e8\u09ec, \u09ac\u09c1\u09a7\u09ac\u09be\u09b0 #PM #TariqueRahman #BNP",
