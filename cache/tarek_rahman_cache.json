    "title": "\u09a2\u09be\u0995\u09be \u09b8\u09c7\u09a8\u09be\u09a8\u09bf\u09ac\u09be\u09b8\u09c7 \u09b8\u09b6\u09b8\u09cd\u09a4\u09cd\u09b0 \u09ac\u09be\u09b9\u09bf\u09a8\u09c0\u09b0 \u09a6\u09b0\u09ac\u09be\u09b0\u09c7 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af \u09aa\u09cd\u09b0\u09a6\u09be\u09a8\u0964 \u09e7\u09e8 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09e8\u09e6\u09e8\u09ec, \u09b0\u09ac\u09bf\u09ac\u09be\u09b0 #P...",
    "description": "\u09a2\u09be\u0995\u09be \u09b8\u09c7\u09a8\u09be\u09a8\u09bf\u09ac\u09be\u09b8\u09c7 \u09b8\u09b6\u09b8\u09cd\u09a4\u09cd\u09b0 \u09ac\u09be\u09b9\u09bf\u09a8\u09c0\u09b0 \u09a6\u09b0\u09ac\u09be\u09b0\u09c7 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af \u09aa\u09cd\u09b0\u09a6\u09be\u09a8\u0964 \u09e7\u09e8 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09e8\u09e6\u09e8\u09ec, \u09b0\u09ac\u09bf\u09ac\u09be\u09b0 #PM #TariqueRahman #BNP",
    "link": "https://www.facebook.com/tariquerahman.bdbnp",
