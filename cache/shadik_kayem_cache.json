    "title": "\u09ac\u09a6\u09b0 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b6\u09c7\u0996\u09be\u09df, \u0988\u09ae\u09be\u09a8, \u09b8\u09ac\u09b0, \u0993 \u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09b0 \u0989\u09aa\u09b0 \u09ad\u09b0\u09b8\u09be\u0987 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ac\u09bf\u099c\u09df\u09c7\u09b0 \u09ae\u09c2\u09b2 \u09b6\u0995\u09cd\u09a4\u09bf\u0964",
