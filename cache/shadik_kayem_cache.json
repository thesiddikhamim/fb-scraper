    "title": "\u09b8\u09cd\u09ac\u09c7\u099a\u09cd\u099b\u09be\u09df \u09a5\u09be\u09a8\u09be\u09df \u0997\u09bf\u09df\u09c7 \u0986\u0987\u09a8\u09bf \u0986\u09b6\u09cd\u09b0\u09df \u099a\u09be\u0987\u09a4\u09c7 \u09af\u09be\u0993\u09df\u09be \u09a2\u09be\u09ac\u09bf \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0 \u09ae\u09be\u09b9\u09ae\u09c1\u09a6\u0995\u09c7 \u09a8\u09bf\u09df\u09c7 \u09aa\u09c1\u09b2\u09bf\u09b6 ...",
    "description": "\u09b8\u09cd\u09ac\u09c7\u099a\u09cd\u099b\u09be\u09df \u09a5\u09be\u09a8\u09be\u09df \u0997\u09bf\u09df\u09c7 \u0986\u0987\u09a8\u09bf \u0986\u09b6\u09cd\u09b0\u09df \u099a\u09be\u0987\u09a4\u09c7 \u09af\u09be\u0993\u09df\u09be \u09a2\u09be\u09ac\u09bf \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0 \u09ae\u09be\u09b9\u09ae\u09c1\u09a6\u0995\u09c7 \u09a8\u09bf\u09df\u09c7 \u09aa\u09c1\u09b2\u09bf\u09b6 \u09ac\u09bf\u0995\u09be\u09b2 \u09a5\u09c7\u0995\u09c7 \u09ad\u09cb\u09b0 \u09b8\u09be\u09dc\u09c7 \u09ea\u099f\u09be \u09aa\u09b0\u09cd\u09af\u09a8\u09cd\u09a4 \u09aa\u09cd\u09b0\u09be\u09df \u09e7\u09e8 \u0998\u09a8\u09cd\u099f\u09be \u09a5\u09be\u09a8\u09be\u09df \u09b0\u09c7\u0996\u09c7 \u099c\u09bf\u09a1\u09bf \u0997\u09cd\u09b0\u09b9\u09a3 \u09a8\u09be \u0995\u09b0\u09c7 \u0989\u09b2\u09cd\u099f\u09cb \u09b9\u09df\u09b0\u09be\u09a8\u09bf \u0995\u09b0\u09c7 \u09a8\u09be\u099f\u0995 \u09b8\u09be\u099c\u09be\u09a8\u09cb\u09b0 \u09af\u09c7 \u09ad\u09df\u0982\u0995\u09b0 \u099a\u09c7\u09b7\u09cd\u099f\u09be \u0995\u09b0\u09c7\u099b\u09c7, \u09b8\u09c7\u099f\u09bf \u09b8\u09b0\u09be\u09b8\u09b0\u09bf \u09ab\u09cd\u09af\u09be\u09b8\u09bf\u09ac\u09be\u09a6\u09c0 \u09aa\u09c1\u09b2\u09bf\u09b6\u09bf \u09aa\u09cd\u09af\u09be\u099f\u09be\u09b0\u09cd\u09a8\u09c7\u09b0 \u09aa\u09c1\u09a8\u09b0\u09be\u09ac\u09c3\u09a4\u09cd\u09a4\u09bf\u0964",
