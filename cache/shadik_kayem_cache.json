  {
    "title": "\u09e8\u09e6\u09e8\u09eb-\u09e8\u09ec \u09b8\u09c7\u09b6\u09a8\u0995\u09c7 \u09b8\u09ac\u09be\u09b0 \u0986\u0997\u09c7 \u09b9\u09b2\u09c7\u09b0 \u09b8\u09bf\u099f \u09ac\u09b0\u09be\u09a6\u09cd\u09a6 \u09a6\u09c7\u0993\u09df\u09be\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u09e7\u09ae \u09ac\u09b0\u09cd\u09b7\u09c7\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u09b8...",
    "description": "\u09e8\u09e6\u09e8\u09eb-\u09e8\u09ec \u09b8\u09c7\u09b6\u09a8\u0995\u09c7 \u09b8\u09ac\u09be\u09b0 \u0986\u0997\u09c7 \u09b9\u09b2\u09c7\u09b0 \u09b8\u09bf\u099f \u09ac\u09b0\u09be\u09a6\u09cd\u09a6 \u09a6\u09c7\u0993\u09df\u09be\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u09e7\u09ae \u09ac\u09b0\u09cd\u09b7\u09c7\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u09b8\u09bf\u099f\u09c7\u09b0 \u0985\u09a7\u09bf\u0995\u09be\u09b0 \u09ac\u09c1\u099d\u09bf\u09df\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u09b9\u09b2\u09cb \u09b6\u09b9\u09c0\u09a6 \u0993\u09b8\u09ae\u09be\u09a8 \u09b9\u09be\u09a6\u09bf \u09b9\u09b2\u09c7 (\u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09be\u09ac\u09bf\u09a4) \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u09a6\u09cd\u09b0\u09c1\u09a4 \u0986\u09ac\u09be\u09b8\u09a8 \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u09a1\u09be\u0995\u09b8\u09c1 \u0993 \u09b9\u09b2 \u09b8\u0982\u09b8\u09a6\u09c7\u09b0 \u09a6\u09be\u09ac\u09bf\u09b0 \u09aa\u09cd\u09b0\u09c7\u0995\u09cd\u09b7\u09bf\u09a4\u09c7 \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df \u09aa\u09cd\u09b0\u09b6\u09be\u09b8\u09a8 \u09e8\u09e6 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09a5\u09c7\u0995\u09c7 \u0986\u09ac\u09c7\u09a6\u09a8 \u0997\u09cd\u09b0\u09b9\u09a3\u09c7\u09b0 \u09b8\u09bf\u09a6\u09cd\u09a7\u09be\u09a8\u09cd\u09a4 \u09a6\u09bf\u09df\u09c7\u099b\u09bf\u09b2\u0964 \u09b6\u09b9\u09c0\u09a6 \u0993\u09b8\u09ae\u09be\u09a8 \u09b9\u09be\u09a6\u09bf \u09b9\u09b2 \u09b8\u0982\u09b8\u09a6\u09c7\u09b0 \u0989\u09a6\u09cd\u09af\u09cb\u0997\u09c7 \u098f\u099f\u09bf \u098f\u0997\u09bf\u09df\u09c7 \u098f\u09a8\u09c7 \u09ef \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09a5\u09c7\u0995\u09c7\u0987 \u0995\u09be\u09b0\u09cd\u09af\u0995\u09cd\u09b0\u09ae \u09b6\u09c1\u09b0\u09c1 \u0995\u09b0\u09be \u09b9\u09df\u0964 \u09aa\u09b0\u09ac\u09b0\u09cd\u09a4\u09c0\u09a4\u09c7, \u0997\u09a4 \u09e8\u09e9 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09b8\u09bf\u099f \u09ac\u09b0\u09be\u09a6\u09cd\u09a6\u09c7\u09b0 \u09ad\u09be\u0987\u09ad\u09be \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09bf\u09a4 \u09b9\u09df \u098f\u09ac\u0982 \u0986\u099c \u09e8\u09e6\u09e8\u09eb\u2013\u09e8\u09ec \u09b8\u09c7\u09b6\u09a8\u09c7\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u09a4\u09be\u09a6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09be\u09aa\u09cd\u09af \u0985\u09a7\u09bf\u0995\u09be\u09b0 \u09ac\u09c1\u099d\u09bf\u09df\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u09b9\u09df\u09c7\u099b\u09c7\u0964",
