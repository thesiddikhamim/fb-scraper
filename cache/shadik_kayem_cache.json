    "title": "\u09b8\u09b9\u09af\u09cb\u09a6\u09cd\u09a7\u09be \u09b8\u09be\u09b0\u099c\u09bf\u09b8 \u0986\u09b2\u09ae\u09c7\u09b0 \u0985\u09b8\u09c1\u09b8\u09cd\u09a5\u09a4\u09be\u09b0 \u0996\u09ac\u09b0 \u09b6\u09c1\u09a8\u09c7 \u09ae\u09a8\u099f\u09be \u0996\u09be\u09b0\u09be\u09aa \u09b9\u09df\u09c7 \u0997\u09bf\u09df\u09c7\u099b\u09bf\u09b2\u0964 \u0986\u09aa\u09a8\u09be\u09a6\u09c7\u09b0 \u09a6\u09cb\u09df\u09be \u0993 ...",
