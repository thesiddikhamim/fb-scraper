  },
  {
    "title": "\u09b6\u09be\u09b9\u09ac\u09be\u0997 \u09a5\u09be\u09a8\u09be\u09df \u09ae\u09ac \u0995\u09b0\u09c7 \u09ae\u09c1\u09b9\u09b8\u09c0\u09a8 \u09b9\u09b2 \u09b8\u0982\u09b8\u09a6\u09c7\u09b0 \u09b8\u0982\u09b8\u09cd\u0995\u09c3\u09a4\u09bf \u09b8\u09ae\u09cd\u09aa\u09be\u09a6\u0995 \u099c\u09c1\u09b2\u09b9\u09be\u09b8 \u0987\u09b8\u09b2\u09be\u09ae\u09c7\u09b0 \u0995\u09be\u09a8\u09c7\u09b0 \u09aa\u09b0\u09cd\u09a6\u09be...",
    "description": "\u09b6\u09be\u09b9\u09ac\u09be\u0997 \u09a5\u09be\u09a8\u09be\u09df \u09ae\u09ac \u0995\u09b0\u09c7 \u09ae\u09c1\u09b9\u09b8\u09c0\u09a8 \u09b9\u09b2 \u09b8\u0982\u09b8\u09a6\u09c7\u09b0 \u09b8\u0982\u09b8\u09cd\u0995\u09c3\u09a4\u09bf \u09b8\u09ae\u09cd\u09aa\u09be\u09a6\u0995 \u099c\u09c1\u09b2\u09b9\u09be\u09b8 \u0987\u09b8\u09b2\u09be\u09ae\u09c7\u09b0 \u0995\u09be\u09a8\u09c7\u09b0 \u09aa\u09b0\u09cd\u09a6\u09be \u09ab\u09be\u099f\u09bf\u09df\u09c7 \u09a6\u09bf\u09df\u09c7\u099b\u09c7 \u099b\u09be\u09a4\u09cd\u09b0\u09a6\u09b2\u09c7\u09b0 \u09b8\u09a8\u09cd\u09a4\u09cd\u09b0\u09be\u09b8\u09c0\u09b0\u09be\u0964 \u09b8\u09be\u0982\u09ac\u09be\u09a6\u09bf\u0995, \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0 \u098f\u09ac\u0982 \u09a1\u09be\u0995\u09b8\u09c1 \u0993 \u09b9\u09b2 \u09b8\u0982\u09b8\u09a6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u09a8\u09bf\u09a7\u09bf\u09a6\u09c7\u09b0 \u0989\u09aa\u09b0 \u09a8\u09cd\u09af\u0995\u09cd\u0995\u09be\u09b0\u099c\u09a8\u0995 \u098f\u0987 \u09b9\u09be\u09ae\u09b2\u09be\u09b0 \u0998\u099f\u09a8\u09be\u09df \u0987\u09a4\u09cb\u09ae\u09a7\u09cd\u09af\u09c7 \u09a4\u09a6\u09a8\u09cd\u09a4 \u0995\u09ae\u09bf\u099f\u09bf \u0997\u09a0\u09a8 \u0995\u09b0\u09c7\u099b\u09c7 \u09a1\u09be\u0995\u09b8\u09c1\u0964 \u09b6\u09c0\u0998\u09cd\u09b0\u0987 \u09aa\u09c2\u09b0\u09cd\u09a3\u09be\u0999\u09cd\u0997 \u09aa\u09cd\u09b0\u09a4\u09bf\u09ac\u09c7\u09a6\u09a8 \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09c1\u09a4 \u0995\u09b0\u09c7 \u09af\u09a5\u09be\u09af\u09a5 \u0986\u0987\u09a8\u09be\u09a8\u09c1\u0997 \u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be \u0997\u09cd\u09b0\u09b9\u09a3 \u0995\u09b0\u09be \u09b9\u09ac\u09c7 \u0987\u09a8\u09b6\u09be\u0986\u09b2\u09cd\u09b2\u09be\u09b9\u0964",
    "link": "https://www.facebook.com/shadik.kayem/posts/pfbid031VAe9Wvvvncgwg48tpf11w2CBXipg59W56yp4V8NjaAggJaRMwkrSZB3ancKGYPVl",
    "guid": "https://www.facebook.com/shadik.kayem/posts/pfbid031VAe9Wvvvncgwg48tpf11w2CBXipg59W56yp4V8NjaAggJaRMwkrSZB3ancKGYPVl",
    "pubDate": "2026-04-26T05:39:16.200222+00:00",
