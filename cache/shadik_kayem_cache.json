    "title": "\u09b8\u09be\u09a6\u09bf\u0995 \u09ae\u09c1\u09a8\u09c7\u09ae \u09b8\u09b9 \u0985\u09a8\u09b6\u09a8\u09b0\u09a4 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09aa\u09c2\u09b0\u09cd\u09a3 \u09b8\u0982\u09b9\u09a4\u09bf",
    "description": "\u09b8\u09be\u09a6\u09bf\u0995 \u09ae\u09c1\u09a8\u09c7\u09ae \u09b8\u09b9 \u0985\u09a8\u09b6\u09a8\u09b0\u09a4 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09aa\u09c2\u09b0\u09cd\u09a3 \u09b8\u0982\u09b9\u09a4\u09bf",
