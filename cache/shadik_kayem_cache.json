    "title": "\u09b9\u09c7 \u0986\u09ae\u09be\u09b0 \u09b0\u09ac! \u098f \u09a8\u0997\u09b0\u09c0\u0995\u09c7 \u0986\u09aa\u09a8\u09bf \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be\u09b0 \u099a\u09be\u09a6\u09b0\u09c7 \u0986\u09ac\u09c3\u09a4 \u0995\u09b0\u09c7 \u09a6\u09bf\u09a8\u0964",
    "description": "\u09b9\u09c7 \u0986\u09ae\u09be\u09b0 \u09b0\u09ac! \u098f \u09a8\u0997\u09b0\u09c0\u0995\u09c7 \u0986\u09aa\u09a8\u09bf \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be\u09b0 \u099a\u09be\u09a6\u09b0\u09c7 \u0986\u09ac\u09c3\u09a4 \u0995\u09b0\u09c7 \u09a6\u09bf\u09a8\u0964",
