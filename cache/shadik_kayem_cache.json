[
  {
    "title": "\u099c\u09c1\u09b2\u09be\u0987 \u09b8\u09a8\u09a6 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09af\u09bc\u09a8 \u0986\u09a6\u09c7\u09b6 \u09b8\u09cd\u09a5\u0997\u09bf\u09a4 \u099a\u09c7\u09af\u09bc\u09c7 \u09b0\u09bf\u099f \u0995\u09b0\u09be \u09b9\u09df\u09c7\u099b\u09c7\u0964 \u09b0\u09bf\u099f\u09c7 \u099c\u09c1\u09b2\u09be\u0987 \u09b8\u09a8\u09a6, \u0997\u09a3\u09ad\u09cb\u099f, \u099c\u09c1\u09b2...",
    "description": "\u099c\u09c1\u09b2\u09be\u0987 \u09b8\u09a8\u09a6 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09af\u09bc\u09a8 \u0986\u09a6\u09c7\u09b6 \u09b8\u09cd\u09a5\u0997\u09bf\u09a4 \u099a\u09c7\u09af\u09bc\u09c7 \u09b0\u09bf\u099f \u0995\u09b0\u09be \u09b9\u09df\u09c7\u099b\u09c7\u0964 \u09b0\u09bf\u099f\u09c7 \u099c\u09c1\u09b2\u09be\u0987 \u09b8\u09a8\u09a6, \u0997\u09a3\u09ad\u09cb\u099f, \u099c\u09c1\u09b2\u09be\u0987 \u09b8\u09a8\u09a6 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09df\u09a8 \u0986\u09a6\u09c7\u09b6, \u0985\u09a7\u09cd\u09af\u09be\u09a6\u09c7\u09b6 \u0993 \u09b8\u0982\u09ac\u09bf\u09a7\u09be\u09a8 \u09b8\u0982\u09b8\u09cd\u0995\u09be\u09b0 \u0995\u09ae\u09bf\u09b6\u09a8\u09c7\u09b0 \u09b6\u09aa\u09a5 \u0997\u09cd\u09b0\u09b9\u09a3\u0995\u09c7 \u099a\u09cd\u09af\u09be\u09b2\u09c7\u099e\u09cd\u099c \u0995\u09b0\u09be \u09b9\u09df\u09c7\u099b\u09c7\u0964 \u09a6\u09c1\u0983\u0996\u099c\u09a8\u0995\u09ad\u09be\u09ac\u09c7 \u098f\u0987 \u09b0\u09bf\u099f\u09c7\u09b0 \u09aa\u09c7\u099b\u09a8\u09c7 \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0 \u09b8\u09cd\u09aa\u09b7\u09cd\u099f \u09aa\u09c3\u09b7\u09cd\u09a0\u09aa\u09cb\u09b7\u0995\u09a4\u09be \u09b0\u09df\u09c7\u099b\u09c7\u0964 \u099c\u09c1\u09b2\u09be\u0987, \u099c\u09c1\u09b2\u09be\u0987 \u09b8\u09a8\u09a6, \u09b8\u0982\u09b8\u09cd\u0995\u09be\u09b0 \u0993 \u0997\u09a3\u09ad\u09cb\u099f \u09aa\u09cd\u09b0\u09b6\u09cd\u09a8\u09c7 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0 \u098f\u0987 \u0985\u09ac\u09b8\u09cd\u09a5\u09be\u09a8 \u099c\u09be\u09a4\u09bf\u09b0 \u09b8\u09be\u09a5\u09c7 \u0997\u09be\u09a6\u09cd\u09a6\u09be\u09b0\u09bf\u09b0 \u09b6\u09be\u09ae\u09bf\u09b2\u0964 \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u09b8\u09c1\u09b8\u09cd\u09aa\u09b7\u09cd\u099f \u0986\u09b9\u09ac\u09be\u09a8, \u099c\u09c1\u09b2\u09be\u0987\u09df\u09c7\u09b0 \u09b6\u09b9\u09c0\u09a6\u09be\u09a8\u09a6\u09c7\u09b0 \u09b0\u0995\u09cd\u09a4 \u09b6\u09c1\u0995\u09be\u09a8\u09cb\u09b0 \u0986\u0997\u09c7\u0987 \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0 \u09b8\u0982\u09b8\u09cd\u0995\u09be\u09b0\u09c7\u09b0 \u09aa\u09a5\u09c7 \u09af\u09c7 \u09a8\u0997\u09cd\u09a8 \u09b9\u09b8\u09cd\u09a4\u0995\u09cd\u09b7\u09c7\u09aa \u09b6\u09c1\u09b0\u09c1 \u09b9\u09df\u09c7\u099b\u09c7, \u09a4\u09be \u09ac\u09a8\u09cd\u09a7 \u0995\u09b0\u09c1\u09a8\u0964 \u099c\u09c1\u09b2\u09be\u0987\u09af\u09bc\u09c7\u09b0 \u09ab\u09b2\u09c7\u0987 \u0986\u099c \u0986\u09aa\u09a8\u09be\u09b0\u09be \u09b8\u09b0\u0995\u09be\u09b0 \u0997\u09a0\u09a8 \u0995\u09b0\u09a4\u09c7 \u09aa\u09c7\u09b0\u09c7\u099b\u09c7\u09a8\u0964 \u099c\u09c1\u09b2\u09be\u0987 \u09a8\u09be \u09a5\u09be\u0995\u09b2\u09c7 \u098f\u0987 \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8 \u0993 \u09b8\u09b0\u0995\u09be\u09b0\u09c7\u09b0\u0993 \u09ac\u09c8\u09a7\u09a4\u09be \u09a5\u09be\u0995\u09ac\u09c7 \u09a8\u09be\u0964",
