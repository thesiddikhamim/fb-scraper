    "title": "\u099c\u09c1\u09ae\u09be \u09ae\u09c1\u09ac\u09be\u09b0\u0995 || \u0986\u09a8\u09cd\u09a6\u09b0\u0995\u09bf\u09b2\u09cd\u09b2\u09be \u09b6\u09be\u09b9\u09c0 \u099c\u09be\u09ae\u09c7 \u09ae\u09b8\u099c\u09bf\u09a6 || \u099a\u099f\u09cd\u099f\u0997\u09cd\u09b0\u09be\u09ae",
    "description": "\u099c\u09c1\u09ae\u09be \u09ae\u09c1\u09ac\u09be\u09b0\u0995 || \u0986\u09a8\u09cd\u09a6\u09b0\u0995\u09bf\u09b2\u09cd\u09b2\u09be \u09b6\u09be\u09b9\u09c0 \u099c\u09be\u09ae\u09c7 \u09ae\u09b8\u099c\u09bf\u09a6 || \u099a\u099f\u09cd\u099f\u0997\u09cd\u09b0\u09be\u09ae",
