    "title": "\u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09c1 \u0986\u0995\u09ac\u09be\u09b0 \u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09c1 \u0986\u0995\u09ac\u09be\u09b0, \u09b2\u09be \u0987\u09b2\u09be\u09b9\u09be \u0987\u09b2\u09cd\u09b2\u09be\u09b2\u09cd\u09b2\u09be\u09b9\u09c1 \u0993\u09df\u09be \u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09c1 \u0986\u0995\u09ac\u09be\u09b0, \u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09c1 \u0986\u0995\u09ac...",
    "description": "\u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09c1 \u0986\u0995\u09ac\u09be\u09b0 \u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09c1 \u0986\u0995\u09ac\u09be\u09b0, \u09b2\u09be \u0987\u09b2\u09be\u09b9\u09be \u0987\u09b2\u09cd\u09b2\u09be\u09b2\u09cd\u09b2\u09be\u09b9\u09c1 \u0993\u09df\u09be \u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09c1 \u0986\u0995\u09ac\u09be\u09b0, \u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09c1 \u0986\u0995\u09ac\u09be\u09b0 \u0993\u09df\u09be \u09b2\u09bf\u09b2\u09cd\u09b2\u09be\u09b9\u09bf\u09b2 \u09b9\u09be\u09ae\u09a6\u0964 \u0988\u09a6 \u09ae\u09cb\u09ac\u09be\u09b0\u0995!",
