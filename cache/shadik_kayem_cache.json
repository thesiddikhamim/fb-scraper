    "title": "\u09b9\u09be\u09b8\u09be\u09a8 \u09a8\u09be\u09b8\u09bf\u09ae\u0995\u09c7 \u0985\u09ac\u09bf\u09b2\u09ae\u09cd\u09ac\u09c7 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf \u09a6\u09bf\u09a4\u09c7 \u09b9\u09ac\u09c7",
