[
  {
    "title": "\u09ad\u09be\u09b7\u09be \u0986\u09a8\u09cd\u09a6\u09cb\u09b2\u09a8, \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be \u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae \u09a5\u09c7\u0995\u09c7 \u09b6\u09c1\u09b0\u09c1 \u0995\u09b0\u09c7 \u099a\u09ac\u09cd\u09ac\u09bf\u09b6\u09c7\u09b0 \u099c\u09c1\u09b2\u09be\u0987 \u09ac\u09bf\u09aa\u09cd\u09b2\u09ac \u098f\u09ac\u0982 \u099c\u09be\u09a4\u09c0\u09df \u099c\u09c0...",
    "description": "\u09ad\u09be\u09b7\u09be \u0986\u09a8\u09cd\u09a6\u09cb\u09b2\u09a8, \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be \u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae \u09a5\u09c7\u0995\u09c7 \u09b6\u09c1\u09b0\u09c1 \u0995\u09b0\u09c7 \u099a\u09ac\u09cd\u09ac\u09bf\u09b6\u09c7\u09b0 \u099c\u09c1\u09b2\u09be\u0987 \u09ac\u09bf\u09aa\u09cd\u09b2\u09ac \u098f\u09ac\u0982 \u099c\u09be\u09a4\u09c0\u09df \u099c\u09c0\u09ac\u09a8\u09c7\u09b0 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae\u09c7 \u09af\u09c1\u0997\u09c7 \u09af\u09c1\u0997\u09c7 \u099b\u09be\u09a4\u09cd\u09b0\u09b8\u09ae\u09be\u099c\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u0995\u09be\u0981\u09a7\u09c7 \u0995\u09be\u0981\u09a7 \u09ae\u09bf\u09b2\u09bf\u09df\u09c7 \u09b2\u09dc\u09be\u0987 \u0995\u09b0\u09c7\u099b\u09c7 \u098f\u09a6\u09c7\u09b6\u09c7\u09b0 \u09ac\u09b9\u09c1 \u09b6\u09cd\u09b0\u09ae\u09bf\u0995\u0964 \u09b6\u09cd\u09b0\u09ae\u09bf\u0995\u09c7\u09b0 \u09b0\u0995\u09cd\u09a4-\u0998\u09be\u09ae\u09c7 \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0 \u098f\u09ac\u0982 \u0985\u09b0\u09cd\u09a5\u09a8\u09c0\u09a4\u09bf\u09b0 \u09ac\u09b9\u09c1 \u09b9\u09bf\u09b8\u09be\u09ac \u09ac\u09a6\u09b2\u09be\u09b2\u09c7\u0993, \u09ac\u09a6\u09b2\u09be\u09df\u09a8\u09bf \u09b6\u09cd\u09b0\u09ae\u099c\u09c0\u09ac\u09c0\u09b0 \u09ad\u09be\u0997\u09cd\u09af! \u200b\u09a8\u09cd\u09af\u09be\u09af\u09cd\u09af \u09ac\u09c7\u09a4\u09a8, \u099c\u09ae\u09c7 \u09a5\u09be\u0995\u09be \u09ac\u0995\u09c7\u09df\u09be \u0995\u09bf\u0982\u09ac\u09be \u09a8\u09cd\u09af\u09c1\u09a8\u09a4\u09ae \u09ae\u09be\u09a8\u09ac\u09bf\u0995 \u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be \u09a5\u09c7\u0995\u09c7\u0993 \u0985\u09a8\u09c7\u0995\u0995\u09cd\u09b7\u09c7\u09a4\u09cd\u09b0\u09c7 \u09ac\u099e\u09cd\u099a\u09bf\u09a4 \u09b9\u09a4\u09c7 \u09b9\u09df \u09b6\u09cd\u09b0\u09ae\u09bf\u0995\u09a6\u09c7\u09b0\u0964 \u0986\u09ae\u09b0\u09be \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u09a6\u09c7\u0996\u09bf \u09ac\u09c8\u09b7\u09ae\u09cd\u09af\u09b9\u09c0\u09a8 \u09b8\u09c7\u0987 \u09b8\u09c1\u09a8\u09cd\u09a6\u09b0 \u09b8\u09ae\u09be\u099c\u09c7\u09b0, \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u0985\u09a8\u09cd\u09af\u09be\u09df\u09ad\u09be\u09ac\u09c7 \u0995\u09c7\u0989 \u0995\u09be\u09b0\u09cb \u0985\u09a7\u09bf\u0995\u09be\u09b0 \u09b9\u09b0\u09a3 \u0995\u09b0\u09ac\u09c7 \u09a8\u09be\u0964 \u09aa\u09be\u0993\u09a8\u09be \u09ae\u099c\u09c1\u09b0\u09bf\u09b0 \u099c\u09a8\u09cd\u09af \u0995\u09be\u0989\u0995\u09c7 \u09a6\u09cd\u09ac\u09be\u09b0\u09c7 \u09a6\u09cd\u09ac\u09be\u09b0\u09c7 \u0998\u09c1\u09b0\u09a4\u09c7 \u09b9\u09ac\u09c7 \u09a8\u09be\u0964 \u0985\u09b0\u09cd\u09a5\u0995\u09b7\u09cd\u099f\u09c7 \u0985\u09a8\u09be\u09b9\u09be\u09b0\u09c7-\u0985\u09b0\u09cd\u09a7\u09be\u09b9\u09be\u09b0\u09c7 \u0995\u09bf\u0982\u09ac\u09be \u09ac\u09bf\u09a8\u09be \u099a\u09bf\u0995\u09bf\u09ce\u09b8\u09be\u09df \u0995\u09be\u0989\u0995\u09c7 \u09a6\u09bf\u09a8\u09be\u09a4\u09bf\u09aa\u09be\u09a4 \u0995\u09b0\u09a4\u09c7 \u09b9\u09ac\u09c7 \u09a8\u09be\u0964 \u200b\u09b8\u0995\u09b2\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u09b8\u0995\u09b2 \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u0985\u09a7\u09bf\u0995\u09be\u09b0 \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u0995\u09b0\u09be\u09b0 \u0989\u09aa\u09af\u09c1\u0995\u09cd\u09a4 \u09b8\u09c7\u0987 \u0995\u09be\u0999\u09cd\u0995\u09cd\u09b7\u09bf\u09a4 '\u09b8\u09ae\u09c3\u09a6\u09cd\u09a7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6' \u09ac\u09bf\u09a8\u09bf\u09b0\u09cd\u09ae\u09be\u09a3\u09c7\u09b0 \u09b2\u0995\u09cd\u09b7\u09cd\u09af\u09c7\u0987 \u09b9\u09cb\u0995 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0986\u0997\u09be\u09ae\u09c0\u09b0 \u09aa\u09a5\u099a\u09b2\u09be\u0964",
