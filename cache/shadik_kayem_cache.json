    "title": "\u09a1\u09be\u0995\u09b8\u09c1\u09b0 \u0986\u09ac\u09c7\u09a6\u09a8\u09c7\u09b0 \u09aa\u09cd\u09b0\u09c7\u0995\u09cd\u09b7\u09bf\u09a4\u09c7 \u099a\u09be\u09b2\u09c1 \u09b9\u099a\u09cd\u099b\u09c7 \u099f\u09bf\u099a\u09be\u09b0 \u098f\u09b8\u09bf\u09b8\u09cd\u099f\u09cd\u09af\u09be\u09a8\u09cd\u099f\u09b6\u09c0\u09aa \u0993 \u09b0\u09bf\u09b8\u09be\u09b0\u09cd\u099a \u098f\u09b8\u09bf\u09b8\u09cd\u099f\u09cd\u09af\u09be\u09a8\u09cd...",
    "description": "\u09a1\u09be\u0995\u09b8\u09c1\u09b0 \u0986\u09ac\u09c7\u09a6\u09a8\u09c7\u09b0 \u09aa\u09cd\u09b0\u09c7\u0995\u09cd\u09b7\u09bf\u09a4\u09c7 \u099a\u09be\u09b2\u09c1 \u09b9\u099a\u09cd\u099b\u09c7 \u099f\u09bf\u099a\u09be\u09b0 \u098f\u09b8\u09bf\u09b8\u09cd\u099f\u09cd\u09af\u09be\u09a8\u09cd\u099f\u09b6\u09c0\u09aa \u0993 \u09b0\u09bf\u09b8\u09be\u09b0\u09cd\u099a \u098f\u09b8\u09bf\u09b8\u09cd\u099f\u09cd\u09af\u09be\u09a8\u09cd\u099f\u09b6\u09c0\u09aa \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u09c7\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09a6\u09c7\u09b0 \u099c\u09cd\u099e\u09be\u09a4\u09be\u09b0\u09cd\u09a5\u09c7, \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u09c7\u09b0 \u09e7\u09e6\u09eb \u09ac\u099b\u09b0\u09c7\u09b0 \u098f\u0995\u09be\u09a1\u09c7\u09ae\u09bf\u0995 \u0987\u09a4\u09bf\u09b9\u09be\u09b8\u09c7 \u0995\u0996\u09a8\u0993 \u099f\u09bf\u099a\u09be\u09b0 \u098f\u09b8\u09bf\u09b8\u09cd\u099f\u09cd\u09af\u09be\u09a8\u09cd\u099f\u09b6\u09c0\u09aa \u099b\u09bf\u09b2 \u09a8\u09be\u0964 \u09aa\u09cd\u09b0\u099c\u09c7\u0995\u09cd\u099f \u09ac\u09c7\u09b8\u09bf\u09b8 \u09b8\u09cd\u09ac\u09b2\u09cd\u09aa \u09aa\u09b0\u09bf\u09b8\u09b0\u09c7 \u09b0\u09bf\u09b8\u09be\u09b0\u09cd\u099a \u098f\u09b8\u09bf\u09b8\u09cd\u099f\u09cd\u09af\u09be\u09a8\u09cd\u099f\u09b6\u09c0\u09aa \u09a5\u09be\u0995\u09b2\u09c7\u0993 \u09a4\u09be\u09b0 \u09aa\u09cd\u09b0\u09be\u09a4\u09bf\u09b7\u09cd\u09a0\u09be\u09a8\u09bf\u0995\u09b0\u09a3 \u09b9\u09df\u09a8\u09bf\u0964 \u09a1\u09be\u0995\u09b8\u09c1\u09b0 \u0995\u09cd\u09af\u09be\u09b0\u09bf\u09df\u09be\u09b0 \u0989\u09a8\u09cd\u09a8\u09df\u09a8 \u09b8\u09ae\u09cd\u09aa\u09be\u09a6\u0995 \u09ae\u09be\u099c\u09b9\u09be\u09b0\u09c1\u09b2 \u0987\u09b8\u09b2\u09be\u09ae \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u09c7\u09b0 \u09ad\u09be\u0987\u09b8 \u099a\u09cd\u09af\u09be\u09a8\u09cd\u09b8\u09c7\u09b2\u09b0 \u09ac\u09b0\u09be\u09ac\u09b0 TA \u0993 RA \u099a\u09be\u09b2\u09c1 \u0995\u09b0\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u0986\u09ac\u09c7\u09a6\u09a8 \u0995\u09b0\u09c7\u099b\u09bf\u09b2\u09c7\u09a8\u0964 \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df \u098f\u09b8\u09ae\u09cd\u09aa\u09b0\u09cd\u0995\u09bf\u09a4 \u098f\u0995\u099f\u09bf \u0995\u09ae\u09bf\u099f\u09bf \u0997\u09a0\u09a8 \u0995\u09b0\u09c7\u099b\u09c7\u0964 \u09a1\u09be\u0995\u09b8\u09c1\u09b0 \u0995\u09cd\u09af\u09be\u09b0\u09bf\u09df\u09be\u09b0 \u0989\u09a8\u09cd\u09a8\u09df\u09a8 \u09b8\u09ae\u09cd\u09aa\u09be\u09a6\u0995 \u09ac\u09bf\u09b6\u09cd\u09ac\u09c7\u09b0 \u09b0\u09bf\u09a8\u09cc\u09a8\u09cd\u09a1 \u0987\u0989\u09a8\u09bf\u09ad\u09be\u09b0\u09cd\u09b8\u09bf\u099f\u09bf\u0997\u09c1\u09b2\u09cb\u09b0 \u09a8\u09c0\u09a4\u09bf\u09ae\u09be\u09b2\u09be \u09b8\u09be\u09ae\u09a8\u09c7 \u09b0\u09c7\u0996\u09c7 \u098f\u0995\u099f\u09bf \u09ae\u09cc\u09b2\u09bf\u0995 \u09a8\u09c0\u09a4\u09bf\u09ae\u09be\u09b2\u09be \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09be\u09ac\u09a8\u09be \u0986\u0995\u09be\u09b0\u09c7 \u09b8\u09be\u09ac\u09ae\u09bf\u099f \u0995\u09b0\u09be\u09b0 \u09aa\u09cd\u09b0\u09c7\u0995\u09cd\u09b7\u09bf\u09a4\u09c7 \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df \u0997\u09a0\u09bf\u09a4 \u0995\u09ae\u09bf\u099f\u09bf \u099f\u09bf\u099a\u09be\u09b0 \u098f\u09b8\u09bf\u09b8\u09cd\u099f\u09cd\u09af\u09be\u09a8\u09cd\u099f\u09b6\u09c0\u09aa \u099a\u09be\u09b2\u09c1 \u0995\u09b0\u09be\u09b0 \u09ac\u09cd\u09af\u09be\u09aa\u09be\u09b0\u09c7 \u0987\u09a4\u09bf\u09ac\u09be\u099a\u0995 \u09b8\u09c1\u09aa\u09be\u09b0\u09bf\u09b6 \u0995\u09b0\u09c7\u099b\u09c7\u0964 \u09b8\u09c1\u09aa\u09be\u09b0\u09bf\u09b6\u099f\u09bf \u0997\u09a4 \u09b8\u09aa\u09cd\u09a4\u09be\u09b9\u09c7 \u09a1\u09bf\u09a8'\u09b8 \u09ae\u09bf\u099f\u09bf\u0982\u09df\u09c7 \u0986\u09b2\u09cb\u099a\u09a8\u09be \u09b9\u09df \u098f\u09ac\u0982 \u09a8\u09c0\u09a4\u09bf\u0997\u09a4\u09ad\u09be\u09ac\u09c7 \u098f\u099f\u09bf \u099a\u09be\u09b2\u09c1 \u0995\u09b0\u09be\u09b0 \u09ac\u09cd\u09af\u09be\u09aa\u09be\u09b0\u09c7 \u09b8\u09bf\u09a6\u09cd\u09a7\u09be\u09a8\u09cd\u09a4 \u09a8\u09c7\u0993\u09df\u09be \u09b9\u09df\u09f7 \u09a1\u09bf\u09a8'\u09b8 \u09ae\u09bf\u099f\u09bf\u0982\u09df\u09c7 \u09aa\u09cd\u09b0\u09b6\u09be\u09b8\u09a8 \u0986\u09b0\u09c7\u0995\u099f\u09bf \u0995\u09ae\u09bf\u099f\u09bf \u0997\u09a0\u09a8 \u0995\u09b0\u09c7 \u09a6\u09c7\u09df \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u099f\u09bf\u099a\u09be\u09b0 \u098f\u09b8\u09bf\u09b8\u09cd\u099f\u09cd\u09af\u09be\u09a8\u09cd\u099f\u09b6\u09c0\u09aa\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u098f\u0995\u099f\u09bf \u09a8\u09c0\u09a4\u09bf\u09ae\u09be\u09b2\u09be \u09a4\u09c8\u09b0\u09bf \u0995\u09b0\u09be \u09b9\u09ac\u09c7\u0964 \u0986\u09ae\u09b0\u09be \u0986\u09b6\u09be\u0995\u09b0\u09bf \u0996\u09c1\u09ac \u09a6\u09cd\u09b0\u09c1\u09a4\u0987 \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09df\u09c7 \u099f\u09bf\u099a\u09be\u09b0 \u098f\u09b8\u09bf\u09b8\u09cd\u099f\u09cd\u09af\u09be\u09a8\u09cd\u099f\u09b6\u09c0\u09aa \u099a\u09be\u09b2\u09c1 \u09b9\u09ac\u09c7 \u0987\u09a8\u09b6\u09be\u0986\u09b2\u09cd\u09b2\u09be\u09b9\u0964",
    "link": "https://www.facebook.com/shadik.kayem/posts/pfbid0VH1EpFct9tzGNsnNr2Ve18cyNa5jVxwb5QS7jtVTA1ipz8zicudEMxPi65MmEVyel",
