[
  {
    "title": "\u09aa\u09cd\u09b0\u09a5\u09ae \u09ac\u09bf\u09b6\u09cd\u09ac\u09af\u09c1\u09a6\u09cd\u09a7\u09c7\u09b0 \u09aa\u09b0\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u098f\u0987 \u09ad\u09c2\u0996\u09a3\u09cd\u09a1\u09c7\u09b0 \u099c\u09a8\u09ae\u09be\u09a8\u09c1\u09b7\u09c7\u09b0 \u09ae\u09a7\u09cd\u09af\u09c7 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be\u09b0 \u09a6\u09be\u09ac\u09bf \u099c\u09cb\u09b0\u09be\u09b2\u09cb...",
    "description": "\u09aa\u09cd\u09b0\u09a5\u09ae \u09ac\u09bf\u09b6\u09cd\u09ac\u09af\u09c1\u09a6\u09cd\u09a7\u09c7\u09b0 \u09aa\u09b0\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u098f\u0987 \u09ad\u09c2\u0996\u09a3\u09cd\u09a1\u09c7\u09b0 \u099c\u09a8\u09ae\u09be\u09a8\u09c1\u09b7\u09c7\u09b0 \u09ae\u09a7\u09cd\u09af\u09c7 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be\u09b0 \u09a6\u09be\u09ac\u09bf \u099c\u09cb\u09b0\u09be\u09b2\u09cb \u09b9\u09af\u09bc\u09c7 \u0993\u09a0\u09c7\u0964 \u09a4\u09be\u09b0\u0987 \u09ab\u09b2\u09b6\u09cd\u09b0\u09c1\u09a4\u09bf\u09a4\u09c7 \u09ac\u09cd\u09b0\u09bf\u099f\u09bf\u09b6\u09a6\u09c7\u09b0 \u0985\u09aa\u09b6\u09be\u09b8\u09a8\u09c7\u09b0 \u09ac\u09bf\u09b0\u09c1\u09a6\u09cd\u09a7\u09c7 \u09b8\u09b0\u09cd\u09ac\u09b8\u09cd\u09a4\u09b0\u09c7\u09b0 \u099c\u09a8\u0997\u09a3 \u09a4\u09c0\u09ac\u09cd\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u09ac\u09be\u09a6\u09c7 \u09b8\u09b0\u09ac \u09b9\u09af\u09bc\u0964 \u098f\u0987 \u09aa\u09cd\u09b0\u09c7\u0995\u09cd\u09b7\u09be\u09aa\u099f\u09c7 \u09e7\u09ef\u09e7\u09ef \u09b8\u09be\u09b2\u09c7 \u09ac\u09cd\u09b0\u09bf\u099f\u09bf\u09b6 \u09b8\u09b0\u0995\u09be\u09b0 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ac\u09bf\u09b0\u09c1\u09a6\u09cd\u09a7\u09c7 \u098f\u0995\u099f\u09bf \u09a6\u09ae\u09a8\u09ae\u09c2\u09b2\u0995 \u0986\u0987\u09a8 \u099a\u09be\u09aa\u09bf\u09af\u09bc\u09c7 \u09a6\u09c7\u09af\u09bc \u09af\u09be \u2018\u09b0\u09be\u0993\u09b2\u09be\u099f \u0986\u0987\u09a8\u2019 \u09a8\u09be\u09ae\u09c7 \u09aa\u09b0\u09bf\u099a\u09bf\u09a4\u0964 \u0985\u09a8\u09cd\u09af\u09be\u09af\u09cd\u09af \u098f \u0986\u0987\u09a8\u09c7 \u09ac\u09bf\u099a\u09be\u09b0 \u099b\u09be\u09a1\u09bc\u09be\u0987 \u0997\u09cd\u09b0\u09c7\u09aa\u09cd\u09a4\u09be\u09b0 \u0993 \u0995\u09cb\u09a8\u09cb \u09aa\u09cd\u09b0\u09ae\u09be\u09a3\u09be\u09a6\u09bf \u099b\u09be\u09a1\u09bc\u09be\u0987 \u09a8\u09bf\u09b0\u09aa\u09b0\u09be\u09a7 \u09ae\u09be\u09a8\u09c1\u09b7\u0995\u09c7 \u0986\u099f\u0995\u09c7 \u09b0\u09be\u0996\u09be\u09b0 \u09ac\u09c8\u09a7\u09a4\u09be \u09aa\u09cd\u09b0\u09a6\u09be\u09a8\u09c7\u09b0 \u09aa\u09be\u09b6\u09be\u09aa\u09be\u09b6\u09bf \u09b8\u0982\u09ac\u09be\u09a6\u09aa\u09a4\u09cd\u09b0\u09c7\u09b0 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be\u0993 \u09b8\u09c0\u09ae\u09bf\u09a4 \u0995\u09b0\u09be \u09b9\u09af\u09bc\u0964 \u098f\u09b0 \u09ab\u09b2\u09c7 \u099c\u09a8\u0997\u09a3\u09c7\u09b0 \u09ae\u09be\u099d\u09c7 \u09a4\u09c0\u09ac\u09cd\u09b0 \u0995\u09cd\u09b7\u09cb\u09ad \u0993 \u0985\u09b8\u09a8\u09cd\u09a4\u09cb\u09b7 \u099b\u09a1\u09bc\u09bf\u09af\u09bc\u09c7 \u09aa\u09a1\u09bc\u09c7 \u098f\u09ac\u0982 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u0985\u099e\u09cd\u099a\u09b2\u09c7 \u09ac\u09bf\u0995\u09cd\u09b7\u09cb\u09ad \u0993 \u09a7\u09b0\u09cd\u09ae\u0998\u099f \u09b6\u09c1\u09b0\u09c1 \u09b9\u09af\u09bc\u0964 \u09aa\u09b0\u09ac\u09b0\u09cd\u09a4\u09c0\u09a4\u09c7 \u09e7\u09e9\u0987 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u0985\u09ae\u09c3\u09a4\u09b8\u09b0\u09c7\u09b0 \u099c\u09be\u09b2\u09bf\u09af\u09bc\u09be\u09a8\u0993\u09af\u09bc\u09be\u09b2\u09be\u09ac\u09be\u0997\u09c7 \u09b9\u09be\u099c\u09be\u09b0 \u09b9\u09be\u099c\u09be\u09b0 \u09ae\u09be\u09a8\u09c1\u09b7 \u09aa\u09cd\u09b0\u09a4\u09bf\u09ac\u09be\u09a6 \u099c\u09be\u09a8\u09be\u09a4\u09c7 \u099c\u09a1\u09bc\u09cb \u09b9\u09b2\u09c7 \u09ac\u09cd\u09b0\u09bf\u099f\u09bf\u09b6 \u09b8\u09c7\u09a8\u09be \u0995\u09b0\u09cd\u09ae\u0995\u09b0\u09cd\u09a4\u09be \u099c\u09c7\u09a8\u09be\u09b0\u09c7\u09b2 \u09a1\u09be\u09af\u09bc\u09be\u09b0\u09c7\u09b0 \u09a8\u09bf\u09b0\u09cd\u09a6\u09c7\u09b6\u09c7 \u09a8\u09bf\u09b0\u09b8\u09cd\u09a4\u09cd\u09b0 \u099c\u09a8\u09b8\u09be\u09a7\u09be\u09b0\u09a3\u09c7\u09b0 \u0989\u09aa\u09b0\u09c7 \u09a8\u09bf\u09b0\u09cd\u09ac\u09bf\u099a\u09be\u09b0\u09c7 \u0997\u09c1\u09b2\u09bf \u099a\u09be\u09b2\u09be\u09a8\u09cb \u09b9\u09af\u09bc\u0964 \u09ac\u09cd\u09b0\u09bf\u099f\u09bf\u09b6 \u0995\u09b0\u09cd\u09a4\u09c3\u0995 \u09b8\u0982\u0997\u09a0\u09bf\u09a4 \u0995\u09c1\u0996\u09cd\u09af\u09be\u09a4 \u098f \u0997\u09a3\u09b9\u09a4\u09cd\u09af\u09be\u09af\u09bc \u0985\u09b8\u0982\u0996\u09cd\u09af \u09ae\u09be\u09a8\u09c1\u09b7 \u0986\u09b9\u09a4 \u0993 \u09a8\u09bf\u09b9\u09a4 \u09b9\u09af\u09bc\u0964 \u099c\u09be\u09b2\u09bf\u09af\u09bc\u09be\u09a8\u0993\u09af\u09bc\u09be\u09b2\u09be\u09ac\u09be\u0997 \u09b9\u09a4\u09cd\u09af\u09be\u0995\u09be\u09a3\u09cd\u09a1\u09c7\u09b0 \u09aa\u09cd\u09b0\u09c7\u0995\u09cd\u09b7\u09be\u09aa\u099f\u09c7 \u0986\u09ae\u09b0\u09be \u09a6\u09c7\u0996\u09bf, \u09b0\u09be\u0993\u09b2\u09be\u099f \u0986\u0987\u09a8\u09c7\u09b0 \u09ae\u09a4\u09cb \u09a6\u09ae\u09a8\u09ae\u09c2\u09b2\u0995 \u0986\u0987\u09a8 \u099c\u09a8\u0997\u09a3\u09c7\u09b0 \u09ae\u09cc\u09b2\u09bf\u0995 \u0985\u09a7\u09bf\u0995\u09be\u09b0 \u0993 \u09a8\u09cd\u09af\u09be\u09af\u09cd\u09af \u09a6\u09be\u09ac\u09bf-\u09a6\u09be\u0993\u09af\u09bc\u09be\u0995\u09c7 \u0995\u09c0\u09ad\u09be\u09ac\u09c7 \u09b9\u09c1\u09ae\u0995\u09bf\u09b0 \u09ae\u09c1\u0996\u09c7 \u09ab\u09c7\u09b2\u09c7\u0964 \u09a4\u09be\u0987, \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8\u09c7\u0993 \u0986\u0987\u09a8 \u09aa\u09cd\u09b0\u09a3\u09af\u09bc\u09a8\u09c7\u09b0 \u0995\u09cd\u09b7\u09c7\u09a4\u09cd\u09b0\u09c7 \u09a6\u09be\u09af\u09bc\u09bf\u09a4\u09cd\u09ac\u09b6\u09c0\u09b2\u09a6\u09c7\u09b0 \u0997\u09c1\u09b0\u09c1\u09a4\u09cd\u09ac\u09be\u09b0\u09cb\u09aa \u0995\u09b0\u09be \u0989\u099a\u09bf\u09ce \u09af\u09be\u09a4\u09c7 \u09aa\u09cd\u09b0\u09a3\u09c0\u09a4 \u09b8\u09c7\u0987 \u0986\u0987\u09a8\u09c7\u09b0 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09af\u09bc\u09a8\u09c7 \u09b8\u09be\u09a7\u09be\u09b0\u09a3 \u099c\u09a8\u0997\u09a3\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09be\u09b6\u09be, \u09ae\u09cc\u09b2\u09bf\u0995 \u0985\u09a7\u09bf\u0995\u09be\u09b0 \u0993 \u09af\u09cc\u0995\u09cd\u09a4\u09bf\u0995 \u099a\u09be\u0993\u09af\u09bc\u09be-\u09aa\u09be\u0993\u09af\u09bc\u09be\u09b0 \u09ac\u09bf\u09b7\u09af\u09bc\u09be\u09a6\u09bf \u09ac\u09be\u09a7\u09be\u0997\u09cd\u09b0\u09b8\u09cd\u09a4 \u09a8\u09be \u09b9\u09af\u09bc\u0964",
