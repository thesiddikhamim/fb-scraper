[
  {
    "title": "\u099c\u09c1\u09b2\u09be\u0987 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ae\u09be\u099d\u09c7 \u09aa\u09c1\u09a8\u09b0\u09be\u09af\u09bc \u0988\u09a6\u09c7\u09b0 \u0986\u09a8\u09a8\u09cd\u09a6 \u09a8\u09bf\u09af\u09bc\u09c7 \u098f\u09b8\u09c7\u099b\u09c7\u0964 \u09a4\u09ac\u09c7, \u09a8\u09a4\u09c1\u09a8 \u0995\u09b0\u09c7 \u09ac\u09be\u0982...",
    "description": "\u099c\u09c1\u09b2\u09be\u0987 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ae\u09be\u099d\u09c7 \u09aa\u09c1\u09a8\u09b0\u09be\u09af\u09bc \u0988\u09a6\u09c7\u09b0 \u0986\u09a8\u09a8\u09cd\u09a6 \u09a8\u09bf\u09af\u09bc\u09c7 \u098f\u09b8\u09c7\u099b\u09c7\u0964 \u09a4\u09ac\u09c7, \u09a8\u09a4\u09c1\u09a8 \u0995\u09b0\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u099c\u09a8\u09b8\u09be\u09a7\u09be\u09b0\u09a3\u09c7\u09b0 \u0986\u09a8\u09a8\u09cd\u09a6, \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be \u0993 \u09ae\u09be\u09a8\u09ac\u09be\u09a7\u09bf\u0995\u09be\u09b0 \u09ab\u09bf\u09b0\u09bf\u09af\u09bc\u09c7 \u0986\u09a8\u09be \u09b0\u0995\u09cd\u09a4\u0995\u09cd\u09b7\u09af\u09bc\u09c0 \u098f \u099c\u09c1\u09b2\u09be\u0987 \u0995\u09c7\u09a1\u09bc\u09c7 \u09a8\u09bf\u09af\u09bc\u09c7\u099b\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0985\u09b8\u0982\u0996\u09cd\u09af \u09b8\u09b9\u09af\u09cb\u09a6\u09cd\u09a7\u09be \u09ad\u09be\u0987-\u09ac\u09cb\u09a8\u09c7\u09b0 \u09a4\u09be\u099c\u09be \u09aa\u09cd\u09b0\u09be\u09a3\u0964 \u099c\u09c1\u09b2\u09be\u0987 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8\u09c7 \u09aa\u09cd\u09b0\u09be\u09a3 \u09ac\u09bf\u09b8\u09b0\u09cd\u099c\u09a8 \u0995\u09b0\u09be \u098f\u09ae\u09a8\u0987 \u098f\u0995\u099c\u09a8 \u09b6\u09b9\u09c0\u09a6 \u09b9\u09b2\u09c7\u09a8 \u09a2\u09be\u0995\u09be \u09b0\u09c7\u09b8\u09bf\u09a1\u09c7\u09a8\u09cd\u09b8\u09bf\u09af\u09bc\u09be\u09b2 \u09ae\u09a1\u09c7\u09b2 \u0995\u09b2\u09c7\u099c\u09c7\u09b0 \u098f\u0995\u09be\u09a6\u09b6 \u09b6\u09cd\u09b0\u09c7\u09a3\u09bf\u09b0 \u09ae\u09c7\u09a7\u09be\u09ac\u09c0 \u099b\u09be\u09a4\u09cd\u09b0 \u09ab\u09be\u09b0\u09b9\u09be\u09a8 \u09ab\u09be\u0987\u09af\u09bc\u09be\u099c\u0964 \u099b\u09be\u09a4\u09cd\u09b0-\u099c\u09a8\u09a4\u09be\u09b0 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8 \u099a\u09b2\u09be\u0995\u09be\u09b2\u09c0\u09a8 \u09e8\u09e6\u09e8\u09ea \u09b8\u09be\u09b2\u09c7\u09b0 \u09e7\u09ee \u099c\u09c1\u09b2\u09be\u0987 \u09a7\u09be\u09a8\u09ae\u09a8\u09cd\u09a1\u09bf \u098f\u09b2\u09be\u0995\u09be\u09af\u09bc \u09aa\u09c1\u09b2\u09bf\u09b6 \u0993 \u099b\u09be\u09a4\u09cd\u09b0\u09b2\u09c0\u0997\u09c7\u09b0 \u09b9\u09be\u09ae\u09b2\u09be\u09af\u09bc \u09ac\u09c1\u0995\u09c7 \u0997\u09c1\u09b2\u09bf\u09ac\u09bf\u09a6\u09cd\u09a7 \u09b9\u09af\u09bc\u09c7 \u09b6\u09be\u09b9\u09be\u09a6\u09be\u09a4 \u09ac\u09b0\u09a3 \u0995\u09b0\u09c7\u09a8 \u09a4\u09bf\u09a8\u09bf\u0964 \u09ab\u09cd\u09af\u09be\u09b8\u09bf\u09ac\u09be\u09a6\u09ae\u09c1\u0995\u09cd\u09a4 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u0985\u09b0\u09cd\u099c\u09a8\u09c7 \u09b6\u09b9\u09c0\u09a6 \u09ab\u09be\u09b0\u09b9\u09be\u09a8 \u09ab\u09be\u0987\u09af\u09bc\u09be\u099c\u09c7\u09b0 \u0986\u09a4\u09cd\u09ae\u09a4\u09cd\u09af\u09be\u0997 \u099a\u09bf\u09b0\u09b8\u09cd\u09ae\u09b0\u09a3\u09c0\u09af\u09bc\u0964 \u0986\u099c \u099c\u09be\u09a4\u09c0\u09af\u09bc \u0988\u09a6\u0997\u09be\u09b9\u09c7 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u0988\u09a6\u09c1\u09b2 \u09ab\u09bf\u09a4\u09b0\u09c7\u09b0 \u09a8\u09be\u09ae\u09be\u099c \u0986\u09a6\u09be\u09af\u09bc \u09b6\u09c7\u09b7\u09c7 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0 \u09b6\u09b9\u09c0\u09a6 \u09ab\u09be\u09b0\u09b9\u09be\u09a8 \u09ab\u09be\u0987\u09af\u09bc\u09be\u099c\u09c7\u09b0 \u09aa\u09b0\u09bf\u09ac\u09be\u09b0\u09c7\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u09b8\u09be\u0995\u09cd\u09b7\u09be\u09ce \u0995\u09b0\u09c7\u09a8\u0964 \u098f\u09b8\u09ae\u09af\u09bc \u0988\u09a6\u09c7\u09b0 \u09b6\u09c1\u09ad\u09c7\u099a\u09cd\u099b\u09be \u09ac\u09bf\u09a8\u09bf\u09ae\u09af\u09bc \u0993 \u09a6\u09c7\u09b6\u09c7\u09b0 \u09b8\u09be\u09ae\u0997\u09cd\u09b0\u09bf\u0995 \u09ac\u09bf\u09b7\u09af\u09bc \u09a8\u09bf\u09af\u09bc\u09c7 \u0986\u09b2\u09cb\u099a\u09a8\u09be\u0995\u09be\u09b2\u09c7 \u099c\u09c1\u09b2\u09be\u0987 \u0997\u09a3\u09b9\u09a4\u09cd\u09af\u09be\u09b0 \u09ac\u09bf\u099a\u09be\u09b0 \u0985\u09a4\u09bf\u09a6\u09cd\u09b0\u09c1\u09a4 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09af\u09bc\u09a8 \u0995\u09b0\u09be\u09b0 \u09ac\u09bf\u09b7\u09af\u09bc\u099f\u09bf \u0997\u09c1\u09b0\u09c1\u09a4\u09cd\u09ac\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u0986\u09b2\u09cb\u099a\u09bf\u09a4 \u09b9\u09af\u09bc\u0964 \u09b6\u09b9\u09c0\u09a6 \u09ab\u09be\u09b0\u09b9\u09be\u09a8 \u09ab\u09be\u0987\u09af\u09bc\u09be\u099c \u09a4\u09be\u09b0 \u09ab\u09c7\u09b8\u09ac\u09c1\u0995 \u09ac\u09be\u09af\u09bc\u09cb\u09a4\u09c7 \u09b2\u09bf\u0996\u09c7\u099b\u09bf\u09b2\u09c7\u09a8, \u2018One day you'll leave this world behind, So live a life you will remember.\u2019 \u09ab\u09be\u09b0\u09b9\u09be\u09a8 \u09ab\u09be\u0987\u09af\u09bc\u09be\u099c\u09c7\u09b0 \u09ae\u09a8\u09c7\u09b0 \u098f\u0987 \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09be\u09b6\u09be \u09b8\u09a4\u09cd\u09af\u09bf \u09b9\u09af\u09bc\u09c7\u099b\u09c7\u0964 \u099c\u09c1\u09b2\u09be\u0987 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8\u09c7 \u09b6\u09be\u09b9\u09be\u09a6\u09be\u09a4 \u09ac\u09b0\u09a3 \u0995\u09b0\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae\u09c0 \u0995\u09be\u09ab\u09c7\u09b2\u09be \u09a5\u09c7\u0995\u09c7 \u09ac\u09bf\u09a6\u09be\u09af\u09bc \u09a8\u09bf\u09b2\u09c7\u0993 \u09a4\u09bf\u09a8\u09bf \u098f \u09a6\u09c7\u09b6\u09c7\u09b0 \u0987\u09a4\u09bf\u09b9\u09be\u09b8\u09c7 \u09ad\u09be\u09b8\u09cd\u09ae\u09b0 \u09b9\u09af\u09bc\u09c7 \u09b0\u0987\u09ac\u09c7\u09a8 \u099a\u09bf\u09b0\u0995\u09be\u09b2\u0964 \u0986\u09ae\u09b0\u09be \u09a6\u09cb\u09af\u09bc\u09be \u0995\u09b0\u09bf, \u09ae\u09b9\u09be\u09a8 \u0986\u09b2\u09cd\u09b2\u09be\u09b9 \u09a4\u09be\u2019\u0986\u09b2\u09be \u09af\u09c7\u09a8 \u09a4\u09be\u09b0 \u09b0\u09c1\u09b9\u09c7\u09b0 \u0989\u09aa\u09b0 \u0995\u09b2\u09cd\u09af\u09be\u09a3 \u09ac\u09b0\u09cd\u09b7\u09bf\u09a4 \u0995\u09b0\u09c7\u09a8\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
    "link": "https://www.facebook.com/NasiruddinNcpOfficial/posts/pfbid07Qj2FCyoW4aX138oH816MfiDQKvyDKaQi9mi7EsYSpx4atPJa1SdqbHrb6Uvap5el",
    "guid": "https://www.facebook.com/NasiruddinNcpOfficial/posts/pfbid07Qj2FCyoW4aX138oH816MfiDQKvyDKaQi9mi7EsYSpx4atPJa1SdqbHrb6Uvap5el",
    "pubDate": "2026-03-22T03:39:20.852659+00:00",
