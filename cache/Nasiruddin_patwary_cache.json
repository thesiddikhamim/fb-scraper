[
  {
    "title": "\u2018\u09e7\u09e8\u0987 \u09ab\u09c7\u09ac\u09cd\u09b0\u09c1\u09af\u09bc\u09be\u09b0\u09bf \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7 \u0997\u09a3\u09a4\u09a8\u09cd\u09a4\u09cd\u09b0\u09c7\u09b0 \u09ac\u09a6\u09b2\u09c7 \u099c\u09bf\u09af\u09bc\u09be\u09a4\u09a8\u09cd\u09a4\u09cd\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be \u0995\u09b0\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09c7\u0964\u2019 \u0997\u09a4...",
    "description": "\u2018\u09e7\u09e8\u0987 \u09ab\u09c7\u09ac\u09cd\u09b0\u09c1\u09af\u09bc\u09be\u09b0\u09bf \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7 \u0997\u09a3\u09a4\u09a8\u09cd\u09a4\u09cd\u09b0\u09c7\u09b0 \u09ac\u09a6\u09b2\u09c7 \u099c\u09bf\u09af\u09bc\u09be\u09a4\u09a8\u09cd\u09a4\u09cd\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be \u0995\u09b0\u09be \u09b9\u09af\u09bc\u09c7\u099b\u09c7\u0964\u2019 \u0997\u09a4 \u09e7\u09ee\u0987 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09b6\u09a8\u09bf\u09ac\u09be\u09b0, \u09e7\u09e7 \u09a6\u09b2\u09c0\u09af\u09bc \u0990\u0995\u09cd\u09af\u09c7\u09b0 \u09b8\u09ae\u09be\u09ac\u09c7\u09b6\u09c7 \u098f \u09ae\u09a8\u09cd\u09a4\u09ac\u09cd\u09af \u0995\u09b0\u09c7\u09a8 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09ae\u09c1\u0996\u09cd\u09af \u09b8\u09ae\u09a8\u09cd\u09ac\u09af\u09bc\u0995 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0\u0964 \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8 \u09b8\u09b0\u0995\u09be\u09b0 \u0995\u09b0\u09cd\u09a4\u09c3\u0995 \u099c\u09a8\u099c\u09c0\u09ac\u09a8\u0995\u09c7 \u09ac\u09bf\u09aa\u09b0\u09cd\u09af\u09b8\u09cd\u09a4 \u0995\u09b0\u09c7 \u09a4\u09cb\u09b2\u09be\u09b0 \u09aa\u09cd\u09b0\u09c7\u0995\u09cd\u09b7\u09be\u09aa\u099f \u098f\u09ac\u0982 \u09a4\u09be\u09a6\u09c7\u09b0 \u09a6\u09b2\u09c0\u09af\u09bc \u09a8\u09c7\u09a4\u09be\u0995\u09b0\u09cd\u09ae\u09c0\u09a6\u09c7\u09b0 \u09a6\u09bf\u09af\u09bc\u09c7 \u09a6\u09c1\u09a6\u0995 \u0993 \u09a6\u09c7\u09b6\u09c7\u09b0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u09ac\u09cd\u09af\u09be\u0982\u0995\u09b8\u09b9 \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be\u09a8\u0997\u09c1\u09b2\u09cb \u09a6\u0996\u09b2 \u0995\u09b0\u09be\u09b0 \u099c\u09cb\u09b0\u09be\u09b2\u09cb \u09aa\u09cd\u09b0\u09a4\u09bf\u09ac\u09be\u09a6 \u099c\u09be\u09a8\u09be\u09a8 \u09a4\u09bf\u09a8\u09bf\u0964 \u09b8\u09a8\u09cd\u09a4\u09cd\u09b0\u09be\u09b8\u09c0 \u0995\u09be\u09af\u09bc\u09a6\u09be\u09af\u09bc \u09e7\u09e7 \u09a6\u09b2\u09c0\u09af\u09bc \u0990\u0995\u09cd\u09af\u09c7\u09b0 \u09a8\u09c7\u09a4\u09c3\u09ac\u09c3\u09a8\u09cd\u09a6\u09c7\u09b0 \u09ac\u09be\u09b8\u09be\u09af\u09bc \u09b9\u09be\u09ae\u09b2\u09be \u0995\u09b0\u09be\u09b0 \u0998\u099f\u09a8\u09be \u0989\u09b2\u09cd\u09b2\u09c7\u0996 \u0995\u09b0\u09c7 \u09a4\u09bf\u09a8\u09bf \u09ac\u09b2\u09c7\u09a8, \u2018\u099c\u09bf\u09af\u09bc\u09be\u0989\u09b0 \u09b0\u09b9\u09ae\u09be\u09a8\u09c7\u09b0 \u09b8\u09a8\u09cd\u09a4\u09be\u09a8\u09c7\u09b0 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09ce \u09af\u09be\u09ac\u09c7 \u09a8\u09be\u2019\u0964 \u09b8\u0982\u0995\u09cd\u09b7\u09bf\u09aa\u09cd\u09a4 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af\u09c7 \u09a4\u09bf\u09a8\u09bf \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09ce \u09b6\u09b9\u09c0\u09a6 \u0993\u09b8\u09ae\u09be\u09a8 \u09b9\u09be\u09a6\u09bf \u098f\u09ac\u0982 \u098f\u0995\u09be\u09a4\u09cd\u09a4\u09b0 \u0993 \u099a\u09ac\u09cd\u09ac\u09bf\u09b6\u09c7\u09b0 \u09b6\u09b9\u09c0\u09a6\u09a6\u09c7\u09b0 \u09aa\u09a5\u09c7 \u09af\u09be\u09ac\u09c7 \u09ac\u09b2\u09c7 \u09ae\u09a4\u09aa\u09cd\u09b0\u0995\u09be\u09b6 \u0995\u09b0\u09c7\u09a8\u0964 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af\u09c7\u09b0 \u09b6\u09c7\u09b7\u09c7 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u098f\u0987 \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be\u09ae\u09af\u09bc \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7\u09b0 \u09aa\u09a5\u09c7 \u09af\u09be\u09b0\u09be \u09ac\u09be\u09a7\u09be \u09b9\u09af\u09bc\u09c7 \u09a6\u09be\u0981\u09a1\u09bc\u09be\u09ac\u09c7 \u09a4\u09be\u09a6\u09c7\u09b0\u0995\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b9\u09a4 \u0995\u09b0\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u09b8\u0995\u09b2\u0995\u09c7 \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09c1\u09a4 \u09a5\u09be\u0995\u09be\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09a8 \u099c\u09be\u09a8\u09be\u09a8\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
