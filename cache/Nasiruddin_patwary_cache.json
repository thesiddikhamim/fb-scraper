  {
    "title": "\u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u09b2\u09be\u0987\u09b2\u09be\u09a4\u09c1\u09b2 \u0995\u09cd\u09ac\u09a6\u09b0 \u0989\u09aa\u09b2\u0995\u09cd\u09b7\u09c7 \u09a6\u09c7\u09b6\u09ac\u09be\u09b8\u09c0\u09b8\u09b9 \u09a4\u09be\u09ae\u09be\u09ae \u09ac\u09bf\u09b6\u09cd\u09ac\u09c7\u09b0 \u09ae\u09c1\u09b8\u09b2\u09bf\u09ae \u0989\u09ae\u09cd\u09ae\u09be\u09b9\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u099c\u09be\u09a8\u09be\u0987...",
    "description": "\u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u09b2\u09be\u0987\u09b2\u09be\u09a4\u09c1\u09b2 \u0995\u09cd\u09ac\u09a6\u09b0 \u0989\u09aa\u09b2\u0995\u09cd\u09b7\u09c7 \u09a6\u09c7\u09b6\u09ac\u09be\u09b8\u09c0\u09b8\u09b9 \u09a4\u09be\u09ae\u09be\u09ae \u09ac\u09bf\u09b6\u09cd\u09ac\u09c7\u09b0 \u09ae\u09c1\u09b8\u09b2\u09bf\u09ae \u0989\u09ae\u09cd\u09ae\u09be\u09b9\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u099c\u09be\u09a8\u09be\u0987 \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995 \u09b6\u09c1\u09ad\u09c7\u099a\u09cd\u099b\u09be \u0993 \u09ae\u09cb\u09ac\u09be\u09b0\u0995\u09ac\u09be\u09a6\u0964 \u09b0\u09ae\u09be\u09a6\u09be\u09a8\u09c7\u09b0 \u09ae\u09b9\u09bf\u09ae\u09be\u09a8\u09cd\u09ac\u09bf\u09a4 \u098f \u09b0\u099c\u09a8\u09c0 \u09ae\u09be\u09a8\u09ac\u099c\u09be\u09a4\u09bf\u09b0 \u099c\u09a8\u09cd\u09af \u0985\u09b8\u09c0\u09ae \u09ac\u09b0\u0995\u09a4\u09ae\u09af\u09bc \u0993 \u09a4\u09be\u09ce\u09aa\u09b0\u09cd\u09af\u09aa\u09c2\u09b0\u09cd\u09a3\u0964 \u098f\u0987 \u09b0\u09be\u09a4\u09c7\u0987 \u0985\u09ac\u09a4\u09c0\u09b0\u09cd\u09a3 \u09b9\u09af\u09bc\u09c7\u099b\u09c7 \u09ac\u09bf\u09b6\u09cd\u09ac \u09ae\u09be\u09a8\u09ac\u09a4\u09be\u09b0 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf \u0993 \u09b9\u09c7\u09a6\u09be\u09af\u09bc\u09c7\u09a4\u09c7\u09b0 \u09ae\u09b9\u09be\u0997\u09cd\u09b0\u09a8\u09cd\u09a5 \u0986\u09b2-\u0995\u09c1\u09b0\u0986\u09a8\u0964 \u2018\u09b8\u09c1\u09b0\u09be-\u0986\u09b2-\u0995\u09cd\u09ac\u09a6\u09b0\u2019-\u098f \u09ae\u09b9\u09be\u09a8 \u0986\u09b2\u09cd\u09b2\u09be\u09b9 \u09a4\u09be\u2019\u0986\u09b2\u09be \u09b2\u09be\u0987\u09b2\u09be\u09a4\u09c1\u09b2 \u0995\u09cd\u09ac\u09a6\u09b0\u0995\u09c7 \u09b9\u09be\u099c\u09be\u09b0 \u09ae\u09be\u09b8\u09c7\u09b0 \u099a\u09c7\u09af\u09bc\u09c7\u0993 \u09b6\u09cd\u09b0\u09c7\u09b7\u09cd\u09a0 \u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be\u09af\u09bc \u09ad\u09c2\u09b7\u09bf\u09a4 \u0995\u09b0\u09c7\u099b\u09c7\u09a8\u0964 \u09b2\u09be\u0987\u09b2\u09be\u09a4\u09c1\u09b2 \u0995\u09cd\u09ac\u09a6\u09b0 \u0986\u09ae\u09be\u09a6\u09c7\u09b0\u0995\u09c7 \u09a4\u0993\u09ac\u09be\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u09ae\u09b9\u09be\u09a8 \u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09b0 \u09a8\u09c8\u0995\u099f\u09cd\u09af \u0985\u09b0\u09cd\u099c\u09a8\u09c7\u09b0 \u0985\u09a8\u09a8\u09cd\u09af \u09b8\u09c1\u09af\u09cb\u0997 \u098f\u09a8\u09c7 \u09a6\u09c7\u09af\u09bc\u0964 \u09a6\u09cb\u09af\u09bc\u09be, \u0987\u09ac\u09be\u09a6\u09a4, \u0995\u09c1\u09b0\u0986\u09a8 \u09a4\u09bf\u09b2\u09be\u0993\u09af\u09bc\u09be\u09a4 \u098f\u09ac\u0982 \u09ae\u09be\u09a8\u09ac\u0995\u09b2\u09cd\u09af\u09be\u09a3\u09c7 \u09a8\u09bf\u099c\u09c7\u0995\u09c7 \u0989\u09ce\u09b8\u09b0\u09cd\u0997 \u0995\u09b0\u09be\u09b0 \u09a8\u09bf\u09af\u09bc\u09cd\u09af\u09a4\u09c7\u09b0 \u09ae\u09a7\u09cd\u09af \u09a6\u09bf\u09af\u09bc\u09c7 \u0986\u09ae\u09b0\u09be \u098f\u0987 \u09b0\u09be\u09a4\u09c7\u09b0 \u09aa\u09cd\u09b0\u0995\u09c3\u09a4 \u09a4\u09be\u09ce\u09aa\u09b0\u09cd\u09af \u0989\u09aa\u09b2\u09ac\u09cd\u09a7\u09bf \u0995\u09b0\u09a4\u09c7 \u09aa\u09be\u09b0\u09bf\u0964 \u0986\u09b8\u09c1\u09a8, \u09ae\u09b9\u09bf\u09ae\u09be\u09a8\u09cd\u09ac\u09bf\u09a4 \u098f \u09b0\u099c\u09a8\u09c0\u09b0 \u0986\u09b2\u09cb\u0995\u09c7 \u0986\u09ae\u09b0\u09be \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ac\u09cd\u09af\u0995\u09cd\u09a4\u09bf\u099c\u09c0\u09ac\u09a8\u09b8\u09b9 \u09b8\u09ae\u09be\u099c \u0993 \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0\u09c7 \u09a8\u09cd\u09af\u09be\u09af\u09bc, \u09b6\u09be\u09a8\u09cd\u09a4\u09bf, \u09b8\u09b9\u09a8\u09b6\u09c0\u09b2\u09a4\u09be \u0993 \u09ae\u09be\u09a8\u09ac\u09bf\u0995 \u09ae\u09c2\u09b2\u09cd\u09af\u09ac\u09cb\u09a7 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be\u09af\u09bc \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09af\u09bc\u09c0 \u09b9\u0987\u0964 \u09aa\u09be\u09b6\u09be\u09aa\u09be\u09b6\u09bf \u09a6\u09b0\u09bf\u09a6\u09cd\u09b0, \u0985\u09b8\u09b9\u09be\u09af\u09bc \u0993 \u09b8\u09c1\u09ac\u09bf\u09a7\u09be\u09ac\u099e\u09cd\u099a\u09bf\u09a4 \u09ae\u09be\u09a8\u09c1\u09b7\u09c7\u09b0 \u09aa\u09be\u09b6\u09c7 \u09a6\u09be\u0981\u09a1\u09bc\u09bf\u09af\u09bc\u09c7 \u09ae\u09be\u09a8\u09ac\u0995\u09b2\u09cd\u09af\u09be\u09a3\u09c7\u09b0 \u09ae\u09b9\u09be\u09a8 \u0986\u09a6\u09b0\u09cd\u09b6\u0995\u09c7 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09af\u09bc\u09bf\u09a4 \u0995\u09b0\u09bf\u0964 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u098f\u0987 \u09b0\u099c\u09a8\u09c0\u09a4\u09c7 \u09ae\u09b9\u09be\u09a8 \u09b0\u09be\u09ac\u09cd\u09ac\u09c1\u09b2 \u0986\u2019\u09b2\u09be\u09ae\u09bf\u09a8\u09c7\u09b0 \u09a6\u09b0\u09ac\u09be\u09b0\u09c7 \u09ac\u09bf\u09a8\u09c0\u09a4 \u09aa\u09cd\u09b0\u09be\u09b0\u09cd\u09a5\u09a8\u09be, \u09a4\u09bf\u09a8\u09bf \u09af\u09c7\u09a8 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u0995\u09b2 \u0987\u09ac\u09be\u09a6\u09a4 \u0995\u09ac\u09c1\u09b2 \u0995\u09b0\u09c7\u09a8, \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0997\u09c1\u09a8\u09be\u09b9\u09b8\u09ae\u09c2\u09b9 \u0995\u09cd\u09b7\u09ae\u09be \u0995\u09b0\u09c7 \u09a6\u09c7\u09a8 \u098f\u09ac\u0982 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u09b2\u09be\u0987\u09b2\u09be\u09a4\u09c1\u09b2 \u0995\u09cd\u09ac\u09a6\u09b0\u09c7\u09b0 \u0985\u09b6\u09c7\u09b7 \u09b0\u09b9\u09ae\u09a4 \u0993 \u09ac\u09b0\u0995\u09a4\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u099c\u09c0\u09ac\u09a8\u0995\u09c7 \u0989\u09a6\u09cd\u09ad\u09be\u09b8\u09bf\u09a4 \u0995\u09b0\u09c7\u09a8\u0964 \u098f\u0995\u0987\u09b8\u09be\u09a5\u09c7 \u09aa\u09cd\u09b0\u09be\u09b0\u09cd\u09a5\u09a8\u09be \u0995\u09b0\u09bf, \u09ae\u09b9\u09be\u09a8 \u0986\u09b2\u09cd\u09b2\u09be\u09b9 \u09af\u09c7\u09a8 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09bf\u09af\u09bc \u09a6\u09c7\u09b6 \u0993 \u099c\u09be\u09a4\u09bf\u0995\u09c7 \u09b6\u09be\u09a8\u09cd\u09a4\u09bf, \u09b8\u09ae\u09cd\u09aa\u09cd\u09b0\u09c0\u09a4\u09bf \u0993 \u09b8\u09ae\u09c3\u09a6\u09cd\u09a7\u09bf\u09b0 \u09aa\u09a5\u09c7 \u09aa\u09b0\u09bf\u099a\u09be\u09b2\u09bf\u09a4 \u0995\u09b0\u09c7\u09a8 \u098f\u09ac\u0982 \u098f\u0987 \u09a6\u09c7\u09b6\u09c7\u09b0 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be-\u09b8\u09be\u09b0\u09cd\u09ac\u09ad\u09cc\u09ae\u09a4\u09cd\u09ac\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u09af\u09be\u09b0\u09be \u09b6\u09be\u09b9\u09be\u09a6\u09be\u09a4 \u09ac\u09b0\u09a3 \u0995\u09b0\u09c7\u099b\u09c7 \u09a4\u09be\u09a6\u09c7\u09b0\u0995\u09c7 \u099c\u09be\u09a8\u09cd\u09a8\u09be\u09a4\u09c1\u09b2 \u09ab\u09c7\u09b0\u09a6\u09be\u0989\u09b8\u09c7 \u09b8\u09ae\u09be\u09b8\u09c0\u09a8 \u0995\u09b0\u09c7\u09a8\u0964 \u09b2\u09be\u0987\u09b2\u09be\u09a4\u09c1\u09b2 \u0995\u09cd\u09ac\u09a6\u09b0\u09c7\u09b0 \u09ae\u09b9\u09bf\u09ae\u09be \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b9\u09c3\u09a6\u09af\u09bc\u09c7 \u0988\u09ae\u09be\u09a8\u09c7\u09b0 \u09a6\u09c3\u09a2\u09bc\u09a4\u09be, \u09a8\u09c8\u09a4\u09bf\u0995\u09a4\u09be\u09b0 \u09b6\u0995\u09cd\u09a4\u09bf \u0993 \u09ae\u09be\u09a8\u09ac\u0995\u09b2\u09cd\u09af\u09be\u09a3\u09c7\u09b0 \u09aa\u09cd\u09b0\u09c7\u09b0\u09a3\u09be \u099c\u09be\u0997\u09bf\u09af\u09bc\u09c7 \u09a4\u09c1\u09b2\u09c1\u0995, \u098f\u0987 \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09be\u09b6\u09be \u0995\u09b0\u09bf\u0964 \u0986\u09ae\u09bf\u09a8\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
    "link": "https://www.facebook.com/NasiruddinNcpOfficial/posts/pfbid02pAMWTyQtNr55k4FaMwyNBmGs1jWEhq6uDd3oSDSicE6JALDdVSmESDBwSXssjcZPl",
    "guid": "https://www.facebook.com/NasiruddinNcpOfficial/posts/pfbid02pAMWTyQtNr55k4FaMwyNBmGs1jWEhq6uDd3oSDSicE6JALDdVSmESDBwSXssjcZPl",
