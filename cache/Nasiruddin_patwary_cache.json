    "title": "\u09b0\u09bf\u09b9\u09b2\u09be-\u098f-\u09a4\u09be\u09b0\u09be\u09ac\u09bf \u0995\u09b0\u09cd\u09ae\u09b8\u09c2\u099a\u09bf\u09b0 \u0985\u0982\u09b6 \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u09b0\u0982\u09aa\u09c1\u09b0 \u09ae\u09a1\u09c7\u09b2 \u09ae\u09b8\u099c\u09bf\u09a6\u09c7 \u09e8\u09e8\u09a4\u09ae \u09a4\u09be\u09b0\u09be\u09ac\u09bf\u09b0 \u09a8\u09be\u09ae\u09be\u099c \u0986\u09a6\u09be\u09df\u09c7\u09b0 ...",
    "description": "\u09b0\u09bf\u09b9\u09b2\u09be-\u098f-\u09a4\u09be\u09b0\u09be\u09ac\u09bf \u0995\u09b0\u09cd\u09ae\u09b8\u09c2\u099a\u09bf\u09b0 \u0985\u0982\u09b6 \u09b9\u09bf\u09b8\u09c7\u09ac\u09c7 \u09b0\u0982\u09aa\u09c1\u09b0 \u09ae\u09a1\u09c7\u09b2 \u09ae\u09b8\u099c\u09bf\u09a6\u09c7 \u09e8\u09e8\u09a4\u09ae \u09a4\u09be\u09b0\u09be\u09ac\u09bf\u09b0 \u09a8\u09be\u09ae\u09be\u099c \u0986\u09a6\u09be\u09df\u09c7\u09b0 \u09aa\u09b0 \u099c\u09a8\u09b8\u09ae\u09c1\u09a6\u09cd\u09b0\u09c7 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09df\u09be\u09b0\u09c0\u0964 \u2014 \u098f\u09a1\u09ae\u09bf\u09a8",
