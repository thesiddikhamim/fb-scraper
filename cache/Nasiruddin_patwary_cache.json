[
  {
    "title": "\u099c\u09c0\u09ac\u09a8\u09c7\u09b0 \u099a\u09c7\u09df\u09c7 \u09a6\u09c3\u09aa\u09cd\u09a4 \u09ae\u09c3\u09a4\u09cd\u09af\u09c1 \u09a4\u0996\u09a8\u09bf \u099c\u09be\u09a8\u09bf \u09b6\u09b9\u09c0\u09a6\u09c0 \u09b0\u0995\u09cd\u09a4\u09c7 \u09b9\u09c7\u09b8\u09c7 \u0993\u09a0\u09c7 \u09af\u09ac\u09c7 \u099c\u09bf\u09a8\u09cd\u09a6\u09c7\u0997\u09be\u09a8\u09bf, \u09a8\u09a4\u09c1\u09a8 \u09b8\u09ab\u09b0...",
    "description": "\u099c\u09c0\u09ac\u09a8\u09c7\u09b0 \u099a\u09c7\u09df\u09c7 \u09a6\u09c3\u09aa\u09cd\u09a4 \u09ae\u09c3\u09a4\u09cd\u09af\u09c1 \u09a4\u0996\u09a8\u09bf \u099c\u09be\u09a8\u09bf \u09b6\u09b9\u09c0\u09a6\u09c0 \u09b0\u0995\u09cd\u09a4\u09c7 \u09b9\u09c7\u09b8\u09c7 \u0993\u09a0\u09c7 \u09af\u09ac\u09c7 \u099c\u09bf\u09a8\u09cd\u09a6\u09c7\u0997\u09be\u09a8\u09bf, \u09a8\u09a4\u09c1\u09a8 \u09b8\u09ab\u09b0\u09c7 \u09b6\u09c1\u09b0\u09c1 \u09b9\u09cb\u0995 \u0986\u099c \u099c\u09c0\u09ac\u09a8 \u09b8\u09c7\u0987; \u09ae\u09c1\u0995\u09cd\u09a4 \u09aa\u09cd\u09b0\u09be\u09a3\u09c7\u09b0 \u09b0\u09cb\u09b6\u09a8\u09bf\u09a4\u09c7 \u09ad\u09df-\u09b6\u0999\u09cd\u0995\u09be \u09a8\u09c7\u0987\u0964 \u09ab\u09b0\u09b0\u09c1\u0996 \u0986\u09b9\u09ae\u09a6",
