  {
    "title": "'\u09a8\u09cd\u09af\u09be\u09b6\u09a8\u09be\u09b2 \u0993\u09b2\u09be\u09ae\u09be \u0985\u09cd\u09af\u09be\u09b2\u09be\u09df\u09c7\u09a8\u09cd\u09b8'-\u098f\u09b0 \u0989\u09a6\u09cd\u09af\u09cb\u0997\u09c7 \u09b6\u09be\u09aa\u09b2\u09be \u0993 '\u09e8\u09ea-\u098f\u09b0 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8\u09c7\u09b0 \u09b6\u09b9\u09c0\u09a6\u09a6\u09c7\u09b0 \u09b8\u09cd...",
    "description": "'\u09a8\u09cd\u09af\u09be\u09b6\u09a8\u09be\u09b2 \u0993\u09b2\u09be\u09ae\u09be \u0985\u09cd\u09af\u09be\u09b2\u09be\u09df\u09c7\u09a8\u09cd\u09b8'-\u098f\u09b0 \u0989\u09a6\u09cd\u09af\u09cb\u0997\u09c7 \u09b6\u09be\u09aa\u09b2\u09be \u0993 '\u09e8\u09ea-\u098f\u09b0 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8\u09c7\u09b0 \u09b6\u09b9\u09c0\u09a6\u09a6\u09c7\u09b0 \u09b8\u09cd\u09ae\u09b0\u09a3\u09c7 \u0986\u09df\u09cb\u099c\u09bf\u09a4 \u0987\u09ab\u09a4\u09be\u09b0 \u0993 \u09a6\u09cb\u09af\u09bc\u09be \u09ae\u09be\u09b9\u09ab\u09bf\u09b2 \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09c7 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
