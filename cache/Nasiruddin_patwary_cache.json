  },
  {
    "title": "\u0986\u0997\u09be\u09ae\u09c0\u0995\u09be\u09b2, \u09e8\u09e7 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2, \u09a5\u09c7\u0995\u09c7 \u09a6\u09be\u0996\u09bf\u09b2, \u098f\u09b8\u098f\u09b8\u09b8\u09bf \u0993 \u09b8\u09ae\u09ae\u09be\u09a8 \u09aa\u09b0\u09c0\u0995\u09cd\u09b7\u09be \u09b6\u09c1\u09b0\u09c1 \u09b9\u09a4\u09c7 \u09af\u09be\u099a\u09cd\u099b\u09c7\u0964 \u098f \u09aa\u09b0\u09c0\u0995\u09cd...",
    "description": "\u0986\u0997\u09be\u09ae\u09c0\u0995\u09be\u09b2, \u09e8\u09e7 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2, \u09a5\u09c7\u0995\u09c7 \u09a6\u09be\u0996\u09bf\u09b2, \u098f\u09b8\u098f\u09b8\u09b8\u09bf \u0993 \u09b8\u09ae\u09ae\u09be\u09a8 \u09aa\u09b0\u09c0\u0995\u09cd\u09b7\u09be \u09b6\u09c1\u09b0\u09c1 \u09b9\u09a4\u09c7 \u09af\u09be\u099a\u09cd\u099b\u09c7\u0964 \u098f \u09aa\u09b0\u09c0\u0995\u09cd\u09b7\u09be\u09df \u0985\u0982\u09b6\u0997\u09cd\u09b0\u09b9\u09a3\u0995\u09be\u09b0\u09c0 \u09b8\u09be\u09b0\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09e7\u09ee \u09b2\u09be\u0996 \u09eb\u09ed \u09b9\u09be\u099c\u09be\u09b0 \u09aa\u09b0\u09c0\u0995\u09cd\u09b7\u09be\u09b0\u09cd\u09a5\u09c0\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u09b0\u0987\u09b2\u09cb \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995 \u09a6\u09cb\u09df\u09be \u0993 \u09b6\u09c1\u09ad\u0995\u09be\u09ae\u09a8\u09be\u0964 \u09a6\u09c7\u09b6 \u0993 \u099c\u09be\u09a4\u09bf\u09b0 \u0985\u0997\u09cd\u09b0\u0997\u09a4\u09bf\u09b0 \u09b8\u09cd\u09ac\u09be\u09b0\u09cd\u09a5\u09c7 \u0986\u0997\u09be\u09ae\u09c0\u09b0 \u0989\u099c\u09cd\u099c\u09cd\u09ac\u09b2 \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7\u09b0 \u09aa\u09a5\u09c7 \u09a4\u09cb\u09ae\u09b0\u09be \u09b8\u09be\u09ab\u09b2\u09cd\u09af\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u098f\u0997\u09bf\u09df\u09c7 \u09af\u09be\u0993, \u098f\u0987 \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09be\u09b6\u09be \u09ac\u09cd\u09af\u0995\u09cd\u09a4 \u0995\u09b0\u09bf\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
    "link": "https://www.facebook.com/NasiruddinNcpOfficial/posts/pfbid02FaAbmVAUTFttUMCAZ9ApkSwPecxbSXjHmyUVHXcm24k9N57Bd5211xQCXchXF2uel",
    "guid": "https://www.facebook.com/NasiruddinNcpOfficial/posts/pfbid02FaAbmVAUTFttUMCAZ9ApkSwPecxbSXjHmyUVHXcm24k9N57Bd5211xQCXchXF2uel",
    "pubDate": "2026-04-21T04:12:34.268359+00:00",
    "image": "https://scontent-ord5-1.xx.fbcdn.net/v/t39.30808-6/671824872_122166502394706874_2257514318825851132_n.jpg?stp=dst-jpg_s640x640_tt6&_nc_cat=108&ccb=1-7&_nc_sid=7b2446&_nc_ohc=13FWLkchMekQ7kNvwESJMaa&_nc_oc=Adol92OdZVpdo43hvJQjuEHXRhasHgU53-AxSbFRvOXkLqjq2QZlk58G9vVlcBUl1Aw&_nc_zt=23&_nc_ht=scontent-ord5-1.xx&_nc_gid=wE97le53vQSLbWE1VAJVxQ&_nc_ss=7a389&oh=00_Af2PAxJUm9DLUDcaDvbXp5iGCgWIK5umscMwwD_wjWzQZQ&oe=69EE099B"
  },
  {
    "title": "\u09a6\u09c0\u09b0\u09cd\u0998 \u09ee \u09ac\u099b\u09b0 \u09aa\u09b0 \u09a2\u09be\u0995\u09be \u099f\u09cd\u09af\u09be\u0995\u09cd\u09b8\u09c7\u09b8 \u09ac\u09be\u09b0 \u098f\u09b8\u09cb\u09b8\u09bf\u09af\u09bc\u09c7\u09b6\u09a8 \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8 \u09e8\u09e6\u09e8\u09ec-\u09e8\u09ed \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09bf\u09a4 \u09b9\u09a4\u09c7 \u09af\u09be\u099a\u09cd\u099b...",
    "description": "\u09a6\u09c0\u09b0\u09cd\u0998 \u09ee \u09ac\u099b\u09b0 \u09aa\u09b0 \u09a2\u09be\u0995\u09be \u099f\u09cd\u09af\u09be\u0995\u09cd\u09b8\u09c7\u09b8 \u09ac\u09be\u09b0 \u098f\u09b8\u09cb\u09b8\u09bf\u09af\u09bc\u09c7\u09b6\u09a8 \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8 \u09e8\u09e6\u09e8\u09ec-\u09e8\u09ed \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09bf\u09a4 \u09b9\u09a4\u09c7 \u09af\u09be\u099a\u09cd\u099b\u09c7\u0964 \u0986\u099c \u09e7\u09ee\u0987 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09b6\u09a8\u09bf\u09ac\u09be\u09b0, \u0989\u0995\u09cd\u09a4 \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8\u09c7 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf - \u098f\u09a8\u09b8\u09bf\u09aa\u09bf \u09b8\u09ae\u09b0\u09cd\u09a5\u09bf\u09a4 \u098f\u09ac\u0982 \u09a8\u09cd\u09af\u09be\u09b6\u09a8\u09be\u09b2 \u099f\u09cd\u09af\u09be\u0995\u09cd\u09b8 \u09b2\u2019\u0987\u09af\u09bc\u09be\u09b0\u09cd\u09b8 \u0985\u09cd\u09af\u09be\u09b2\u09be\u09af\u09bc\u09c7\u09a8\u09cd\u09b8 - \u098f\u09a8\u099f\u09bf\u098f\u09b2\u098f \u09ae\u09a8\u09cb\u09a8\u09c0\u09a4 \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8\u09c0 \u09aa\u09cd\u09af\u09be\u09a8\u09c7\u09b2\u09c7\u09b0 \u09aa\u09b0\u09bf\u099a\u09bf\u09a4\u09bf \u09b8\u09ad\u09be \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09bf\u09a4 \u09b9\u09af\u09bc\u0964 \u0989\u0995\u09cd\u09a4 \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09c7 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u099b\u09bf\u09b2\u09c7\u09a8 \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09ae\u09c1\u0996\u09cd\u09af \u09b8\u09ae\u09a8\u09cd\u09ac\u09af\u09bc\u0995 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0\u0964 \u098f\u099b\u09be\u09a1\u09bc\u09be\u0993 \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09b8\u09a6\u09b8\u09cd\u09af \u09b8\u099a\u09bf\u09ac \u0986\u0996\u09a4\u09be\u09b0 \u09b9\u09cb\u09b8\u09c7\u09a8, \u098f\u09ae\u09aa\u09bf\u09b8\u09b9 \u09a6\u09b2\u09c7\u09b0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u09aa\u09b0\u09cd\u09af\u09be\u09af\u09bc\u09c7\u09b0 \u0995\u09c7\u09a8\u09cd\u09a6\u09cd\u09b0\u09c0\u09af\u09bc \u09a8\u09c7\u09a4\u09c3\u09ac\u09c3\u09a8\u09cd\u09a6 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u099b\u09bf\u09b2\u09c7\u09a8\u0964 \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09c7 \u0986\u0997\u09be\u09ae\u09c0 \u09e8\u09e8 \u0993 \u09e8\u09e9 \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u0986\u09af\u09bc\u09cb\u099c\u09bf\u09a4 \u09a8\u09bf\u09b0\u09cd\u09ac\u09be\u099a\u09a8\u09c7 \u098f\u09a8\u09b8\u09bf\u09aa\u09bf \u09b8\u09ae\u09b0\u09cd\u09a5\u09bf\u09a4 \u09aa\u09cd\u09af\u09be\u09a8\u09c7\u09b2\u09c7\u09b0 \u09aa\u0995\u09cd\u09b7\u09c7 \u09ac\u09bf\u099c\u09cd\u099e \u0986\u0987\u09a8\u099c\u09c0\u09ac\u09c0\u09a6\u09c7\u09b0 \u09ad\u09cb\u099f, \u09a6\u09cb\u09af\u09bc\u09be \u0993 \u09b8\u09ae\u09b0\u09cd\u09a5\u09a8\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09be\u09b6\u09be \u09ac\u09cd\u09af\u0995\u09cd\u09a4 \u0995\u09b0\u09be \u09b9\u09af\u09bc\u0964 \u09a8\u09cd\u09af\u09be\u09b6\u09a8\u09be\u09b2 \u099f\u09cd\u09af\u09be\u0995\u09cd\u09b8 \u09b2\u2018\u0987\u09af\u09bc\u09be\u09b0\u09cd\u09b8 \u0985\u09cd\u09af\u09be\u09b2\u09be\u09af\u09bc\u09c7\u09a8\u09cd\u09b8\u09c7 \u09af\u09c1\u0995\u09cd\u09a4 \u09b9\u09a4\u09c7 \u09af\u09cb\u0997\u09be\u09af\u09cb\u0997 \u0995\u09b0\u09c1\u09a8: +8801915-805460 (\u098f\u09a1\u09ae\u09bf\u09a8)",
