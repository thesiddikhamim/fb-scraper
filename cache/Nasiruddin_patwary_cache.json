[
  {
    "title": "'\u09ae\u09af\u09bc\u09ae\u09a8\u09b8\u09bf\u0982\u09b9 \u09ac\u09a1\u09bc \u09ae\u09b8\u099c\u09bf\u09a6\u09c7' \u09e8\u09ea \u09a4\u09ae \u09b0\u09ae\u09be\u09a6\u09be\u09a8\u09c7\u09b0 \u09a4\u09be\u09b0\u09be\u09ac\u09c0 \u0986\u09a6\u09be\u09af\u09bc \u09b6\u09c7\u09b7\u09c7 \u09ae\u09c1\u09b8\u09b2\u09cd\u09b2\u09bf\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09ae\u09a4\u09ac\u09bf\u09a8\u09bf\u09ae\u09af...",
    "description": "'\u09ae\u09af\u09bc\u09ae\u09a8\u09b8\u09bf\u0982\u09b9 \u09ac\u09a1\u09bc \u09ae\u09b8\u099c\u09bf\u09a6\u09c7' \u09e8\u09ea \u09a4\u09ae \u09b0\u09ae\u09be\u09a6\u09be\u09a8\u09c7\u09b0 \u09a4\u09be\u09b0\u09be\u09ac\u09c0 \u0986\u09a6\u09be\u09af\u09bc \u09b6\u09c7\u09b7\u09c7 \u09ae\u09c1\u09b8\u09b2\u09cd\u09b2\u09bf\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09ae\u09a4\u09ac\u09bf\u09a8\u09bf\u09ae\u09af\u09bc \u0995\u09b0\u09c7\u09a8 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0\u0964 \u09ae\u09a4\u09ac\u09bf\u09a8\u09bf\u09ae\u09af\u09bc\u0995\u09be\u09b2\u09c7 \u09a4\u09bf\u09a8\u09bf \u09ac\u09b2\u09c7\u09a8, \u098f\u0995 \u0986\u09b2\u09cd\u09b2\u09be\u09b9 \u09ac\u09cd\u09af\u09a4\u09c0\u09a4 \u09a6\u09c1\u09a8\u09bf\u09af\u09bc\u09be\u09b0 \u0985\u09a8\u09cd\u09af \u0995\u09be\u0989\u0995\u09c7 \u09ad\u09af\u09bc \u09aa\u09be\u0993\u09df\u09be \u0989\u099a\u09bf\u09a4 \u09a8\u09af\u09bc\u0964 \u09a4\u09bf\u09a8\u09bf \u09aa\u09b0\u09ae \u0995\u09b0\u09c1\u09a3\u09be\u09ae\u09af\u09bc \u0986\u09b2\u09cd\u09b2\u09be\u09b9\u09b0 \u09a8\u09c8\u0995\u099f\u09cd\u09af \u0985\u09b0\u09cd\u099c\u09a8\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u09b0\u09be\u09b8\u09c1\u09b2 (\u09b8\u09be)-\u098f\u09b0 \u09b8\u09c1\u09a8\u09cd\u09a8\u09be\u09b9 \u0985\u09a8\u09c1\u09b8\u09be\u09b0\u09c7 \u099c\u09c0\u09ac\u09a8\u0997\u09a0\u09a8 \u0995\u09b0\u09be\u09b0 \u09a4\u09be\u09ce\u09aa\u09b0\u09cd\u09af \u09a4\u09c1\u09b2\u09c7 \u09a7\u09b0\u09c7\u09a8\u0964 \u09aa\u09b0\u09bf\u09b6\u09c7\u09b7\u09c7, \u09a6\u09c7\u09b6\u09c7\u09b0 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be-\u09b8\u09be\u09b0\u09cd\u09ac\u09ad\u09cc\u09ae\u09a4\u09cd\u09ac \u0985\u099f\u09c1\u099f \u09b0\u09be\u0996\u09a4\u09c7 \u09b8\u09ac\u09be\u0987\u0995\u09c7 \u09a6\u09c3\u09a2\u09bc \u0985\u0999\u09cd\u0997\u09c0\u0995\u09be\u09b0\u09ac\u09a6\u09cd\u09a7 \u09b9\u0993\u09af\u09bc\u09be\u09b0 \u0986\u09b9\u09cd\u09ac\u09be\u09a8 \u099c\u09be\u09a8\u09be\u09a8\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
