  {
    "title": "\u09ae\u09b9\u09bf\u09ae\u09be\u09a8\u09cd\u09ac\u09bf\u09a4 \u09b0\u099c\u09a8\u09c0 \u09b2\u09be\u0987\u09b2\u09be\u09a4\u09c1\u09b2 \u0995\u09cd\u09ac\u09a6\u09b0\u09c7 '\u09a7\u09be\u09a8\u09ae\u09a3\u09cd\u09a1\u09bf \u09a4\u09be\u0995\u0993\u09af\u09bc\u09be \u09b8\u09cb\u09b8\u09be\u0987\u099f\u09bf \u099c\u09be\u09ae\u09c7 \u09ae\u09b8\u099c\u09bf\u09a6\u09c7\u2019 \u09b8\u09ae\u09ac\u09c7\u09a4 \u09b9\u09af\u09bc...",
    "description": "\u09ae\u09b9\u09bf\u09ae\u09be\u09a8\u09cd\u09ac\u09bf\u09a4 \u09b0\u099c\u09a8\u09c0 \u09b2\u09be\u0987\u09b2\u09be\u09a4\u09c1\u09b2 \u0995\u09cd\u09ac\u09a6\u09b0\u09c7 '\u09a7\u09be\u09a8\u09ae\u09a3\u09cd\u09a1\u09bf \u09a4\u09be\u0995\u0993\u09af\u09bc\u09be \u09b8\u09cb\u09b8\u09be\u0987\u099f\u09bf \u099c\u09be\u09ae\u09c7 \u09ae\u09b8\u099c\u09bf\u09a6\u09c7\u2019 \u09b8\u09ae\u09ac\u09c7\u09a4 \u09b9\u09af\u09bc\u09c7\u099b\u09bf\u09b2\u09c7\u09a8 \u0985\u09b8\u0982\u0996\u09cd\u09af \u09ae\u09c1\u09b8\u09b2\u09cd\u09b2\u09bf\u0964 \u09b8\u09be\u09b0\u09be\u09a6\u09bf\u09a8\u09c7\u09b0 \u09b8\u09bf\u09af\u09bc\u09be\u09ae \u09b8\u09be\u09a7\u09a8\u09be\u09b0 \u09aa\u09b0 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u098f \u09b0\u099c\u09a8\u09c0\u09a4\u09c7 \u09ae\u09b9\u09be\u09ae\u09b9\u09bf\u09ae \u09b0\u09be\u09ac\u09cd\u09ac\u09c1\u09b2 \u0986\u2019\u09b2\u09be\u09ae\u09c0\u09a8\u09c7\u09b0 \u09a6\u09b0\u09ac\u09be\u09b0\u09c7 \u09a8\u09a4 \u09b9\u09af\u09bc\u09c7\u099b\u09bf\u09b2\u09c7\u09a8 \u09b8\u0995\u09b2 \u09b6\u09cd\u09b0\u09c7\u09a3\u09bf-\u09aa\u09c7\u09b6\u09be\u09b0 \u09ae\u09be\u09a8\u09c1\u09b7\u099c\u09a8\u0964 \u09af\u09bf\u0995\u09bf\u09b0-\u0986\u09af\u0995\u09be\u09b0, \u0987\u09ac\u09be\u09a6\u09a4-\u09ac\u09a8\u09cd\u09a6\u09c7\u0997\u09bf \u0993 \u09ae\u09b9\u09be\u09a8 \u09aa\u09cd\u09b0\u09a4\u09bf\u09aa\u09be\u09b2\u0995\u09c7\u09b0 \u09a8\u09bf\u0995\u099f\u09c7 \u0986\u09a4\u09cd\u09ae \u09b8\u0981\u09aa\u09c7 \u09a6\u09c7\u0993\u09af\u09bc\u09be\u09b0 \u098f\u0987 \u09b8\u09cd\u09a8\u09bf\u0997\u09cd\u09a7 \u0986\u09ac\u09b9\u09c7 \u09b8\u0995\u09b2\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u0995\u09bf\u09af\u09bc\u09be\u09ae\u09c1\u09b2 \u09b2\u09be\u0987\u09b2 \u09aa\u09be\u09b2\u09a8\u09c7 \u09b6\u09b0\u09bf\u0995 \u09b9\u09a8 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
