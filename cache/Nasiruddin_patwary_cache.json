    "title": "'\u09b0\u09bf\u09b9\u09b2\u09be-\u098f-\u09a4\u09be\u09b0\u09be\u09ac\u09c0' \u0995\u09b0\u09cd\u09ae\u09b8\u09c2\u099a\u09bf\u09b0 \u09a7\u09be\u09b0\u09be\u09ac\u09be\u09b9\u09bf\u0995\u09a4\u09be\u09af\u09bc \u0986\u099c \u09e7\u09ef \u09a4\u09ae \u09b0\u09ae\u09be\u09a6\u09be\u09a8\u09c7\u09b0 \u09a4\u09be\u09b0\u09be\u09ac\u09c0 \u09ac\u09b0\u09bf\u09b6\u09be\u09b2\u09c7\u09b0 '\u0995\u09c7\u09a8\u09cd...",
    "description": "'\u09b0\u09bf\u09b9\u09b2\u09be-\u098f-\u09a4\u09be\u09b0\u09be\u09ac\u09c0' \u0995\u09b0\u09cd\u09ae\u09b8\u09c2\u099a\u09bf\u09b0 \u09a7\u09be\u09b0\u09be\u09ac\u09be\u09b9\u09bf\u0995\u09a4\u09be\u09af\u09bc \u0986\u099c \u09e7\u09ef \u09a4\u09ae \u09b0\u09ae\u09be\u09a6\u09be\u09a8\u09c7\u09b0 \u09a4\u09be\u09b0\u09be\u09ac\u09c0 \u09ac\u09b0\u09bf\u09b6\u09be\u09b2\u09c7\u09b0 '\u0995\u09c7\u09a8\u09cd\u09a6\u09cd\u09b0\u09c0\u09af\u09bc \u0995\u09b8\u09be\u0987\u0996\u09be\u09a8\u09be \u099c\u09be\u09ae\u09c7 \u09ae\u09b8\u099c\u09bf\u09a6\u09c7' \u0986\u09a6\u09be\u09af\u09bc \u0995\u09b0\u09c7\u09a8 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0\u0964 \u09a8\u09be\u09ae\u09be\u099c \u09b6\u09c7\u09b7\u09c7 \u09a4\u09bf\u09a8\u09bf \u09ae\u09b8\u099c\u09bf\u09a6\u09c7 \u0986\u0997\u09a4 \u09ae\u09c1\u09b8\u09b2\u09cd\u09b2\u09bf\u09ac\u09c3\u09a8\u09cd\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09b8\u09be\u09b2\u09be\u09ae \u0993 \u09b6\u09c1\u09ad\u09c7\u099a\u09cd\u099b\u09be \u09ac\u09bf\u09a8\u09bf\u09ae\u09af\u09bc \u0995\u09b0\u09c7\u09a8\u0964 \u09ac\u09b0\u09bf\u09b6\u09be\u09b2\u09c7\u09b0 \u099c\u09a8\u09b8\u09be\u09a7\u09be\u09b0\u09a3\u09c7\u09b0 \u0985\u09ad\u09c2\u09a4\u09aa\u09c2\u09b0\u09cd\u09ac \u09ad\u09be\u09b2\u09cb\u09ac\u09be\u09b8\u09be \u0993 \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995\u09a4\u09be\u09af\u09bc \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0 \u0997\u09ad\u09c0\u09b0\u09ad\u09be\u09ac\u09c7 \u09ae\u09c1\u0997\u09cd\u09a7 \u09b9\u09af\u09bc\u09c7\u099b\u09c7\u09a8\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
