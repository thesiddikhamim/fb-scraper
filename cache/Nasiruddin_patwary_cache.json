    "title": "'\u09b0\u09bf\u09b9\u09b2\u09be-\u098f-\u099c\u09c1\u09ae\u09c1\u0986' \u09a4\u09a5\u09be \u09b8\u09aa\u09cd\u09a4\u09be\u09b9\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u09b6\u09c1\u0995\u09cd\u09b0\u09ac\u09be\u09b0 \u09b8\u09be\u09b0\u09be \u09a6\u09c7\u09b6\u09c7\u09b0 \u09ad\u09bf\u09a8\u09cd\u09a8 \u09ad\u09bf\u09a8\u09cd\u09a8 \u09ae\u09b8\u099c\u09bf\u09a6\u09c7 \u099c\u09c1\u09ae\u09c1\u0986'...",
    "description": "'\u09b0\u09bf\u09b9\u09b2\u09be-\u098f-\u099c\u09c1\u09ae\u09c1\u0986' \u09a4\u09a5\u09be \u09b8\u09aa\u09cd\u09a4\u09be\u09b9\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u09b6\u09c1\u0995\u09cd\u09b0\u09ac\u09be\u09b0 \u09b8\u09be\u09b0\u09be \u09a6\u09c7\u09b6\u09c7\u09b0 \u09ad\u09bf\u09a8\u09cd\u09a8 \u09ad\u09bf\u09a8\u09cd\u09a8 \u09ae\u09b8\u099c\u09bf\u09a6\u09c7 \u099c\u09c1\u09ae\u09c1\u0986' \u0986\u09a6\u09be\u09df \u0995\u09b0\u09cd\u09ae\u09b8\u09c2\u099a\u09bf\u09b0 \u09a7\u09be\u09b0\u09be\u09ac\u09be\u09b9\u09bf\u0995\u09a4\u09be\u09df \u0986\u099c \u09e7\u09b2\u09be \u09ae\u09c7 \u09b6\u09c1\u0995\u09cd\u09b0\u09ac\u09be\u09b0, '\u0995\u0995\u09cd\u09b8\u09ac\u09be\u099c\u09be\u09b0 \u09ac\u09a1\u09bc \u09ac\u09be\u099c\u09be\u09b0 \u099c\u09be\u09ae\u09c7 \u09ae\u09b8\u099c\u09bf\u09a6 \u0995\u09ae\u09aa\u09cd\u09b2\u09c7\u0995\u09cd\u09b8 \u09a8\u09c2\u09b0\u09be\u09a8\u09c0 \u09ae\u09be\u09a6\u09cd\u09b0\u09be\u09b8\u09be\u09df' \u099c\u09c1\u09ae\u09c1\u0986' \u0986\u09a6\u09be\u09df \u0995\u09b0\u09ac\u09c7\u09a8 \u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf - \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09ae\u09c1\u0996\u09cd\u09af \u09b8\u09ae\u09a8\u09cd\u09ac\u09df\u0995 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09df\u09be\u09b0\u09c0\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
