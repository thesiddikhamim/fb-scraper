    "title": "\u09a7\u09a8\u09cd\u09af\u09ac\u09be\u09a6 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf\u0995\u09c7 \u0985\u09a4\u09bf \u0989\u09ce\u09b8\u09be\u09b9\u09c0 \u09ae\u09be\u09ae\u09b2\u09be\u09ac\u09be\u099c\u0995\u09c7 \u09b6\u09cb\u0995\u099c \u0995\u09b0\u09be\u09b0 \u099c\u09a8\u09cd\u09af\u0964 \u0986\u09ae\u09bf \u0986\u09ae\u09be\u09b0 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09be\u09b9...",
    "description": "\u09a7\u09a8\u09cd\u09af\u09ac\u09be\u09a6 \u09ac\u09bf\u098f\u09a8\u09aa\u09bf\u0995\u09c7 \u0985\u09a4\u09bf \u0989\u09ce\u09b8\u09be\u09b9\u09c0 \u09ae\u09be\u09ae\u09b2\u09be\u09ac\u09be\u099c\u0995\u09c7 \u09b6\u09cb\u0995\u099c \u0995\u09b0\u09be\u09b0 \u099c\u09a8\u09cd\u09af\u0964 \u0986\u09ae\u09bf \u0986\u09ae\u09be\u09b0 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09be\u09b9\u09be\u09b0 \u0995\u09b0\u09c7 \u09a8\u09bf\u09b2\u09be\u09ae\u0964 \u0986\u09b6\u09be \u0995\u09b0\u09bf \u09ad\u09ac\u09bf\u09b7\u09cd\u09af\u09a4\u09c7 \u098f \u09a7\u09b0\u09a8\u09c7\u09b0 \u0985\u09af\u09a5\u09be \u0985\u09b6\u09be\u09a8\u09cd\u09a4\u09bf\u09b0 \u09b8\u09c3\u09b7\u09cd\u099f\u09bf \u0986\u09b0 \u0995\u09b0\u09ac\u09c7\u09a8 \u09a8\u09be\u0964",
