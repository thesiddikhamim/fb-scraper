    "title": "\u0990\u09a4\u09bf\u09b9\u09be\u09b8\u09bf\u0995 \u09b6\u09cd\u09b0\u09ae\u09bf\u0995 \u09a6\u09bf\u09ac\u09b8\u09c7 \u09b8\u0995\u09b2 \u09b6\u09cd\u09b0\u09ae\u099c\u09c0\u09ac\u09c0 \u09ae\u09be\u09a8\u09c1\u09b7\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u099c\u09cd\u099e\u09be\u09aa\u09a8 \u0995\u09b0\u099b\u09bf \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995 \u09b6\u09cd\u09b0\u09a6\u09cd\u09a7\u09be \u0993 \u0995...",
