    "title": "\u0997\u09a4\u09b0\u09be\u09a4\u09c7 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u099b\u09be\u09a4\u09cd\u09b0\u09b6\u0995\u09cd\u09a4\u09bf, \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09af\u09bc \u0995\u09ae\u09bf\u099f\u09bf\u09b0 \u09b8\u09be\u0982\u0997\u09a0\u09a8\u09bf\u0995 \u09b8\u09ae\u09cd\u09aa\u09be\u09a6\u0995 \u098f\u09ac\u0982 \u09b9\u09be\u099c\u09c0 \u09ae...",
    "description": "\u0997\u09a4\u09b0\u09be\u09a4\u09c7 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u099b\u09be\u09a4\u09cd\u09b0\u09b6\u0995\u09cd\u09a4\u09bf, \u09a2\u09be\u0995\u09be \u09ac\u09bf\u09b6\u09cd\u09ac\u09ac\u09bf\u09a6\u09cd\u09af\u09be\u09b2\u09af\u09bc \u0995\u09ae\u09bf\u099f\u09bf\u09b0 \u09b8\u09be\u0982\u0997\u09a0\u09a8\u09bf\u0995 \u09b8\u09ae\u09cd\u09aa\u09be\u09a6\u0995 \u098f\u09ac\u0982 \u09b9\u09be\u099c\u09c0 \u09ae\u09c1\u09b9\u09ae\u09cd\u09ae\u09a6 \u09ae\u09c1\u09b9\u09b8\u09c0\u09a8 \u09b9\u09b2 \u09b8\u0982\u09b8\u09a6\u09c7\u09b0 \u09b8\u09ae\u09be\u099c\u09b8\u09c7\u09ac\u09be \u09b8\u09ae\u09cd\u09aa\u09be\u09a6\u0995 \u09ae\u09cb: \u09b8\u09be\u0987\u09ab\u09c1\u09b2\u09cd\u09b2\u09be\u09b9\u09b0 \u0997\u09cd\u09b0\u09be\u09ae\u09c7\u09b0 \u09ac\u09be\u09dc\u09bf\u09a4\u09c7 \u09b9\u09be\u09ae\u09b2\u09be \u0993 \u0985\u0997\u09cd\u09a8\u09bf\u09b8\u0982\u09af\u09cb\u0997 \u0995\u09b0\u09c7 \u09ab\u09cd\u09af\u09be\u09b8\u09bf\u09b8\u09cd\u099f \u0986\u0993\u09df\u09be\u09ae\u09c0 \u09b2\u09c0\u0997\u09c7\u09b0 \u09b8\u09a8\u09cd\u09a4\u09cd\u09b0\u09be\u09b8\u09c0\u09b0\u09be\u0964 \u0986\u099c \u09b8\u0995\u09be\u09b2\u09c7 \u0985\u0997\u09cd\u09a8\u09bf \u09ad\u09b8\u09cd\u09ae\u09c0\u09ad\u09c2\u09a4 \u09ac\u09be\u09dc\u09bf \u09aa\u09b0\u09bf\u09a6\u09b0\u09cd\u09b6\u09a8\u09c7 \u0997\u09bf\u09df\u09c7 \u09ae\u09cb: \u09b8\u09be\u0987\u09ab\u09c1\u09b2\u09cd\u09b2\u09be\u09b9\u09b0 \u09aa\u09b0\u09bf\u09ac\u09be\u09b0\u09c7\u09b0 \u09b8\u09a6\u09b8\u09cd\u09af\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09b8\u09be\u0995\u09cd\u09b7\u09be\u09ce \u0995\u09b0\u09c7\u09a8 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09df\u09be\u09b0\u09c0\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
