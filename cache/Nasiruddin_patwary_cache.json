  },
  {
    "title": "\u09a6\u09c0\u09b0\u09cd\u0998 \u098f\u0995 \u09ae\u09be\u09b8\u09c7\u09b0 \u09b8\u09bf\u09af\u09bc\u09be\u09ae \u09b8\u09be\u09a7\u09a8\u09be\u09b0 \u09aa\u09b0 \u0986\u099c \u09b8\u09be\u09b0\u09be\u09a6\u09c7\u09b6\u09c7 \u0989\u09ce\u09b8\u09ac\u09ae\u09c1\u0996\u09b0 \u09aa\u09b0\u09bf\u09ac\u09c7\u09b6\u09c7 \u0989\u09a6\u09af\u09be\u09aa\u09bf\u09a4 \u09b9\u09af\u09bc\u09c7\u099b\u09c7 \u09aa\u09ac\u09bf\u09a4...",
    "description": "\u09a6\u09c0\u09b0\u09cd\u0998 \u098f\u0995 \u09ae\u09be\u09b8\u09c7\u09b0 \u09b8\u09bf\u09af\u09bc\u09be\u09ae \u09b8\u09be\u09a7\u09a8\u09be\u09b0 \u09aa\u09b0 \u0986\u099c \u09b8\u09be\u09b0\u09be\u09a6\u09c7\u09b6\u09c7 \u0989\u09ce\u09b8\u09ac\u09ae\u09c1\u0996\u09b0 \u09aa\u09b0\u09bf\u09ac\u09c7\u09b6\u09c7 \u0989\u09a6\u09af\u09be\u09aa\u09bf\u09a4 \u09b9\u09af\u09bc\u09c7\u099b\u09c7 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u0988\u09a6\u09c1\u09b2 \u09ab\u09bf\u09a4\u09b0\u0964 \u09aa\u09cd\u09b0\u09bf\u09af\u09bc\u099c\u09a8\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u0986\u09a8\u09a8\u09cd\u09a6\u09c7\u09b0 \u09ae\u09c1\u09b9\u09c2\u09b0\u09cd\u09a4\u0997\u09c1\u09b2\u09cb \u09ad\u09be\u0997\u09be\u09ad\u09be\u0997\u09bf \u0995\u09b0\u09c7 \u09a8\u09c7\u0993\u09af\u09bc\u09be\u09b0 \u09ae\u09be\u09a7\u09cd\u09af\u09ae\u09c7 \u099a\u09be\u09b0\u09bf\u09a6\u09bf\u0995\u09c7 \u09a8\u09c7\u09ae\u09c7 \u098f\u09b8\u09c7\u099b\u09c7 \u09aa\u09cd\u09b0\u09b6\u09be\u09a8\u09cd\u09a4\u09bf\u09b0 \u0986\u09ac\u09b9\u0964 \u0986\u099c\u0995\u09c7\u09b0 \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u098f\u0987 \u09a6\u09bf\u09a8\u09c7 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u0988\u09a6\u0997\u09be\u09b9\u09c7 \u0988\u09a6\u09c7\u09b0 \u09a8\u09be\u09ae\u09be\u099c \u0986\u09a6\u09be\u09af\u09bc \u0995\u09b0\u09c7\u099b\u09c7\u09a8 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0\u0964 \u09a8\u09be\u09ae\u09be\u099c \u0986\u09a6\u09be\u09af\u09bc \u09b6\u09c7\u09b7\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u099c\u09be\u09ae\u09be\u09af\u09bc\u09be\u09a4\u09c7 \u0987\u09b8\u09b2\u09be\u09ae\u09c0\u09b0 \u09b8\u09ae\u09cd\u09ae\u09be\u09a8\u09bf\u09a4 \u0986\u09ae\u09c0\u09b0 \u0993 \u09a6\u09b2\u09c7\u09b0 \u0985\u09a8\u09cd\u09af\u09be\u09a8\u09cd\u09af \u09a8\u09c7\u09a4\u09c3\u09ac\u09c3\u09a8\u09cd\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09ae\u09cb\u09b2\u09be\u0995\u09be\u09a4 \u0995\u09b0\u09c7 \u0988\u09a6\u09c7\u09b0 \u09b6\u09c1\u09ad\u09c7\u099a\u09cd\u099b\u09be \u0993 \u09ae\u09cb\u09ac\u09be\u09b0\u0995\u09ac\u09be\u09a6 \u09ac\u09bf\u09a8\u09bf\u09ae\u09af\u09bc \u0995\u09b0\u09c7\u09a8 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0\u0964 \u0988\u09a6\u09c7\u09b0 \u09a8\u09be\u09ae\u09be\u099c-\u09aa\u09b0\u09ac\u09b0\u09cd\u09a4\u09c0 \u09b9\u09c3\u09a6\u09cd\u09af\u09a4\u09be\u09aa\u09c2\u09b0\u09cd\u09a3 \u098f \u09ae\u09bf\u09b2\u09a8\u09ae\u09c7\u09b2\u09be\u09af\u09bc \u09b0\u09be\u099c\u09a8\u09c8\u09a4\u09bf\u0995 \u09b8\u09b9\u09af\u09be\u09a4\u09cd\u09b0\u09c0 \u0993 \u09b6\u09c1\u09ad\u09be\u0995\u09be\u0999\u09cd\u0995\u09cd\u09b7\u09c0\u09a6\u09c7\u09b0 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4\u09bf\u09a4\u09c7 \u098f\u0995 \u09ae\u09a8\u09cb\u09ae\u09c1\u0997\u09cd\u09a7\u0995\u09b0 \u09aa\u09b0\u09bf\u09ac\u09c7\u09b6\u09c7\u09b0 \u09b8\u09c3\u09b7\u09cd\u099f\u09bf \u09b9\u09af\u09bc\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
