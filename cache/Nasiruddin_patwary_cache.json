  {
    "title": "\u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09b0\u09be\u099c\u09b6\u09be\u09b9\u09c0 \u09ac\u09bf\u09ad\u09be\u0997\u09c0\u09df \u0987\u09ab\u09a4\u09be\u09b0\u09c7 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09df\u09be\u09b0\u09c0\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
    "description": "\u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09b0\u09be\u099c\u09b6\u09be\u09b9\u09c0 \u09ac\u09bf\u09ad\u09be\u0997\u09c0\u09df \u0987\u09ab\u09a4\u09be\u09b0\u09c7 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09df\u09be\u09b0\u09c0\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
