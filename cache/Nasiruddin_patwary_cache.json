[
  {
    "title": "\u0986\u099c \u09e8\u09ec\u09b6\u09c7 \u09ae\u09be\u09b0\u09cd\u099a, \u09ae\u09b9\u09be\u09a8 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be \u09a6\u09bf\u09ac\u09b8\u0964 \u0986\u099c\u0995\u09c7\u09b0 \u098f\u0987 \u09a6\u09bf\u09a8\u099f\u09bf \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u0987\u09a4\u09bf\u09b9\u09be\u09b8\u09c7\u09b0 \u09a7\u09be...",
    "description": "\u0986\u099c \u09e8\u09ec\u09b6\u09c7 \u09ae\u09be\u09b0\u09cd\u099a, \u09ae\u09b9\u09be\u09a8 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be \u09a6\u09bf\u09ac\u09b8\u0964 \u0986\u099c\u0995\u09c7\u09b0 \u098f\u0987 \u09a6\u09bf\u09a8\u099f\u09bf \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u0987\u09a4\u09bf\u09b9\u09be\u09b8\u09c7\u09b0 \u09a7\u09be\u09b0\u09be\u09ac\u09be\u09b9\u09bf\u0995\u09a4\u09be\u09af\u09bc \u098f\u0995 \u09af\u09c1\u0997\u09be\u09a8\u09cd\u09a4\u0995\u09be\u09b0\u09c0 \u09b8\u09a8\u09cd\u09a7\u09bf\u0995\u09cd\u09b7\u09a3\u0964 \u098f\u0995\u09be\u09a4\u09cd\u09a4\u09b0\u09c7\u09b0 \u098f \u09a6\u09bf\u09a8\u09c7\u0987 \u09a4\u09ce\u0995\u09be\u09b2\u09c0\u09a8 \u09aa\u09c2\u09b0\u09cd\u09ac \u09aa\u09be\u0995\u09bf\u09b8\u09cd\u09a4\u09be\u09a8\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09cd\u09af\u09c7\u0995 \u0985\u09a7\u09bf\u09ac\u09be\u09b8\u09c0\u09b0 \u0986\u09a4\u09cd\u09ae\u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be \u0993 \u09b0\u09be\u099c\u09a8\u09c8\u09a4\u09bf\u0995 \u099a\u09c7\u09a4\u09a8\u09be \u099a\u09c2\u09a1\u09bc\u09be\u09a8\u09cd\u09a4\u09b0\u09c2\u09aa\u09c7 \u09b8\u09cd\u09aa\u09b7\u09cd\u099f \u09b9\u09af\u09bc\u09c7 \u0993\u09a0\u09c7\u0964 \u09a4\u09be\u09b0\u0987 \u09ab\u09b2\u09b6\u09cd\u09b0\u09c1\u09a4\u09bf\u09a4\u09c7 \u0986\u09b0\u09ae\u09cd\u09ad \u09b9\u09af\u09bc \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u09b6\u09b8\u09cd\u09a4\u09cd\u09b0 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be\u09b0 \u09af\u09c1\u09a6\u09cd\u09a7\u0964 \u09a6\u09c0\u09b0\u09cd\u0998 \u09a8\u09af\u09bc \u09ae\u09be\u09b8\u09ac\u09cd\u09af\u09be\u09aa\u09c0 \u098f \u09af\u09c1\u09a6\u09cd\u09a7\u09c7\u09b0 \u09ae\u09c2\u09b2 \u09b2\u0995\u09cd\u09b7\u09cd\u09af \u099b\u09bf\u09b2 \u098f\u0995\u099f\u09bf \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8, \u09b8\u09be\u09b0\u09cd\u09ac\u09ad\u09cc\u09ae \u0993 \u09a8\u09cd\u09af\u09be\u09af\u09bc\u09ad\u09bf\u09a4\u09cd\u09a4\u09bf\u0995 \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be \u0995\u09b0\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09bf\u09b0 \u09ad\u09c2\u09b2\u09c1\u09a3\u09cd\u09a0\u09bf\u09a4 \u09b8\u09ae\u09cd\u09ae\u09be\u09a8 \u0993 \u0986\u09a4\u09cd\u09ae\u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be\u0995\u09c7 \u09aa\u09c1\u09a8\u09b0\u09cd\u099c\u09c0\u09ac\u09bf\u09a4 \u0995\u09b0\u09be\u0964 \u0986\u099c \u09ae\u09b9\u09be\u09a8 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8\u09a4\u09be \u09a6\u09bf\u09ac\u09b8\u09c7 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09aa\u0995\u09cd\u09b7 \u09a5\u09c7\u0995\u09c7 \u09b8\u09be\u09ad\u09be\u09b0\u09c7 \u099c\u09be\u09a4\u09c0\u09af\u09bc \u09b8\u09cd\u09ae\u09c3\u09a4\u09bf\u09b8\u09cc\u09a7\u09c7 \u09b6\u09cd\u09b0\u09a6\u09cd\u09a7\u09be\u099e\u09cd\u099c\u09b2\u09bf \u0985\u09b0\u09cd\u09aa\u09a3 \u0995\u09b0\u09c7\u09a8 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0\u0964 \u098f \u09b8\u09ae\u09af\u09bc \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09b8\u09a6\u09b8\u09cd\u09af \u09b8\u099a\u09bf\u09ac \u0986\u0996\u09a4\u09be\u09b0 \u09b9\u09cb\u09b8\u09c7\u09a8, \u098f\u09ae\u09aa\u09bf \u0993 \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09ae\u09c1\u0996\u09aa\u09be\u09a4\u09cd\u09b0 \u0986\u09b8\u09bf\u09ab \u09ae\u09be\u09b9\u09ae\u09c1\u09a6 \u09b8\u099c\u09c0\u09ac \u09ad\u09c2\u0981\u0987\u09af\u09bc\u09be\u09b8\u09b9 \u09a6\u09b2\u09c7\u09b0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u09b8\u09cd\u09a4\u09b0\u09c7\u09b0 \u0985\u09a8\u09cd\u09af\u09be\u09a8\u09cd\u09af \u09a8\u09c7\u09a4\u09c3\u09ac\u09c3\u09a8\u09cd\u09a6 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u099b\u09bf\u09b2\u09c7\u09a8\u0964 \u09b6\u09cd\u09b0\u09a6\u09cd\u09a7\u09be\u099e\u09cd\u099c\u09b2\u09bf \u0985\u09b0\u09cd\u09aa\u09a3\u09c7 \u09b6\u09b9\u09c0\u09a6\u09a6\u09c7\u09b0 \u09ae\u09be\u0997\u09ab\u09bf\u09b0\u09be\u09a4 \u0995\u09be\u09ae\u09a8\u09be \u0995\u09b0\u09c7 \u09b8\u09be\u09ae\u09cd\u09af, \u09a8\u09cd\u09af\u09be\u09af\u09bc\u09ac\u09bf\u099a\u09be\u09b0 \u0993 \u09ae\u09be\u09a8\u09ac\u09bf\u0995 \u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be\u09b0 \u09ad\u09bf\u09a4\u09cd\u09a4\u09bf\u09a4\u09c7 \u098f\u0995\u099f\u09bf \u09b8\u09be\u09b0\u09cd\u09ac\u09ad\u09cc\u09ae \u09b0\u09be\u09b7\u09cd\u099f\u09cd\u09b0 \u09ac\u09bf\u09a8\u09bf\u09b0\u09cd\u09ae\u09be\u09a3\u09c7 \u0985\u09ac\u09bf\u099a\u09b2 \u0985\u0999\u09cd\u0997\u09c0\u0995\u09be\u09b0\u09c7\u09b0 \u0995\u09a5\u09be \u09aa\u09c1\u09a8\u09b0\u09cd\u09ac\u09cd\u09af\u0995\u09cd\u09a4 \u0995\u09b0\u09be \u09b9\u09af\u09bc\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
    "link": "https://www.facebook.com/NasiruddinNcpOfficial",
