[
  {
    "title": "\u09b0\u09ae\u099c\u09be\u09a8\u09c7\u09b0 \u09ae\u09a4\u09cb \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u09ae\u09be\u09b8\u09c7\u0993 \u09af\u0996\u09a8 \u099a\u09be\u0981\u09a6\u09be\u09ac\u09be\u099c\u09bf\u09b0 \u099c\u09a8\u09cd\u09af \u098f\u0995\u099c\u09a8 \u09ae\u09be\u09a8\u09c1\u09b7\u0995\u09c7 \u0996\u09c1\u09a8 \u09b9\u09a4\u09c7 \u09b9\u09df, \u09a4\u0996\u09a8 \u09a4\u09be \u09b6\u09c1\u09a7...",
    "description": "\u09b0\u09ae\u099c\u09be\u09a8\u09c7\u09b0 \u09ae\u09a4\u09cb \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u09ae\u09be\u09b8\u09c7\u0993 \u09af\u0996\u09a8 \u099a\u09be\u0981\u09a6\u09be\u09ac\u09be\u099c\u09bf\u09b0 \u099c\u09a8\u09cd\u09af \u098f\u0995\u099c\u09a8 \u09ae\u09be\u09a8\u09c1\u09b7\u0995\u09c7 \u0996\u09c1\u09a8 \u09b9\u09a4\u09c7 \u09b9\u09df, \u09a4\u0996\u09a8 \u09a4\u09be \u09b6\u09c1\u09a7\u09c1 \u098f\u0995\u099f\u09bf \u0985\u09aa\u09b0\u09be\u09a7 \u09a8\u09df \u098f\u099f\u09bf \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u09ae\u09be\u099c\u09c7\u09b0 \u09a8\u09c8\u09a4\u09bf\u0995 \u0985\u09ac\u0995\u09cd\u09b7\u09df\u09c7\u09b0 \u098f\u0995 \u09a8\u09bf\u09b0\u09cd\u09ae\u09ae \u09aa\u09cd\u09b0\u09a4\u09bf\u099a\u09cd\u099b\u09ac\u09bf\u0964 \u09af\u09c7 \u09ae\u09be\u09b8\u09c7 \u09ae\u09be\u09a8\u09c1\u09b7 \u09b8\u0982\u09af\u09ae, \u09a6\u09df\u09be \u0993 \u09ae\u09be\u09a8\u09ac\u09a4\u09be\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be \u0997\u09cd\u09b0\u09b9\u09a3 \u0995\u09b0\u09c7, \u09b8\u09c7\u0987 \u09ae\u09be\u09b8\u09c7\u0987 \u09af\u09a6\u09bf \u09b8\u09a8\u09cd\u09a4\u09cd\u09b0\u09be\u09b8 \u0993 \u099a\u09be\u0981\u09a6\u09be\u09ac\u09be\u099c\u09bf\u09b0 \u09ad\u09df \u09ae\u09be\u09a8\u09c1\u09b7\u0995\u09c7 \u09a4\u09be\u09dc\u09be \u0995\u09b0\u09c7 \u09ac\u09c7\u09dc\u09be\u09df, \u09a4\u09ac\u09c7 \u09a4\u09be \u0985\u09a4\u09cd\u09af\u09a8\u09cd\u09a4 \u09b2\u099c\u09cd\u099c\u09be\u099c\u09a8\u0995 \u0993 \u0989\u09a6\u09cd\u09ac\u09c7\u0997\u099c\u09a8\u0995\u0964 \u099a\u09be\u0981\u09a6\u09be\u09ac\u09be\u099c\u09bf \u0993 \u09b8\u09a8\u09cd\u09a4\u09cd\u09b0\u09be\u09b8\u09c7\u09b0 \u09ac\u09bf\u09b0\u09c1\u09a6\u09cd\u09a7\u09c7 \u0995\u09a0\u09cb\u09b0 \u0985\u09ac\u09b8\u09cd\u09a5\u09be\u09a8 \u09a8\u09c7\u0993\u09df\u09be \u098f\u0996\u09a8 \u09b8\u09ae\u09df\u09c7\u09b0 \u09a6\u09be\u09ac\u09bf\u0964 \u09ae\u09be\u09a8\u09c1\u09b7\u09c7\u09b0 \u099c\u09c0\u09ac\u09a8 \u0993 \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be \u0995\u09cb\u09a8\u09cb \u09b8\u09a8\u09cd\u09a4\u09cd\u09b0\u09be\u09b8\u09c0 \u099a\u0995\u09cd\u09b0\u09c7\u09b0 \u09b9\u09be\u09a4\u09c7 \u099c\u09bf\u09ae\u09cd\u09ae\u09bf \u09b9\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7 \u09a8\u09be\u0964",
