[
  {
    "title": "\u099c\u09a8\u0997\u09a3 \u09af\u09be\u09b0 \u09b6\u0995\u09cd\u09a4\u09bf, \u09a4\u09be\u09b0 \u0986\u09b0 \u09ad\u09df-\u0987 \u09ac\u09be \u0995\u09c0\u09b8\u09c7? \u0986\u099c \u09b0\u09be\u099c\u09b6\u09be\u09b9\u09c0\u09b0 '\u09b8\u09be\u09b9\u09c7\u09ac \u09ac\u09be\u099c\u09be\u09b0 \u099c\u09bf\u09b0\u09cb \u09aa\u09df\u09c7\u09a8\u09cd\u099f \u09ac\u09dc \u09ae\u09b8\u099c...",
    "description": "\u099c\u09a8\u0997\u09a3 \u09af\u09be\u09b0 \u09b6\u0995\u09cd\u09a4\u09bf, \u09a4\u09be\u09b0 \u0986\u09b0 \u09ad\u09df-\u0987 \u09ac\u09be \u0995\u09c0\u09b8\u09c7? \u0986\u099c \u09b0\u09be\u099c\u09b6\u09be\u09b9\u09c0\u09b0 '\u09b8\u09be\u09b9\u09c7\u09ac \u09ac\u09be\u099c\u09be\u09b0 \u099c\u09bf\u09b0\u09cb \u09aa\u09df\u09c7\u09a8\u09cd\u099f \u09ac\u09dc \u09ae\u09b8\u099c\u09bf\u09a6' \u09aa\u09cd\u09b0\u09be\u0999\u09cd\u0997\u09a3\u09c7 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09df\u09be\u09b0\u09c0\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
