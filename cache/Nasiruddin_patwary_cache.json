[
  {
    "title": "\u0986\u099c \u09e8\u09eb \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09b6\u09a8\u09bf\u09ac\u09be\u09b0, \u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf - \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u0987\u09a8\u09cd\u09a1\u09be\u09b8\u09cd\u099f\u09cd\u09b0\u09bf \u0985\u09cd\u09af\u09be\u09a8\u09cd\u09a1 \u0995\u09ae\u09be\u09b0\u09cd\u09b8 \u09b8\u09c7...",
    "description": "\u0986\u099c \u09e8\u09eb \u098f\u09aa\u09cd\u09b0\u09bf\u09b2 \u09b6\u09a8\u09bf\u09ac\u09be\u09b0, \u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf - \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u0987\u09a8\u09cd\u09a1\u09be\u09b8\u09cd\u099f\u09cd\u09b0\u09bf \u0985\u09cd\u09af\u09be\u09a8\u09cd\u09a1 \u0995\u09ae\u09be\u09b0\u09cd\u09b8 \u09b8\u09c7\u09b2\u09c7\u09b0 \u0989\u09a6\u09cd\u09af\u09cb\u0997\u09c7 'Delay Is Costly: Why Immediate Economic Reforms Are Non-Negotiable' \u09b6\u09c0\u09b0\u09cd\u09b7\u0995 \u09b8\u09c7\u09ae\u09bf\u09a8\u09be\u09b0 \u0986\u09df\u09cb\u099c\u09bf\u09a4 \u09b9\u09df\u09c7\u099b\u09c7\u0964 \u0989\u0995\u09cd\u09a4 \u09b8\u09c7\u09ae\u09bf\u09a8\u09be\u09b0\u09c7 \u09a6\u09c7\u09b6\u09c7\u09b0 \u09b6\u09c0\u09b0\u09cd\u09b7\u09b8\u09cd\u09a5\u09be\u09a8\u09c0\u09df \u0985\u09b0\u09cd\u09a5\u09a8\u09c0\u09a4\u09bf\u09ac\u09bf\u09a6 \u0993 \u09b0\u09be\u099c\u09a8\u09c8\u09a4\u09bf\u0995 \u09a8\u09c7\u09a4\u09c3\u09ac\u09c3\u09a8\u09cd\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u099b\u09bf\u09b2\u09c7\u09a8 \u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf - \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09ae\u09c1\u0996\u09cd\u09af \u09b8\u09ae\u09a8\u09cd\u09ac\u09df\u0995 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09df\u09be\u09b0\u09c0\u0964 \u09b8\u09c7\u09ae\u09bf\u09a8\u09be\u09b0\u09c7 \u09aa\u09cd\u09b0\u09a6\u09a4\u09cd\u09a4 \u09ac\u0995\u09cd\u09a4\u09ac\u09cd\u09af\u09c7 \u09a4\u09bf\u09a8\u09bf \u09a6\u09c7\u09b6\u09c7\u09b0 \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8 \u09b8\u0982\u0995\u099f\u09ae\u09df \u09aa\u09b0\u09bf\u09b8\u09cd\u09a5\u09bf\u09a4\u09bf\u09a4\u09c7 \u0985\u09b0\u09cd\u09a5\u09a8\u09c8\u09a4\u09bf\u0995 \u09b8\u09cd\u09a5\u09bf\u09a4\u09bf\u09b6\u09c0\u09b2\u09a4\u09be \u09ac\u099c\u09be\u09df \u09b0\u09be\u0996\u09be \u0993 \u09b8\u09ae\u09df\u09cb\u099a\u09bf\u09a4 \u0985\u09b0\u09cd\u09a5\u09a8\u09c8\u09a4\u09bf\u0995 \u09b8\u0982\u09b8\u09cd\u0995\u09be\u09b0\u09c7\u09b0 \u0986\u09ac\u09b6\u09cd\u09af\u09bf\u0995\u09a4\u09be\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u0997\u09c1\u09b0\u09c1\u09a4\u09cd\u09ac\u09be\u09b0\u09cb\u09aa \u09aa\u09cd\u09b0\u09a6\u09be\u09a8 \u0995\u09b0\u09c7\u09a8\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
