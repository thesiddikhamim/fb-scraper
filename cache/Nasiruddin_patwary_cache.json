    "title": "'\u09b0\u09bf\u09b9\u09b2\u09be-\u098f-\u09a4\u09be\u09b0\u09be\u09ac\u09c0' \u0995\u09b0\u09cd\u09ae\u09b8\u09c2\u099a\u09bf\u09b0 \u09a7\u09be\u09b0\u09be\u09ac\u09be\u09b9\u09bf\u0995\u09a4\u09be\u09af\u09bc \u0986\u099c \u09e8\u09ef \u09a4\u09ae \u09b0\u09ae\u09be\u09a6\u09be\u09a8\u09c7\u09b0 \u09a4\u09be\u09b0\u09be\u09ac\u09c0 \u099a\u09be\u0981\u09a6\u09aa\u09c1\u09b0\u09c7\u09b0 '\u09ac\u09be\u0987...",
    "description": "'\u09b0\u09bf\u09b9\u09b2\u09be-\u098f-\u09a4\u09be\u09b0\u09be\u09ac\u09c0' \u0995\u09b0\u09cd\u09ae\u09b8\u09c2\u099a\u09bf\u09b0 \u09a7\u09be\u09b0\u09be\u09ac\u09be\u09b9\u09bf\u0995\u09a4\u09be\u09af\u09bc \u0986\u099c \u09e8\u09ef \u09a4\u09ae \u09b0\u09ae\u09be\u09a6\u09be\u09a8\u09c7\u09b0 \u09a4\u09be\u09b0\u09be\u09ac\u09c0 \u099a\u09be\u0981\u09a6\u09aa\u09c1\u09b0\u09c7\u09b0 '\u09ac\u09be\u0987\u09a4\u09c1\u09b2 \u0986\u09ae\u09be\u09a8 \u09b0\u09c7\u09b2\u0993\u09df\u09c7 \u099c\u09be\u09ae\u09c7 \u09ae\u09b8\u099c\u09bf\u09a6\u09c7' \u0986\u09a6\u09be\u09af\u09bc \u0995\u09b0\u09c7\u099b\u09c7\u09a8 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09af\u09bc\u09be\u09b0\u09c0\u0964 \u09a4\u09be\u09b0\u09be\u09ac\u09c0 \u09b6\u09c7\u09b7\u09c7 \u09ae\u09b8\u099c\u09bf\u09a6 \u09aa\u09cd\u09b0\u09be\u0999\u09cd\u0997\u09a3\u09c7 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u09b9\u09be\u099c\u09be\u09b0\u09cb \u099b\u09be\u09a4\u09cd\u09b0-\u099c\u09a8\u09a4\u09be\u09b0 \u09b8\u09be\u09a5\u09c7 \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995 \u09b8\u09be\u09b2\u09be\u09ae, \u09b6\u09c1\u09ad\u09c7\u099a\u09cd\u099b\u09be \u0993 \u0995\u09c1\u09b6\u09b2\u09be\u09a6\u09bf \u09ac\u09bf\u09a8\u09bf\u09ae\u09df \u0995\u09b0\u09c7\u09a8 \u09a4\u09bf\u09a8\u09bf\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
