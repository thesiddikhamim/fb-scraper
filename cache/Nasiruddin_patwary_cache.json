[
  {
    "title": "\u098f \u09ad\u09c2\u0996\u09a3\u09cd\u09a1\u09c7\u09b0 \u09b8\u0995\u09b2 \u09ae\u09be\u09df\u09c7\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u09c7\u09b0 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u0997\u09dc\u09a4\u09c7 \u0986\u09ae\u09b0\u09be \u0985\u0999\u09cd\u0997\u09c0\u0995\u09be\u09b0\u09ac\u09a6\u09cd\u09a7\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
    "description": "\u098f \u09ad\u09c2\u0996\u09a3\u09cd\u09a1\u09c7\u09b0 \u09b8\u0995\u09b2 \u09ae\u09be\u09df\u09c7\u09b0 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8\u09c7\u09b0 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u0997\u09dc\u09a4\u09c7 \u0986\u09ae\u09b0\u09be \u0985\u0999\u09cd\u0997\u09c0\u0995\u09be\u09b0\u09ac\u09a6\u09cd\u09a7\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
