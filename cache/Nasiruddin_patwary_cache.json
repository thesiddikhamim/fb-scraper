[
  {
    "title": "\u0986\u099c \u09e8\u09ed \u09ae\u09be\u09b0\u09cd\u099a \u09b6\u09c1\u0995\u09cd\u09b0\u09ac\u09be\u09b0, \u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf - \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09af\u09c1\u0997\u09cd\u09ae \u09ae\u09c1\u0996\u09cd\u09af \u09b8\u09ae\u09a8\u09cd\u09ac\u09df\u0995 \u09b0\u09be\u09ab\u09bf\u09a6 \u09ae\u09c1...",
    "description": "\u0986\u099c \u09e8\u09ed \u09ae\u09be\u09b0\u09cd\u099a \u09b6\u09c1\u0995\u09cd\u09b0\u09ac\u09be\u09b0, \u099c\u09be\u09a4\u09c0\u09df \u09a8\u09be\u0997\u09b0\u09bf\u0995 \u09aa\u09be\u09b0\u09cd\u099f\u09bf - \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09af\u09c1\u0997\u09cd\u09ae \u09ae\u09c1\u0996\u09cd\u09af \u09b8\u09ae\u09a8\u09cd\u09ac\u09df\u0995 \u09b0\u09be\u09ab\u09bf\u09a6 \u09ae\u09c1\u09a4\u09be\u09b8\u09bf\u09ae \u09ad\u09c2\u0981\u0987\u09df\u09be\u09b0 \u09ac\u09bf\u09ac\u09be\u09b9\u09cb\u09a4\u09cd\u09a4\u09b0 \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09c7 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u099b\u09bf\u09b2\u09c7\u09a8 \u098f\u09a8\u09b8\u09bf\u09aa\u09bf\u09b0 \u09ae\u09c1\u0996\u09cd\u09af \u09b8\u09ae\u09a8\u09cd\u09ac\u09df\u0995 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09df\u09be\u09b0\u09c0\u0964 \u09ae\u09a8\u09cb\u09ae\u09c1\u0997\u09cd\u09a7\u0995\u09b0 \u098f \u0985\u09a8\u09c1\u09b7\u09cd\u09a0\u09be\u09a8\u09c7 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u098f\u0995\u09cd\u099f\u09bf\u09ad\u09bf\u09b8\u09cd\u099f, \u09b0\u09be\u099c\u09a8\u09c0\u09a4\u09bf\u09ac\u09bf\u09a6 \u0993 \u09ac\u09b0-\u0995\u09a8\u09c7 \u09aa\u09b0\u09bf\u09ac\u09be\u09b0\u09c7\u09b0 \u09b8\u09a6\u09b8\u09cd\u09af\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09b8\u09be\u09b2\u09be\u09ae \u0993 \u09b8\u09cc\u09b9\u09be\u09b0\u09cd\u09a6\u09cd\u09af\u09aa\u09c2\u09b0\u09cd\u09a3 \u09b6\u09c1\u09ad\u09c7\u099a\u09cd\u099b\u09be \u09ac\u09bf\u09a8\u09bf\u09ae\u09df \u0995\u09b0\u09c7\u09a8 \u09a4\u09bf\u09a8\u09bf\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
