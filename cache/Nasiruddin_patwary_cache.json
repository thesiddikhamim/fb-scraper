[
  {
    "title": "\u09a6\u09c7\u09b6\u09c7\u09b0 \u09a4\u09b0\u09c7 \u0986\u09a4\u09cd\u09ae\u09cb\u09ce\u09b8\u09b0\u09cd\u0997 \u0995\u09b0\u09be \u09b6\u09b9\u09c0\u09a6\u09a6\u09c7\u09b0 \u09b0\u0995\u09cd\u09a4\u09c7\u09b0 \u098b\u09a3 \u0995\u0996\u09a8\u09cb \u09ac\u09bf\u09b8\u09cd\u09ae\u09c3\u09a4 \u09b9\u0993\u09af\u09bc\u09be\u09b0 \u09a8\u09af\u09bc\u0964 \u0995\u09c3\u09a4\u099c\u09cd\u099e\u099a\u09bf\u09a4\u09cd\u09a4\u09c7...",
    "description": "\u09a6\u09c7\u09b6\u09c7\u09b0 \u09a4\u09b0\u09c7 \u0986\u09a4\u09cd\u09ae\u09cb\u09ce\u09b8\u09b0\u09cd\u0997 \u0995\u09b0\u09be \u09b6\u09b9\u09c0\u09a6\u09a6\u09c7\u09b0 \u09b0\u0995\u09cd\u09a4\u09c7\u09b0 \u098b\u09a3 \u0995\u0996\u09a8\u09cb \u09ac\u09bf\u09b8\u09cd\u09ae\u09c3\u09a4 \u09b9\u0993\u09af\u09bc\u09be\u09b0 \u09a8\u09af\u09bc\u0964 \u0995\u09c3\u09a4\u099c\u09cd\u099e\u099a\u09bf\u09a4\u09cd\u09a4\u09c7 \u09a4\u09be\u09a6\u09c7\u09b0 \u09b8\u09cd\u09ae\u09b0\u09a3\u09c7 \u09b0\u09c7\u0996\u09c7 \u0987\u09a8\u09b8\u09be\u09ab \u09aa\u09cd\u09b0\u09a4\u09bf\u09b7\u09cd\u09a0\u09be\u09b0 \u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u0990\u0995\u09cd\u09af\u09ac\u09a6\u09cd\u09a7 \u09ad\u09c2\u09ae\u09bf\u0995\u09be \u09b9\u09cb\u0995 \u0986\u09aa\u09b8\u09b9\u09c0\u09a8\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
