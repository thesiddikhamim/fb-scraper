    "guid": "https://www.facebook.com/NasiruddinNcpOfficial/posts/pfbid02UQxw8vM7EJUjrpKVyJoymLkJ2Wzu14nUK4tY8W2L3ZLUGBcRzDmyEyJwiY37kQF1l",
    "pubDate": "2026-03-27T10:46:58.386609+00:00",
