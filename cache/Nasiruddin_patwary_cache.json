[
  {
    "title": "\u0986\u099c \u09ee \u09ae\u09be\u09b0\u09cd\u099a, \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09a8\u09be\u09b0\u09c0 \u09a6\u09bf\u09ac\u09b8\u0964 \u098f\u0987 \u09a6\u09bf\u09a8\u099f\u09bf \u0995\u09c7\u09ac\u09b2 \u098f\u0995\u099f\u09bf \u09a6\u09bf\u09ac\u09b8 \u09a8\u09df, \u09ac\u09b0\u0982 \u098f\u099f\u09bf \u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae \u0993...",
    "description": "\u0986\u099c \u09ee \u09ae\u09be\u09b0\u09cd\u099a, \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09a8\u09be\u09b0\u09c0 \u09a6\u09bf\u09ac\u09b8\u0964 \u098f\u0987 \u09a6\u09bf\u09a8\u099f\u09bf \u0995\u09c7\u09ac\u09b2 \u098f\u0995\u099f\u09bf \u09a6\u09bf\u09ac\u09b8 \u09a8\u09df, \u09ac\u09b0\u0982 \u098f\u099f\u09bf \u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae \u0993 \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be\u09b0 \u09aa\u09cd\u09b0\u09a4\u09c0\u0995\u0964 \u09ae\u09be\u09a8\u09ac \u09b8\u09ad\u09cd\u09af\u09a4\u09be\u09b0 \u0987\u09a4\u09bf\u09b9\u09be\u09b8\u09c7 \u09af\u0996\u09a8\u0987 \u0995\u09cb\u09a8\u09cb \u09aa\u09b0\u09bf\u09ac\u09b0\u09cd\u09a4\u09a8 \u098f\u09b8\u09c7\u099b\u09c7, \u09a4\u0996\u09a8\u0987 \u09a8\u09be\u09b0\u09c0\u09b0\u09be \u099b\u09bf\u09b2\u09c7\u09a8 \u0985\u0997\u09cd\u09b0\u09ad\u09be\u0997\u09c7\u0964 \u09a4\u09be\u0987 \u09a4\u09cb \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u099c\u09be\u09a4\u09c0\u09df \u0995\u09ac\u09bf \u0995\u09be\u099c\u09c0 \u09a8\u099c\u09b0\u09c1\u09b2 \u0987\u09b8\u09b2\u09be\u09ae \u09b2\u09bf\u0996\u09c7\u099b\u09c7\u09a8- \u201c\u09ac\u09bf\u09b6\u09cd\u09ac\u09c7 \u09af\u09be-\u0995\u09bf\u099b\u09c1 \u09ae\u09b9\u09be\u09a8 \u09b8\u09c3\u09b7\u09cd\u099f\u09bf \u099a\u09bf\u09b0-\u0995\u09b2\u09cd\u09af\u09be\u09a3\u0995\u09b0, \u0985\u09b0\u09cd\u09a7\u09c7\u0995 \u09a4\u09be\u09b0 \u0995\u09b0\u09bf\u09df\u09be\u099b\u09c7 \u09a8\u09be\u09b0\u09c0, \u0985\u09b0\u09cd\u09a7\u09c7\u0995 \u09a4\u09be\u09b0 \u09a8\u09b0\u0964\u201d \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u0987\u09a4\u09bf\u09b9\u09be\u09b8\u0993 \u098f\u09b0 \u09ac\u09cd\u09af\u09a4\u09bf\u0995\u09cd\u09b0\u09ae \u09a8\u09df\u0964 \u098f\u0987 \u09a6\u09c7\u09b6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u0985\u09b0\u09cd\u099c\u09a8 \u0993 \u0985\u0997\u09cd\u09b0\u0997\u09a4\u09bf\u09b0 \u09aa\u09c7\u099b\u09a8\u09c7 \u09a8\u09be\u09b0\u09c0\u09b0\u09be \u098f\u0995 \u0985\u09a8\u09a8\u09cd\u09af \u09b6\u0995\u09cd\u09a4\u09bf \u09b9\u09df\u09c7 \u09a6\u09be\u0981\u09dc\u09bf\u09df\u09c7 \u0986\u099b\u09c7\u09a8\u0964 \u09ae\u09c1\u0995\u09cd\u09a4\u09bf\u09af\u09c1\u09a6\u09cd\u09a7 \u09a5\u09c7\u0995\u09c7 \u09b6\u09c1\u09b0\u09c1 \u0995\u09b0\u09c7 \u0986\u099c\u0995\u09c7\u09b0 \u09b8\u09cd\u09ac\u09be\u09a7\u09c0\u09a8 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09a6\u09c0\u09b0\u09cd\u0998 \u09aa\u09a5\u099a\u09b2\u09be\u09df \u09a4\u09be\u09b0\u09be\u09ae\u09a8 \u09ac\u09bf\u09ac\u09bf\u09b0 \u09ae\u09a4\u09cb \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09ae\u09be \u0993 \u09ac\u09cb\u09a8\u09c7\u09b0\u09be \u0985\u09b8\u0982\u0996\u09cd\u09af\u09ac\u09be\u09b0 \u09a4\u09cd\u09af\u09be\u0997, \u09b8\u09be\u09b9\u09b8 \u0993 \u09a8\u09c7\u09a4\u09c3\u09a4\u09cd\u09ac\u09c7\u09b0 \u09a8\u099c\u09bf\u09b0 \u09b8\u09cd\u09a5\u09be\u09aa\u09a8 \u0995\u09b0\u09c7\u099b\u09c7\u09a8\u0964 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09a8\u09be\u09b0\u09c0\u09b0\u09be \u0986\u099c \u098f\u0987 \u09a6\u09c7\u09b6\u09c7\u09b0 \u0985\u09b0\u09cd\u09a5\u09a8\u09c0\u09a4\u09bf\u09b0 \u099a\u09be\u09b2\u09bf\u0995\u09be\u09b6\u0995\u09cd\u09a4\u09bf\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09a4\u09c8\u09b0\u09bf \u09aa\u09cb\u09b6\u09be\u0995 \u09b6\u09bf\u09b2\u09cd\u09aa\u09c7 \u09b2\u09be\u0996\u09cb \u09a8\u09be\u09b0\u09c0 \u09b6\u09cd\u09b0\u09ae\u09bf\u0995 \u09a4\u09be\u0981\u09a6\u09c7\u09b0 \u09b6\u09cd\u09b0\u09ae \u0993 \u09ae\u09c7\u09a7\u09be \u09a6\u09bf\u09df\u09c7 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u0985\u09b0\u09cd\u09a5\u09a8\u09c0\u09a4\u09bf\u0995\u09c7 \u09b6\u0995\u09cd\u09a4 \u09ad\u09bf\u09a4\u09c7\u09b0 \u0993\u09aa\u09b0 \u09a6\u09be\u0981\u09dc \u0995\u09b0\u09bf\u09df\u09c7\u099b\u09c7\u09a8\u0964 \u0997\u09cd\u09b0\u09be\u09ae\u09c7\u09b0 \u09a8\u09be\u09b0\u09c0 \u0989\u09a6\u09cd\u09af\u09cb\u0995\u09cd\u09a4\u09be\u09b0\u09be \u09b8\u09cd\u09ac\u09be\u09ac\u09b2\u09ae\u09cd\u09ac\u09bf\u09a4\u09be\u09b0 \u09a8\u09a4\u09c1\u09a8 \u09a6\u09c3\u09b7\u09cd\u099f\u09be\u09a8\u09cd\u09a4 \u09a4\u09c8\u09b0\u09bf \u0995\u09b0\u099b\u09c7\u09a8\u0964 \u09b6\u09bf\u0995\u09cd\u09b7\u09be, \u099a\u09bf\u0995\u09bf\u09ce\u09b8\u09be, \u09aa\u09cd\u09b0\u09b6\u09be\u09b8\u09a8, \u09aa\u09cd\u09b0\u09af\u09c1\u0995\u09cd\u09a4\u09bf\u09b8\u09b9 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u0995\u09cd\u09b7\u09c7\u09a4\u09cd\u09b0\u09c7\u0987 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09a8\u09be\u09b0\u09c0\u09b0\u09be \u09a8\u09bf\u099c\u09c7\u09a6\u09c7\u09b0 \u09b8\u0995\u09cd\u09b7\u09ae\u09a4\u09be \u09aa\u09cd\u09b0\u09ae\u09be\u09a3 \u0995\u09b0\u099b\u09c7\u09a8\u0964 \u0995\u09bf\u09a8\u09cd\u09a4\u09c1 \u098f\u0987 \u09aa\u09a5 \u09b8\u09ac\u09b8\u09ae\u09df \u09b8\u09b9\u099c \u099b\u09bf\u09b2 \u09a8\u09be\u0964 \u0985\u09b8\u0982\u0996\u09cd\u09af \u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae \u0993 \u09aa\u09cd\u09b0\u09a4\u09bf\u0995\u09c2\u09b2\u09a4\u09be \u09aa\u09c7\u09b0\u09bf\u09df\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09a8\u09be\u09b0\u09c0\u09b0\u09be \u0986\u099c \u09aa\u09cc\u0981\u099b\u09c7\u099b\u09c7\u09a8 \u098f\u0987 \u0985\u09ac\u09b8\u09cd\u09a5\u09be\u09a8\u09c7\u0964 \u099c\u09c1\u09b2\u09be\u0987 \u0997\u09a3\u0985\u09ad\u09cd\u09af\u09c1\u09a4\u09cd\u09a5\u09be\u09a8\u09c7 \u0986\u09ae\u09b0\u09be \u09a6\u09c7\u0996\u09c7\u099b\u09bf, \u098f\u0987 \u09a6\u09c7\u09b6\u09c7\u09b0 \u09a8\u09be\u09b0\u09c0\u09b0\u09be \u0985\u09a7\u09bf\u0995\u09be\u09b0 \u0993 \u0997\u09a3\u09a4\u09a8\u09cd\u09a4\u09cd\u09b0\u09c7\u09b0 \u09b8\u0982\u0997\u09cd\u09b0\u09be\u09ae\u09c7\u0993 \u0985\u0997\u09cd\u09b0\u09ad\u09be\u0997\u09c7 \u09a6\u09be\u0981\u09dc\u09be\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u09a8\u0964 \u09b8\u09c7\u0987 \u099c\u09c1\u09b2\u09be\u0987\u09df\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09e7\u09e6 \u099c\u09a8 \u09ae\u09be-\u09ac\u09cb\u09a8 \u09b6\u09be\u09b9\u09be\u09a6\u09be\u09a4 \u09ac\u09b0\u09a3 \u0995\u09b0\u09c7\u099b\u09c7\u09a8\u0964 \u09a4\u09be\u0981\u09a6\u09c7\u09b0 \u09ae\u09b9\u09be\u09a8 \u0986\u09a4\u09cd\u09ae\u09a4\u09cd\u09af\u09be\u0997 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b8\u09cd\u09ae\u09b0\u09a3 \u0995\u09b0\u09bf\u09df\u09c7 \u09a6\u09c7\u09df-\u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09a8\u09be\u09b0\u09c0\u09b0\u09be \u09a6\u09c7\u09b6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09df\u09cb\u099c\u09a8\u09c7 \u099c\u09c0\u09ac\u09a8 \u09a6\u09bf\u09a4\u09c7\u0993 \u09aa\u09cd\u09b0\u09b8\u09cd\u09a4\u09c1\u09a4\u0964 \u0986\u099c \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09a8\u09be\u09b0\u09c0 \u09a6\u09bf\u09ac\u09b8\u09c7 \u09a6\u09c7\u09b6\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u09aa\u09cd\u09b0\u09be\u09a3 \u09ac\u09bf\u09b2\u09bf\u09df\u09c7 \u09a6\u09c7\u0993\u09df\u09be \u09b8\u09c7\u0987 \u09ae\u09b9\u09c0\u09df\u09b8\u09c0 \u09a8\u09be\u09b0\u09c0\u09a6\u09c7\u09b0 \u0997\u09ad\u09c0\u09b0 \u09b6\u09cd\u09b0\u09a6\u09cd\u09a7\u09be\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u09b8\u09cd\u09ae\u09b0\u09a3 \u0995\u09b0\u099b\u09bf\u0964 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6\u09c7\u09b0 \u09b8\u09b0\u09cd\u09ac\u09b6\u09c7\u09b7 \u099c\u09a8\u09b6\u09c1\u09ae\u09be\u09b0\u09bf \u0985\u09a8\u09c1\u09af\u09be\u09df\u09c0, \u09a6\u09c7\u09b6\u09c7 \u09ae\u09cb\u099f \u099c\u09a8\u09b8\u0982\u0996\u09cd\u09af\u09be\u09b0 \u09ae\u09a7\u09cd\u09af\u09c7 \u09a8\u09be\u09b0\u09c0\u09b0 \u09b8\u0982\u0996\u09cd\u09af\u09be \u09aa\u09cd\u09b0\u09be\u09df \u09ee \u0995\u09cb\u099f\u09bf \u09eb\u09ec \u09b2\u09be\u0996, \u09af\u09be \u09aa\u09c1\u09b0\u09c1\u09b7\u09c7\u09b0 \u09a4\u09c1\u09b2\u09a8\u09be\u09df \u09b8\u09be\u09ae\u09be\u09a8\u09cd\u09af \u09ac\u09c7\u09b6\u09bf\u0964 \u0985\u09b0\u09cd\u09a5\u09be\u09ce \u09a6\u09c7\u09b6\u09c7\u09b0 \u09ae\u09cb\u099f \u099c\u09a8\u09b8\u0982\u0996\u09cd\u09af\u09be\u09b0 \u09aa\u09cd\u09b0\u09be\u09df \u09eb\u09e6 \u09b6\u09a4\u09be\u0982\u09b6\u09c7\u09b0\u0993 \u09ac\u09c7\u09b6\u09bf \u09a8\u09be\u09b0\u09c0\u0964 \u098f\u0995\u0987 \u0997\u09a3\u09b6\u09c1\u09ae\u09be\u09b0\u09bf \u0985\u09a8\u09c1\u09af\u09be\u09df\u09c0 \u09a6\u09c7\u09b6\u09c7 \u09ae\u09cb\u099f \u09b8\u09be\u0995\u09cd\u09b7\u09b0\u09a4\u09be\u09b0 \u09b9\u09be\u09b0 \u09aa\u09cd\u09b0\u09be\u09df \u09ed\u09ea.\u09ec\u09ec \u09b6\u09a4\u09be\u0982\u09b6, \u09af\u09be\u09b0 \u09ae\u09a7\u09cd\u09af\u09c7 \u09a8\u09be\u09b0\u09c0\u09a6\u09c7\u09b0 \u09b8\u09be\u0995\u09cd\u09b7\u09b0\u09a4\u09be\u09b0 \u09b9\u09be\u09b0 \u09aa\u09cd\u09b0\u09be\u09df \u09ed\u09e8.\u09ee\u09e8 \u09b6\u09a4\u09be\u0982\u09b6\u0964 \u098f\u099f\u09bf \u09aa\u09cd\u09b0\u09ae\u09be\u09a3 \u0995\u09b0\u09c7 \u09af\u09c7 \u09b6\u09bf\u0995\u09cd\u09b7\u09be \u0995\u09cd\u09b7\u09c7\u09a4\u09cd\u09b0\u09c7\u0993 \u09a8\u09be\u09b0\u09c0\u09b0\u09be \u09a6\u09cd\u09b0\u09c1\u09a4 \u098f\u0997\u09bf\u09df\u09c7 \u09af\u09be\u099a\u09cd\u099b\u09c7\u09a8\u0964 \u0985\u09a8\u09cd\u09af\u09a6\u09bf\u0995\u09c7 \u09b6\u09cd\u09b0\u09ae\u09ac\u09be\u099c\u09be\u09b0\u09c7\u0993 \u09a8\u09be\u09b0\u09c0\u09a6\u09c7\u09b0 \u0985\u0982\u09b6\u0997\u09cd\u09b0\u09b9\u09a3 \u0989\u09b2\u09cd\u09b2\u09c7\u0996\u09af\u09cb\u0997\u09cd\u09af\u09ad\u09be\u09ac\u09c7 \u09ac\u09c7\u09dc\u09c7\u099b\u09c7\u0964 \u09ac\u09b0\u09cd\u09a4\u09ae\u09be\u09a8\u09c7 \u09aa\u09cd\u09b0\u09be\u09df \u09ea\u09ea \u09b6\u09a4\u09be\u0982\u09b6 \u09a8\u09be\u09b0\u09c0 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u09aa\u09c7\u09b6\u09be \u0993 \u0995\u09b0\u09cd\u09ae\u0995\u09cd\u09b7\u09c7\u09a4\u09cd\u09b0\u09c7 \u09af\u09c1\u0995\u09cd\u09a4 \u09b9\u09df\u09c7 \u09a6\u09c7\u09b6\u09c7\u09b0 \u0985\u09b0\u09cd\u09a5\u09a8\u09c8\u09a4\u09bf\u0995 \u0985\u0997\u09cd\u09b0\u0997\u09a4\u09bf\u09a4\u09c7 \u0997\u09c1\u09b0\u09c1\u09a4\u09cd\u09ac\u09aa\u09c2\u09b0\u09cd\u09a3 \u0985\u09ac\u09a6\u09be\u09a8 \u09b0\u09be\u0996\u099b\u09c7\u09a8\u0964 \u09a4\u09ac\u09c7 \u09a8\u09be\u09b0\u09c0\u09a6\u09c7\u09b0 \u098f\u0987 \u0985\u0997\u09cd\u09b0\u09af\u09be\u09a4\u09cd\u09b0\u09be\u0995\u09c7 \u0986\u09b0\u0993 \u09b6\u0995\u09cd\u09a4\u09bf\u09b6\u09be\u09b2\u09c0 \u0995\u09b0\u09a4\u09c7 \u09b9\u09b2\u09c7 \u09a4\u09be\u0981\u09a6\u09c7\u09b0 \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u0995\u09b0\u09be \u0985\u09a4\u09cd\u09af\u09a8\u09cd\u09a4 \u099c\u09b0\u09c1\u09b0\u09bf\u0964 \u0986\u09b0 \u09a4\u09be \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u0995\u09b0\u09a4\u09c7 \u09ac\u09bf\u09b6\u09c7\u09b7\u09be\u09df\u09bf\u09a4 \u09a8\u09be\u09b0\u09c0 \u09b8\u09b9\u09be\u09df\u09a4\u09be \u09a1\u09c7\u09b8\u09cd\u0995, \u09a6\u09cd\u09b0\u09c1\u09a4 \u0985\u09ad\u09bf\u09af\u09cb\u0997 \u0997\u09cd\u09b0\u09b9\u09a3 \u0993 \u09a4\u09be\u09ce\u0995\u09cd\u09b7\u09a3\u09bf\u0995 \u0986\u0987\u09a8\u09bf \u09b8\u09b9\u09be\u09df\u09a4\u09be, \u09a8\u09bf\u09b0\u09be\u09aa\u09a6 \u0997\u09a3\u09aa\u09b0\u09bf\u09ac\u09b9\u09a8 \u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be, \u09aa\u09cd\u09b0\u09af\u09c1\u0995\u09cd\u09a4\u09bf\u09a8\u09bf\u09b0\u09cd\u09ad\u09b0 \u099c\u09b0\u09c1\u09b0\u09bf \u09b8\u09b9\u09be\u09df\u09a4\u09be \u0985\u09cd\u09af\u09be\u09aa \u098f\u09ac\u0982 \u09a8\u09be\u09b0\u09c0\u09a6\u09c7\u09b0 \u09aa\u09cd\u09b0\u09a4\u09bf \u09b8\u09b9\u09bf\u0982\u09b8\u09a4\u09be\u09b0 \u0998\u099f\u09a8\u09be\u09df \u0995\u09a0\u09cb\u09b0 \u0993 \u09a6\u09cd\u09b0\u09c1\u09a4 \u09ac\u09bf\u099a\u09be\u09b0\u09ac\u09cd\u09af\u09ac\u09b8\u09cd\u09a5\u09be \u099a\u09be\u09b2\u09c1 \u0995\u09b0\u09a4\u09c7 \u09b9\u09ac\u09c7\u0964 \u098f \u09a7\u09b0\u09a8\u09c7\u09b0 \u09b8\u09ae\u09a8\u09cd\u09ac\u09bf\u09a4 \u0989\u09a6\u09cd\u09af\u09cb\u0997 \u09a8\u09be\u09b0\u09c0\u09a6\u09c7\u09b0 \u099c\u09a8\u09cd\u09af \u09a8\u09bf\u09b0\u09be\u09aa\u09a6 \u09aa\u09b0\u09bf\u09ac\u09c7\u09b6 \u09a4\u09c8\u09b0\u09bf \u0995\u09b0\u09ac\u09c7 \u098f\u09ac\u0982 \u09a4\u09be\u0981\u09a6\u09c7\u09b0 \u0995\u09b0\u09cd\u09ae\u0995\u09cd\u09b7\u09c7\u09a4\u09cd\u09b0, \u09b6\u09bf\u0995\u09cd\u09b7\u09be \u0993 \u09b8\u09be\u09ae\u09be\u099c\u09bf\u0995 \u099c\u09c0\u09ac\u09a8\u09c7 \u0986\u09b0\u0993 \u0986\u09a4\u09cd\u09ae\u09ac\u09bf\u09b6\u09cd\u09ac\u09be\u09b8\u09c7\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u098f\u0997\u09bf\u09df\u09c7 \u09af\u09c7\u09a4\u09c7 \u09b8\u09b9\u09be\u09df\u09a4\u09be \u0995\u09b0\u09ac\u09c7\u0964 \u09aa\u09cd\u09b0\u09bf\u09df \u09a6\u09c7\u09b6\u09ac\u09be\u09b8\u09c0, \u098f\u0995\u099f\u09bf \u099c\u09be\u09a4\u09bf\u09b0 \u09aa\u09cd\u09b0\u0995\u09c3\u09a4 \u0985\u0997\u09cd\u09b0\u0997\u09a4\u09bf \u09a4\u0996\u09a8\u0987 \u09ac\u09be\u09b8\u09cd\u09a4\u09ac\u09be\u09df\u09bf\u09a4 \u09b9\u09df, \u09af\u0996\u09a8 \u09b8\u09c7\u0987 \u099c\u09be\u09a4\u09bf\u09b0 \u09a8\u09be\u09b0\u09c0\u09b0\u09be \u09b8\u09ae\u09be\u09a8 \u09b8\u09c1\u09af\u09cb\u0997, \u09ae\u09b0\u09cd\u09af\u09be\u09a6\u09be \u098f\u09ac\u0982 \u09a8\u09bf\u09b0\u09be\u09aa\u09a4\u09cd\u09a4\u09be \u09a8\u09bf\u09df\u09c7 \u098f\u0997\u09bf\u09df\u09c7 \u09af\u09c7\u09a4\u09c7 \u09aa\u09be\u09b0\u09c7\u0964 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09b2\u0995\u09cd\u09b7\u09cd\u09af \u09b9\u0993\u09df\u09be \u0989\u099a\u09bf\u09a4 \u098f\u09ae\u09a8 \u098f\u0995\u099f\u09bf \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u0997\u09dc\u09c7 \u09a4\u09cb\u09b2\u09be, \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09ae\u09c7\u09df\u09c7\u09b6\u09bf\u09b6\u09c1\u09b0 \u09b6\u09bf\u0995\u09cd\u09b7\u09be \u09a8\u09bf\u09b6\u09cd\u099a\u09bf\u09a4 \u09b9\u09ac\u09c7, \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09a8\u09be\u09b0\u09c0 \u09a8\u09bf\u09b0\u09be\u09aa\u09a6\u09c7 \u0995\u09be\u099c \u0995\u09b0\u09a4\u09c7 \u09aa\u09be\u09b0\u09ac\u09c7 \u098f\u09ac\u0982 \u09a4\u09be\u09b0 \u09b9\u09c3\u09a6\u09df\u09c7 \u09b2\u09be\u09b2\u09bf\u09a4 \u09b8\u09cd\u09ac\u09aa\u09cd\u09a8 \u09aa\u09c2\u09b0\u09a3\u09c7\u09b0 \u09aa\u09c2\u09b0\u09cd\u09a3 \u09b8\u09c1\u09af\u09cb\u0997 \u09aa\u09be\u09ac\u09c7\u0964 \u0986\u09b8\u09c1\u09a8, \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09a8\u09be\u09b0\u09c0 \u09a6\u09bf\u09ac\u09b8\u09c7 \u0986\u09ae\u09b0\u09be \u09b8\u09ac\u09be\u0987 \u0985\u0999\u09cd\u0997\u09c0\u0995\u09be\u09b0 \u0995\u09b0\u09bf-\u0986\u09ae\u09b0\u09be \u098f\u09ae\u09a8 \u098f\u0995\u099f\u09bf \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u0997\u09dc\u09ac \u09af\u09c7\u0996\u09be\u09a8\u09c7 \u09b8\u09ae\u09a4\u09be \u09a5\u09be\u0995\u09ac\u09c7, \u09b8\u09ae\u09cd\u09ae\u09be\u09a8 \u09a5\u09be\u0995\u09ac\u09c7 \u098f\u09ac\u0982 \u09aa\u09cd\u09b0\u09a4\u09bf\u099f\u09bf \u09a8\u09be\u09b0\u09c0 \u09a4\u09be\u09b0 \u09aa\u09c2\u09b0\u09cd\u09a3 \u09b8\u09ae\u09cd\u09ad\u09be\u09ac\u09a8\u09be \u09a8\u09bf\u09df\u09c7 \u098f\u0997\u09bf\u09df\u09c7 \u09af\u09c7\u09a4\u09c7 \u09aa\u09be\u09b0\u09ac\u09c7\u0964 \u09ac\u09be\u0982\u09b2\u09be\u09a6\u09c7\u09b6 \u098f\u0997\u09bf\u09df\u09c7 \u09af\u09be\u09ac\u09c7\u0964 \u0986\u09b0 \u09b8\u09c7\u0987 \u0985\u0997\u09cd\u09b0\u09af\u09be\u09a4\u09cd\u09b0\u09be\u09b0 \u0985\u09a8\u09cd\u09af\u09a4\u09ae \u099a\u09be\u09b2\u09bf\u0995\u09be\u09b6\u0995\u09cd\u09a4\u09bf \u09b9\u09ac\u09c7 \u0986\u09ae\u09be\u09a6\u09c7\u09b0 \u09a8\u09be\u09b0\u09c0\u09b0\u09be\u0964 \u09b8\u09ac\u09b6\u09c7\u09b7\u09c7, \u09a6\u09c7\u09b6\u09c7\u09b0 \u09b8\u0995\u09b2 \u09a8\u09be\u09b0\u09c0\u0995\u09c7 \u099c\u09be\u09a8\u09be\u0987 \u0986\u09a8\u09cd\u09a4\u09b0\u09cd\u099c\u09be\u09a4\u09bf\u0995 \u09a8\u09be\u09b0\u09c0 \u09a6\u09bf\u09ac\u09b8\u09c7\u09b0 \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995 \u09b6\u09c1\u09ad\u09c7\u099a\u09cd\u099b\u09be\u0964",
