    "title": "\u09a6\u09c1\u09b0\u09cd\u0997\u09ae \u0997\u09bf\u09b0\u09bf \u0995\u09be\u09a8\u09cd\u09a4\u09be\u09b0-\u09ae\u09b0\u09c1 \u09a6\u09c1\u09b8\u09cd\u09a4\u09b0 \u09aa\u09be\u09b0\u09be\u09ac\u09be\u09b0 \u09b9\u09c7 \u09b2\u0999\u09cd\u0998\u09bf\u09a4\u09c7 \u09b9\u09ac\u09c7 \u09b0\u09be\u09a4\u09cd\u09b0\u09bf \u09a8\u09bf\u09b6\u09c0\u09a5\u09c7 \u09af\u09be\u09a4\u09cd\u09b0\u09c0\u09b0\u09be \u09b9\u09c1\u0981...",
    "description": "\u09a6\u09c1\u09b0\u09cd\u0997\u09ae \u0997\u09bf\u09b0\u09bf \u0995\u09be\u09a8\u09cd\u09a4\u09be\u09b0-\u09ae\u09b0\u09c1 \u09a6\u09c1\u09b8\u09cd\u09a4\u09b0 \u09aa\u09be\u09b0\u09be\u09ac\u09be\u09b0 \u09b9\u09c7 \u09b2\u0999\u09cd\u0998\u09bf\u09a4\u09c7 \u09b9\u09ac\u09c7 \u09b0\u09be\u09a4\u09cd\u09b0\u09bf \u09a8\u09bf\u09b6\u09c0\u09a5\u09c7 \u09af\u09be\u09a4\u09cd\u09b0\u09c0\u09b0\u09be \u09b9\u09c1\u0981\u09b6\u09bf\u09df\u09be\u09b0! \u0995\u09be\u099c\u09c0 \u09a8\u099c\u09b0\u09c1\u09b2 \u0987\u09b8\u09b2\u09be\u09ae",
