  {
    "title": "\u0986\u099c \u09ac\u09be\u0982\u09b2\u09be\u09ae\u09cb\u099f\u09b0\u09c7 '\u09ae\u09b8\u099c\u09bf\u09a6-\u098f-\u09a8\u09c2\u09b0'-\u098f \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u09a4\u09be\u09b0\u09be\u09ac\u09c0\u09b0 \u09a8\u09be\u09ae\u09be\u099c \u0986\u09a6\u09be\u09df \u0995\u09b0\u09c7\u09a8 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09df\u09be\u09b0...",
    "description": "\u0986\u099c \u09ac\u09be\u0982\u09b2\u09be\u09ae\u09cb\u099f\u09b0\u09c7 '\u09ae\u09b8\u099c\u09bf\u09a6-\u098f-\u09a8\u09c2\u09b0'-\u098f \u09aa\u09ac\u09bf\u09a4\u09cd\u09b0 \u09a4\u09be\u09b0\u09be\u09ac\u09c0\u09b0 \u09a8\u09be\u09ae\u09be\u099c \u0986\u09a6\u09be\u09df \u0995\u09b0\u09c7\u09a8 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09df\u09be\u09b0\u09c0\u0964 \u09a8\u09be\u09ae\u09be\u099c \u09b6\u09c7\u09b7\u09c7 \u098f\u0995\u099c\u09a8 \u09b8\u09ae\u09cd\u09ae\u09be\u09a8\u09bf\u09a4 \u09ae\u09c1\u09b8\u09b2\u09cd\u09b2\u09bf \u09a4\u09be\u0995\u09c7 \u09ae\u09b8\u099c\u09bf\u09a6 \u09b8\u0982\u09b2\u0997\u09cd\u09a8 \u09a8\u09bf\u099c \u09ac\u09be\u09b8\u09be\u09df \u0986\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09a3 \u099c\u09be\u09a8\u09be\u09a8\u0964 \u0986\u09a8\u09cd\u09a4\u09b0\u09bf\u0995 \u09b8\u09c7\u0987 \u0986\u09ae\u09a8\u09cd\u09a4\u09cd\u09b0\u09a3 \u09b8\u09be\u09a6\u09b0\u09c7 \u0997\u09cd\u09b0\u09b9\u09a3 \u0995\u09b0\u09c7\u09a8 \u09a8\u09be\u09b8\u09c0\u09b0\u09c1\u09a6\u09cd\u09a6\u09c0\u09a8 \u09aa\u09be\u099f\u0993\u09df\u09be\u09b0\u09c0\u0964 \u09ac\u09be\u09b8\u09be\u09df \u09aa\u09cc\u0981\u099b\u09c7 \u099a\u09be-\u09a8\u09be\u09b8\u09cd\u09a4\u09be \u0997\u09cd\u09b0\u09b9\u09a3\u09c7\u09b0 \u09ab\u09be\u0981\u0995\u09c7 \u0989\u09aa\u09b8\u09cd\u09a5\u09bf\u09a4 \u09b8\u09ac\u09be\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u09b8\u09cc\u09b9\u09be\u09b0\u09cd\u09a6\u09cd\u09af\u09aa\u09c2\u09b0\u09cd\u09a3 \u09aa\u09b0\u09bf\u09ac\u09c7\u09b6\u09c7 \u09ac\u09bf\u09ad\u09bf\u09a8\u09cd\u09a8 \u09b8\u09ae\u09b8\u09be\u09ae\u09df\u09bf\u0995 \u09ac\u09bf\u09b7\u09df \u09a8\u09bf\u09df\u09c7 \u0986\u09b2\u09be\u09aa-\u0986\u09b2\u09cb\u099a\u09a8\u09be \u0995\u09b0\u09c7\u09a8\u0964 \u0989\u09b7\u09cd\u09a3 \u0986\u09a4\u09bf\u09a5\u09c7\u09df\u09a4\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u0995\u09c3\u09a4\u099c\u09cd\u099e\u09a4\u09be \u09aa\u09cd\u09b0\u0995\u09be\u09b6 \u0995\u09b0\u09c7 \u098f\u09ac\u0982 \u09b8\u09ac\u09be\u09b0 \u09b8\u0999\u09cd\u0997\u09c7 \u09b8\u09be\u09b2\u09be\u09ae \u09ac\u09bf\u09a8\u09bf\u09ae\u09df \u0995\u09b0\u09c7 \u09a4\u09bf\u09a8\u09bf \u09ac\u09bf\u09a6\u09be\u09df \u09a8\u09c7\u09a8\u0964 (\u098f\u09a1\u09ae\u09bf\u09a8)",
